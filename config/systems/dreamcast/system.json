{
  "schema_version": 1,
  "name": "Sega Dreamcast",
  "aliases": [],
  "es_de": {
    "platforms": [
      "dreamcast"
    ],
    "theme": "dreamcast"
  },
  "rom": {
    "dir": "dreamcast",
    "extensions": [
      ".cdi",
      ".chd",
      ".cue",
      ".elf",
      ".gdi",
      ".iso",
      ".lst",
      ".m3u",
      ".7z",
      ".zip"
    ]
  },
  "verification": {
    "rom_descriptors": [
      "Ikaruga (Japan).chd",
      "Sonic Adventure (USA) (En,Ja,Fr,De,Es) (Rev A).chd"
    ],
    "capture_frame": 180
  },
  "emulators": [
    {
      "emulator": "flycast",
      "platforms": [
        "linux"
      ]
    },
    {
      "emulator": "retroarch",
      "label": "Flycast (Libretro)",
      "core": "flycast",
      "platforms": [
        "macos"
      ]
    }
  ],
  "bios": {
    "required": false,
    "match": "all",
    "files": [
      {
        "name": "dc_boot.bin"
      },
      {
        "name": "dc_flash.bin"
      }
    ],
    "dir": "bios/dc"
  },
  "display": {
    "scaling": {
      "mode": "integer_preferred",
      "basis": "native_game_surface",
      "fit": "contain",
      "fallback": "fractional_downscale"
    },
    "screens": [
      {
        "id": "main",
        "native": {
          "w": 640,
          "h": 480
        }
      }
    ],
    "aspect": {
      "w": 4,
      "h": 3
    },
    "widescreen": {
      "aspect": {
        "w": 16,
        "h": 9
      },
      "detect": "emulator_reported_content_aspect",
      "fallback": "default_aspect",
      "switch_at": "frame_boundary"
    }
  },
  "render": {
    "style": "console",
    "asset_profile": "crt4x3",
    "priority": "game",
    "corner_radius": 0.045,
    "curvature": 0.04,
    "reflect": 0.18,
    "glow": 0.18,
    "bloom": 0.2,
    "vignette": 0.22
  },
  "doc": {
    "hardware": "consumer CRT or VGA monitor",
    "intent": "Prefer 4:3 CRT; swap to 16:9/flat only when config or game profile proves widescreen. Linux and Steam Deck use the source-built standalone Flycast slice; macOS retains the libretro fallback.",
    "native_note": "256x240 carried over from RenderOptionCatalog (the tap's integer-scale base today), not true Dreamcast output res. Change deliberately, not as a migration side effect.",
    "bios": "Flycast can use HLE for many games, but original BIOS files improve compatibility."
  }
}
