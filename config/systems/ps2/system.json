{
  "schema_version": 1,
  "name": "Sony PlayStation 2",
  "aliases": [],
  "es_de": {
    "platforms": [
      "ps2"
    ],
    "theme": "ps2"
  },
  "rom": {
    "dir": "ps2",
    "extensions": [
      ".bin",
      ".chd",
      ".cso",
      ".dump",
      ".gz",
      ".img",
      ".iso",
      ".m3u",
      ".mdf",
      ".nrg",
      ".7z",
      ".zip"
    ]
  },
  "verification": {
    "rom_descriptors": [
      "SSX (USA).iso",
      "NBA Street (USA).iso"
    ],
    "capture_frame": 180
  },
  "emulators": [
    {
      "emulator": "pcsx2",
      "label_aliases": [
        "PCSX2 (Standalone)"
      ],
      "platforms": [
        "linux"
      ]
    }
  ],
  "bios": {
    "required": true,
    "match": "any",
    "files": [
      {
        "name": "ps2-0230a-20080220.bin"
      },
      {
        "name": "ps2-0230e-20080220.bin"
      },
      {
        "name": "ps2-0230j-20080220.bin"
      },
      {
        "name": "SCPH-10000.bin"
      },
      {
        "name": "SCPH-30004R.bin"
      },
      {
        "name": "SCPH-39001.bin"
      },
      {
        "name": "SCPH-70012.bin"
      },
      {
        "name": "SCPH-90006.bin"
      }
    ],
    "dir": "bios/ps2"
  },
  "display": {
    "scaling": {
      "mode": "integer_preferred",
      "basis": "native_game_surface",
      "fit": "contain",
      "fallback": "fractional_downscale"
    },
    "screens": [
      {
        "id": "main",
        "native": {
          "w": 640,
          "h": 448
        }
      }
    ],
    "aspect": {
      "w": 4,
      "h": 3
    },
    "widescreen": {
      "aspect": {
        "w": 16,
        "h": 9
      },
      "detect": "emulator_reported_content_aspect",
      "fallback": "default_aspect",
      "switch_at": "frame_boundary"
    },
    "doc": {
      "native": "Real 1x emulator output (was a 256x240 placeholder that corrupted integer placement)."
    }
  },
  "render": {
    "style": "console",
    "priority": "game",
    "corner_radius": 0.045
  },
  "doc": {
    "hardware": "consumer CRT, component CRT, or early flat panel",
    "intent": "Aspect should follow PCSX2/game widescreen state.",
    "native_note": "256x240 carried over from RenderOptionCatalog (the tap's integer-scale base today), not true PS2 output res. Change deliberately, not as a migration side effect.",
    "bios": "PCSX2 needs at least one legally dumped PS2 BIOS image."
  }
}
