{
  "schema_version": 1,
  "id": "gc",
  "fullname": "Nintendo GameCube",
  "platform": "gc",
  "theme": "gc",
  "rom_dir": "gc",
  "controller_profile": "steam-deck",
  "extensions": [
    ".ciso",
    ".dol",
    ".elf",
    ".gcm",
    ".gcz",
    ".iso",
    ".nkit.iso",
    ".rvz",
    ".tgc",
    ".wad",
    ".wbfs",
    ".wia",
    ".7z",
    ".zip"
  ],
  "routes": {
    "linux": [
      {
        "role": "primary",
        "emulator": "dolphin",
        "label": "Dolphin"
      }
    ],
    "macos": [
      {
        "role": "primary",
        "emulator": "dolphin",
        "label": "Dolphin",
        "args": [
          "--config",
          "Dolphin.Display.Fullscreen=True",
          "-b",
          "-e"
        ]
      }
    ]
  },
  "requirements": {
    "bios": [],
    "keys": []
