  "rom_policy": {
    "external_roots": "read_only",
    "allow_in_place_metadata": false,
    "generated_metadata_root": "${semu_home}/generated/systems/gc",
    "owned_state_root": "${semu_home}/state/systems/gc"
  },
  "bios": []
