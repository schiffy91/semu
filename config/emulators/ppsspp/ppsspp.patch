+	step->semuRenderFrame = frame;
+	step->tag = "SemuRenderGame";
+	steps_.push_back(step);
+	semuRenderFrame_ = frame;
+	semuRenderFrameReady_ = true;
+
+	curRenderStep_ = nullptr;
