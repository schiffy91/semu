+    if (native_width == 0 || native_height == 0 || !std::isfinite(native_x) ||
+        !std::isfinite(native_y) || native_x < 0.0f || native_y < 0.0f ||
+        native_x > static_cast<float>(native_width - 1) ||
+        native_y > static_cast<float>(native_height - 1)) {
+        return false;
+    }
+    std::scoped_lock guard{touch_state->mutex};
+    if (require_pressed && !touch_state->touch_pressed) {
+        return false;
+    }
+    touch_state->touch_x = native_x / static_cast<float>(native_width);
+    touch_state->touch_y = native_y / static_cast<float>(native_height);
+    touch_state->touch_pressed = true;
+    return true;
+}
