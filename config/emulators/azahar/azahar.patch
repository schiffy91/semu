+bool IsSemuRenderSurfaceValid(const Layout::FramebufferLayout& layout,
+                              const Common::Rectangle<u32>& rectangle) {
+    return rectangle.left < rectangle.right && rectangle.top < rectangle.bottom &&
+           rectangle.right <= layout.width && rectangle.bottom <= layout.height;
+}
+
+bool BuildSemuRenderFrame(const Layout::FramebufferLayout& layout) {
+    semu_render_frame = {};
+    const bool geometry_valid = IsSemuRenderSurfaceValid(layout, layout.top_screen) &&
+                                IsSemuRenderSurfaceValid(layout, layout.bottom_screen);
+    if (!geometry_valid) {
+        return false;
+    }
+
+    const auto set_surface = [](SemuRenderSurfaceGl& surface,
+                                const Common::Rectangle<u32>& rectangle,
+                                int native_width, int native_height) {
+        surface.x = static_cast<int>(rectangle.left);
+        surface.y = static_cast<int>(rectangle.top);
+        surface.width = static_cast<int>(rectangle.GetWidth());
+        surface.height = static_cast<int>(rectangle.GetHeight());
+        surface.native_width = native_width;
+        surface.native_height = native_height;
+        surface.rotation = 0;
+        surface.origin = SEMU_RENDER_ORIGIN_TOP_LEFT;
+    };
+
+    semu_render_frame.abi = SEMU_RENDER_ABI_GL;
+    semu_render_frame.struct_size = sizeof(semu_render_frame);
+    semu_render_frame.frame_id = ++semu_render_frame_id;
+    semu_render_frame.framebuffer = 0;
+    semu_render_frame.color_buffer = GL_BACK;
+    semu_render_frame.framebuffer_width = static_cast<int>(layout.width);
+    semu_render_frame.framebuffer_height = static_cast<int>(layout.height);
+    semu_render_frame.surface_count = 2;
+    set_surface(semu_render_frame.surfaces[0], layout.top_screen,
+                Core::kScreenTopWidth, Core::kScreenTopHeight);
+    set_surface(semu_render_frame.surfaces[1], layout.bottom_screen,
+                Core::kScreenBottomWidth, Core::kScreenBottomHeight);
+    semu_render_frame.get_proc = GetProcAddressGL;
+    semu_render_frame.current_context = GetCurrentContextGL;
+    return true;
+}
