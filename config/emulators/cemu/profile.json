        "chord": "Ctrl+Tab",
        "consumer": "LatteRenderTarget_copyToBackbuffer"
      }
    ],
    "unsupported": [
      {
        "action": "state.save",
        "reason": "Cemu 2.6 has no savestate implementation or native save-state command."
      },
      {
        "action": "state.load",
        "reason": "Cemu 2.6 has no savestate implementation or native load-state command."
      }
    ]
