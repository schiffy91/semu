  "files": [
    {
      "path": "${emulator_name}/config/controllerProfiles/controller0.xml",
      "lines": [
        "<?xml version=\"1.0\" encoding=\"UTF-8\"?>",
        "<emulated_controller>",
        "\t<type>${controller_type}</type>",
        "\t<controller>",
        "\t\t<api>${controller_api}</api>",
        "\t\t<uuid>${controller_uuid}</uuid>",
        "\t\t<display_name>${controller_display_name}</display_name>",
        "\t\t<rumble>${controller_rumble}</rumble>",
        "\t\t<axis>",
        "\t\t\t<deadzone>0.1</deadzone>",
        "\t\t\t<range>1</range>",
        "\t\t</axis>",
        "\t\t<rotation>",
        "\t\t\t<deadzone>0.1</deadzone>",
        "\t\t\t<range>1</range>",
        "\t\t</rotation>",
        "\t\t<trigger>",
        "\t\t\t<deadzone>0.1</deadzone>",
        "\t\t\t<range>1</range>",
        "\t\t</trigger>",
        "\t\t<mappings>",
        "@lines:controller_mappings",
        "\t\t</mappings>",
        "\t</controller>",
        "</emulated_controller>"
      ]
    },
    {
      "path": "${emulator_name}/config/settings.xml",
      "lines": [
        "<?xml version=\"1.0\" encoding=\"UTF-8\"?>",
        "<content>",
        "\t<Graphic>",
        "\t\t<${renderer_key}>${renderer_value}</${renderer_key}>",
        "\t\t<FullscreenScaling>0</FullscreenScaling>",
        "\t\t<Notification>",
        "\t\t\t<ControllerProfiles>false</ControllerProfiles>",
        "\t\t\t<ControllerBattery>false</ControllerBattery>",
        "\t\t</Notification>",
        "\t</Graphic>",
        "\t<fullscreen>true</fullscreen>",
        "\t<fullscreen_menubar>false</fullscreen_menubar>",
        "\t<open_pad>false</open_pad>",
        "\t<disable_screensaver>true</disable_screensaver>",
        "\t<feral_gamemode>false</feral_gamemode>",
        "\t<use_discord_presence>false</use_discord_presence>",
        "\t<play_boot_sound>false</play_boot_sound>",
        "\t<check_update>false</check_update>",
        "</content>"
      ]
    }
  ],
  "doc": {
    "controller": "Cemu automatically loads controllerProfiles/controller0.xml for player one before CafeSystem initialization. The 0_ prefix is Cemu's duplicate-GUID index followed by SDL_JoystickGetGUIDString's 32 lowercase hexadecimal digits. Mapping ids are VPAD ButtonId values; button ids are the pinned 2.6 SDL_GameControllerButton values and Controller.h synthetic axis values. The Semu source build ignores per-title controller overrides so this generated profile remains authoritative.",
    "display": "open_pad=false leaves one primary game window. Ctrl+Tab changes whether that main window presents TV or GamePad output; the separate pad window remains closed.",
    "storage": "The profile pins only input and UI settings. emulator.json owns the XDG and -m paths that keep normal Wii U title saves inside the isolated MLC root.",
    "actions": "Native rows are fail-closed invariants checked against steamdeck.skm before emission. Unsupported rows document shared Semu actions that this exact upstream release cannot consume."
  }
}
