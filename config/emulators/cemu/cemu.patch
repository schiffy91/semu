+#ifdef HAVE_SEMU_RENDERER
+void OpenGLRenderer::SemuRenderGame(sint32 framebufferWidth, sint32 framebufferHeight,
+	sint32 contentX, sint32 contentY, sint32 contentWidth, sint32 contentHeight,
+	sint32 nativeWidth, sint32 nativeHeight)
+{
+	SemuClearFrame();
+	if (framebufferWidth <= 0 || framebufferHeight <= 0 ||
+		contentWidth <= 0 || contentHeight <= 0 ||
+		nativeWidth <= 0 || nativeHeight <= 0)
+	{
+		return;
+	}
+
+	s_semu_renderer_context = this;
+	if (++s_semu_frame_id == 0)
+		s_semu_frame_id = 1;
+
+	s_semu_frame.abi = SEMU_RENDER_ABI_GL;
+	s_semu_frame.struct_size = sizeof(s_semu_frame);
+	s_semu_frame.frame_id = s_semu_frame_id;
+	s_semu_frame.framebuffer = 0;
+	s_semu_frame.color_buffer = GL_BACK;
+	s_semu_frame.framebuffer_width = framebufferWidth;
+	s_semu_frame.framebuffer_height = framebufferHeight;
+	s_semu_frame.presentation_aspect = static_cast<float>(contentWidth) /
+		static_cast<float>(contentHeight);
+	s_semu_frame.layout_variant = s_semu_frame.presentation_aspect >= 1.5f ?
+		SEMU_RENDER_LAYOUT_VARIANT_B : SEMU_RENDER_LAYOUT_DEFAULT;
+	s_semu_frame.surface_count = 1;
+	s_semu_frame.surfaces[0].x = contentX;
+	s_semu_frame.surfaces[0].y = contentY;
+	s_semu_frame.surfaces[0].width = contentWidth;
+	s_semu_frame.surfaces[0].height = contentHeight;
+	s_semu_frame.surfaces[0].native_width = nativeWidth;
+	s_semu_frame.surfaces[0].native_height = nativeHeight;
+	s_semu_frame.surfaces[0].rotation = 0;
+	s_semu_frame.surfaces[0].origin = SEMU_RENDER_ORIGIN_BOTTOM_LEFT;
+	s_semu_frame.get_proc = SemuGlProc;
+	s_semu_frame.current_context = SemuCurrentContext;
+	semu_render_game_gl(&s_semu_frame);
+}
+
+void OpenGLRenderer::SemuRenderPostUi()
+{
+	if (s_semu_frame.frame_id != 0 && s_semu_renderer_context == this)
+		semu_render_post_ui_gl(&s_semu_frame);
+	SemuClearFrame();
+}
+#endif
+
