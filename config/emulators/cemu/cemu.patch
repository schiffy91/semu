+{
+	if (!name)
+		return nullptr;
+#define GLFUNC(type, function) \
+	if (std::strcmp(name, STRINGIFY(function)) == 0) \
+		return reinterpret_cast<void*>(function);
+#define EGLFUNC(type, function)
+#include "Common/GLInclude/glFunctions.h"
+#undef EGLFUNC
+#undef GLFUNC
+	return nullptr;
+}
