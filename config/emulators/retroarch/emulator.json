              "source": {
                "kind": "render_resolution",
                "basis": "combined",
                "display_aspect": "standard",
                "anchor": "width"
              }
            },
            {
              "key": "mupen64plus-169screensize",
              "aspect": "widescreen",
              "source": {
                "kind": "render_resolution",
                "basis": "combined",
                "display_aspect": "widescreen",
                "anchor": "width",
                "minimum_scale": 2
              }
            },
            {
              "key": "mupen64plus-EnableFBEmulation",
              "source": {
