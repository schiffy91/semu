        ]
      },
      "args": [
        "-f"
      ],
      "core_loader": {
        "filename": "${core}_libretro.dylib",
        "directories": [
          "${asset_root}/cores"
        ],
        "args": [
          "-L",
          "${core_file}"
        ]
      },
      "retroarch": {
        "video_driver": "metal",
        "frame_output": {
          "fullscreen": true,
          "scope": "game_only",
          "origin": "top_left",
          "orientation": "upright",
          "filter": "nearest",
          "native_shader": false
        },
        "core_options": {
