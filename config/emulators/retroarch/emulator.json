          },
          {
            "path": "${asset_root}",
            "mode": "ro"
          },
          {
            "path": "${roms}",
            "mode": "ro"
          },
          {
            "path": "${emulation_root}",
            "mode": "ro"
          },
          {
            "path": "${bios}",
            "mode": "ro"
          },
          {
            "path": "${state_root}",
            "mode": "create"
          }
        ]
      },
      "env": {
        "set": {
          "HOME": "${state_root}/home",
          "SEMU_RETROARCH_CONFIG": "${state_root}/config/RetroArch/retroarch.cfg"
        }
      },
      "state": {
        "config_home": "preserve",
        "data_home": "preserve",
        "profile_config_dir": "${state_root}/config/RetroArch",
        "managed_profile_files": [
          "config/retroarch.cfg"
        ]
      },
      "firmware": {
        "dir": "${emulation_root}/RetroArch/config/system",
        "fallback_dirs": [
