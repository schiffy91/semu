+         (input_st->flags & INP_FLAG_KB_MAPPING_BLOCKED) ? true : false,
+         0, RARCH_DEVICE_MOUSE_SCREEN, 0,
+         RETRO_DEVICE_ID_MOUSE_Y);
+   bool pressed = input_state_wrap(input_st->current_driver,
+         input_st->current_data, joypad, sec_joypad, &joypad_info,
+         (*input_st->libretro_input_binds),
+         (input_st->flags & INP_FLAG_KB_MAPPING_BLOCKED) ? true : false,
+         0, RARCH_DEVICE_MOUSE_SCREEN, 0,
+         RETRO_DEVICE_ID_MOUSE_LEFT) != 0;
+   video_driver_semu_pointer_sample(screen_x, screen_y, pressed, true);
+}
+#endif
