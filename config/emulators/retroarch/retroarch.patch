+         (input_st->flags & INP_FLAG_KB_MAPPING_BLOCKED) ? true : false,
+         0, RARCH_DEVICE_MOUSE_SCREEN, 0,
+         RETRO_DEVICE_ID_MOUSE_X);
+   int16_t screen_y = (int16_t)input_state_wrap(input_st->current_driver,
