+#endif
+   if (!allowed)
+   {
+      video_driver_semu_pointer_sample(0, 0, false, false);
+      return;
+   }
+
+   joypad_info.joy_idx        = settings->uints.input_joypad_index[0];
+   joypad_info.auto_binds     = input_autoconf_binds[joypad_info.joy_idx];
+   joypad_info.axis_threshold = settings->floats.input_axis_threshold;
+   int16_t screen_x = (int16_t)input_state_wrap(input_st->current_driver,
+         input_st->current_data, joypad, sec_joypad, &joypad_info,
