+static void *semu_gl2_context_data;
+
+static void *semu_gl2_get_proc(const char *name)
+{
+   if (!semu_gl2_context_driver || !semu_gl2_context_driver->get_proc_address)
+      return NULL;
+   return (void*)semu_gl2_context_driver->get_proc_address(name);
+}
+
+static void *semu_gl2_current_context(void)
+{
+   void *context = NULL;
+   if (!semu_gl2_context_driver)
+      return NULL;
+   if (semu_gl2_context_driver->get_context_data)
+      context = semu_gl2_context_driver->get_context_data(semu_gl2_context_data);
+   return context ? context : semu_gl2_context_data;
+}
 #endif
 
