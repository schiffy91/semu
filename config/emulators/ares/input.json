{
  "schema_version": 1,
  "controllerProfile": "steam-deck",
  "hotkeys": {
    "source": "default-keymap",
    "renderTarget": "none",
    "stateActions": "disabled",
    "fullscreenAction": "native"
  },
  "actionMap": {
    "quit": {
      "handling": "launcher_or_emulator_hotkey",
      "emittedInput": [
        "Esc",
        "Cmd+Q"
      ]
    },
    "pause": {
      "handling": "native",
      "binding": "pause"
    },
    "escape": {
      "handling": "emulator_hotkey",
      "emittedInput": [
        "Esc"
      ]
    },
    "save": {
      "handling": "unsupported",
      "reason": "No Semu-owned ares save-state hotkey contract yet."
    },
    "load": {
      "handling": "unsupported",
      "reason": "No Semu-owned ares load-state hotkey contract yet."
    },
    "slot_prev": {
      "handling": "unsupported",
      "reason": "No Semu-owned ares slot hotkey contract yet."
    },
    "slot_next": {
      "handling": "unsupported",
      "reason": "No Semu-owned ares slot hotkey contract yet."
    },
    "menu": {
      "handling": "native",
      "binding": "open_menu"
    },
    "fullscreen": {
      "handling": "native",
      "binding": "toggle_fullscreen"
    },
    "screenshot": {
      "handling": "native",
      "binding": "screenshot"
    },
    "fast": {
      "handling": "native",
      "binding": "fast_forward"
    },
    "rewind": {
      "handling": "unsupported",
      "reason": "ares rewind is not part of the Semu generated contract."
    },
    "screen_swap": {
      "handling": "unsupported",
      "reason": "Not applicable to Nintendo 64."
    }
  }
}
