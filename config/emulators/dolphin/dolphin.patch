+
+bool ProfileCycler::ActivateSemuControllerMode(SemuControllerMode mode)
+{
+  auto& system = Core::System::GetInstance();
+  if (!Core::IsRunning(system) || !system.IsWii())
+    return false;
+
+  Common::IniFile dolphin_ini;
+  if (!dolphin_ini.Load(File::GetUserPath(D_CONFIG_IDX) + "Dolphin.ini"))
+    return false;
+
+  std::string profile_name;
+  const auto* section = dolphin_ini.GetOrCreateSection("Semu Controller Modes");
+  if (!section->Get(GetSemuProfileKey(mode), &profile_name) ||
+      !IsSafeSemuProfileName(profile_name))
+  {
+    Core::DisplayMessage("Invalid Semu controller profile", display_message_ms);
+    return false;
+  }
+
+  InputConfig* input_config =
+      mode == SemuControllerMode::GameCube ? Pad::GetConfig() : Wiimote::GetConfig();
+  if (input_config == nullptr || input_config->GetControllerCount() == 0)
+    return false;
+
+  std::error_code path_error;
+  const std::filesystem::path profile_root = std::filesystem::weakly_canonical(
+      input_config->GetUserProfileDirectoryPath(), path_error);
+  const std::filesystem::path profile_path = profile_root / (profile_name + ".ini");
+  const std::filesystem::file_status profile_status =
+      std::filesystem::symlink_status(profile_path, path_error);
+  const std::filesystem::path canonical_profile =
+      std::filesystem::canonical(profile_path, path_error);
+  if (path_error || std::filesystem::is_symlink(profile_status) ||
+      !std::filesystem::is_regular_file(profile_status) ||
+      canonical_profile.parent_path() != profile_root)
+  {
+    Core::DisplayMessage("Unable to load Semu controller profile '" + profile_name + "'",
+                         display_message_ms);
+    return false;
+  }
+
+  if (!UpdateToProfile(canonical_profile.string(), input_config->GetController(0), input_config))
+    return false;
+
+  const bool gamecube = mode == SemuControllerMode::GameCube;
+  {
+    Config::ConfigChangeCallbackGuard config_guard;
+    Config::SetCurrent(Config::WIIMOTE_1_SOURCE,
+                       gamecube ? WiimoteSource::None : WiimoteSource::Emulated);
+    Config::SetCurrent(Config::GetInfoForSIDevice(0),
+                       gamecube ? SerialInterface::SIDEVICE_GC_CONTROLLER :
+                                  SerialInterface::SIDEVICE_NONE);
+  }
+  {
+    const Core::CPUThreadGuard guard(system);
+    system.GetSerialInterface().ChangeDevice(
+        gamecube ? SerialInterface::SIDEVICE_GC_CONTROLLER : SerialInterface::SIDEVICE_NONE, 0);
+  }
+  return true;
 }
