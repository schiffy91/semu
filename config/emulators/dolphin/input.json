{
  "schema_version": 1,
  "controllerProfile": "steam-deck",
  "hotkeys": {
    "source": "default-keymap",
    "renderTarget": "dolphin",
    "stateActions": "generated",
    "fullscreenAction": "native"
  },
  "actionMap": {
    "quit": {
      "handling": "launcher_or_emulator_hotkey",
      "emittedInput": [
        "Esc",
        "Alt+F4"
      ]
    },
    "pause": {
      "handling": "generated_config",
      "binding": "pause"
    },
    "escape": {
      "handling": "emulator_hotkey",
      "emittedInput": [
        "Esc"
      ]
    },
    "save": {
      "handling": "generated_config",
      "binding": "save_state"
    },
    "load": {
      "handling": "generated_config",
      "binding": "load_state"
    },
    "slot_prev": {
      "handling": "generated_config",
      "binding": "state_slot_decrease"
    },
    "slot_next": {
      "handling": "generated_config",
      "binding": "state_slot_increase"
    },
    "menu": {
      "handling": "native",
      "binding": "open_menu"
    },
    "fullscreen": {
      "handling": "native",
      "binding": "toggle_fullscreen"
    },
    "screenshot": {
      "handling": "generated_config",
      "binding": "screenshot"
    },
    "fast": {
      "handling": "generated_config",
      "binding": "toggle_turbo"
    },
    "rewind": {
      "handling": "unsupported",
      "reason": "Dolphin has no stable generated rewind contract in Semu yet."
    },
    "screen_swap": {
      "handling": "unsupported",
      "reason": "Not applicable to GameCube or Wii."
    }
  }
}
