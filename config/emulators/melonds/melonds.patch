+
+bool FillSemuRenderSurface(SemuRenderSurfaceGl& surface, const float* transform,
+                           int framebufferWidth, int framebufferHeight,
+                           float scale)
+{
+    if (!transform || framebufferWidth <= 0 || framebufferHeight <= 0
+        || !std::isfinite(scale)
+        || scale <= 0.0f)
+        return false;
+
+    const float sourceX[4] = {0.0f, 256.0f, 0.0f, 256.0f};
+    const float sourceY[4] = {0.0f, 0.0f, 192.0f, 192.0f};
+    float minX = 0.0f;
+    float minY = 0.0f;
+    float maxX = 0.0f;
+    float maxY = 0.0f;
+
+    for (int corner = 0; corner < 4; corner++)
+    {
+        float x = sourceX[corner] * transform[0]
+            + sourceY[corner] * transform[2] + transform[4];
+        float y = sourceX[corner] * transform[1]
+            + sourceY[corner] * transform[3] + transform[5];
+        if (!std::isfinite(x) || !std::isfinite(y))
+            return false;
+
+        if (corner == 0)
+        {
+            minX = maxX = x;
+            minY = maxY = y;
+        }
+        else
+        {
+            minX = std::min(minX, x);
+            minY = std::min(minY, y);
+            maxX = std::max(maxX, x);
+            maxY = std::max(maxY, y);
+        }
+    }
+
+    int left = std::max(0, std::min(framebufferWidth,
+        static_cast<int>(std::floor(minX * scale))));
+    int top = std::max(0, std::min(framebufferHeight,
+        static_cast<int>(std::floor(minY * scale))));
+    int right = std::max(0, std::min(framebufferWidth,
+        static_cast<int>(std::ceil(maxX * scale))));
+    int bottom = std::max(0, std::min(framebufferHeight,
+        static_cast<int>(std::ceil(maxY * scale))));
+    if (right <= left || bottom <= top)
+        return false;
+
+    surface.x = left;
+    surface.y = top;
+    surface.width = right - left;
+    surface.height = bottom - top;
+    surface.native_width = 256;
+    surface.native_height = 192;
+    surface.rotation = 0;
+    surface.origin = SEMU_RENDER_ORIGIN_TOP_LEFT;
+    return true;
+}
+
+bool BuildSemuRenderFrame(SemuRenderFrameGl& frame, unsigned long long frameId,
+                          int framebufferWidth, int framebufferHeight,
+                          float scale, int numScreens,
+                          const float screenMatrix[][6],
+                          const int screenKind[])
+{
+    frame = {};
+    frame.abi = SEMU_RENDER_ABI_GL;
+    frame.struct_size = sizeof(frame);
+    frame.frame_id = frameId;
+    frame.framebuffer = 0;
+    frame.color_buffer = GL_BACK;
+    frame.framebuffer_width = framebufferWidth;
+    frame.framebuffer_height = framebufferHeight;
+    frame.get_proc = SemuGetProcAddress;
+    frame.current_context = SemuCurrentContext;
+
+    bool seen[2] = {false, false};
+    bool valid = frameId != 0 && numScreens == 2 && screenMatrix && screenKind;
+    for (int screen = 0; valid && screen < numScreens; screen++)
+    {
+        int screenKindValue = screenKind[screen];
+        if (screenKindValue < 0 || screenKindValue > 1 || seen[screenKindValue]
+            || !FillSemuRenderSurface(frame.surfaces[screenKindValue],
+                screenMatrix[screen], framebufferWidth, framebufferHeight,
+                scale))
+        {
+            valid = false;
+            break;
+        }
+        seen[screenKindValue] = true;
+    }
+
+    frame.surface_count = valid && seen[0] && seen[1] ? 2 : 0;
+    return frame.surface_count == 2;
+}
+
+} // namespace
+
+
+void ScreenPanel::storeSemuPointerMap(const SemuRenderFrameGl* frame)
+{
+    semuPointerMapLock.lock();
+    if (frame && frame->map_pointer
+        && frame->pointer_map.abi == SEMU_RENDER_ABI_GL
+        && frame->pointer_map.surface_count > 1)
+    {
+        semuPointerMap = frame->pointer_map;
+        semuMapPointer = frame->map_pointer;
+    }
+    else
+    {
+        semuPointerMap = {};
+        semuMapPointer = nullptr;
+    }
+    semuPointerMapLock.unlock();
+}
+
+bool ScreenPanel::mapSemuTouch(int viewportX, int viewportY, bool capture,
+                               int& nativeX, int& nativeY)
+{
+    SemuRenderPointerMap pointerMap{};
+    SemuRenderMapPointer mapPointer = nullptr;
+    semuPointerMapLock.lock();
+    pointerMap = semuPointerMap;
+    mapPointer = semuMapPointer;
+    semuPointerMapLock.unlock();
+
+    const int viewportWidth = width();
+    const int viewportHeight = height();
+    if (!mapPointer || pointerMap.surface_count <= 1
+        || viewportWidth <= 0 || viewportHeight <= 0)
+        return false;
+
+    float pointerX = static_cast<float>(viewportX);
+    float pointerY = static_cast<float>(viewportY);
+    if (capture)
+    {
+        pointerX = std::clamp(pointerX, 0.0f,
+            static_cast<float>(viewportWidth));
+        pointerY = std::clamp(pointerY, 0.0f,
+            static_cast<float>(viewportHeight));
+    }
+
+    SemuRenderPointerQuery query{};
+    query.abi = SEMU_RENDER_ABI_GL;
+    query.struct_size = sizeof(query);
+    query.frame_id = pointerMap.frame_id;
+    query.x = pointerX;
+    query.y = pointerY;
+    query.viewport_width = viewportWidth;
+    query.viewport_height = viewportHeight;
+    query.origin = SEMU_RENDER_ORIGIN_TOP_LEFT;
+    query.surface_index = 1;
+    query.clamp = capture ? 1 : 0;
+
+    SemuRenderPointerResult result{};
+    if (mapPointer(&pointerMap, &query, &result)
+            != SEMU_RENDER_POINTER_MAPPED
+        || result.surface_index != 1
+        || !std::isfinite(result.native_x)
+        || !std::isfinite(result.native_y))
+        return false;
+
+    nativeX = static_cast<int>(std::lround(result.native_x));
+    nativeY = static_cast<int>(std::lround(result.native_y));
+    return true;
+}
