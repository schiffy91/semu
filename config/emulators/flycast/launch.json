{
  "schema_version": 1,
  "romArg": "positional",
  "fullscreenContract": {
    "required": true,
    "mode": "argument",
    "verification": "argv_contains_window_fullscreen_config"
  },
  "linux": {
    "launcher": "flatpak",
    "flatpakId": "org.flycast.Flycast",
    "executable": "flycast",
    "env": {
      "XDG_CONFIG_HOME": "${generated}/emulators/flycast/xdg/config",
      "XDG_DATA_HOME": "${generated}/emulators/flycast/xdg/data",
      "XDG_CACHE_HOME": "${generated}/emulators/flycast/xdg/cache"
    },
    "defaultArgs": [
      "-config",
      "window:fullscreen=yes"
    ],
    "fullscreenArgs": [
      "-config",
      "window:fullscreen=yes"
    ]
  }
}
