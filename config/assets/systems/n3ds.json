{
  "schema_version": 2,
  "system": "n3ds",
  "label": "Nintendo 3DS",
  "default_emulator": "AZAHAR",
  "emulator": "azahar",
  "emulator_config": "qt-config.ini",
  "hardware_display": "dual LCDs, 400x240 top and 320x240 bottom",
  "display_class": "dual_screen_lcd",
  "content_viewport": {
    "native_size": {
      "width": 400,
      "height": 480
    },
    "content_aspect": "5:6",
    "default_aspect": "5:6",
    "dynamic_aspect": false,
    "layout": {
      "kind": "dual_vertical_asymmetric",
      "screen_order": [
        "top",
        "bottom"
      ],
      "align": "center",
      "screens": [
        {
          "id": "top",
          "native_size": {
            "width": 400,
            "height": 240
          },
          "content_aspect": "5:3"
        },
        {
          "id": "bottom",
          "native_size": {
            "width": 320,
            "height": 240
          },
          "content_aspect": "4:3"
        }
      ]
    },
    "scale_policy": "layout_integer_or_aspect"
  },
  "renderer": {
    "model": "semu_source_hook_renderer",
    "viewport_source": "content_viewport",
    "profile": "n3ds_dual_lcd",
    "shader": {
      "family": "n3ds_lcd",
      "enabled_by_default": true,
      "intent": "3DS LCD panels with asymmetric top/bottom geometry",
      "source_asset": "handheld/lcd-grid-v2-nds-color.slangp",
      "widescreen_source_asset": null,
      "effect_file": "semu-n3ds.fx"
    },
    "bezel": {
      "family": "dual_screen_handheld",
      "enabled_by_default": true,
      "intent": "good-looking 3DS bezel that maximizes top and bottom screens",
      "source_asset": "bezels/3ds/maximized-dual-screen.json",
      "widescreen_source_asset": null,
      "composition_effect_file": "semu-n3ds.fx"
    }
  },
  "notes": "Azahar is only an emulator; Semu owns the dual-screen rendering contract."
}
