      "effect_file": "semu-dmg-lcd.fx"
    },
    "bezel": {
      "family": "classic_grey_game_boy",
      "enabled_by_default": true,
      "intent": "classic grey Game Boy shell",
      "source_asset": "handheld/console-border/dmg.slangp",
      "widescreen_source_asset": null,
      "composition_effect_file": "semu-gb.fx"
    }
  },
  "notes": "Prefer DMG green palette and ghosting over sharp monochrome output."
