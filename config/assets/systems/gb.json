          "id": "main",
          "native_size": {
            "width": 160,
            "height": 144
          },
          "content_aspect": "10:9"
        }
      ]
    },
    "scale_policy": "integer"
  },
  "renderer": {
    "model": "semu_source_hook_renderer",
