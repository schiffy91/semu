<?xml version="1.0"?>
<!-- Schemulator preferred emulator defaults -->
<!-- Only systems where we override ES-DE's built-in defaults -->
<systemList>
  <system>
    <name>n3ds</name>
    <fullname>Nintendo 3DS</fullname>
    <path>%ROMPATH%/n3ds</path>
    <extension>.3ds .3DS .3dsx .3DSX .app .APP .axf .AXF .cci .CCI .cxi .CXI .elf .ELF .7z .7Z .zip .ZIP</extension>
    <command label="Azahar (Standalone)">%EMULATOR_AZAHAR% --fullscreen %ROM%</command>
    <platform>n3ds</platform>
    <theme>n3ds</theme>
  </system>
  <system>
    <name>psx</name>
    <fullname>Sony PlayStation</fullname>
    <path>%ROMPATH%/psx</path>
    <extension>.bin .BIN .ccd .CCD .chd .CHD .cue .CUE .ecm .ECM .exe .EXE .img .IMG .iso .ISO .m3u .M3U .pbp .PBP .psexe .PSEXE .toc .TOC .7z .7Z .zip .ZIP</extension>
    <command label="SwanStation">%EMULATOR_RETROARCH% -f -L %CORE_RETROARCH%/swanstation_libretro.dylib %ROM%</command>
    <command label="Beetle PSX HW">%EMULATOR_RETROARCH% -f -L %CORE_RETROARCH%/mednafen_psx_hw_libretro.dylib %ROM%</command>
    <platform>psx</platform>
    <theme>psx</theme>
  </system>
  <system>
    <name>gc</name>
    <fullname>Nintendo GameCube</fullname>
    <path>%ROMPATH%/gc</path>
    <extension>.ciso .CISO .dol .DOL .elf .ELF .gcm .GCM .gcz .GCZ .iso .ISO .nkit.iso .NKIT.ISO .rvz .RVZ .tgc .TGC .wad .WAD .wbfs .WBFS .wia .WIA .7z .7Z .zip .ZIP</extension>
    <command label="Dolphin (Standalone)">%EMULATOR_DOLPHIN% -b -e --config Dolphin.Display.Fullscreen=True %ROM%</command>
    <platform>gc</platform>
    <theme>gc</theme>
  </system>
  <system>
    <name>wii</name>
    <fullname>Nintendo Wii</fullname>
    <path>%ROMPATH%/wii</path>
    <extension>.ciso .CISO .dol .DOL .elf .ELF .gcm .GCM .gcz .GCZ .iso .ISO .nkit.iso .NKIT.ISO .rvz .RVZ .tgc .TGC .wad .WAD .wbfs .WBFS .wia .WIA .7z .7Z .zip .ZIP</extension>
    <command label="Dolphin (Standalone)">%EMULATOR_DOLPHIN% -b -e --config Dolphin.Display.Fullscreen=True %ROM%</command>
    <platform>wii</platform>
    <theme>wii</theme>
  </system>
  <system>
    <name>dreamcast</name>
    <fullname>Sega Dreamcast</fullname>
    <path>%ROMPATH%/dreamcast</path>
    <extension>.cdi .CDI .chd .CHD .cue .CUE .gdi .GDI .iso .ISO .7z .7Z .zip .ZIP</extension>
    <command label="Flycast">%EMULATOR_RETROARCH% -f -L %CORE_RETROARCH%/flycast_libretro.dylib %ROM%</command>
    <platform>dreamcast</platform>
    <theme>dreamcast</theme>
  </system>
  <system>
    <name>gb</name>
    <fullname>Nintendo Game Boy</fullname>
    <path>%ROMPATH%/gb</path>
    <extension>.bin .BIN .dmg .DMG .gb .GB .gbs .GBS .7z .7Z .zip .ZIP</extension>
    <command label="Gambatte">%EMULATOR_RETROARCH% -f -L %CORE_RETROARCH%/gambatte_libretro.dylib %ROM%</command>
    <platform>gb</platform>
    <theme>gb</theme>
  </system>
  <system>
    <name>gba</name>
    <fullname>Nintendo Game Boy Advance</fullname>
    <path>%ROMPATH%/gba</path>
    <extension>.gba .GBA .7z .7Z .zip .ZIP</extension>
    <command label="mGBA">%EMULATOR_RETROARCH% -f -L %CORE_RETROARCH%/mgba_libretro.dylib %ROM%</command>
    <platform>gba</platform>
    <theme>gba</theme>
  </system>
  <system>
    <name>gbc</name>
