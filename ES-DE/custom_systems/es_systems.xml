    <platform>nes</platform>
    <theme>nes</theme>
  </system>
  <system>
    <name>ps2</name>
    <fullname>Sony PlayStation 2</fullname>
    <path>%ROMPATH%/ps2</path>
    <extension>.bin .BIN .chd .CHD .cso .CSO .dump .DUMP .gz .GZ .img .IMG .iso .ISO .mdf .MDF .nrg .NRG .7z .7Z .zip .ZIP</extension>
