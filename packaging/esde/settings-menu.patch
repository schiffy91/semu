+//  SPDX-License-Identifier: MIT
+//
+//  Generic Semu settings bridge. The installed manifest selects one stable
+//  launcher; the BTRC CLI supplies the typed UI document and owns all writes.
+
+#include "guis/GuiSemuSettings.h"
+
+#include "Log.h"
+#include "Settings.h"
+#include "components/OptionListComponent.h"
+#include "components/SwitchComponent.h"
+#include "components/TextComponent.h"
+#include "guis/GuiMsgBox.h"
+#include "rapidjson/document.h"
+#include "utils/FileSystemUtil.h"
+#include "utils/StringUtil.h"
+
+#include <algorithm>
+#include <array>
+#include <cerrno>
+#include <csignal>
+#include <cstdlib>
+#include <fstream>
+#include <memory>
+#include <string>
