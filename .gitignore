# Emulator config/data dirs (runtime state, not source-controlled)
Azahar/data/
Cemu/config/
Cemu/data/
Dolphin/config/
Dolphin/data/
Lime3DS/data/
PCSX2/config/
RetroArch/config/
RetroArch/retroarch.cfg
Ryujinx/config/

# Sync runtime data. Keep the editable sync profile, ignore generated service
# helpers, logs, and Syncthing's local keys/database.
sync/bin/
sync/logs/
sync/syncthing/
!sync/sync.json

# Curated/generated defaults are source-controlled under emulators/.
# Root emulator directories are local runtime state only.
