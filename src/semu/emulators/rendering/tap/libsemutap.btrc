            int nw = G.env_nw > 0 ? G.env_nw : (G.g_state.native_w > 0 ? G.g_state.native_w : (sw > 0 ? sw : 320));
            if ((G.ov_l | G.ov_r | G.ov_t | G.ov_b) != 0 && nw > 0 && nh > 0) {
