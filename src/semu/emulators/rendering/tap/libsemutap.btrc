                float scl = 1.0f;
                if (mh > (float)h * 0.92f) { scl = (float)h * 0.92f / mh; }
                mw = mw * scl; mh = mh * scl;
                G.p_u4f(G.uMenuRect, ((float)w - mw) * 0.5f, ((float)h - mh) * 0.5f, mw, mh);
            }
            G.p_draw(GL_TRIANGLES, 0, 3);
            G.frames = G.frames + 1;
            if (G.frames <= 2 || (G.menu_on != 0 && (G.frames % 30) == 0)) {
                FILE* lf = (FILE*)tap_fopen("semutap.log", "a");
                if (lf != null) { fprintf(lf, "frame%ld: fb=%dx%d native=%dx%d content=(%d,%d,%d,%d) pri=%d game=(%d,%d,%d,%d) bd=(%d,%d,%d,%d) menu_on=%d effArt=%.1f bidx=%d bcnt=%d uMenuOn=%d uHasArt=%d\n", G.frames, w, h, nw, nh, G.g_state.content_x, G.g_state.content_y, G.g_state.content_w, G.g_state.content_h, G.priority_mode, gx, gy, gw2, gh2, (int)bdx_gl, (int)bdy_gl, (int)bdw, (int)bdh, G.menu_on, eff_has_art, G.bezel_idx, G.bezel_count, (G.uMenuOn >= 0) ? 1 : 0, (G.uHasArt >= 0) ? 1 : 0); fclose(lf); }
            }
            { FILE* shotTrigger = (FILE*)tap_fopen("semu-shot", "r");
              if (shotTrigger != null) { fclose(shotTrigger); tap_remove("semu-shot"); write_composited_shot(w, h); } }
            gl_state_restore();
        }
    }
}

// nds/wii per-screen integer scale factor (the C used a local float[5])
float scale_factor(int i) {
    if (i == 0) { return 0.25f; }
    if (i == 1) { return 0.5f; }
    if (i == 2) { return 1.0f; }
    if (i == 3) { return 2.0f; }
    return 3.0f;
}

// ================= public present hooks (exported) =================
void glXSwapBuffers(void* dpy, unsigned long drawable) {
    tap_frame(dpy, drawable, 0);
    if (G.real_swap != null) { G.real_swap(dpy, drawable); return; }
    if (G.null_swap_logged_glx == 0) { G.null_swap_logged_glx = 1; logf_("glXSwapBuffers real pointer NULL - present dropped\n", 0, 0, 0); }
}
unsigned int eglSwapBuffers(void* dpy, void* surface) {
    tap_frame(dpy, (unsigned long)surface, 1);
    if (G.real_egl_swap != null) { return G.real_egl_swap(dpy, surface); }
    if (G.null_swap_logged_egl == 0) { G.null_swap_logged_egl = 1; logf_("eglSwapBuffers real pointer NULL - present dropped\n", 0, 0, 0); }
    return 0;
}
