// libsemutap.btrc — Semu compositor OpenGL back end (the GL "tap"), ported from
// libsemutap.c (1016 lines) to btrc. Faithful transliteration.
//
// SAME EXPORTED C SYMBOLS as the C build: semu_tap_report, dlsym, glXSwapBuffers,
// eglSwapBuffers. btrc preserves top-level function names verbatim as C symbols,
// so the LD_PRELOAD/dlsym interposition works identically. Build MUST use
// --no-dce (a library has no main(); DCE would drop the exports).
//
// FULLY STANDALONE btrc — the former companion header semutap_glue.h is GONE.
// Every C construct the tap needs is now native btrc (see the block below the
// includes): GL enum / ABI constants as `int`; GL/X11 fn-ptr typedefs as
// __fn_ptr<> struct fields called DIRECTLY (the dlsym'd void* is cast to the
// fn-ptr type — the multi-word __fn_ptr typedef-name bug that once forced the
// glue is fixed); the C's [4][1024]/[4][4] arrays FLATTENED into 1-D via the
// PathStr/Rect4 row holders; the single global `G`; and stat_mtime_d. There is
// ZERO hand-written C: this is the whole tap.
//
// CONSTRUCTOR -> LAZY INIT: the C had __attribute__((constructor)) semu_loaded
// (writes semu-loaded.log to prove LD_PRELOAD applied) AND a lazy `inited` guard
// in tap_init. btrc has no constructor attribute, so the load-log is folded into
// tap_init (first-hook-call), guarded by G.inited exactly like the C. This is the
// one behavioral change: semu-loaded.log is written on the FIRST swap instead of
// at library load. If no swap is ever hooked, the log is not written (the C wrote
// it at load unconditionally) — see the migration notes.

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <math.h>
#include <time.h>
#include <sys/stat.h>
#include <dlfcn.h>

// ============================================================================
// This file is literal, standalone btrc: the former semutap_glue.h is fully
// dissolved here. Every C construct the tap needs is now expressed natively —
//   - GL enum / ABI / menu constants -> btrc `int` module constants (below)
//   - GL type typedefs (GLenum=unsigned int, ...) -> raw btrc types in situ
//   - GL/X11 fn-ptr typedefs (PFN_*) -> btrc `__fn_ptr<ret, params...>` fields
//     on the state struct; the dlsym'd void* pointers are cast to those fn-ptr
//     types and CALLED DIRECTLY (no gl_*/x_* wrapper indirection)
//   - contract + state structs (with the C's [4][1024]/[4][4] arrays FLATTENED
//     to 1-D, indexed row*stride+col via the PathStr/Rect4 holders) -> raw btrc
//     `struct` decls, which pass through to the generated C verbatim
//   - the single global state `G` -> a btrc file-scope global
//   - stat_mtime_d -> a btrc function (declares `struct stat` + `stat`)
// The behavior is preserved bit-for-bit vs libsemutap.c; see the migration note
// on the constructor->lazy-init fold below.
// ============================================================================

// ---- externs resolved at runtime (glibc dlvsym) / linked (stb_image) ----
void* dlvsym(void* handle, char* symbol, char* version);
unsigned char* stbi_load(char* path, int* w, int* h, int* n, int desired);
void stbi_image_free(void* p);

// ============================ GL / ABI / menu constants ============================
// (were #defines / GLenum values in semutap_glue.h + libsemutap.c). Used identically:
// passed where the GL API expects a GLenum (unsigned int) — implicit int->unsigned
// conversion, same value.
int GL_VIEWPORT = 0x0BA2;
int GL_TEXTURE_2D = 0x0DE1;
int GL_RGB = 0x1907;
int GL_RGBA = 0x1908;
int GL_UNSIGNED_BYTE = 0x1401;
int GL_TEXTURE_MIN_FILTER = 0x2801;
int GL_TEXTURE_MAG_FILTER = 0x2800;
int GL_LINEAR = 0x2601;
int GL_LINEAR_MIPMAP_LINEAR = 0x2703;
int GL_TEXTURE_WRAP_S = 0x2802;
int GL_TEXTURE_WRAP_T = 0x2803;
int GL_CLAMP_TO_EDGE = 0x812F;
int GL_UNPACK_ALIGNMENT = 0x0CF5;
int GL_UNPACK_ROW_LENGTH = 0x0CF2;
int GL_UNPACK_SKIP_ROWS = 0x0CF3;
int GL_UNPACK_SKIP_PIXELS = 0x0CF4;
int GL_PIXEL_UNPACK_BUFFER = 0x88EC;
int GL_PIXEL_UNPACK_BUFFER_BINDING = 0x88EF;
int GL_TEXTURE0 = 0x84C0;
int GL_TEXTURE1 = 0x84C1;
int GL_TEXTURE2 = 0x84C2;
int GL_TEXTURE3 = 0x84C3;
int GL_FRAGMENT_SHADER = 0x8B30;
int GL_VERTEX_SHADER = 0x8B31;
int GL_COMPILE_STATUS = 0x8B81;
int GL_LINK_STATUS = 0x8B82;
int GL_TRIANGLES = 0x0004;
int GL_DEPTH_TEST = 0x0B71;
int GL_BLEND = 0x0BE2;
int GL_SCISSOR_TEST = 0x0C11;
int GLX_WIDTH = 0x801D;
int GLX_HEIGHT = 0x801E;
int GL_CURRENT_PROGRAM = 0x8B8D;
int GL_VERTEX_ARRAY_BINDING = 0x85B5;
int GL_ACTIVE_TEXTURE = 0x84E0;
int GL_TEXTURE_BINDING_2D = 0x8069;
int GL_PACK_ALIGNMENT = 0x0D05;
int SEMU_TAP_ABI = 1;
int SEMU_TAP_ORIGIN_TOP_LEFT = 1;

// ---- contract structs (semu_tap.h ABI + tap_geometry.h/tap_menu.h I/O) ----
struct SemuTapState {
    int abi; int active;
    int fb_width; int fb_height;
    int content_x; int content_y; int content_w; int content_h;
    int native_w; int native_h;
    int rotation; int origin; int reserved[4];
};
struct SemuTapGeometryInput {
    int win_w; int win_h; int native_w; int native_h;
    float display_aspect; int priority_bezel; int fill_hole; int has_art;
    int art_w; int art_h; float hole_x; float hole_y; float hole_w; float hole_h;
};
struct SemuTapGeometry {
    int game_x; int game_y; int game_w; int game_h;
    float bezel_x; float bezel_y; float bezel_w; float bezel_h; int bezel_priority;
};
struct SemuTapMenuState {
    int level; int selected; int system_kind; int priority_mode;
    int bezel_index; int bezel_count; int shader_index; int save_slot;
    int nds_layout; int nds_primary_scale; int nds_secondary_scale;
    int wii_controller; int action; int action_slot;
};

// nested-struct holders so the flattened arrays keep the C's row identity.
// The C used char glass_paths[4][1024] / float scr_rects[4][4]; btrc's parser
// only accepts single-dim fixed arrays (known-language-gaps #9), so each ROW is
// a struct holding a 1-D array, and the outer dimension is an array-of-struct.
// Same total bytes, same [row].v[col] access as the C's [row][col].
struct PathStr { char v[1024]; };
struct Rect4 { float v[4]; };

// One global state struct = all the C file-scope statics. The p_* GL/X11 entry
// points are typed __fn_ptr fields (were void* in the glue's TapG); they are
// assigned the dlsym'd void* via an explicit cast and called directly.
struct TapG {
    struct SemuTapState g_state; int g_have; int win_w; int win_h;

    __fn_ptr<void, void*, unsigned long> real_swap;
    __fn_ptr<unsigned int, void*, void*> real_egl_swap;
    __fn_ptr<void, void*, unsigned long, int, unsigned int*> p_query;
    __fn_ptr<void, unsigned int, int*> p_getiv;
    __fn_ptr<void, int, unsigned int*> p_gentex;
    __fn_ptr<void, unsigned int, unsigned int> p_bindtex;
    __fn_ptr<void, unsigned int, int, int, int, int, int, unsigned int, unsigned int, void*> p_teximg;
    __fn_ptr<void, unsigned int, int, unsigned int, int, int, int, int, int> p_copytex;
    __fn_ptr<void, unsigned int, unsigned int, int> p_texpar;
    __fn_ptr<void, unsigned int> p_active;
    __fn_ptr<void, int, unsigned int*> p_genva;
    __fn_ptr<void, unsigned int> p_bindva;
    __fn_ptr<unsigned int, unsigned int> p_createsh;
    __fn_ptr<void, unsigned int, int, char**, int*> p_shsrc;
    __fn_ptr<void, unsigned int> p_compsh;
    __fn_ptr<void, unsigned int, unsigned int, int*> p_shiv;
    __fn_ptr<void, unsigned int, int, int*, char*> p_shlog;
    __fn_ptr<unsigned int> p_createpr;
    __fn_ptr<void, unsigned int, unsigned int> p_attach;
    __fn_ptr<void, unsigned int> p_link;
    __fn_ptr<void, unsigned int, unsigned int, int*> p_priv;
    __fn_ptr<void, unsigned int> p_use;
    __fn_ptr<int, unsigned int, char*> p_uloc;
    __fn_ptr<void, int, int> p_u1i;
    __fn_ptr<void, int, float, float> p_u2f;
    __fn_ptr<void, int, float, float, float, float> p_u4f;
    __fn_ptr<void, int, float, float, float> p_u3f;
    __fn_ptr<void, int, float> p_u1f;
    __fn_ptr<void, unsigned int, int, int> p_draw;
    __fn_ptr<void, int, int, int, int> p_viewport;
    __fn_ptr<void, unsigned int> p_disable;
    __fn_ptr<void, unsigned int> p_genmip;
    __fn_ptr<void, unsigned int, int> p_pixstore;
    __fn_ptr<void, unsigned int, unsigned int> p_bindbuf;
    __fn_ptr<int, void*, char*> p_qkm;
    __fn_ptr<unsigned char, void*, unsigned long> p_k2kc;
    __fn_ptr<unsigned long, char*> p_s2ks;
    __fn_ptr<unsigned char, unsigned int> p_isenab;
    __fn_ptr<void, unsigned int> p_enable;
    __fn_ptr<void, int, int, int, int, unsigned int, unsigned int, void*> p_readpix;
    __fn_ptr<void*, void*, char*> real_dlsym;

    int inited; int disabled; int gl_ready; int tap_style; int env_nw; int env_nh; int debug_on;
    int standalone;
    int ov_l; int ov_r; int ov_t; int ov_b;
    int retro_on; int priority_mode;
    int bezel_idx; int shader_idx; int bezel_count;
    int nds_layout; int nds_pri; int nds_sec; int dual_mode;
    float pip_expand_budget; float pip_seconds; float pip_w_current;
    double pip_expand_until; double pip_touch_seen;
    int fill_hole; int align_on;
    struct PathStr glass_paths[4];
    float reflect_amt; float curve_amt; float screen_corner;
    float glow_amt; float bloom_amt; float vignette_amt;
    float lcd_grid_amt; float lcd_subpixel_amt;
    float lcd_mono_amt; float lcd_wash_amt;
    int menu_on; int menu_lvl; int menu_sel;
    int save_slot; int wii_ctrl; int sys_kind;
    unsigned int menu_tex; unsigned char* menu_buf; int menu_dirty;
    unsigned char* atlas_buf; int atlas_w; int atlas_h;
    int GLY_W; int GLY_H;
    struct PathStr menu_font_path_s;
    float retro_lod; char retro_key[32];
    int kcode[7]; int kprev[7]; int kready;
    float debug_thresh;
    float shell_r; float shell_g; float shell_b;
    float tv_mask; float tv_scan; float tv_corner; float tv_bzlw;
    float has_art; struct PathStr art_paths[4]; int art_w; int art_h;
    int art_ws[4]; int art_hs[4];
    float scr_x; float scr_y; float scr_w; float scr_h;
    struct Rect4 scr_rects[4];
    struct Rect4 pri_rects[4]; struct Rect4 sec_rects[4];
    int dual_hole_set[4];
    float disp_aspect;
    unsigned int prog; unsigned int vao; unsigned int game_tex;
    unsigned int bezel_texs[4]; unsigned int glass_texs[4];
    int uWin; int uRect; int uSrc; int uBezelRect; int uNative; int uStyle; int uShell;
    int uTV; int uRef; int uHasArt; int uDebug; int uRetro; int uShaderMode;
    int uRect2; int uSrc2; int uDual; int uAlign; int uHole; int uGlass; int uHasGlass;
    int uReflect; int uCurve; int uScreenCorner; int uLcdGrid; int uLcdSub; int uLcdMono; int uLcdWash;
    int uMenuRect; int uMenuOn;
    long frames;
    char tap_state_dir_buf[1024]; int tap_state_dir_ready;

    int saved_unpack_pbo;
    int sv_prog; int sv_vao; int sv_active; int sv_tex[4]; int sv_view[4]; int sv_unpack[4];
    unsigned char sv_depth; unsigned char sv_blend; unsigned char sv_scissor;

    int swaptype_logged; int null_swap_logged_glx; int null_swap_logged_egl; int loaded_logged;
};

// The one global (was `static TapG G;` in the glue). C zero-initializes it.
struct TapG G;

// mtime as a double (0 if the file is absent). Linux st_mtim; the shipped C
// fallback (libsemutap.c) keeps the macOS st_mtimespec #ifdef, but this btrc
// port only builds the Linux .so, so the Linux member is used directly.
double stat_mtime_d(char* path);

