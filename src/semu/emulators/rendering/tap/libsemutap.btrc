            float swn = G.scr_rects[avar].v[2];
            float shn = G.scr_rects[avar].v[3];
            int awv = G.art_ws[avar] > 0 ? G.art_ws[avar] : G.art_w;
            int ahv = G.art_hs[avar] > 0 ? G.art_hs[avar] : G.art_h;
