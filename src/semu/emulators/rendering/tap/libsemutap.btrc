                    r1x = (int)(hx + (hw2 - fw) * 0.5f); r1y = (int)(hy + (hh2 - fh) * 0.5f); r1w = (int)fw; r1h = (int)fh;
                    hx = bdx_gl + G.sec_rects[hv].v[0] * bdw; hw2 = G.sec_rects[hv].v[2] * bdw;
                    hh2 = G.sec_rects[hv].v[3] * bdh; hy = bdy_gl + (1.0f - G.sec_rects[hv].v[1] - G.sec_rects[hv].v[3]) * bdh;
                    if (G.priority_mode == 3) { fw = hw2; fh = hh2; }
