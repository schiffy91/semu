{
  "schema_version": 1,
  "doc": {
    "purpose": "PCSX2 profile tree content (the Deck-proven goldens: config/inis/PCSX2.ini plus config/inputprofiles/Steam Deck.ini) as data, substituted by Pcsx2Emitter. Variables: ${pad} is the steam_input.json pcsx2_pad device identity, ${bios_directory} the resolved firmware folder, ${renderer_key}/${automatic_renderer} the contract graphics key with PCSX2's automatic sentinel, ${emulator_name} the contract name.",
    "grammar": "PCSX2's ini wire format: '<device>/<control> | Keyboard/<key>' pad bindings, 'Keyboard/Control & Keyboard/P' hotkey chords (translated by Pcsx2Emitter from the keymap)."
  },
  "blocks": {
    "pad_sections": [
      "[Pad]",
      "UseProfileHotkeyBindings = true",
      "MultitapPort1 = false",
      "MultitapPort2 = false",
      "",
      "[InputSources]",
      "Keyboard = true",
      "Mouse = true",
      "SDL = true",
      "DInput = false",
      "XInput = false",
      "",
      "[Pad1]",
      "Type = DualShock2",
      "Up = ${pad}/DPadUp | Keyboard/Up",
      "Right = ${pad}/DPadRight | Keyboard/Right",
      "Down = ${pad}/DPadDown | Keyboard/Down",
      "Left = ${pad}/DPadLeft | Keyboard/Left",
      "Triangle = ${pad}/Y | Keyboard/I",
      "Circle = ${pad}/B | Keyboard/X",
      "Cross = ${pad}/A | Keyboard/Z",
      "Square = ${pad}/X | Keyboard/A",
      "Select = ${pad}/Back | Keyboard/Backspace",
      "Start = ${pad}/Start | Keyboard/Enter",
      "L1 = ${pad}/LeftShoulder",
      "L2 = ${pad}/+LeftTrigger",
      "R1 = ${pad}/RightShoulder",
      "R2 = ${pad}/+RightTrigger",
      "L3 = ${pad}/LeftStick",
      "R3 = ${pad}/RightStick",
      "LUp = ${pad}/-LeftY",
      "LRight = ${pad}/+LeftX",
      "LDown = ${pad}/+LeftY",
      "LLeft = ${pad}/-LeftX",
      "RUp = ${pad}/-RightY",
      "RRight = ${pad}/+RightX",
      "RDown = ${pad}/+RightY",
      "RLeft = ${pad}/-RightX",
      "",
      "[Pad2]",
      "Type = None"
    ]
  },
  "hotkeys": {
    "keymap": [
      { "setting": "OpenPauseMenu", "action": "ui.menu" },
      { "setting": "TogglePause", "action": "ui.pause" },
      { "setting": "ToggleFullscreen", "action": "ui.fullscreen" },
      { "setting": "PreviousSaveStateSlot", "action": "state.prev" },
      { "setting": "NextSaveStateSlot", "action": "state.next" },
      { "setting": "SaveStateToSlot", "action": "state.save" },
      { "setting": "LoadStateFromSlot", "action": "state.load" },
      { "setting": "Screenshot", "action": "ui.screenshot" },
      { "setting": "ToggleTurbo", "action": "speed.fast" },
      { "setting": "ToggleSlowMotion", "action": "speed.rewind" }
    ]
  },
  "files": [
    {
      "path": "${emulator_name}/config/inis/PCSX2.ini",
      "lines": [
        "[UI]",
        "SettingsVersion = 1",
        "InhibitScreensaver = true",
        "ConfirmShutdown = false",
        "StartPaused = false",
        "PauseOnFocusLoss = false",
        "StartFullscreen = true",
        "DoubleClickTogglesFullscreen = true",
        "HideMouseCursor = true",
        "RenderToSeparateWindow = false",
        "HideMainWindowWhenRunning = true",
        "DisableWindowResize = false",
        "PreferEnglishGameList = false",
        "Theme = darkfusionblue",
        "SetupWizardIncomplete = false",
        "",
        "[Folders]",
        "Bios = ${bios_directory}",
        "Snapshots = snaps",
        "Savestates = sstates",
        "MemoryCards = memcards",
        "Logs = logs",
        "Cheats = cheats",
        "Patches = patches",
        "UserResources = resources",
        "Cache = cache",
        "Textures = textures",
        "InputProfiles = inputprofiles",
        "",
        "[EmuCore]",
        "EnablePatches = true",
        "EnableWideScreenPatches = false",
        "EnableFastBoot = true",
        "UseSavestateSelector = true",
        "McdFolderAutoManage = true",
        "",
        "[EmuCore/GS]",
        "AspectRatio = Auto 4:3/3:2",
        "IntegerScaling = true",
        "${renderer_key} = ${automatic_renderer}",
        "upscale_multiplier = 1",
        "filter = 0",
        "VsyncEnable = true",
        "",
        "@block:pad_sections"
      ]
    },
    {
      "path": "${emulator_name}/config/inputprofiles/Steam Deck.ini",
      "lines": [
        "@block:pad_sections",
        "[Hotkeys]",
        "@lines:keymap_hotkeys"
      ]
    }
  ]
}
