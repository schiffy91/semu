+
 #include <string.h>
 
 /*
@@ -286,3 +288,5 @@
 
 	memset(ctx, 0, sizeof(*ctx));
 }
+
+#endif /* !__APPLE__: CommonCrypto provides MD5_* (see lrc_hash.h) */
