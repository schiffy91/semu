Fixes RetroArch v1.22.2 `make` builds on macOS (upstream builds with Xcode,
which masks all of these):
1. libretro-common/utils/md5.c is compiled unconditionally, but lrc_hash.h
   maps MD5_Init/Update/Final to CommonCrypto on __APPLE__, so the duplicate
   C implementation breaks against CC_MD5state_st. The upstream Xcode project
   simply excludes the file; guard it the same way for the make build.
2. menu/menu_displaylist.c uses CFBundle* under #ifdef __APPLE__ without
   including CoreFoundation (the Xcode precompiled prefix provides it).
3. ui/drivers/ui_cocoa.m calls functions implemented in cocoa_common.m whose
   prototypes are only declared there (or only for iOS in apple_platform.h),
   and uses menu symbols without including the menu headers.
4. Makefile.common never compiles the apple display server / CoreLocation
   driver objects video_driver.c and retroarch.c reference on __APPLE__, and
   never links QuartzCore (CAMetalLayer, CAFrameRateRangeMake) or
   AVFoundation (the accessibility narrator in platform_darwin.m).
5. cocoa_common.m messages the Swift-implemented RetroArchPlaylistManager;
   make builds have no Swift integration, so route around it (content
   loading still works through the regular companion-UI path).
--- a/Makefile.common	2026-07-02 21:34:44
+++ b/Makefile.common	2026-07-02 21:36:48
@@ -2584,7 +2584,15 @@
    DEFINES += -DHAVE_MAIN -DOSX
    OBJ += input/drivers/cocoa_input.o \
           ui/drivers/ui_cocoa.o \
-          ui/drivers/cocoa/cocoa_common.o
+          ui/drivers/cocoa/cocoa_common.o \
+          gfx/display_servers/dispserv_apple.o
+
+   # objects/frameworks the Xcode project carries but the make build forgot
+   LIBS += -framework QuartzCore -framework AVFoundation
+   ifeq ($(HAVE_CORELOCATION), 1)
+      OBJ += location/drivers/corelocation.o
+      LIBS += -framework CoreLocation
+   endif
 
    ifeq ($(HAVE_OPENGL), 1)
            DEFINES += -DGL_SILENCE_DEPRECATION
--- a/libretro-common/utils/md5.c	2026-07-02 21:34:44
+++ b/libretro-common/utils/md5.c	2026-07-02 21:34:44
@@ -36,6 +36,8 @@
  */
 #include <lrc_hash.h>
 
