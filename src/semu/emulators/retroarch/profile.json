{
  "schema_version": 1,
  "doc": {
    "purpose": "RetroArch profile content (retroarch.cfg, golden line order) as data, substituted by RetroArchEmitter. The visual block is the profile default: fullscreen integer scaling with shaders off — session-specific shader/driver pins are runtime upserts owned by RetroArchRendering, not baked into the profile.",
    "variables": "${profile_name} contract name; ${input_driver}/${audio_driver} resolved by the emulator class (lines drop when empty); ${content_root} the shared runtime content root."
  },
  "hotkeys": {
    "keymap": [
      { "setting": "input_load_state", "action": "state.load" },
      { "setting": "input_menu_toggle", "action": "ui.menu" },
      { "setting": "input_save_state", "action": "state.save" },
      { "setting": "input_screenshot", "action": "ui.screenshot" },
      { "setting": "input_state_slot_decrease", "action": "state.prev" },
      { "setting": "input_state_slot_increase", "action": "state.next" },
      { "setting": "input_toggle_fast_forward", "action": "speed.fast" },
      { "setting": "input_toggle_fullscreen", "action": "ui.fullscreen" }
    ]
  },
  "files": [
    {
      "path": "${profile_name}/retroarch.cfg",
      "lines": [
        "config_save_on_exit = \"true\"",
        { "if": "audio_driver", "line": "audio_driver = \"${audio_driver}\"" },
        { "if": "input_driver", "line": "input_driver = \"${input_driver}\"" },
        "input_autodetect_enable = \"true\"",
        "input_remap_binds_enable = \"true\"",
        "savestate_directory = \"${content_root}/states\"",
        "savefile_directory = \"${content_root}/saves\"",
        "screenshot_directory = \"${content_root}/screenshots\"",
        "video_fullscreen = \"true\"",
        "video_scale_integer = \"true\"",
        "video_force_aspect = \"true\"",
        "video_vsync = \"true\"",
        "video_shader_enable = \"false\"",
        "@lines:keymap_hotkeys"
      ]
    }
  ]
}
