{
  "schema_version": 1,
  "name": "RetroArch",
  "kind": "libretro_frontend",
  "input": {
    "actions": [
      "ui.pause",
      "ui.screenshot",
      "ui.menu",
      "app.quit",
      "state.prev",
      "state.next",
      "state.load",
      "state.save",
      "speed.rewind",
      "speed.fast"
    ]
  },
  "platforms": {
    "linux": {
      "backend": "flatpak",
      "flatpak_id": "org.libretro.RetroArch",
      "display_server": "x11",
      "display_default": ":0",
      "sessions": {
        "gamescope": {
          "display_default": ":1"
        },
        "desktop": {
          "display_default": ":0"
        }
      },
      "args": [
        "-f"
      ],
      "gl_wrapper": "nixgl",
      "sandbox": {
        "sockets": [
          "pulseaudio"
        ],
        "devices": [
          "all"
        ],
        "share": [
          "ipc"
        ],
        "filesystems": [
          {
            "path": "host",
            "mode": "rw"
          }
        ],
        "extra_args": [
          "--devel"
        ],
        "runtime": "org.kde.Sdk//6.10",
        "command": "${asset_root}/bin/retroarch-semu"
      },
      "state": {
        "data_home": "preserve"
      },
      "firmware": {
        "dir": "${emulation_root}/RetroArch/config/system",
        "fallback_dirs": [
          "${paths.project_bios}"
        ]
      },
      "retroarch": {
        "video_driver": "glcore",
        "input_driver": "sdl2",
        "core_suffix": ".so",
        "core_dirs": [
          "${env:SEMU_RETROARCH_CORE_DIR}",
          "${nix_result}/lib/retroarch/cores",
          "/usr/lib/x86_64-linux-gnu/libretro",
          "/usr/lib/aarch64-linux-gnu/libretro",
          "/usr/lib/libretro"
        ],
        "settings_overrides": {
          "input_driver": "sdl2",
          "input_joypad_driver": "sdl2",
          "joypad_autoconfig_dir": "${flatpak_home}/config/retroarch/autoconfig"
        },
        "core_options": {
          "mupen64plus_next": {
            "aspect_force": "mupen64plus-aspect=4:3",
            "res_4x3": "mupen64plus-43screensize",
            "res_16x9": "mupen64plus-169screensize"
          }
        },
        "tap_binary": [
          "${home}/ra-build/RetroArch-1.22.2/retroarch",
          "${asset_root}/bin/retroarch-semu"
        ]
      }
    },
    "macos": {
      "backend": "nix",
      "executable": "${nix_result}/bin/retroarch",
      "args": [
        "-f"
      ],
      "retroarch": {
        "video_driver": "gl",
        "core_suffix": ".dylib",
        "core_dirs": [
          "${nix_result}/cores"
        ]
      }
    }
  },
  "doc": {
    "sandbox": "runtime/command/extra_args apply to the patched-RA tap launch (launcher.btrc:743-751); the sdl2 settings_overrides fix the Steam Virtual Gamepad in Game Mode (launcher.btrc:248-255).",
    "state": "data_home=preserve: RetroArch loads assets/autoconfig from its own flatpak data dir; isolating XDG_DATA_HOME makes RA abort before the GL context (launcher.btrc:636-643)."
  }
}
