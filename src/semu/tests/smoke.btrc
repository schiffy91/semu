ExecResult e2eRunSettingsUiScript(string exe, string home, string project, string script) {
    Vector<string> uiArgs = [];
    return e2eRunSettingsUiScriptArgs(exe, home, project, uiArgs, script);
}

ExecResult e2eRunSettingsUiScriptArgs(string exe, string home, string project, Vector<string> uiArgs, string script) {
    string command = "printf %s " + ShellWords.quote(script)
        + " | SEMU_HOME=" + ShellWords.quote(home)
        + " SEMU_BIN=" + ShellWords.quote(exe)
        + " PATH=/usr/bin:/bin "
        + ShellWords.quote(exe)
        + " settings ui";
    for arg in uiArgs {
        command = command + " " + ShellWords.quote(arg);
    }
    command = command + " --project " + ShellWords.quote(project);
    UnixShell shell = UnixShell();
    return shell.runRaw(command, true, false, "");
}

