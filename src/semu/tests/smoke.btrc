ExecResult e2eRunDeck(string exe, string home, string project, Vector<string> deckArgs) {
    return e2eRunDeckEnv(exe, home, project, deckArgs, "", "");
}

ExecResult e2eRunDeckEnv(string exe, string home, string project, Vector<string> deckArgs, string session, string steamRunning) {
    Command command = Command(exe)
        .envVar("SEMU_HOME", home)
        .envVar("SEMU_BIN", exe)
        .envVar("PATH", "/usr/bin:/bin")
        .arg("deck")
        .capture(true)
        .check(false);
    if (session.len() > 0) {
        command.envVar("SEMU_DECK_SESSION", session);
    }
    if (steamRunning.len() > 0) {
        command.envVar("SEMU_STEAM_RUNNING", steamRunning);
    }
    for arg in deckArgs {
        command.arg(arg);
    }
    command.flag("--project", project);
    UnixShell shell = UnixShell();
    return shell.runCommand(command);
}

ExecResult e2eRunLauncher(string exe, string home, string project, string roms, string binDir, string captureDir, string bwrapPath, string emulator, Vector<string> emulatorArgs) {
    Command command = Command(exe)
        .envVar("SEMU_HOME", home)
        .envVar("SEMU_BIN", exe)
        .envVar("SEMU_PROJECT_DIR", project)
        .envVar("SEMU_ROMS_DIR", roms)
        .envVar("SEMU_FLATPAK_CAPTURE", captureDir)
        .envVar("SEMU_BWRAP", bwrapPath)
        .envVar("SEMU_FORCE_ROUTED_NIX", "1")
        .envVar("SEMU_SCREENSHOT_HOOKS", "1")
        .envVar("SEMU_SCREENSHOT_DELAY_SECONDS", "0")
        .envVar("PATH", binDir + ":/usr/bin:/bin")
        .envVar("WAYLAND_DISPLAY", "wayland-test")
        .arg("launcher")
        .arg(emulator)
        .capture(true)
        .check(false);
    for arg in emulatorArgs {
        command.arg(arg);
    }
    UnixShell shell = UnixShell();
    ExecResult result = shell.runCommand(command);
    return result;
}

string e2eDeckEnumerateBlock(string output, string system) {
    string marker = "* " + system + "\n";
    int start = output.indexOf(marker);
    if (start < 0) { return ""; }
    string tail = output.substring(start, output.len() - start);
    int next = tail.indexOf("\n* ");
    if (next < 0) { return tail; }
    return tail.substring(0, next);
}

ExecResult e2eRunRoutedLauncher(string exe, string home, string project, string roms, string binDir, string captureDir, string emulator, string routedExe, Vector<string> emulatorArgs) {
    Command command = Command(exe)
        .envVar("SEMU_HOME", home)
        .envVar("SEMU_BIN", exe)
        .envVar("SEMU_PROJECT_DIR", project)
        .envVar("SEMU_ROMS_DIR", roms)
        .envVar("SEMU_FLATPAK_CAPTURE", captureDir)
        .envVar("SEMU_SCREENSHOT_HOOKS", "0")
        .envVar("PATH", binDir + ":/usr/bin:/bin")
        .arg("launcher")
        .arg("routed")
        .arg(emulator)
        .arg(routedExe)
        .capture(true)
        .check(false);
    for arg in emulatorArgs {
        command.arg(arg);
    }
    UnixShell shell = UnixShell();
    ExecResult result = shell.runCommand(command);
    return result;
}

bool e2eRunOk(ExecResult result, string label) {
    if (result.ok()) { return true; }
    print("E2E FAIL " + label);
    print(result.stdout());
    return false;
}

bool e2eWaitForFile(string path, string label) {
    UnixShell shell = UnixShell();
    ExecResult result = shell.runRaw("for i in 1 2 3 4 5; do [ -f " + ShellWords.quote(path) + " ] && exit 0; sleep 0.1; done; exit 1", false, false, "");
    return e2eOk(result.ok(), label + ": missing " + path);
}

bool e2eCatalogConsistency(string project, string launcherBin) {
    string systems = FileSystem.readText(joinPath(customSystemsRoot(project), "es_systems.xml"));
    string rules = FileSystem.readText(joinPath(customSystemsRoot(project), "es_find_rules.xml"));
    for id in declaredSystemIds() {
        if (!e2eContains(systems, "<name>" + id + "</name>", "ES-DE system catalog " + id)) { return false; }
    }
    for emulator in linuxLauncherNames() {
        string launcher = joinPath(launcherBin, semuLauncherName(emulator));
        if (!e2eContains(rules, "<emulator name=\"" + emulator + "\">", "ES-DE find rule " + emulator)) { return false; }
        if (!e2eContains(rules, launcher, "ES-DE launcher path " + emulator)) { return false; }
        if (!e2eOk(FileSystem.exists(launcher), "launcher missing " + launcher)) { return false; }
    }
    string settingsLauncher = joinPath(launcherBin, "semu-settings");
    if (!e2eContains(systems, "<name>semu-settings</name>", "ES-DE settings system")) { return false; }
    if (!e2eContains(systems, SettingsEntries.root(project), "ES-DE settings path")) { return false; }
    if (!e2eContains(rules, "<emulator name=\"SEMU_SETTINGS\">", "ES-DE settings find rule")) { return false; }
    if (!e2eContains(rules, settingsLauncher, "ES-DE settings launcher path")) { return false; }
    if (!e2eOk(FileSystem.exists(settingsLauncher), "settings launcher missing " + settingsLauncher)) { return false; }
    if (!e2eOk(FileSystem.exists(joinPath(SettingsEntries.root(project), "Toggle Bezels.semu")), "settings entry missing")) { return false; }
    return true;
}

// ---- render_options_smoke.btrc ----
int e2eRenderOptionsSmoke(CliArgs args) {
    string tmp = e2eTempDir("semu-render-options-smoke");
    string home = joinPath(tmp, "home");
    string exe = e2eExecutable(args);
    string project = args.valueAfter("--project", Environment.get("SEMU_PROJECT_DIR", "."));
    ensureDir(home);

    ExecResult enumerate = e2eRunDeck(exe, home, project, ["enumerate"]);
    if (!e2eRunOk(enumerate, "deck enumerate render options")) { return 1; }
    string output = enumerate.stdout();
    if (!e2eContains(output, "render : " + renderModeOptionsText(), "render mode options")) { return 1; }
    if (!e2eContains(output, "shader : A B C + Off", "global shader options")) { return 1; }
    if (!e2eContains(output, "bezel  : A B C + Off", "global bezel options")) { return 1; }
    if (!e2eContains(output, "save   : " + renderSaveOptionsText(), "save slot options")) { return 1; }

    for id in declaredSystemIds() {
        string block = e2eDeckEnumerateBlock(output, id);
        if (!e2eOk(block.len() > 0, "missing deck enumerate block for " + id)) { return 1; }
        if (!e2eContains(block, "class :", "render class for " + id)) { return 1; }
        if (!e2eContains(block, "shader: A B C + Off", "shader options for " + id)) { return 1; }
        if (!e2eContains(block, "bezel : A B C + Off", "bezel options for " + id)) { return 1; }
        if (!e2eContains(block, "hole  :", "bezel hole for " + id)) { return 1; }
        string extra = renderDynamicOptionsText(id);
        if (extra.len() > 0 && !e2eContains(block, "extra : " + extra, "dynamic options for " + id)) { return 1; }
    }

    print("OK BTRC render options smoke");
    return 0;
}

// ---- lifecycle_smoke.btrc ----
int e2eLifecycleSmoke(CliArgs args) {
    string tmp = e2eTempDir("semu-lifecycle-smoke");
    string project = joinPath(tmp, "project");
    string home = joinPath(tmp, "home");
    string romsOne = joinPath(tmp, "roms-one");
    string romsTwo = joinPath(tmp, "roms-two");
    string exe = e2eExecutable(args);
    ensureDir(project);
    ensureDir(home);
    ensureDir(joinPath(romsOne, "existing"));
    ensureDir(joinPath(romsTwo, "existing"));

    if (!e2eRunOk(e2eRunLifecycle(exe, home, "install", project, romsOne), "install")) { return 1; }
    if (!e2eRunOk(e2eRunLifecycle(exe, home, "install", project, romsOne), "install idempotent")) { return 1; }
    if (!e2eCatalogConsistency(project, linuxLauncherBin(project))) { return 1; }
    if (!e2eOk(SemuGeneratedFiles.isProjectSource(project, syncConfigPath(project)), "sync config should be classified as owned source")) { return 1; }
    if (!e2eOk(SemuGeneratedFiles.isProjectSource(project, semuSettingsPath(project)), "settings config should be classified as owned source")) { return 1; }
    if (!e2eOk(SemuGeneratedFiles.isProjectSource(project, keymapSourcePath(project)), "keymap should be classified as owned source")) { return 1; }
    if (!e2eOk(SemuGeneratedFiles.isProjectSource(project, screenshotConfigPath(project)), "screenshot config should be classified as owned source")) { return 1; }
    if (!e2eOk(SemuGeneratedFiles.isProjectSource(project, joinPath(presentationSettingsRoot(project), "gb.json")), "presentation config should be classified as owned source")) { return 1; }
    if (!e2eOk(SemuGeneratedFiles.isProjectGenerated(project, esDeSettingsPath(project)), "ES-DE settings should be classified as generated")) { return 1; }
    if (!e2eOk(SemuGeneratedFiles.isProjectGenerated(project, emulatorProfilePath(project, "RetroArch/retroarch.cfg")), "emulator profile should be classified as generated")) { return 1; }
    if (!e2eOk(SemuGeneratedFiles.isProjectGenerated(project, emulatorProfilePath(project, "Dolphin/config/Dolphin.ini")), "Dolphin runtime config should be classified as generated")) { return 1; }
    if (!e2eOk(SemuGeneratedFiles.isProjectGenerated(project, emulatorProfilePath(project, "Dolphin/config/GCPadNew.ini")), "Dolphin runtime pad config should be classified as generated")) { return 1; }
    if (!e2eOk(SemuGeneratedFiles.isProjectGenerated(project, emulatorProfilePath(project, "Dolphin/config/WiimoteNew.ini")), "Dolphin runtime Wiimote config should be classified as generated")) { return 1; }
    if (!e2eOk(SemuGeneratedFiles.isProjectGenerated(project, joinPath(project, "generated/packaging/input/steam-input/neptune-simple.vdf")), "Steam Input template should be classified as generated")) { return 1; }
    if (!e2eOk(SemuGeneratedFiles.isAdapterState(project, lifecycleStatePath(project)), "lifecycle state should be classified as adapter state")) { return 1; }
    if (!e2eOk(SemuGeneratedFiles.isAdapterState(project, joinPath(launcherRoutedStateRoot(project, "pcsx2"), "config/PCSX2/inis/PCSX2.ini")), "routed emulator home should be classified as adapter state")) { return 1; }
    if (!e2eOk(SemuGeneratedFiles.isAdapterState(project, deckQuitEvidencePath(project, "retroarch")), "quit-watch evidence should be classified as adapter state")) { return 1; }
    if (!e2eOk(SemuGeneratedFiles.isProjectOwned(project, syncConfigPath(project)), "sync config should be owned")) { return 1; }
    if (!e2eOk(SemuGeneratedFiles.isProjectOwned(project, emulatorProfilePath(project, "RetroArch/retroarch.cfg")), "emulator profile should be owned generated output")) { return 1; }
    if (!e2eContains(FileSystem.readText(emulatorProfilePath(project, "Dolphin/config/Dolphin.ini")), "PermissionAsked = True", "generated Dolphin analytics prompt config")) { return 1; }
    if (!e2eContains(FileSystem.readText(emulatorProfilePath(project, "Dolphin/config/GCPadNew.ini")), "[GCPad1]", "generated Dolphin GameCube runtime config")) { return 1; }
    if (!e2eContains(FileSystem.readText(emulatorProfilePath(project, "Dolphin/config/WiimoteNew.ini")), "Buttons/A = Return|`Click 1`|`SteamDeck/0/Steam Deck:A`", "generated Dolphin Wii runtime config")) { return 1; }
    if (!e2eOk(!SemuGeneratedFiles.isProjectGenerated(project, joinPath(romsOne, "gba")), "external ROM root should not be generated output")) { return 1; }
    if (!e2eOk(!SemuGeneratedFiles.isProjectOwned(project, joinPath(romsOne, "gba")), "external ROM root should not be Semu-owned")) { return 1; }
    if (!e2eOk(!SemuGeneratedFiles.isProjectSource(project, emulatorProfilePath(project, "RetroArch/retroarch.cfg")), "generated RetroArch profile should not be source-editable")) { return 1; }
    if (!e2eOk(!SemuGeneratedFiles.isAdapterState(project, emulatorProfilePath(project, "RetroArch/retroarch.cfg")), "generated RetroArch profile should not be adapter-state editable")) { return 1; }
    if (!e2eOk(!SemuGeneratedFiles.isProjectGenerated(project, syncConfigPath(project)), "sync source should not be generated output")) { return 1; }
    if (!e2eOk(!FileSystem.exists(joinPath(romsOne, "gba")), "install mutated external ROM dirs")) { return 1; }
    if (!e2eOk(FileSystem.isDir(joinPath(romsRoot(project), "gba")), "install did not create project fallback ROM dirs")) { return 1; }
    if (!e2eContains(FileSystem.readText(syncConfigPath(project)), romsOne, "sync config after install")) { return 1; }
    if (!e2eContains(FileSystem.readText(screenshotConfigPath(project)), "output_pattern", "screenshot config after install")) { return 1; }
    if (!e2eOk(FileSystem.exists(joinPath(home, ".local/share/applications/semu.desktop")), "desktop entry missing after install")) { return 1; }
    if (!e2eOk(FileSystem.exists(joinPath(home, ".config/systemd/user/semu-syncthing.service")), "systemd service missing after install")) { return 1; }
    string steamTemplates = joinPath(home, "steam-templates");
    if (!e2eRunOk(e2eRunSteamInput(exe, home, project, ["install", "--dest", steamTemplates]), "steam-input install")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(steamTemplates, "neptune-simple.vdf")), "\"controller_type\"\t\t\"controller_neptune\"", "installed Steam Input simple template")) { return 1; }
    string shortcutsFile = joinPath(home, "steam-userdata/52445373/config/shortcuts.vdf");
    if (!e2eWriteSteamShortcutFixture(shortcutsFile)) { return 1; }
    string configSetFile = joinPath(home, "controller-configs/52445373/config/configset_controller_neptune.vdf");
    if (!e2eWriteSteamConfigSetFixture(configSetFile)) { return 1; }
    ExecResult selection = e2eRunSteamInput(exe, home, project, [
        "select",
        "--shortcuts-file", shortcutsFile,
        "--configset-file", configSetFile,
        "--app-name", "Semu-x86_64.AppImage",
        "--exe", "/home/deck/Applications/Semu/Semu-x86_64.AppImage"
    ]);
    if (!e2eRunOk(selection, "steam-input shortcut selection")) { return 1; }
    string configSetText = FileSystem.readText(configSetFile);
    if (!e2eContains(configSetText, "\"semu-x8664appimage\"", "Steam Input selection key")) { return 1; }
    if (!e2eContains(configSetText, "\"template\"\t\t\"neptune-full.vdf\"", "Steam Input selected template")) { return 1; }
    ExecResult shortcutStatus = e2eRunSteamInput(exe, home, project, [
        "status",
        "--shortcuts-file", shortcutsFile,
        "--configset-file", configSetFile,
        "--app-name", "Semu-x86_64.AppImage",
        "--exe", "/home/deck/Applications/Semu/Semu-x86_64.AppImage"
    ]);
    if (!e2eRunOk(shortcutStatus, "steam-input shortcut status")) { return 1; }
    if (!e2eContains(shortcutStatus.stdout(), "OK shortcut: Semu-x86_64.AppImage", "Steam shortcut status")) { return 1; }
    if (!e2eContains(shortcutStatus.stdout(), "appid: 3834341984", "Steam shortcut appid")) { return 1; }
    if (!e2eContains(shortcutStatus.stdout(), "launch_id: 16468373422993309696", "Steam shortcut launch id")) { return 1; }
    if (!e2eContains(shortcutStatus.stdout(), "steam://rungameid/16468373422993309696", "Steam shortcut URI")) { return 1; }
    if (!e2eContains(shortcutStatus.stdout(), "OK selection: semu-x8664appimage -> neptune-full.vdf", "Steam Input selection status")) { return 1; }

    e2eSeedFile(joinPath(contentRoot(project), "saves/gba/game.sav"));
    e2eSeedFile(joinPath(biosRoot(project), "ps2/ps2-0230a-20080220.bin"));
    e2eSeedFile(joinPath(linuxLauncherBin(project), "semu-obsolete"));
    e2eSeedFile(joinPath(joinPath(semuStateRoot(project), "appimage-state"), "gopher64/config/sentinel"));
    if (!e2eRunOk(e2eRunLifecycle(exe, home, "reconfigure", project, romsTwo), "reconfigure")) { return 1; }
    if (!e2eContains(FileSystem.readText(syncConfigPath(project)), romsTwo, "sync config after reconfigure")) { return 1; }
    if (!e2eContains(FileSystem.readText(esDeSettingsPath(project)), romsTwo, "ES-DE settings after reconfigure")) { return 1; }
    if (!e2eOk(FileSystem.exists(joinPath(romsOne, "existing")), "original ROM root sentinel missing")) { return 1; }
    if (!e2eOk(!FileSystem.exists(joinPath(romsTwo, "gba")), "reconfigure mutated external ROM dirs")) { return 1; }
    if (!e2eOk(FileSystem.exists(joinPath(contentRoot(project), "saves/gba/game.sav")), "save should survive reconfigure")) { return 1; }
    if (!e2eOk(FileSystem.exists(joinPath(biosRoot(project), "ps2/ps2-0230a-20080220.bin")), "BIOS should survive reconfigure")) { return 1; }
    if (!e2eOk(!FileSystem.exists(joinPath(linuxLauncherBin(project), "semu-obsolete")), "reconfigure should prune stale launcher")) { return 1; }
    if (!e2eOk(!FileSystem.exists(joinPath(joinPath(semuStateRoot(project), "appimage-state"), "gopher64")), "reconfigure should prune obsolete emulator state")) { return 1; }

    if (!e2eRunOk(e2eRunLifecycleChange(exe, home, project, "state.save", "Ctrl+V"), "change keymap")) { return 1; }
    if (!e2eContains(FileSystem.readText(keymapSourcePath(project)), "action state.save = Ctrl+V", "keymap source after change")) { return 1; }
    if (!e2eContains(FileSystem.readText(emulatorProfilePath(project, "RetroArch/retroarch.cfg")), "input_save_state = \"v\"", "RetroArch keymap after change")) { return 1; }
    if (!e2eContains(FileSystem.readText(emulatorProfilePath(project, "Dolphin/config/Profiles/Hotkeys/Steam Deck.ini")), "Save State/Save State Slot 1 = @(Ctrl+V)", "Dolphin keymap after change")) { return 1; }
    if (!e2eContains(FileSystem.readText(emulatorProfilePath(project, "PCSX2/config/inputprofiles/Steam Deck.ini")), "SaveStateToSlot = Keyboard/Control & Keyboard/V", "PCSX2 keymap after change")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(project, "generated/packaging/input/steam-input/neptune-full.vdf")), "key_press V, Save State", "Steam Input keymap after change")) { return 1; }

    string keymapBeforeFailure = FileSystem.readText(keymapSourcePath(project));
    string retroarchBeforeFailure = FileSystem.readText(emulatorProfilePath(project, "RetroArch/retroarch.cfg"));
    if (!e2eOk(!e2eRunLifecycleArgs(exe, home, project, ["change", "--action", "state.save"]).ok(), "lifecycle change without command unexpectedly succeeded")) { return 1; }
    if (!e2eOk(!e2eRunLifecycleChange(exe, home, project, "missing.action", "Ctrl+B").ok(), "unknown keymap action unexpectedly succeeded")) { return 1; }
    if (!e2eOk(!e2eRunLifecycleChange(exe, home, project, "state.save", "Ctrl").ok(), "invalid keymap command unexpectedly succeeded")) { return 1; }
    if (!e2eOk(!e2eRunLifecycleArgs(exe, home, project, ["definitely-not-a-mode"]).ok(), "unknown lifecycle mode unexpectedly succeeded")) { return 1; }
    if (!e2eOk(FileSystem.readText(keymapSourcePath(project)).equals(keymapBeforeFailure), "failed keymap change mutated source")) { return 1; }
    if (!e2eOk(FileSystem.readText(emulatorProfilePath(project, "RetroArch/retroarch.cfg")).equals(retroarchBeforeFailure), "failed keymap change mutated RetroArch config")) { return 1; }

    if (!e2eRunOk(e2eRunLifecycle(exe, home, "uninstall", project, ""), "uninstall")) { return 1; }
    if (!e2eOk(!FileSystem.exists(joinPath(home, ".local/share/applications/semu.desktop")), "uninstall clears desktop entry")) { return 1; }
    if (!e2eOk(!FileSystem.exists(joinPath(home, ".config/systemd/user/semu-syncthing.service")), "uninstall clears systemd service")) { return 1; }
    if (!e2eOk(FileSystem.exists(syncConfigPath(project)), "sync config should survive uninstall")) { return 1; }
    if (!e2eOk(FileSystem.exists(joinPath(contentRoot(project), "saves/gba/game.sav")), "save should survive uninstall")) { return 1; }
    if (!e2eOk(FileSystem.exists(joinPath(biosRoot(project), "ps2/ps2-0230a-20080220.bin")), "BIOS should survive uninstall")) { return 1; }

    if (!e2eRunOk(e2eRunLifecycle(exe, home, "reinstall", project, ""), "reinstall")) { return 1; }
    if (!e2eOk(FileSystem.exists(joinPath(home, ".local/share/applications/semu.desktop")), "desktop entry missing after reinstall")) { return 1; }
    if (!e2eContains(FileSystem.readText(syncConfigPath(project)), romsTwo, "sync config after reinstall")) { return 1; }

    FileSystem.writeText(manifestPath(project), "{\"previous_manifest\": true}\n");
    if (!e2eRunOk(e2eRunLifecycle(exe, home, "upgrade", project, ""), "upgrade")) { return 1; }
    if (!e2eContains(FileSystem.readText(upgradeBackupPath(project)), "\"previous_manifest\": true", "upgrade backup")) { return 1; }
    if (!e2eContains(FileSystem.readText(manifestPath(project)), "\"schema_version\": 1", "regenerated manifest")) { return 1; }
    if (!e2eContains(FileSystem.readText(keymapSourcePath(project)), "action state.save = Ctrl+V", "keymap should survive upgrade")) { return 1; }

    if (!e2eRunOk(e2eRunLifecycleArgs(exe, home, project, ["uninstall", "--purge-generated", "--purge-state"]), "purge uninstall")) { return 1; }
    if (!e2eOk(!FileSystem.exists(customSystemsRoot(project)), "custom systems should be purged")) { return 1; }
    if (!e2eOk(!FileSystem.exists(lifecycleStatePath(project)), "lifecycle state should be purged")) { return 1; }

    print("OK BTRC lifecycle smoke");
    return 0;
}

// ---- sandbox_smoke.btrc ----
bool e2ePrepareSandbox(string project, string scratchRoot, string emulator) {
    string scratch = joinPath(scratchRoot, emulator);
    FileSystem.removeRecursive(scratch);
    string emuDir = sandboxProjectEmulatorDir(project, emulator);
    if (!e2eOk(emuDir.len() > 0, "missing emulator dir " + emulator)) {
        return false;
    }
    ensureDir(scratch);
    if (!e2eOk(sandboxApplyKnownLinks(project, emulator.toLower(), emuDir, scratch), "missing sandbox spec " + emulator)) {
        return false;
    }
    if (!e2eOk(sandboxApplyKnownLinks(project, emulator.toLower(), emuDir, scratch), "sandbox idempotency failed " + emulator)) {
        return false;
    }
    return true;
}

int e2eSandboxSmoke() {
    string tmp = e2eTempDir("semu-sandbox-smoke");
    string project = joinPath(tmp, "project");
    string scratchRoot = joinPath(tmp, "scratch");
    ensureDir(project);
    ensureDir(scratchRoot);

    e2eSeedFile(emulatorProfilePath(project, "Azahar/data/qt-config.ini"));
    if (!e2ePrepareSandbox(project, scratchRoot, "azahar")) { return 1; }
    if (!e2eAssertLink(joinPath(scratchRoot, "azahar/.local/share/azahar-emu/qt-config.ini"), emulatorProfilePath(project, "Azahar/data/qt-config.ini"))) { return 1; }

    e2eSeedFile(emulatorProfilePath(project, "Cemu/config/settings.xml"));
    e2eSeedFile(emulatorProfilePath(project, "Cemu/data/keys.txt"));
    if (!e2ePrepareSandbox(project, scratchRoot, "cemu")) { return 1; }
    if (!e2eAssertLink(joinPath(scratchRoot, "cemu/.config/Cemu/settings.xml"), emulatorProfilePath(project, "Cemu/config/settings.xml"))) { return 1; }
    if (!e2eAssertLink(joinPath(scratchRoot, "cemu/.local/share/Cemu/keys.txt"), emulatorProfilePath(project, "Cemu/data/keys.txt"))) { return 1; }

    e2eSeedFile(emulatorProfilePath(project, "Dolphin/config/Dolphin.ini"));
    e2eSeedFile(emulatorProfilePath(project, "Dolphin/data/Wii/title.dat"));
    if (!e2ePrepareSandbox(project, scratchRoot, "dolphin")) { return 1; }
    if (!e2eAssertLink(joinPath(scratchRoot, "dolphin/.config/dolphin-emu/Dolphin.ini"), emulatorProfilePath(project, "Dolphin/config/Dolphin.ini"))) { return 1; }
    if (!e2eAssertLink(joinPath(scratchRoot, "dolphin/.local/share/dolphin-emu/Wii"), emulatorProfilePath(project, "Dolphin/data/Wii"))) { return 1; }

    e2eSeedFile(joinPath(romsRoot(project), ".keep"));
    e2eSeedFile(esDeSettingsPath(project));
    e2eSeedFile(joinPath(customSystemsRoot(project), "es_find_rules.xml"));
    if (!e2ePrepareSandbox(project, scratchRoot, "es-de")) { return 1; }
    if (!e2eAssertLink(joinPath(scratchRoot, "es-de/ES-DE/ROMs"), romsRoot(project))) { return 1; }
    if (!e2eAssertLink(joinPath(scratchRoot, "es-de/ES-DE/settings/es_settings.xml"), esDeSettingsPath(project))) { return 1; }
    if (!e2eAssertLink(joinPath(scratchRoot, "es-de/ES-DE/custom_systems/es_find_rules.xml"), joinPath(customSystemsRoot(project), "es_find_rules.xml"))) { return 1; }

    e2eSeedFile(emulatorProfilePath(project, "Lime3DS/data/qt-config.ini"));
    if (!e2ePrepareSandbox(project, scratchRoot, "lime3ds")) { return 1; }
    if (!e2eAssertLink(joinPath(scratchRoot, "lime3ds/.config/lime3ds-emu/qt-config.ini"), emulatorProfilePath(project, "Lime3DS/data/qt-config.ini"))) { return 1; }

    e2eSeedFile(emulatorProfilePath(project, "PCSX2/config/PCSX2.ini"));
    if (!e2ePrepareSandbox(project, scratchRoot, "pcsx2")) { return 1; }
    if (!e2eAssertLink(joinPath(scratchRoot, "pcsx2/.config/PCSX2/PCSX2.ini"), emulatorProfilePath(project, "PCSX2/config/PCSX2.ini"))) { return 1; }

    e2eSeedFile(emulatorProfilePath(project, "RetroArch/config/input.cfg"));
    e2eSeedFile(emulatorProfilePath(project, "RetroArch/retroarch.cfg"));
    if (!e2ePrepareSandbox(project, scratchRoot, "retroarch")) { return 1; }
    if (!e2eAssertLink(joinPath(scratchRoot, "retroarch/.config/retroarch/input.cfg"), emulatorProfilePath(project, "RetroArch/config/input.cfg"))) { return 1; }
    if (!e2eAssertLink(joinPath(scratchRoot, "retroarch/.config/retroarch/retroarch.cfg"), emulatorProfilePath(project, "RetroArch/retroarch.cfg"))) { return 1; }

    e2eSeedFile(emulatorProfilePath(project, "Ryujinx/config/Config.json"));
    if (!e2ePrepareSandbox(project, scratchRoot, "ryujinx")) { return 1; }
    if (!e2eAssertLink(joinPath(scratchRoot, "ryujinx/.config/Ryujinx/Config.json"), emulatorProfilePath(project, "Ryujinx/config/Config.json"))) { return 1; }

    if (!e2eOk(sandboxProjectEmulatorDir(project, "missing").len() == 0, "missing emulator unexpectedly resolved")) { return 1; }
    ensureDir(joinPath(project, "Foo"));
    if (!e2eOk(!sandboxApplyKnownLinks(project, "foo", joinPath(project, "Foo"), joinPath(scratchRoot, "foo")), "unknown emulator spec unexpectedly succeeded")) { return 1; }

    print("OK BTRC sandbox smoke");
    return 0;
}

// ---- sync_smoke.btrc ----
void e2eWriteSyncFakes(string binDir) {
    string fakeSystemctl = joinPath(binDir, "systemctl");
    FileSystem.writeText(fakeSystemctl,
        "#!/usr/bin/env sh\n"
        + "set -eu\n"
        + "mkdir -p \"${SEMU_CAPTURE:?}\"\n"
        + "printf '%s\\n' \"$*\" >> \"$SEMU_CAPTURE/systemctl.log\"\n"
    );
    FileSystem.chmod(fakeSystemctl, 493);

    string fakeCurl = joinPath(binDir, "curl");
    FileSystem.writeText(fakeCurl,
        "#!/usr/bin/env sh\n"
        + "set -eu\n"
        + "mkdir -p \"${SEMU_CAPTURE:?}\"\n"
        + "printf '%s\\n' \"$*\" >> \"$SEMU_CAPTURE/curl.log\"\n"
    );
    FileSystem.chmod(fakeCurl, 493);

    string fakeSyncthing = joinPath(binDir, "syncthing");
    FileSystem.writeText(fakeSyncthing,
        "#!/usr/bin/env sh\n"
        + "set -eu\n"
        + "mkdir -p \"${SEMU_CAPTURE:?}\"\n"
        + "printf '%s\\n' \"$*\" >> \"$SEMU_CAPTURE/syncthing.log\"\n"
        + "if [ \"${1:-}\" = generate ]; then\n"
        + "  home=\"\"\n"
        + "  while [ $# -gt 0 ]; do\n"
        + "    if [ \"$1\" = -H ]; then home=\"$2\"; shift 2; else shift; fi\n"
        + "  done\n"
        + "  mkdir -p \"$home\"\n"
        + "  printf '<configuration><gui><apikey>test-key</apikey></gui></configuration>\\n' > \"$home/config.xml\"\n"
        + "  exit 0\n"
        + "fi\n"
        + "exit 0\n"
    );
    FileSystem.chmod(fakeSyncthing, 493);
}

int e2eSyncSmoke(CliArgs args) {
    string tmp = e2eTempDir("semu-sync-smoke");
    string project = joinPath(tmp, "project");
    string missingProject = joinPath(tmp, "missing-project");
    string home = joinPath(tmp, "home");
    string binDir = joinPath(tmp, "bin");
    string capture = joinPath(tmp, "capture");
    string exe = e2eExecutable(args);
    ensureDir(project);
    ensureDir(missingProject);
    ensureDir(home);
    ensureDir(binDir);
    ensureDir(capture);
    e2eWriteSyncFakes(binDir);

    if (!e2eRunOk(e2eRunSync(exe, home, binDir, project, ["setup"]), "sync setup")) { return 1; }
    string systemctlLog = FileSystem.readText(joinPath(capture, "systemctl.log"));
    string syncService = FileSystem.readText(joinPath(home, ".config/systemd/user/semu-syncthing.service"));
    string syncForceScript = FileSystem.readText(joinPath(project, "generated/packaging/sync/bin/sync-force.sh"));
    if (!e2eContains(syncService, " sync serve --project ", "sync service stable semu entrypoint")) { return 1; }
    if (!e2eContains(syncForceScript, " sync force all --project ", "sync force stable semu entrypoint")) { return 1; }
    if (!e2eContains(systemctlLog, "--user daemon-reload", "sync daemon-reload")) { return 1; }
    if (!e2eContains(systemctlLog, "--user enable semu-syncthing.service", "sync enable service")) { return 1; }
    if (!e2eContains(systemctlLog, "--user enable semu-sync-force.timer", "sync enable timer")) { return 1; }
    if (!e2eContains(systemctlLog, "--user start semu-syncthing.service", "sync start service")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "syncthing.log")), "semu-emulator_state", "sync emulator state folder")) { return 1; }

    if (!e2eRunOk(e2eRunSync(exe, home, binDir, project, ["force", "all"]), "sync force all")) { return 1; }
    if (!e2eRunOk(e2eRunSync(exe, home, binDir, project, ["force", "saves"]), "sync force saves")) { return 1; }
    string curlLog = FileSystem.readText(joinPath(capture, "curl.log"));
    if (!e2eContains(curlLog, "/rest/db/scan", "sync force all url")) { return 1; }
    if (!e2eContains(curlLog, "?folder=semu-saves", "sync force saves url")) { return 1; }
    if (!e2eContains(curlLog, "X-API-Key: test-key", "sync force api key")) { return 1; }

    if (!e2eRunOk(e2eRunSync(exe, home, binDir, project, ["autostart", "disable"]), "sync autostart disable")) { return 1; }
    if (!e2eRunOk(e2eRunSync(exe, home, binDir, project, ["autostart", "enable"]), "sync autostart enable")) { return 1; }
    systemctlLog = FileSystem.readText(joinPath(capture, "systemctl.log"));
    if (!e2eContains(systemctlLog, "--user disable semu-syncthing.service", "sync disable service")) { return 1; }
    if (!e2eContains(systemctlLog, "--user enable semu-syncthing.service", "sync re-enable service")) { return 1; }

    if (!e2eOk(!e2eRunSync(exe, home, binDir, missingProject, ["force", "all"]).ok(), "sync force without API key unexpectedly succeeded")) { return 1; }

    print("OK BTRC sync smoke");
    return 0;
}

// ---- settings_smoke.btrc ----
int e2eSettingsSmoke(CliArgs args) {
    string tmp = e2eTempDir("semu-settings-smoke");
    string project = joinPath(tmp, "project");
    string home = joinPath(tmp, "home");
    string sdRoot = joinPath(tmp, "sd-card");
    string normalizedRoms = joinPath(sdRoot, "Emulation/ES-DE/ES-DE/ROMs");
    string configRoot = joinPath(tmp, "config-card");
    string configRoms = joinPath(configRoot, "Emulation/ES-DE/ES-DE/ROMs");
    string exe = e2eExecutable(args);
    ensureDir(project);
    ensureDir(home);
    ensureDir(normalizedRoms);
    ensureDir(configRoms);

    if (!e2eRunOk(e2eRunSettings(exe, home, project, ["put", "visual.integer_scaling", "true"]), "settings put bool")) { return 1; }
    if (!e2eRunOk(e2eRunSettings(exe, home, project, ["put", "ui.theme", "deck-dark"]), "settings put string")) { return 1; }
    ExecResult list = e2eRunSettings(exe, home, project, ["list"]);
    if (!e2eRunOk(list, "settings list")) { return 1; }
    if (!e2eContains(list.stdout(), "visual.integer_scaling=true", "settings list bool")) { return 1; }
    if (!e2eContains(list.stdout(), "ui.theme=deck-dark", "settings list string")) { return 1; }
    if (!e2eOk(!e2eRunSettings(exe, home, project, ["put", "visual.integer_scaling", "maybe"]).ok(), "invalid boolean setting unexpectedly succeeded")) { return 1; }

    if (!e2eRunOk(e2eRunConfig(exe, home, project, ["set-roms", configRoot]), "config set-roms source-only")) { return 1; }
    if (!e2eContains(FileSystem.readText(syncConfigPath(project)), configRoms, "config set-roms persisted owned source")) { return 1; }
    if (!e2eOk(!FileSystem.exists(esDeSettingsPath(project)), "config set-roms mutated generated ES-DE before apply")) { return 1; }
    if (!e2eRunOk(e2eRunConfig(exe, home, project, ["set-roms", sdRoot, "--apply"]), "config set-roms apply")) { return 1; }
    if (!e2eContains(FileSystem.readText(syncConfigPath(project)), normalizedRoms, "config set-roms apply persisted owned source")) { return 1; }
    if (!e2eContains(FileSystem.readText(esDeSettingsPath(project)), normalizedRoms, "config set-roms apply regenerated ES-DE")) { return 1; }

    ExecResult uiEdit = e2eRunSettingsUiScript(exe, home, project, "1\n" + sdRoot + "\na\nq\n");
    if (!e2eRunOk(uiEdit, "settings ui edit/apply")) { return 1; }
    if (!e2eContains(uiEdit.stdout(), "Semu Settings", "settings ui title")) { return 1; }
    if (!e2eContains(uiEdit.stdout(), "Edits update Semu-owned JSON", "settings ui owned boundary")) { return 1; }
    if (!e2eContains(uiEdit.stdout(), "ROM Directory", "settings ui rom row")) { return 1; }
    if (!e2eContains(FileSystem.readText(syncConfigPath(project)), normalizedRoms, "settings ui normalized ROM path")) { return 1; }
    if (!e2eOk(FileSystem.exists(esDeSettingsPath(project)), "settings ui apply did not reconfigure ES-DE")) { return 1; }

    ExecResult uiToggle = e2eRunSettingsUiScript(exe, home, project, "13\nq\n");
    if (!e2eRunOk(uiToggle, "settings ui toggle")) { return 1; }
    if (!e2eContains(FileSystem.readText(semuSettingsPath(project)), "\"visual_integer_scaling\": false", "settings ui toggled bool")) { return 1; }
    if (!e2eContains(FileSystem.readText(semuSettingsPath(project)), "\n    \"ui_theme\": \"deck-dark\"", "settings json pretty output")) { return 1; }

    ExecResult uiEof = e2eRunSettingsUiScript(exe, home, project, "");
    if (!e2eRunOk(uiEof, "settings ui eof")) { return 1; }

    ExecResult presentationUiEdit = e2eRunSettingsUiScriptArgs(exe, home, project, ["presentation"], "1\n10\nbezels/gb/ui-owned.json\nplan\nb\nq\n");
    if (!e2eRunOk(presentationUiEdit, "presentation settings ui edit")) { return 1; }
    if (!e2eContains(presentationUiEdit.stdout(), "Semu Presentation Settings", "presentation ui title")) { return 1; }
    if (!e2eContains(presentationUiEdit.stdout(), "Edits update Semu-owned JSON", "presentation ui owned boundary")) { return 1; }
    if (!e2eContains(presentationUiEdit.stdout(), "\"selected_bezel_file\": \"bezels/gb/ui-owned.json\"", "presentation ui plan")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(presentationSettingsRoot(project), "gb.json")), "ui-owned", "presentation ui persisted owned config")) { return 1; }

    ExecResult visualAuditUi = e2eRunSettingsUiScript(exe, home, project, "v\nq\n");
    if (!e2eRunOk(visualAuditUi, "settings ui visual audit")) { return 1; }
    if (!e2eContains(visualAuditUi.stdout(), "Presentation asset audit", "settings ui audit output")) { return 1; }
    if (!e2eContains(visualAuditUi.stdout(), "report: " + presentationAssetAuditPath(project), "settings ui audit report path")) { return 1; }
    if (!e2eOk(SemuGeneratedFiles.isAdapterState(project, presentationAssetAuditPath(project)), "presentation audit report should be adapter state")) { return 1; }

    string retroarchBeforeInputUi = FileSystem.readText(emulatorProfilePath(project, "RetroArch/retroarch.cfg"));
    ExecResult inputUiEdit = e2eRunSettingsUiScriptArgs(exe, home, project, ["input"], "10\nc\nCtrl+W\nback\nq\n");
    if (!e2eRunOk(inputUiEdit, "input settings ui edit")) { return 1; }
    if (!e2eContains(inputUiEdit.stdout(), "Semu Input Settings", "input ui title")) { return 1; }
    if (!e2eContains(inputUiEdit.stdout(), "Edits update Semu-owned keymap source", "input ui owned boundary")) { return 1; }
    if (!e2eContains(FileSystem.readText(keymapSourcePath(project)), "action state.save = Ctrl+W", "input ui persisted owned keymap")) { return 1; }
    if (!e2eOk(FileSystem.readText(emulatorProfilePath(project, "RetroArch/retroarch.cfg")).equals(retroarchBeforeInputUi), "input ui edit mutated generated RetroArch profile before apply")) { return 1; }
    if (!e2eContains(e2eRunKeymap(exe, home, project, ["get", "state.save"]).stdout(), "state.save=Ctrl+W", "keymap get edited command")) { return 1; }
    ExecResult stateCapabilities = e2eRunKeymap(exe, home, project, ["capabilities", "state.save"]);
    if (!e2eRunOk(stateCapabilities, "keymap state capability report")) { return 1; }
    if (!e2eContains(stateCapabilities.stdout(), "pending state.save: generated=retroarch,dolphin,pcsx2", "state save generated capabilities")) { return 1; }
    if (!e2eContains(stateCapabilities.stdout(), "disabled=azahar,ppsspp,flycast,melonds,cemu,ryujinx", "state save disabled capabilities")) { return 1; }
    if (!e2eRunOk(e2eRunKeymap(exe, home, project, ["put", "state.save", "Ctrl+W", "--apply"]), "keymap put apply")) { return 1; }
    if (!e2eContains(FileSystem.readText(emulatorProfilePath(project, "RetroArch/retroarch.cfg")), "input_save_state = \"w\"", "input apply regenerated RetroArch profile")) { return 1; }

    string syncServicePath = joinPath(home, ".config/systemd/user/semu-syncthing.service");
    string syncServiceBeforeUi = FileSystem.exists(syncServicePath) ? FileSystem.readText(syncServicePath) : "";
    ExecResult syncUiEdit = e2eRunSettingsUiScriptArgs(exe, home, project, ["sync"], "6\nq\n");
    if (!e2eRunOk(syncUiEdit, "sync settings ui edit")) { return 1; }
    if (!e2eContains(syncUiEdit.stdout(), "Semu Sync Settings", "sync ui title")) { return 1; }
    if (!e2eContains(syncUiEdit.stdout(), "Edits update Semu-owned config/settings/sync.json", "sync ui owned boundary")) { return 1; }
    if (!e2eContains(FileSystem.readText(syncConfigPath(project)), "\"sync_saves\": false", "sync ui persisted owned config")) { return 1; }
    if (!e2eOk(FileSystem.exists(syncServicePath), "sync service missing before sync UI boundary check")) { return 1; }
    if (!e2eOk(FileSystem.readText(syncServicePath).equals(syncServiceBeforeUi), "sync ui edit mutated generated service before apply")) { return 1; }
    if (!e2eContains(e2eRunSync(exe, home, "/usr/bin", project, ["get", "sync_saves"]).stdout(), "sync_saves=false", "sync get edited value")) { return 1; }
    if (!e2eRunOk(e2eRunSync(exe, home, "/usr/bin", project, ["put", "sync_saves", "true", "--apply"]), "sync put apply")) { return 1; }
    if (!e2eContains(FileSystem.readText(syncConfigPath(project)), "\"sync_saves\": true", "sync apply persisted owned config")) { return 1; }
    if (!e2eOk(FileSystem.exists(esDeSettingsPath(project)), "sync apply did not reconfigure ES-DE")) { return 1; }
    if (!e2eRunOk(e2eRunSettings(exe, home, project, ["compile"]), "settings compile")) { return 1; }
    if (!e2eContains(FileSystem.readText(lifecycleStatePath(project)), "\"action\": \"compile\"", "settings compile lifecycle state")) { return 1; }

    SettingsEntries.write(project);
    string presentationEntry = joinPath(SettingsEntries.root(project), "Open Presentation Settings.semu");
    if (!e2eContains(FileSystem.readText(presentationEntry), "ui presentation", "presentation ES-DE entry action")) { return 1; }
    string inputEntry = joinPath(SettingsEntries.root(project), "Open Input Settings.semu");
    if (!e2eContains(FileSystem.readText(inputEntry), "ui input", "input ES-DE entry action")) { return 1; }
    string syncEntry = joinPath(SettingsEntries.root(project), "Open Sync Settings.semu");
    string compileEntry = joinPath(SettingsEntries.root(project), "Compile Settings.semu");
    if (!e2eContains(FileSystem.readText(syncEntry), "ui sync", "sync ES-DE entry action")) { return 1; }
    if (!e2eContains(FileSystem.readText(compileEntry), "compile", "compile ES-DE entry action")) { return 1; }
    if (!e2eContains(e2eRunSettings(exe, home, project, ["entry", syncEntry]).stdout(), "Semu Sync Settings", "sync settings ES-DE UI entry")) { return 1; }
    if (!e2eContains(e2eRunSettings(exe, home, project, ["entry", compileEntry]).stdout(), "OK settings compiled", "compile settings ES-DE entry")) { return 1; }
    string presentationPutEntry = joinPath(SettingsEntries.root(project), "Set GB Bezel.semu");
    FileSystem.writeText(presentationPutEntry, "presentation put gb bezel_file bezels/gb/from-entry.json\n");
    if (!e2eRunOk(e2eRunSettings(exe, home, project, ["entry", presentationPutEntry]), "presentation settings ES-DE put entry")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(presentationSettingsRoot(project), "gb.json")), "from-entry", "presentation entry persisted owned config")) { return 1; }
    string entry = joinPath(SettingsEntries.root(project), "Toggle Bezels.semu");
    if (!e2eRunOk(e2eRunSettings(exe, home, project, ["entry", entry]), "settings ES-DE entry")) { return 1; }
    if (!e2eContains(FileSystem.readText(semuSettingsPath(project)), "\"visual_bezels\": false", "settings entry toggled bezel setting")) { return 1; }
    string systemsXml = systemCatalog().esSystemsXml(project);
    if (!e2eContains(systemsXml, "<name>semu-settings</name>", "settings ES-DE system")) { return 1; }
    if (!e2eContains(systemsXml, SettingsEntries.root(project), "settings ES-DE action path")) { return 1; }

    print("OK BTRC settings smoke");
    return 0;
}

// ---- presentation_smoke.btrc ----
int e2ePresentationSmoke(CliArgs args) {
    string tmp = e2eTempDir("semu-presentation-smoke");
    string project = joinPath(tmp, "project");
    string home = joinPath(tmp, "home");
    string exe = e2eExecutable(args);
    ensureDir(project);
    ensureDir(home);

    if (!e2eRunOk(e2eRunPresentation(exe, home, project, ["defaults"]), "presentation defaults")) { return 1; }
    if (!e2eOk(FileSystem.exists(joinPath(presentationSettingsRoot(project), "gb.json")), "gb presentation config missing")) { return 1; }
    if (!e2eOk(FileSystem.exists(joinPath(presentationSettingsRoot(project), "n3ds.json")), "n3ds presentation config missing")) { return 1; }
    string shaderRoot = joinPath(nixResultRoot(project), "share/libretro/shaders/shaders_slang");
    ensureDir(joinPath(shaderRoot, "handheld/console-border"));
    FileSystem.writeText(joinPath(shaderRoot, "handheld/gameboy.slangp"), "# fake gb shader\n");
    FileSystem.writeText(joinPath(shaderRoot, "handheld/console-border/dmg.slangp"), "# fake gb runtime/bezel\n");

    ExecResult gb = e2eRunPresentation(exe, home, project, ["plan", "gb"]);
    if (!e2eRunOk(gb, "presentation gb plan")) { return 1; }
    if (!e2eContains(gb.stdout(), "\"system\": \"gb\"", "gb plan system")) { return 1; }
    if (!e2eContains(gb.stdout(), "\"shader_file\": \"handheld/gameboy.slangp\"", "gb shader")) { return 1; }
    if (!e2eContains(gb.stdout(), "classic grey Game Boy", "gb bezel intent")) { return 1; }
    if (!e2eContains(gb.stdout(), "\"scale_policy\": \"integer_native\"", "gb integer scale")) { return 1; }
    if (!e2eContains(gb.stdout(), "\"resolved_shader_file\": \"" + joinPath(shaderRoot, "handheld/gameboy.slangp") + "\"", "gb resolved shader file")) { return 1; }
    if (!e2eContains(gb.stdout(), "\"resolved_bezel_file\": \"" + joinPath(shaderRoot, "handheld/console-border/dmg.slangp") + "\"", "gb resolved bezel file")) { return 1; }
    if (!e2eContains(gb.stdout(), "\"resolved_runtime_preset\": \"" + joinPath(shaderRoot, "handheld/console-border/dmg.slangp") + "\"", "gb resolved runtime preset")) { return 1; }
    if (!e2eContains(gb.stdout(), "\"resolved_launcher_shader\": \"" + joinPath(shaderRoot, "handheld/console-border/dmg.slangp") + "\"", "gb launcher shader")) { return 1; }
    if (!e2eContains(gb.stdout(), "\"launcher_shader_status\": \"ok\"", "gb launcher shader status")) { return 1; }

    ExecResult gbAudit = e2eRunPresentation(exe, home, project, ["audit", "gb", "--strict"]);
    if (!e2eRunOk(gbAudit, "presentation gb asset audit")) { return 1; }
    if (!e2eContains(gbAudit.stdout(), "OK gb shader=ok bezel=ok runtime=ok launcher=ok", "gb audit ok line")) { return 1; }
    string auditReport = presentationAssetAuditPath(project);
    if (!e2eOk(FileSystem.exists(auditReport), "presentation audit report missing")) { return 1; }
    if (!e2eOk(SemuGeneratedFiles.isAdapterState(project, auditReport), "presentation audit report should be adapter state")) { return 1; }
    if (!e2eContains(FileSystem.readText(auditReport), "\"system\": \"gb\"", "gb audit report system")) { return 1; }
    if (!e2eContains(FileSystem.readText(auditReport), "\"missing_asset_count\": 0", "gb audit report missing asset count")) { return 1; }
    if (!e2eContains(FileSystem.readText(auditReport), "\"missing_dependency_count\": 0", "gb audit report missing dependency count")) { return 1; }

    string shaderBundleRoot = joinPath(nixResultRoot(project), "share/libretro/shaders");
    string dependencyPreset = joinPath(shaderBundleRoot, "Mega_Bezel_Packs/test/root.slangp");
    ensureDir(joinPath(shaderBundleRoot, "Mega_Bezel_Packs/test/base"));
    ensureDir(joinPath(shaderBundleRoot, "Mega_Bezel_Packs/test/images"));
    FileSystem.writeText(joinPath(shaderBundleRoot, "Mega_Bezel_Packs/test/base/base.slangp"), "# fake base shader\n");
    FileSystem.writeText(joinPath(shaderBundleRoot, "Mega_Bezel_Packs/test/images/shell.png"), "fake bezel image\n");
    FileSystem.writeText(dependencyPreset, "#reference \"base/base.slangp\"\nBackgroundImage = \"images/shell.png\"\n");
    if (!e2eRunOk(e2eRunPresentation(exe, home, project, ["put", "gb", "runtime_preset", "Mega_Bezel_Packs/test/root.slangp"]), "presentation dependency preset put")) { return 1; }
    ExecResult dependencyAudit = e2eRunPresentation(exe, home, project, ["audit", "gb", "--strict"]);
    if (!e2eRunOk(dependencyAudit, "presentation dependency audit")) { return 1; }
    if (!e2eContains(dependencyAudit.stdout(), "deps=ok", "presentation dependency audit line")) { return 1; }
    if (!e2eContains(FileSystem.readText(auditReport), "\"dependency_count\": 2", "presentation dependency count")) { return 1; }
    if (!e2eContains(FileSystem.readText(auditReport), "\"missing_dependency_count\": 0", "presentation dependency missing count")) { return 1; }

    FileSystem.writeText(dependencyPreset, "#reference \"base/missing.slangp\"\nBackgroundImage = \"images/shell.png\"\n");
    ExecResult missingDependencyAudit = e2eRunPresentation(exe, home, project, ["audit", "gb", "--strict"]);
    if (!e2eOk(!missingDependencyAudit.ok(), "presentation missing dependency audit unexpectedly succeeded")) { return 1; }
    if (!e2eContains(missingDependencyAudit.stdout(), "deps=missing", "presentation missing dependency audit line")) { return 1; }
    if (!e2eContains(FileSystem.readText(auditReport), "base/missing.slangp", "presentation missing dependency report")) { return 1; }
    if (!e2eRunOk(e2eRunPresentation(exe, home, project, ["put", "gb", "runtime_preset", "handheld/console-border/dmg.slangp"]), "presentation restore gb runtime")) { return 1; }

    ExecResult pspAudit = e2eRunPresentation(exe, home, project, ["audit", "psp", "--strict"]);
    if (!e2eOk(!pspAudit.ok(), "presentation psp strict audit unexpectedly succeeded")) { return 1; }
    if (!e2eContains(pspAudit.stdout(), "MISSING psp", "psp audit missing line")) { return 1; }
    if (!e2eContains(FileSystem.readText(auditReport), "\"system\": \"psp\"", "psp audit report system")) { return 1; }

    ExecResult allAudit = e2eRunPresentation(exe, home, project, ["audit"]);
    if (!e2eRunOk(allAudit, "presentation all asset audit")) { return 1; }
    if (!e2eContains(allAudit.stdout(), "Presentation asset audit", "all audit title")) { return 1; }
    if (!e2eContains(allAudit.stdout(), "DISABLED switch", "all audit disabled switch")) { return 1; }
    if (!e2eContains(allAudit.stdout(), "missing:", "all audit summary")) { return 1; }

    if (!e2eRunOk(e2eRunSettings(exe, home, project, ["put", "visual.crt_shaders", "false"]), "presentation disable shaders setting")) { return 1; }
    if (!e2eRunOk(e2eRunSettings(exe, home, project, ["put", "visual.bezels", "false"]), "presentation disable bezels setting")) { return 1; }
    ExecResult gbDisabled = e2eRunPresentation(exe, home, project, ["plan", "gb"]);
    if (!e2eRunOk(gbDisabled, "presentation gb disabled visual plan")) { return 1; }
    if (!e2eContains(gbDisabled.stdout(), "\"launcher_visuals_enabled\": false", "gb disabled launcher visuals")) { return 1; }
    if (!e2eContains(gbDisabled.stdout(), "\"resolved_launcher_shader\": \"\"", "gb disabled launcher shader")) { return 1; }
    if (!e2eContains(gbDisabled.stdout(), "\"launcher_shader_status\": \"disabled\"", "gb disabled launcher shader status")) { return 1; }
    if (!e2eRunOk(e2eRunSettings(exe, home, project, ["put", "visual.crt_shaders", "true"]), "presentation reenable shaders setting")) { return 1; }
    if (!e2eRunOk(e2eRunSettings(exe, home, project, ["put", "visual.bezels", "true"]), "presentation reenable bezels setting")) { return 1; }

    ExecResult gbc = e2eRunPresentation(exe, home, project, ["plan", "gbc"]);
    if (!e2eRunOk(gbc, "presentation gbc plan")) { return 1; }
    if (!e2eContains(gbc.stdout(), "frost purple Game Boy Color", "gbc bezel intent")) { return 1; }

    ExecResult gba = e2eRunPresentation(exe, home, project, ["plan", "gba"]);
    if (!e2eRunOk(gba, "presentation gba plan")) { return 1; }
    if (!e2eContains(gba.stdout(), "purple wide Game Boy Advance", "gba bezel intent")) { return 1; }

    ExecResult genesis = e2eRunPresentation(exe, home, project, ["plan", "genesis"]);
    if (!e2eRunOk(genesis, "presentation genesis plan")) { return 1; }
    if (!e2eContains(genesis.stdout(), "ntsc/ntsc-320px-composite-scanline.slangp", "genesis runtime preset")) { return 1; }

    ExecResult n3ds = e2eRunPresentation(exe, home, project, ["plan", "n3ds", "--emulator", "AZAHAR"]);
    if (!e2eRunOk(n3ds, "presentation n3ds plan")) { return 1; }
    if (!e2eContains(n3ds.stdout(), "\"adapter\": \"azahar\"", "n3ds adapter")) { return 1; }
    if (!e2eContains(n3ds.stdout(), "\"role\": \"top\"", "n3ds top region")) { return 1; }
    if (!e2eContains(n3ds.stdout(), "\"native_size\": \"320x240\"", "n3ds bottom native")) { return 1; }
    if (!e2eContains(n3ds.stdout(), "Azahar is only an adapter", "n3ds not overfit")) { return 1; }

    ExecResult ps2 = e2eRunPresentation(exe, home, project, ["plan", "ps2"]);
    if (!e2eRunOk(ps2, "presentation ps2 plan")) { return 1; }
    if (!e2eContains(ps2.stdout(), "\"dynamic_aspect\": true", "ps2 dynamic aspect")) { return 1; }
    if (!e2eContains(ps2.stdout(), "\"effective_aspect\": \"4:3\"", "ps2 default effective aspect")) { return 1; }
    if (!e2eContains(ps2.stdout(), "\"presentation_mode\": \"crt_4x3\"", "ps2 default crt mode")) { return 1; }
    if (!e2eContains(ps2.stdout(), "Panasonic", "ps2 crt bezel")) { return 1; }

    string pcsx2IniPath = joinPath(launcherRoutedStateRoot(project, "pcsx2"), "config/PCSX2/inis/PCSX2.ini");
    ensureDir(PathTools.dirname(pcsx2IniPath));
    FileSystem.writeText(pcsx2IniPath, "[EmuCore/GS]\nAspectRatio = 16:9\nEnableWidescreenPatches = true\n");
    ExecResult ps2State = e2eRunPresentation(exe, home, project, ["state", "ps2"]);
    if (!e2eRunOk(ps2State, "presentation ps2 state")) { return 1; }
    if (!e2eContains(ps2State.stdout(), "\"aspect\": \"16:9\"", "ps2 state widescreen")) { return 1; }
    if (!e2eContains(ps2State.stdout(), "\"confidence\": \"config\"", "ps2 state confidence")) { return 1; }
    ExecResult ps2Wide = e2eRunPresentation(exe, home, project, ["plan", "ps2"]);
    if (!e2eRunOk(ps2Wide, "presentation ps2 widescreen plan")) { return 1; }
    if (!e2eContains(ps2Wide.stdout(), "\"effective_aspect\": \"16:9\"", "ps2 widescreen effective aspect")) { return 1; }
    if (!e2eContains(ps2Wide.stdout(), "\"presentation_mode\": \"widescreen_frame\"", "ps2 widescreen mode")) { return 1; }
    if (!e2eContains(ps2Wide.stdout(), "\"selected_bezel_file\": \"bezels/tv/clean-component-16x9.json\"", "ps2 widescreen selected bezel")) { return 1; }
    if (!e2eRunOk(e2eRunPresentation(exe, home, project, ["put", "ps2", "widescreen_bezel_file", "bezels/ps2/custom-wide.json"]), "presentation widescreen bezel put")) { return 1; }
    ExecResult ps2CustomWide = e2eRunPresentation(exe, home, project, ["plan", "ps2"]);
    if (!e2eContains(ps2CustomWide.stdout(), "\"selected_bezel_file\": \"bezels/ps2/custom-wide.json\"", "ps2 custom widescreen bezel")) { return 1; }
    if (!e2eRunOk(e2eRunPresentation(exe, home, project, ["broadcast", "ps2"]), "presentation ps2 broadcast")) { return 1; }
    if (!e2eContains(FileSystem.readText(presentationStatePath(project, "ps2")), "\"aspect\": \"16:9\"", "presentation broadcast state")) { return 1; }

    ExecResult psp = e2eRunPresentation(exe, home, project, ["plan", "psp"]);
    if (!e2eRunOk(psp, "presentation psp plan")) { return 1; }
    if (!e2eContains(psp.stdout(), "red God of War PSP or original black PSP shell", "psp bezel intent")) { return 1; }

    ExecResult switchPlan = e2eRunPresentation(exe, home, project, ["plan", "switch"]);
    if (!e2eRunOk(switchPlan, "presentation switch plan")) { return 1; }
    if (!e2eContains(switchPlan.stdout(), "\"shader_backend\": \"off_by_default\"", "switch shader off")) { return 1; }
    if (!e2eContains(switchPlan.stdout(), "\"layout\": \"modern_fullscreen\"", "switch modern fullscreen")) { return 1; }

    if (!e2eRunOk(e2eRunPresentation(exe, home, project, ["put", "gb", "bezel_file", "bezels/gb/classic-grey-game-boy.json"]), "presentation put")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(presentationSettingsRoot(project), "gb.json")), "classic-grey-game-boy", "presentation put persisted")) { return 1; }
    if (!e2eContains(e2eRunPresentation(exe, home, project, ["get", "gb", "bezel_file"]).stdout(), "classic-grey-game-boy", "presentation get")) { return 1; }
    if (!e2eRunOk(e2eRunPresentation(exe, home, project, ["put", "ps2", "dynamic_aspect", "false"]), "presentation bool put")) { return 1; }
    if (!e2eContains(e2eRunPresentation(exe, home, project, ["get", "ps2", "dynamic_aspect"]).stdout(), "false", "presentation bool get")) { return 1; }

    print("OK BTRC presentation smoke");
    return 0;
}

// ---- launcher_smoke.btrc ----
int e2eLauncherSmoke(CliArgs args) {
    string tmp = e2eTempDir("semu-launcher-smoke");
    string project = joinPath(tmp, "project");
    string emulationRoot = joinPath(tmp, "sd/Emulation");
    string roms = joinPath(emulationRoot, "ES-DE/ES-DE/ROMs");
    string home = joinPath(tmp, "home");
    string capture = joinPath(tmp, "capture");
    string binDir = joinPath(tmp, "bin");
    string exe = e2eExecutable(args);
    ensureDir(project);
    ensureDir(roms);
    ensureDir(home);
    ensureDir(capture);
    ensureDir(binDir);
    string shaderPreset = joinPath(nixResultRoot(project), "share/libretro/shaders/shaders_slang/bezel/Mega_Bezel/Presets/MBZ__5__POTATO.slangp");
    e2eSeedFile(shaderPreset);
    e2eSeedFile(joinPath(emulationRoot, "Cemu/data/keys.txt"));
    e2eSeedFile(joinPath(emulationRoot, "PCSX2/config/bios/SCPH-39001.bin"));
    ensureDir(joinPath(emulationRoot, "Cemu/data/mlc01"));
    e2eSeedFile(joinPath(emulationRoot, "Ryujinx/config/bis/system/Contents/registered/firmware.nca"));
    e2eSeedFile(joinPath(emulationRoot, "Ryujinx/config/games/0100/game.json"));
    e2eSeedFile(joinPath(emulationRoot, "Ryujinx/config/mods/contents/0100/mod.txt"));
    e2eSeedFile(joinPath(emulationRoot, "Ryujinx/config/sdcard/Nintendo/save.dat"));

    string fakeFlatpak = joinPath(binDir, "flatpak");
    FileSystem.writeText(fakeFlatpak,
        "#!/usr/bin/env sh\n"
        + "set -eu\n"
        + "capture=\"${SEMU_FLATPAK_CAPTURE:?}\"\n"
        + "mkdir -p \"$capture\"\n"
        + "idx=\"$(find \"$capture\" -type f -name 'flatpak-*.args' | wc -l | tr -d ' ')\"\n"
        + "idx=\"$((idx + 1))\"\n"
        + "printf '%s\\n' \"$@\" > \"$capture/flatpak-$idx.args\"\n"
    );
    FileSystem.chmod(fakeFlatpak, 493);

    string fakeBwrap = joinPath(binDir, "bwrap");
    FileSystem.writeText(fakeBwrap,
        "#!/usr/bin/env sh\n"
        + "set -eu\n"
        + "printf '%s\\n' \"$@\" > \"${SEMU_FLATPAK_CAPTURE:?}/retroarch.args\"\n"
    );
    FileSystem.chmod(fakeBwrap, 493);

    string fakeGrim = joinPath(binDir, "grim");
    FileSystem.writeText(fakeGrim,
        "#!/usr/bin/env sh\n"
        + "set -eu\n"
        + "out=\"${1:?}\"\n"
        + "mkdir -p \"$(dirname \"$out\")\"\n"
        + "printf 'fake screenshot %s\\n' \"$out\" > \"$out\"\n"
        + "printf '%s\\n' \"$out\" >> \"${SEMU_FLATPAK_CAPTURE:?}/grim.log\"\n"
    );
    FileSystem.chmod(fakeGrim, 493);

    if (!e2eRunOk(e2eRunLauncher(exe, home, project, roms, binDir, capture, fakeBwrap, "cemu", ["game.wua"]), "launcher cemu")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-1.args")), "run", "cemu flatpak args")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-1.args")), "--filesystem=" + project, "cemu project grant")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-1.args")), "--filesystem=" + roms, "cemu rom grant")) { return 1; }
    string cemuState = launcherFlatpakStateRoot(project, "cemu");
    if (!e2eOk(FileSystem.isDir(joinPath(cemuState, "config")), "cemu flatpak config state missing")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-1.args")), "--filesystem=" + cemuState + ":create", "cemu state grant")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-1.args")), "--env=XDG_CONFIG_HOME=" + joinPath(cemuState, "config"), "cemu config env")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-1.args")), "--socket=x11", "cemu x11")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-1.args")), "info.cemu.Cemu", "cemu flatpak id")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-1.args")), "-f", "cemu fullscreen flag")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-1.args")), "-g", "cemu game flag")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-1.args")), "game.wua", "cemu rom arg")) { return 1; }
    string cemuScreens = joinPath(contentRoot(project), "screenshots/verification/cemu");
    if (!e2eOk(FileSystem.exists(joinPath(cemuScreens, "before_launch.png")), "cemu before_launch screenshot missing")) { return 1; }
    if (!e2eWaitForFile(joinPath(cemuScreens, "after_spawn.png"), "cemu after_spawn screenshot")) { return 1; }
    if (!e2eOk(FileSystem.exists(joinPath(cemuScreens, "after_exit.png")), "cemu after_exit screenshot missing")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(cemuScreens, "after_exit.png")), "fake screenshot", "cemu screenshot content")) { return 1; }

    if (!e2eRunOk(e2eRunLauncher(exe, home, project, roms, binDir, capture, fakeBwrap, "dolphin", ["game.iso"]), "launcher dolphin")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-2.args")), "--socket=x11", "dolphin x11")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-2.args")), "org.DolphinEmu.dolphin-emu", "dolphin flatpak id")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-2.args")), "Dolphin.Display.Fullscreen=True", "dolphin fullscreen config")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-2.args")), "-b", "dolphin boot flag")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-2.args")), "-e", "dolphin execute flag")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-2.args")), "game.iso", "dolphin rom arg")) { return 1; }

    if (!e2eRunOk(e2eRunLauncher(exe, home, project, roms, binDir, capture, fakeBwrap, "azahar", ["game.3ds"]), "launcher azahar")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-3.args")), "--socket=x11", "azahar x11")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-3.args")), "org.azahar_emu.Azahar", "azahar flatpak id")) { return 1; }
    string azaharArgLines = "\n" + FileSystem.readText(joinPath(capture, "flatpak-3.args")) + "\n";
    if (!e2eOk(!azaharArgLines.contains("\n-f\n"), "azahar should not receive -f because it prevents positional ROM boot")) { return 1; }
    string azaharConfig = azaharConfigText(project);
    if (!e2eContains(azaharConfig, "firstStart=false", "azahar first-run prompts disabled")) { return 1; }
    if (!e2eContains(azaharConfig, "renderer_debug=false", "azahar renderer debug disabled")) { return 1; }
    if (!e2eContains(azaharConfig, "renderer_debug\\default=false", "azahar renderer debug explicitly configured")) { return 1; }
    if (!e2eContains(azaharConfig, "graphics_api=2", "azahar uses Vulkan on Steam Deck (so vkBasalt can composite the bezel)")) { return 1; }
    if (!e2eContains(azaharConfig, "graphics_api\\default=false", "azahar graphics api explicitly configured")) { return 1; }

    if (!e2eRunOk(e2eRunLauncher(exe, home, project, roms, binDir, capture, fakeBwrap, "pcsx2", ["game.iso"]), "launcher pcsx2")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-4.args")), "--socket=x11", "pcsx2 x11")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-4.args")), "net.pcsx2.PCSX2", "pcsx2 flatpak id")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-4.args")), "-batch", "pcsx2 batch flag")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-4.args")), "-fullscreen", "pcsx2 fullscreen flag")) { return 1; }
    string pcsx2Ini = FileSystem.readText(joinPath(launcherFlatpakStateRoot(project, "pcsx2"), "config/PCSX2/inis/PCSX2.ini"));
    if (!e2eContains(pcsx2Ini, "Bios = " + joinPath(emulationRoot, "PCSX2/config/bios"), "pcsx2 Deck BIOS path")) { return 1; }
    if (!e2eOk(!pcsx2Ini.contains("/Users/"), "pcsx2 config leaked host-local path")) { return 1; }

    if (!e2eRunOk(e2eRunLauncher(exe, home, project, roms, binDir, capture, fakeBwrap, "ryujinx", ["game.nsp"]), "launcher ryujinx")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-5.args")), "org.ryujinx.Ryujinx", "ryujinx flatpak id")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-5.args")), "--fullscreen", "ryujinx fullscreen flag")) { return 1; }

    if (!e2eRunOk(e2eRunLauncher(exe, home, project, roms, binDir, capture, fakeBwrap, "ppsspp", ["game.iso"]), "launcher ppsspp")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-6.args")), "org.ppsspp.PPSSPP", "ppsspp flatpak id")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-6.args")), "--fullscreen", "ppsspp fullscreen flag")) { return 1; }

    if (!e2eRunOk(e2eRunLauncher(exe, home, project, roms, binDir, capture, fakeBwrap, "flycast", ["game.chd"]), "launcher flycast")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-7.args")), "org.flycast.Flycast", "flycast flatpak id")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-7.args")), "-config", "flycast config flag")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-7.args")), "window:fullscreen=yes", "flycast fullscreen config")) { return 1; }

    if (!e2eRunOk(e2eRunLauncher(exe, home, project, roms, binDir, capture, fakeBwrap, "melonds", ["game.nds"]), "launcher melonds")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-8.args")), "net.kuribo64.melonDS", "melonds flatpak id")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-8.args")), "--fullscreen", "melonds fullscreen flag")) { return 1; }

    if (!e2eRunOk(e2eRunLauncher(exe, home, project, roms, binDir, capture, fakeBwrap, "dolphin", ["--help"]), "launcher dolphin help")) { return 1; }
    if (!e2eOk(!FileSystem.readText(joinPath(capture, "flatpak-9.args")).contains("Dolphin.Display.Fullscreen=True"), "dolphin help should not receive fullscreen defaults")) { return 1; }

    e2eSeedFile(emulatorProfilePath(project, "RetroArch/config/input.cfg"));
    e2eSeedFile(emulatorProfilePath(project, "RetroArch/retroarch.cfg"));
    if (!e2eRunOk(e2eRunLauncher(exe, home, project, roms, binDir, capture, fakeBwrap, "retroarch", ["-L", "core.so", "game.gba"]), "launcher retroarch")) { return 1; }
    string retroarchArgs = FileSystem.readText(joinPath(capture, "retroarch.args"));
    string expectedLauncherShader = presentationResolvedShaderPath(project, "gba");
    string expectedConfigShader = retroArchShaderPresetPath(project);
    if (!e2eContains(retroarchArgs, "/usr/bin/retroarch", "retroarch executable")) { return 1; }
    if (!e2eContains(retroarchArgs, "-f", "retroarch fullscreen flag")) { return 1; }
    if (!e2eContains(retroarchArgs, "-L", "retroarch core flag")) { return 1; }
    if (!e2eContains(retroarchArgs, "core.so", "retroarch core arg")) { return 1; }
    if (!e2eContains(retroarchArgs, "game.gba", "retroarch rom arg")) { return 1; }
    if (!e2eContains(retroarchArgs, "--ro-bind-try", "retroarch rom bind")) { return 1; }
    if (!e2eContains(retroarchArgs, "--set-shader=" + expectedLauncherShader, "retroarch shader argv")) { return 1; }
    string generatedRetroarchConfig = launcherRetroArchConfig(project);
    if (!e2eContains(generatedRetroarchConfig, "video_shader_enable = \"true\"", "retroarch shader enabled")) { return 1; }
    if (!e2eContains(generatedRetroarchConfig, expectedConfigShader, "retroarch Mega_Bezel preset")) { return 1; }
    if (!e2eContains(generatedRetroarchConfig, "video_scale_integer = \"true\"", "retroarch integer scaling")) { return 1; }
    string retroScreens = joinPath(contentRoot(project), "screenshots/verification/retroarch");
    if (!e2eOk(FileSystem.exists(joinPath(retroScreens, "before_launch.png")), "retroarch before_launch screenshot missing")) { return 1; }
    if (!e2eWaitForFile(joinPath(retroScreens, "after_spawn.png"), "retroarch after_spawn screenshot")) { return 1; }
    if (!e2eOk(FileSystem.exists(joinPath(retroScreens, "after_exit.png")), "retroarch after_exit screenshot missing")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "grim.log")), "screenshots/verification/retroarch/after_exit.png", "retroarch screenshot hook log")) { return 1; }

    string fakeQuitWatch = joinPath(binDir, "semu-quit-watch");
    FileSystem.writeText(fakeQuitWatch,
        "#!/usr/bin/env sh\n"
        + "set -eu\n"
        + "if [ \"${1:-}\" = \"--\" ]; then shift; fi\n"
        + "exec \"$@\"\n"
    );
    FileSystem.chmod(fakeQuitWatch, 493);

    string fakeRouted = joinPath(binDir, "fake-emulator");
    FileSystem.writeText(fakeRouted,
        "#!/usr/bin/env sh\n"
        + "set -eu\n"
        + "env | grep '^SEMU_QUIT_WATCH_LOG=' > \"${SEMU_FLATPAK_CAPTURE:?}/routed-dolphin.env\"\n"
        + "printf '%s\\n' \"$@\" > \"${SEMU_FLATPAK_CAPTURE:?}/routed-dolphin.args\"\n"
    );
    FileSystem.chmod(fakeRouted, 493);
    if (!e2eRunOk(e2eRunRoutedLauncher(exe, home, project, roms, binDir, capture, "dolphin", fakeRouted, ["game.iso"]), "routed dolphin")) { return 1; }
    string dolphinQuitLog = launcherQuitWatchLogPath(project, "dolphin");
    if (!e2eContains(FileSystem.readText(joinPath(capture, "routed-dolphin.env")), "SEMU_QUIT_WATCH_LOG=" + dolphinQuitLog, "routed dolphin quit evidence env")) { return 1; }
    if (!e2eOk(FileSystem.isDir(PathTools.dirname(dolphinQuitLog)), "routed quit-watch evidence dir missing")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "routed-dolphin.args")), "Dolphin.Display.Fullscreen=True", "routed dolphin fullscreen config")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "routed-dolphin.args")), "-b", "routed dolphin batch flag")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "routed-dolphin.args")), "-e", "routed dolphin exec flag")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "routed-dolphin.args")), "game.iso", "routed dolphin rom arg")) { return 1; }

    string fakeCemu = joinPath(binDir, "fake-cemu");
    FileSystem.writeText(fakeCemu,
        "#!/usr/bin/env sh\n"
        + "set -eu\n"
        + "printf '%s\\n' \"$@\" > \"${SEMU_FLATPAK_CAPTURE:?}/routed-cemu.args\"\n"
    );
    FileSystem.chmod(fakeCemu, 493);
    if (!e2eRunOk(e2eRunRoutedLauncher(exe, home, project, roms, binDir, capture, "cemu", fakeCemu, ["game.wua"]), "routed cemu")) { return 1; }
    string routedCemuSettings = joinPath(launcherRoutedStateRoot(project, "cemu"), "config/Cemu/settings.xml");
    if (!e2eContains(FileSystem.readText(routedCemuSettings), "<mlc_path>" + joinPath(emulationRoot, "Cemu/data/mlc01") + "</mlc_path>", "routed cemu mlc path")) { return 1; }
    if (!e2eContains(FileSystem.readText(routedCemuSettings), "<Entry>" + joinPath(roms, "wiiu") + "</Entry>", "routed cemu game path")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(launcherRoutedStateRoot(project, "cemu"), "data/Cemu/keys.txt")), "seed", "routed cemu keys")) { return 1; }

    string fakeRyujinx = joinPath(binDir, "fake-ryujinx");
    FileSystem.writeText(fakeRyujinx,
        "#!/usr/bin/env sh\n"
        + "set -eu\n"
        + "printf '%s\\n' \"$@\" > \"${SEMU_FLATPAK_CAPTURE:?}/routed-ryujinx.args\"\n"
    );
    FileSystem.chmod(fakeRyujinx, 493);
    if (!e2eRunOk(e2eRunRoutedLauncher(exe, home, project, roms, binDir, capture, "ryujinx", fakeRyujinx, ["game.nsp"]), "routed ryujinx")) { return 1; }
    string routedRyujinxRoot = joinPath(launcherRoutedStateRoot(project, "ryujinx"), "config/Ryujinx");
    if (!e2eAssertLink(joinPath(routedRyujinxRoot, "bis/system/Contents/registered"), joinPath(emulationRoot, "Ryujinx/config/bis/system/Contents/registered"))) { return 1; }
    if (!e2eAssertLink(joinPath(routedRyujinxRoot, "games"), joinPath(emulationRoot, "Ryujinx/config/games"))) { return 1; }
    if (!e2eAssertLink(joinPath(routedRyujinxRoot, "mods"), joinPath(emulationRoot, "Ryujinx/config/mods"))) { return 1; }
    if (!e2eAssertLink(joinPath(routedRyujinxRoot, "sdcard"), joinPath(emulationRoot, "Ryujinx/config/sdcard"))) { return 1; }

    print("OK BTRC launcher smoke");
    return 0;
}

// ---- n3ds_smoke.btrc ----
bool e2eWriteFakeN3dsRom(string path, bool noCrypto, bool decrypted) {
    ensureDir(PathTools.dirname(path));
    BinaryEditor editor = BinaryEditor(path, "w+b");
    if (!editor.ok()) { return false; }
    bool ok = true;
    long partOffset = 0x200;
    ok = ok && editor.writeAscii(0x100, "NCSD");
    ok = ok && editor.writeLe32(0x120, 1);
    ok = ok && editor.writeLe32(0x124, 4);
    ok = ok && editor.writeAscii(partOffset + 0x100, "NCCH");
    ok = ok && editor.writeU8(partOffset + 0x100 + 0x8b, noCrypto ? 0 : 1);
    ok = ok && editor.writeU8(partOffset + 0x100 + 0x8f, noCrypto ? 4 : 0);
    ok = ok && editor.writeLe32(partOffset + 0x100 + 0xa0, 1);
    ok = ok && editor.writeAscii(partOffset + 0x200, decrypted ? ".code" : "cipher");
    editor.close();
    return ok;
}

ExecResult e2eRunN3dsNoCrypto(string exe, string input, string outputDir, Vector<string> extraArgs) {
    Command command = Command(exe)
        .envVar("SEMU_BIN", exe)
        .envVar("PATH", "/usr/bin:/bin")
        .arg("utils")
        .arg("n3ds-nocrypto")
        .arg(input)
        .capture(true)
        .check(false);
    if (outputDir.len() > 0) {
        command.flag("-o", outputDir);
    }
    for arg in extraArgs {
        command.arg(arg);
    }
    UnixShell shell = UnixShell();
    ExecResult result = shell.runCommand(command);
    return result;
}

ExecResult e2eRunDecrypt3dsNoCrypto(string exe, string input, Vector<string> extraArgs) {
    Command command = Command(exe)
        .envVar("SEMU_BIN", exe)
        .envVar("PATH", "/usr/bin:/bin")
        .arg("utils")
        .arg("decrypt3ds")
        .arg(input)
        .capture(true)
        .check(false);
    for arg in extraArgs {
        command.arg(arg);
    }
    UnixShell shell = UnixShell();
    ExecResult result = shell.runCommand(command);
    return result;
}

int e2eN3dsNoCryptoSmoke(CliArgs args) {
    string tmp = e2eTempDir("semu-n3ds-nocrypto-smoke");
    string input = joinPath(tmp, "input");
    string output = joinPath(tmp, "output");
    string project = joinPath(tmp, "project");
    string home = joinPath(tmp, "home");
    string externalRoms = joinPath(tmp, "sd/Emulation/ES-DE/ES-DE/ROMs");
    string exe = e2eExecutable(args);
    ensureDir(input);
    ensureDir(output);
    ensureDir(project);
    ensureDir(home);
    ensureDir(joinPath(externalRoms, "n3ds"));
    string needsPath = joinPath(input, "needs.3ds");
    string okPath = joinPath(input, "already-ok.3ds");
    string externalOkPath = joinPath(externalRoms, "n3ds/external-ok.3ds");
    if (!e2eOk(e2eWriteFakeN3dsRom(needsPath, false, true), "fake needs-fix 3DS ROM")) { return 1; }
    if (!e2eOk(e2eWriteFakeN3dsRom(okPath, true, true), "fake OK 3DS ROM")) { return 1; }
    if (!e2eOk(e2eWriteFakeN3dsRom(externalOkPath, true, true), "fake external OK 3DS ROM")) { return 1; }

    ExecResult check = e2eRunN3dsNoCrypto(exe, input, "", ["--check"]);
    if (!e2eRunOk(check, "n3ds-nocrypto check")) { return 1; }
    if (!e2eContains(check.stdout(), "NEEDS FIX: needs.3ds", "n3ds-nocrypto check output")) { return 1; }
    if (!e2eContains(check.stdout(), "OK:        already-ok.3ds", "n3ds-nocrypto OK output")) { return 1; }
    if (!e2eRunOk(e2eRunDecrypt3dsNoCrypto(exe, input, ["--check"]), "decrypt3ds compatibility check")) { return 1; }

    Vector<string> noArgs = [];
    if (!e2eRunOk(e2eRunN3dsNoCrypto(exe, input, output, noArgs), "n3ds-nocrypto fix")) { return 1; }
    string fixedPath = joinPath(output, "needs.3ds");
    N3dsRomCheck fixed = checkN3dsRom(fixedPath);
    if (!e2eOk(fixed.status.equals("OK"), "fixed fake ROM should be OK")) { return 1; }
    BinaryReader reader = BinaryReader(fixedPath);
    int flags = reader.readU8(0x200 + 0x100 + 0x8f);
    int cryptoMethod = reader.readU8(0x200 + 0x100 + 0x8b);
    reader.close();
    if (!e2eOk(n3dsNoCryptoFlag(flags), "fixed fake ROM NoCrypto flag missing")) { return 1; }
    if (!e2eOk(cryptoMethod == 0, "fixed fake ROM crypto method not cleared")) { return 1; }
    if (!e2eOk(checkN3dsRom(joinPath(output, "already-ok.3ds")).status.equals("OK"), "already OK fake ROM copy")) { return 1; }

    writeSyncDefaults(project, externalRoms);
    ExecResult doctor = e2eRunDoctor(exe, home, project);
    if (!e2eRunOk(doctor, "doctor configured n3ds preflight")) { return 1; }
    if (!e2eContains(doctor.stdout(), "OK n3ds/external-ok.3ds", "doctor should preflight configured external n3ds ROMs")) { return 1; }

    print("OK BTRC n3ds-nocrypto smoke");
    return 0;
}

// ---- deck_evidence_smoke.btrc ----
string e2eQuitEvidenceText(string emulator, bool quit) {
    Vector<string> lines = [
        "time=1 start child=100 command=" + emulator,
        "time=2 exit child=100 status=0 quit_requested=0"
    ];
    if (quit) {
        lines = [
            "time=1 start child=100 command=" + emulator,
            "time=2 terminate child=100 reason=select+start",
            "time=3 exit child=100 status=143 quit_requested=1"
        ];
    }
    return textLines(lines);
}

string e2eStateEvidenceText(string emulator, bool save, bool load) {
    Vector<string> lines = [
        "time=1 emulator=" + emulator + " action=launch result=ok"
    ];
    if (save) {
        lines.push("time=2 emulator=" + emulator + " action=state.save result=ok slot=1");
    }
    if (load) {
        lines.push("time=3 emulator=" + emulator + " action=state.load result=ok slot=1");
    }
    return textLines(lines);
}

string e2eVisualAnalysisText(string system) {
    return textLines(deckVisualAnalysisRequiredTokens(system));
}

void e2eSeedVisualEvidence(string project, Vector<string> systems) {
    for system in systems {
        for priority in deckVisualEvidencePriorities() {
            for variant in deckVisualEvidenceVariants() {
                SemuGeneratedFiles.writeProject(
                    project,
                    deckVisualScreenshotPath(project, system, priority, variant),
                    "fake jpg " + system + " " + priority + " " + variant + "\n"
                );
            }
        }
        SemuGeneratedFiles.writeProject(project, deckVisualClipPath(project, system), "fake mp4 " + system + "\n");
        SemuGeneratedFiles.writeProject(project, deckVisualAnalysisPath(project, system), e2eVisualAnalysisText(system));
    }
}

string e2ePresentationAuditOkText(string project) {
    return jsonPrettyText(jsonObject([
        jsonField("schema_version", "1"),
        jsonStrField("project", project),
        jsonStrField("system", ""),
        jsonBoolField("strict", true),
        jsonField("ok_count", "0"),
        jsonField("missing_system_count", "0"),
        jsonField("missing_asset_count", "0"),
        jsonField("missing_dependency_count", "0"),
        jsonField("disabled_count", "0"),
        jsonField("systems", "[]")
    ]));
}

int e2eDeckEvidenceSmoke(CliArgs args) {
    string tmp = e2eTempDir("semu-deck-evidence-smoke");
    string project = joinPath(tmp, "project");
    string home = joinPath(tmp, "home");
    string roms = joinPath(tmp, "roms");
    string exe = e2eExecutable(args);
    ensureDir(project);
    ensureDir(home);
    ensureDir(roms);
    if (!e2eRunOk(e2eRunLifecycle(exe, home, "install", project, roms), "deck evidence lifecycle install")) { return 1; }

    ExecResult missing = e2eRunDeck(exe, home, project, ["game-mode-evidence", "retroarch"]);
    if (!e2eOk(!missing.ok(), "missing Game Mode evidence unexpectedly succeeded")) { return 1; }
    if (!e2eContains(missing.stdout(), "PENDING retroarch", "missing evidence status")) { return 1; }

    ExecResult prepare = e2eRunDeck(exe, home, project, ["game-mode-evidence", "retroarch", "--prepare"]);
    if (!e2eRunOk(prepare, "game-mode evidence prepare")) { return 1; }
    string checklist = joinPath(semuStateRoot(project), "verification/game-mode-checklist.txt");
    if (!e2eOk(FileSystem.exists(checklist), "Game Mode checklist missing")) { return 1; }
    if (!e2eContains(FileSystem.readText(checklist), "physical left-trackpad radial menu", "Game Mode checklist physical input")) { return 1; }
    if (!e2eOk(SemuGeneratedFiles.isAdapterState(project, checklist), "Game Mode checklist should be adapter state")) { return 1; }

    string retroarchLog = deckQuitEvidencePath(project, "retroarch");
    SemuGeneratedFiles.writeAdapterState(project, retroarchLog, e2eQuitEvidenceText("retroarch", false));
    ExecResult partial = e2eRunDeck(exe, home, project, ["game-mode-evidence", "retroarch", "--allow-pending"]);
    if (!e2eRunOk(partial, "partial Game Mode evidence with allow-pending")) { return 1; }
    if (!e2eContains(partial.stdout(), "PARTIAL retroarch", "partial evidence status")) { return 1; }
    if (!e2eOk(!e2eRunDeck(exe, home, project, ["game-mode-evidence", "retroarch"]).ok(), "partial Game Mode evidence unexpectedly succeeded")) { return 1; }

    SemuGeneratedFiles.writeAdapterState(project, retroarchLog, e2eQuitEvidenceText("retroarch", true));
    ExecResult ok = e2eRunDeck(exe, home, project, ["game-mode-evidence", "--emulator", "retroarch"]);
    if (!e2eRunOk(ok, "complete Game Mode evidence")) { return 1; }
    if (!e2eContains(ok.stdout(), "OK retroarch", "complete evidence status")) { return 1; }

    for emulator in lowercaseValues(linuxLauncherNames()) {
        SemuGeneratedFiles.writeAdapterState(project, deckQuitEvidencePath(project, emulator), e2eQuitEvidenceText(emulator, true));
    }
    ExecResult all = e2eRunDeck(exe, home, project, ["game-mode-evidence"]);
    if (!e2eRunOk(all, "all Game Mode evidence")) { return 1; }
    if (!e2eContains(all.stdout(), "OK Game Mode quit evidence", "all evidence status")) { return 1; }
    if (!e2eOk(!e2eRunDeck(exe, home, project, ["game-mode-evidence", "gopher64"]).ok(), "unknown evidence emulator unexpectedly succeeded")) { return 1; }

    ExecResult stateMissing = e2eRunDeck(exe, home, project, ["state-evidence", "retroarch"]);
    if (!e2eOk(!stateMissing.ok(), "missing state evidence unexpectedly succeeded")) { return 1; }
    if (!e2eContains(stateMissing.stdout(), "PENDING retroarch", "missing state evidence status")) { return 1; }

    ExecResult statePrepare = e2eRunDeck(exe, home, project, ["state-evidence", "retroarch", "--prepare"]);
    if (!e2eRunOk(statePrepare, "state evidence prepare")) { return 1; }
    string stateChecklist = deckStateEvidenceChecklistPath(project);
    if (!e2eOk(FileSystem.exists(stateChecklist), "state evidence checklist missing")) { return 1; }
    if (!e2eContains(FileSystem.readText(stateChecklist), "physical left-trackpad radial Save State", "state checklist physical save")) { return 1; }
    if (!e2eOk(SemuGeneratedFiles.isAdapterState(project, stateChecklist), "state checklist should be adapter state")) { return 1; }

    string stateLog = deckStateEvidencePath(project, "retroarch");
    SemuGeneratedFiles.writeAdapterState(project, stateLog, e2eStateEvidenceText("retroarch", true, false));
    ExecResult statePartial = e2eRunDeck(exe, home, project, ["state-evidence", "retroarch", "--allow-pending"]);
    if (!e2eRunOk(statePartial, "partial state evidence with allow-pending")) { return 1; }
    if (!e2eContains(statePartial.stdout(), "save=ok load=missing", "partial state evidence status")) { return 1; }
    if (!e2eOk(!e2eRunDeck(exe, home, project, ["state-evidence", "retroarch"]).ok(), "partial state evidence unexpectedly succeeded")) { return 1; }

    SemuGeneratedFiles.writeAdapterState(project, stateLog, e2eStateEvidenceText("retroarch", true, true));
    ExecResult stateOk = e2eRunDeck(exe, home, project, ["state-evidence", "--emulator", "retroarch"]);
    if (!e2eRunOk(stateOk, "complete state evidence")) { return 1; }
    if (!e2eContains(stateOk.stdout(), "OK retroarch", "complete state evidence status")) { return 1; }
    if (!e2eOk(!e2eRunDeck(exe, home, project, ["state-evidence", "ppsspp"]).ok(), "disabled state evidence emulator unexpectedly succeeded")) { return 1; }

    for emulator in deckStateEvidenceEmulators() {
        SemuGeneratedFiles.writeAdapterState(project, deckStateEvidencePath(project, emulator), e2eStateEvidenceText(emulator, true, true));
    }
    ExecResult stateAll = e2eRunDeck(exe, home, project, ["state-evidence"]);
    if (!e2eRunOk(stateAll, "all generated state evidence")) { return 1; }
    if (!e2eContains(stateAll.stdout(), "OK Game Mode state evidence", "all state evidence status")) { return 1; }

    ExecResult visualMissing = e2eRunDeck(exe, home, project, ["visual-evidence", "gb"]);
    if (!e2eOk(!visualMissing.ok(), "missing visual evidence unexpectedly succeeded")) { return 1; }
    if (!e2eContains(visualMissing.stdout(), "PENDING gb screenshot game-priority/A", "missing visual evidence screenshot status")) { return 1; }

    ExecResult visualPrepare = e2eRunDeck(exe, home, project, ["visual-evidence", "gb", "--prepare"]);
    if (!e2eRunOk(visualPrepare, "visual evidence prepare")) { return 1; }
    if (!e2eOk(FileSystem.exists(deckVisualEvidenceChecklistPath(project)), "visual evidence checklist missing")) { return 1; }
    if (!e2eOk(FileSystem.exists(deckVisualEvidenceManifestPath(project)), "visual evidence manifest missing")) { return 1; }
    if (!e2eOk(SemuGeneratedFiles.isProjectGenerated(project, deckVisualEvidenceManifestPath(project)), "visual evidence manifest should be generated test output")) { return 1; }
    if (!e2eContains(FileSystem.readText(deckVisualEvidenceChecklistPath(project)), "duration_s=30", "visual evidence checklist analysis contract")) { return 1; }
    string visualManifest = FileSystem.readText(deckVisualEvidenceManifestPath(project));
    if (!e2eContains(visualManifest, "\"emulator\": \"retroarch\"", "visual evidence manifest emulator contract")) { return 1; }
    if (!e2eContains(visualManifest, "\"viewport_alignment=ok\"", "visual evidence manifest analysis contract")) { return 1; }
    if (!e2eContains(visualManifest, "\"screenshot.game-priority.A=ok\"", "visual evidence manifest screenshot analysis token")) { return 1; }

    for priority in deckVisualEvidencePriorities() {
        for variant in deckVisualEvidenceVariants() {
            SemuGeneratedFiles.writeProject(
                project,
                deckVisualScreenshotPath(project, "gb", priority, variant),
                "fake jpg gb " + priority + " " + variant + "\n"
            );
        }
    }
    SemuGeneratedFiles.writeProject(project, deckVisualClipPath(project, "gb"), "fake mp4 gb\n");
    SemuGeneratedFiles.writeProject(project, deckVisualAnalysisPath(project, "gb"), textLines([
        "system=gb",
        "emulator=retroarch",
        "visual=ok",
        "input=ok",
        "duration_s=30"
    ]));
    ExecResult visualWeakAnalysis = e2eRunDeck(exe, home, project, ["visual-evidence", "gb", "--allow-pending"]);
    if (!e2eRunOk(visualWeakAnalysis, "weak visual evidence analysis with allow-pending")) { return 1; }
    if (!e2eContains(visualWeakAnalysis.stdout(), "viewport_alignment=ok", "weak visual evidence should list missing alignment token")) { return 1; }

    e2eSeedVisualEvidence(project, ["gb"]);
    ExecResult visualGb = e2eRunDeck(exe, home, project, ["visual-evidence", "--system", "gb"]);
    if (!e2eRunOk(visualGb, "gb visual evidence")) { return 1; }
    if (!e2eContains(visualGb.stdout(), "OK gb: visual screenshots, 30s clip, and analysis complete", "gb visual evidence status")) { return 1; }

    string appImage = joinPath(tmp, "Semu-x86_64.AppImage");
    e2eSeedFile(appImage);
    FileSystem.chmod(appImage, 493);
    string shortcutsFile = joinPath(home, "steam-userdata/52445373/config/shortcuts.vdf");
    if (!e2eWriteSteamShortcutFixtureFor(shortcutsFile, appImage)) { return 1; }
    string configSetFile = joinPath(home, "controller-configs/52445373/config/configset_controller_neptune.vdf");
    if (!e2eWriteSteamConfigSetFixture(configSetFile)) { return 1; }
    ExecResult selection = e2eRunSteamInput(exe, home, project, [
        "select",
        "--shortcuts-file", shortcutsFile,
        "--configset-file", configSetFile,
        "--exe", appImage,
        "--app-name", "Semu-x86_64.AppImage"
    ]);
    if (!e2eRunOk(selection, "Game Mode Steam Input selection")) { return 1; }
    Vector<string> readyArgs = [
        "game-mode-ready",
        "--shortcuts-file", shortcutsFile,
        "--configset-file", configSetFile,
        "--exe", appImage,
        "--appimage", appImage,
        "--prepare"
    ];
    ExecResult desktop = e2eRunDeckEnv(exe, home, project, readyArgs, "desktop_mode", "1");
    if (!e2eOk(!desktop.ok(), "Desktop Mode readiness unexpectedly succeeded without --allow-desktop")) { return 1; }
    if (!e2eContains(desktop.stdout(), "PENDING session: desktop_mode", "Desktop Mode readiness status")) { return 1; }

    Vector<string> desktopAllowedArgs = [
        "game-mode-ready",
        "--shortcuts-file", shortcutsFile,
        "--configset-file", configSetFile,
        "--exe", appImage,
        "--appimage", appImage,
        "--prepare",
        "--allow-desktop"
    ];
    ExecResult desktopAllowed = e2eRunDeckEnv(exe, home, project, desktopAllowedArgs, "desktop_mode", "1");
    if (!e2eRunOk(desktopAllowed, "Desktop readiness with explicit override")) { return 1; }
    if (!e2eContains(desktopAllowed.stdout(), "OK session: desktop_mode", "Desktop override status")) { return 1; }
    if (!e2eContains(desktopAllowed.stdout(), "OK shortcut: Semu-x86_64.AppImage", "readiness shortcut status")) { return 1; }
    if (!e2eContains(desktopAllowed.stdout(), "OK appimage: " + appImage, "readiness AppImage status")) { return 1; }

    ExecResult mixedAllowed = e2eRunDeckEnv(exe, home, project, desktopAllowedArgs, "mixed_gamescope_desktop", "1");
    if (!e2eRunOk(mixedAllowed, "mixed Desktop/Gamescope readiness with explicit override")) { return 1; }
    if (!e2eContains(mixedAllowed.stdout(), "OK session: mixed_gamescope_desktop", "mixed Desktop override status")) { return 1; }

    ExecResult missingSteam = e2eRunDeckEnv(exe, home, project, readyArgs, "game_mode", "0");
    if (!e2eOk(!missingSteam.ok(), "readiness unexpectedly succeeded without Steam")) { return 1; }
    if (!e2eContains(missingSteam.stdout(), "MISSING steam: not running", "missing Steam readiness status")) { return 1; }

    ExecResult gameReady = e2eRunDeckEnv(exe, home, project, readyArgs, "game_mode", "1");
    if (!e2eRunOk(gameReady, "Game Mode readiness")) { return 1; }
    if (!e2eContains(gameReady.stdout(), "OK session: game_mode", "Game Mode readiness status")) { return 1; }
    if (!e2eContains(gameReady.stdout(), "steam://rungameid/", "Game Mode launch URI")) { return 1; }

    Vector<string> requireEvidenceArgs = [
        "game-mode-ready",
        "--shortcuts-file", shortcutsFile,
        "--configset-file", configSetFile,
        "--exe", appImage,
        "--appimage", appImage,
        "--prepare",
        "--require-evidence"
    ];
    ExecResult requireEvidence = e2eRunDeckEnv(exe, home, project, requireEvidenceArgs, "game_mode", "1");
    if (!e2eRunOk(requireEvidence, "Game Mode readiness with required evidence")) { return 1; }
    if (!e2eContains(requireEvidence.stdout(), "OK evidence: physical quit logs complete", "required evidence readiness status")) { return 1; }
    string readinessReport = deckGameModeReadinessPath(project);
    if (!e2eOk(FileSystem.exists(readinessReport), "Game Mode readiness report missing")) { return 1; }
    if (!e2eOk(SemuGeneratedFiles.isAdapterState(project, readinessReport), "Game Mode readiness report should be adapter state")) { return 1; }
    string readinessJson = FileSystem.readText(readinessReport);
    if (!e2eContains(readinessJson, "\n    \"session\": \"game_mode\"", "readiness report should be pretty JSON")) { return 1; }
    if (!e2eContains(readinessJson, "\"shortcut_found\": true", "readiness report shortcut flag")) { return 1; }
    if (!e2eContains(readinessJson, "\"evidence_required\": true", "readiness report evidence gate")) { return 1; }

    Vector<string> productionArgs = [
        "production-ready",
        "--shortcuts-file", shortcutsFile,
        "--configset-file", configSetFile,
        "--exe", appImage,
        "--appimage", appImage,
        "--prepare",
        "--allow-desktop"
    ];
    ExecResult productionMissingAudit = e2eRunDeckEnv(exe, home, project, productionArgs, "game_mode", "1");
    if (!e2eOk(!productionMissingAudit.ok(), "production readiness unexpectedly succeeded without presentation audit")) { return 1; }
    if (!e2eContains(productionMissingAudit.stdout(), "PENDING presentation audit", "production missing presentation audit")) { return 1; }

    SemuGeneratedFiles.writeAdapterState(project, presentationAssetAuditPath(project), e2ePresentationAuditOkText(project));
    ExecResult productionMissingVisual = e2eRunDeckEnv(exe, home, project, productionArgs, "game_mode", "1");
    if (!e2eOk(!productionMissingVisual.ok(), "production readiness unexpectedly succeeded without visual evidence")) { return 1; }
    if (!e2eContains(productionMissingVisual.stdout(), "PENDING visual evidence", "production missing visual evidence")) { return 1; }

    e2eSeedVisualEvidence(project, declaredSystemIds());
    ExecResult visualAll = e2eRunDeck(exe, home, project, ["visual-evidence"]);
    if (!e2eRunOk(visualAll, "all visual evidence")) { return 1; }
    if (!e2eContains(visualAll.stdout(), "OK Semu visual evidence", "all visual evidence status")) { return 1; }

    ExecResult productionReady = e2eRunDeckEnv(exe, home, project, productionArgs, "game_mode", "1");
    if (!e2eRunOk(productionReady, "production readiness with physical evidence")) { return 1; }
    if (!e2eContains(productionReady.stdout(), "OK owned config sources", "production source boundary")) { return 1; }
    if (!e2eContains(productionReady.stdout(), "OK presentation audit", "production presentation audit")) { return 1; }
    if (!e2eContains(productionReady.stdout(), "OK state evidence: physical save/load logs complete", "production state evidence")) { return 1; }
    if (!e2eContains(productionReady.stdout(), "OK visual evidence: screenshots and clips complete", "production visual evidence")) { return 1; }
    string productionReport = deckProductionReadinessPath(project);
    if (!e2eOk(FileSystem.exists(productionReport), "production readiness report missing")) { return 1; }
    if (!e2eOk(SemuGeneratedFiles.isAdapterState(project, productionReport), "production readiness report should be adapter state")) { return 1; }
    string productionJson = FileSystem.readText(productionReport);
    if (!e2eContains(productionJson, "\n    \"source_config_ok\": true", "production report should be pretty JSON")) { return 1; }
    if (!e2eContains(productionJson, "\"state_evidence_ok\": true", "production report state evidence flag")) { return 1; }
    if (!e2eContains(productionJson, "\"visual_evidence_ok\": true", "production report visual evidence flag")) { return 1; }

    print("OK BTRC Deck evidence smoke");
    return 0;
}

// ---- shell_syntax.btrc ----
int e2eShellSyntaxSmoke(string project) {
    string root = project;
    string command = "cd " + ShellWords.quote(root)
        + " && bash -n"
        + " packaging/linux/AppRun"
        + " packaging/linux/sandbox.sh"
        + " packaging/linux/build-appimage.sh"
        + " packaging/linux/bin/semu-*"
        + " packaging/steamdeck/bootstrap.sh";
    ExecResult result = UnixShell().runRaw(command, true, false, "");
    if (!result.ok()) {
        print(result.stdout());
        return result.code;
    }
    print("OK shell artifact syntax");
    return 0;
}

// ---- quit_watch.btrc ----
int e2eQuitWatchSmoke(string project) {
    if (!commandExists("cc")) {
        print("SKIP quit-watch smoke: cc not found");
        return 0;
    }

    string tmp = e2eTempDir("semu-quit-watch");
    string source = joinPath(project, "src/semu/quit-watch.c");
    string output = joinPath(tmp, "semu-quit-watch");
    string log = joinPath(tmp, "quit-watch.log");
    if (!e2eOk(FileSystem.exists(source), "quit-watch source missing")) { return 1; }

    string buildCommand = "cc " + ShellWords.quote(source)
        + " -std=c11 -Wall -Wextra -o " + ShellWords.quote(output);
    ExecResult build = UnixShell().runRaw(buildCommand, true, false, "");
    if (!e2eRunOk(build, "compile quit-watch")) { return 1; }

    string runCommand = "SEMU_QUIT_WATCH_LOG=" + ShellWords.quote(log)
        + " " + ShellWords.quote(output)
        + " -- sh -c " + ShellWords.quote("exit 0");
    ExecResult run = UnixShell().runRaw(runCommand, true, false, "");
    if (!e2eRunOk(run, "run quit-watch")) { return 1; }
    if (!e2eOk(FileSystem.exists(log), "quit-watch evidence log missing")) { return 1; }

    string evidence = FileSystem.readText(log);
    if (!e2eContains(evidence, " start child=", "quit-watch start evidence")) { return 1; }
    if (!e2eContains(evidence, " exit child=", "quit-watch exit evidence")) { return 1; }

    print("OK quit-watch evidence smoke");
    return 0;
}
