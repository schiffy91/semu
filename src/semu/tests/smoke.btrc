bool e2eWriteSteamShortcutFixtureFor(string path, string exe) {
    ensureDir(PathTools.dirname(path));
    string payload = "\\000shortcuts\\000\\0000\\000\\002appid\\000\\140\\152\\213\\344\\001AppName\\000Semu-x86_64.AppImage\\000\\001Exe\\000\""
        + exe
        + "\"\\000\\001StartDir\\000"
        + PathTools.dirname(exe)
        + "/\\000\\001LaunchOptions\\000\\000\\010\\010";
    UnixShell shell = UnixShell();
    ExecResult result = shell.runRaw("printf " + ShellWords.quote(payload) + " > " + ShellWords.quote(path), false, false, "");
    return e2eOk(result.ok(), "write Steam shortcut fixture");
}

bool e2eWriteSteamShortcutFixture(string path) {
    return e2eWriteSteamShortcutFixtureFor(path, "/home/deck/Applications/Semu/Semu-x86_64.AppImage");
}

bool e2eWriteSteamConfigSetFixture(string path) {
    ensureDir(PathTools.dirname(path));
    FileSystem.writeText(path,
        "\"controller_config\"\n"
        + "{\n"
        + "\t\"retrodeck\"\n"
        + "\t{\n"
        + "\t\t\"template\"\t\t\"RetroDECK_controller_steamdeck_neptune_full.vdf\"\n"
        + "\t}\n"
        + "}\n"
    );
    return e2eOk(FileSystem.exists(path), "write Steam configset fixture");
}

