bool e2eOk(bool condition, string message) {
    if (condition) { return true; }
    print("E2E FAIL " + message);
    return false;
}

bool e2eContains(string text, string expected, string message) {
    return e2eOk(text.contains(expected), message + ": missing " + expected);
}

string e2eTempDir(string label) {
    string tmp = FileSystem.tempDir(label);
    if (tmp.len() > 0) { return tmp; }
    string fallback = joinPath(Environment.get("TMPDIR", "/tmp"), label + "-fallback");
    FileSystem.removeRecursive(fallback);
    ensureDir(fallback);
    return fallback;
}

void e2eSeedFile(string path) {
    ensureDir(PathTools.dirname(path));
    FileSystem.writeText(path, "seed " + path + "\n");
}

bool e2eAssertLink(string linkPath, string targetPath) {
    if (!e2eOk(FileSystem.isSymlink(linkPath), "expected symlink " + linkPath)) {
        return false;
    }
    string target = FileSystem.readLink(linkPath);
    if (!e2eOk(target.len() > 0, "readlink failed " + linkPath)) {
        return false;
    }
    return e2eOk(target.equals(targetPath), "bad symlink target for " + linkPath);
}

ExecResult e2eRunLifecycle(string exe, string home, string mode, string project, string romsDir) {
    Command command = Command(exe)
        .envVar("SEMU_HOME", home)
        .envVar("SEMU_BIN", exe)
        .envVar("PATH", "/usr/bin:/bin")
        .arg("lifecycle")
        .arg(mode)
        .flag("--project", project)
        .capture(true)
        .check(false);
    if (romsDir.len() > 0) {
        command.flag("--roms", romsDir);
    }
    UnixShell shell = UnixShell();
    ExecResult result = shell.runCommand(command);
    return result;
}

ExecResult e2eRunLifecycleChange(string exe, string home, string project, string actionId, string commandText) {
    Command command = Command(exe)
        .envVar("SEMU_HOME", home)
        .envVar("SEMU_BIN", exe)
