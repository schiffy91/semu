string deckVisualEvidenceRoot(string project) {
    return joinPath(generatedTestRoot(project), "visual-evidence");
}

string deckVisualEvidenceChecklistPath(string project) {
    return joinPath(deckVisualEvidenceRoot(project), "VISUAL_EVIDENCE.md");
}

string deckVisualEvidenceManifestPath(string project) {
    return joinPath(deckVisualEvidenceRoot(project), "visual-evidence.json");
}

Vector<string> deckVisualEvidencePriorities() {
    return ["game-priority", "bezel-priority"];
}

Vector<string> deckVisualEvidenceVariants() {
    return ["A", "B", "C"];
}

string deckVisualScreenshotPath(string project, string system, string priority, string variant) {
    return joinPath(deckVisualEvidenceRoot(project), joinPath(system, joinPath(priority, variant + ".jpg")));
}

string deckVisualClipPath(string project, string system) {
    return joinPath(deckVisualEvidenceRoot(project), joinPath(system, "start-of-gameplay-30s.mp4"));
}

string deckVisualAnalysisPath(string project, string system) {
    return joinPath(deckVisualEvidenceRoot(project), joinPath(system, "start-of-gameplay-analysis.txt"));
}

string deckVisualCaptureTapStateDir(CliArgs args, string project) {
    string explicit = args.valueAfter("--tap-state-dir", "");
    if (explicit.len() > 0) { return explicit; }
    string env = Environment.get("SEMU_TAP_STATE_DIR", "");
    if (env.len() > 0) { return env; }
    return "/home/deck";
}

string deckVisualCaptureSettleSeconds(CliArgs args) {
    return args.valueAfter("--settle-seconds", Environment.get("SEMU_VISUAL_CAPTURE_SETTLE_SECONDS", "1"));
}

void deckVisualWriteTapState(string stateDir, string name, string value) {
    ensureDir(stateDir);
    FileSystem.writeText(joinPath(stateDir, name), value);
}

string deckVisualPriorityState(string priority) {
    return priority.equals("bezel-priority") ? "b" : "g";
}

string deckVisualVariantIndex(string variant) {
    string v = variant.toLower();
    if (v.equals("b")) { return "1"; }
    if (v.equals("c")) { return "2"; }
    if (v.equals("off")) { return "3"; }
    return "0";
}

void deckVisualApplyTapState(string stateDir, string priority, string variant) {
    string index = deckVisualVariantIndex(variant);
    deckVisualWriteTapState(stateDir, "semu-priority", deckVisualPriorityState(priority));
    deckVisualWriteTapState(stateDir, "semu-bezel", index);
    deckVisualWriteTapState(stateDir, "semu-shader", index);
}

string deckVisualExpandClipCommandTemplate(string project, string value, string system, string output, string duration) {
    string result = Strings.replace(value, "${project}", ShellWords.quote(project));
    result = Strings.replace(result, "${system}", ShellWords.quote(system));
    result = Strings.replace(result, "${emulator}", ShellWords.quote(deckVisualExpectedEmulator(system)));
    result = Strings.replace(result, "${duration}", ShellWords.quote(duration));
    result = Strings.replace(result, "${output}", ShellWords.quote(output));
    return result;
}

string deckVisualClipCommand(string project, string system, string output, string duration) {
    string template = Environment.get("SEMU_VISUAL_CLIP_CMD", "");
    if (template.len() > 0) {
        if (template.contains("${output}")) {
            return deckVisualExpandClipCommandTemplate(project, template, system, output, duration);
        }
        return shellAppend(ShellWords.quote(template), output);
    }
    if (commandExists("wf-recorder")) {
        return shellAppendAll("wf-recorder", ["-d", duration, "-f", output]);
    }
    if (commandExists("ffmpeg") && Environment.get("DISPLAY", "").len() > 0) {
        string display = Environment.get("DISPLAY", ":0");
        string size = Environment.get("SEMU_VISUAL_CLIP_SIZE", "1280x800");
        return shellAppendAll("ffmpeg", ["-y", "-f", "x11grab", "-video_size", size, "-i", display + ".0", "-t", duration, "-pix_fmt", "yuv420p", output]);
    }
    return "";
}

bool deckVisualCaptureClip(string project, string system, string duration) {
    string output = deckVisualClipPath(project, system);
    ensureDir(PathTools.dirname(output));
    string command = deckVisualClipCommand(project, system, output, duration);
    if (command.len() == 0) {
        print("MISSING visual_clip_tool: install wf-recorder/ffmpeg or set SEMU_VISUAL_CLIP_CMD");
        return false;
    }
    ExecResult result = UnixShell().runRaw(command, false, false, "");
    if (result.ok() && deckEvidenceFilePresent(output)) {
        print("OK capture " + system + " clip: " + output);
        return true;
    }
    print("MISSING capture " + system + " clip: " + output);
    return false;
}

string deckVisualLaunchLogPath(string project, string system) {
    return joinPath(deckVisualEvidenceRoot(project), joinPath(system, "launch.log"));
}

string deckVisualLaunchPidPath(string project, string system) {
    return joinPath(deckVisualEvidenceRoot(project), joinPath(system, "launch.pid"));
}

string deckVisualExpandLaunchCommandTemplate(CliArgs args, string project, string value, string system, string rom) {
    string result = Strings.replace(value, "${project}", ShellWords.quote(project));
    result = Strings.replace(result, "${system}", ShellWords.quote(system));
    result = Strings.replace(result, "${emulator}", ShellWords.quote(deckVisualExpectedEmulator(system)));
    result = Strings.replace(result, "${rom}", ShellWords.quote(rom));
    return result;
}

string deckVisualLauncherCli(string project) {
    string env = Environment.get("SEMU_BIN", "");
    if (env.len() > 0) { return env; }
    string generated = generatedBinaryPath(project);
    if (FileSystem.isFile(generated)) { return generated; }
    return "semu";
}

string deckVisualRetroArchCoreRoot(string project) {
    string env = Environment.get("SEMU_RETROARCH_CORE_DIR", "");
    if (env.len() > 0) { return env; }
    return joinPath(nixResultRoot(project), "lib/retroarch/cores");
}

string deckVisualCatalogLaunchCommand(string project, string system, string rom) {
    string template = systemPrimaryLinuxCommand(system);
    if (template.len() == 0 || rom.len() == 0) { return ""; }

    string cli = ShellWords.quote(deckVisualLauncherCli(project));
    string result = template;
    result = Strings.replace(result, "%EMULATOR_RETROARCH%", cli + " launcher retroarch");
    result = Strings.replace(result, "%EMULATOR_MELONDS%", cli + " launcher melonds");
    result = Strings.replace(result, "%EMULATOR_FLYCAST%", cli + " launcher flycast");
    result = Strings.replace(result, "%EMULATOR_PCSX2%", cli + " launcher pcsx2");
    result = Strings.replace(result, "%EMULATOR_PPSSPP%", cli + " launcher ppsspp");
    result = Strings.replace(result, "%EMULATOR_AZAHAR%", cli + " launcher azahar");
    result = Strings.replace(result, "%EMULATOR_DOLPHIN%", cli + " launcher dolphin");
    result = Strings.replace(result, "%EMULATOR_CEMU%", cli + " launcher cemu");
    result = Strings.replace(result, "%EMULATOR_RYUJINX%", cli + " launcher ryujinx");
    result = Strings.replace(result, "%CORE_RETROARCH%", ShellWords.quote(deckVisualRetroArchCoreRoot(project)));
    result = Strings.replace(result, "%ROM%", ShellWords.quote(rom));
    if (result.contains("%EMULATOR_") || result.contains("%CORE_") || result.contains("%ROM%")) {
        return "";
    }
    return result;
}

string deckVisualLaunchCommandForRom(CliArgs args, string project, string system, string rom) {
    string command = args.valueAfter("--launch-command", "");
    if (command.len() > 0) {
        return deckVisualExpandLaunchCommandTemplate(args, project, command, system, rom);
    }
    return deckVisualCatalogLaunchCommand(project, system, rom);
}

string deckVisualLaunchCommand(CliArgs args, string project, string system) {
    return deckVisualLaunchCommandForRom(args, project, system, args.valueAfter("--rom", ""));
}

string deckVisualRomRoot(CliArgs args, string project) {
    string explicit = args.valueAfter("--rom-root", args.valueAfter("--roms", ""));
    if (explicit.len() > 0) { return explicit; }
    return configuredRomsRoot(project);
}

string deckVisualFindRomInDir(string dir, Vector<string> extensions, int depth) {
    if (!FileSystem.isDir(dir)) { return ""; }
    Vector<string> entries = FileSystem.listDir(dir);
    for extension in extensions {
        string lowerExt = extension.toLower();
        for name in entries {
            string path = joinPath(dir, name);
            if (FileSystem.isFile(path) && name.toLower().endsWith(lowerExt)) {
                return path;
            }
        }
    }
    if (depth <= 0) { return ""; }
    for name in entries {
        if (name.startsWith(".")) { continue; }
        string path = joinPath(dir, name);
        if (FileSystem.isDir(path)) {
            string found = deckVisualFindRomInDir(path, extensions, depth - 1);
            if (found.len() > 0) { return found; }
        }
    }
    return "";
}

string deckVisualRepresentativeRom(CliArgs args, string project, string system) {
    string explicit = args.valueAfter("--rom", "");
    if (explicit.len() > 0) { return explicit; }
    string root = deckVisualRomRoot(args, project);
    string dir = joinPath(root, systemRomDir(system));
    return deckVisualFindRomInDir(dir, systemRomExtensions(system), 3);
}

bool deckVisualStartLaunchCommand(CliArgs args, string project, string system, string command) {
    string log = deckVisualLaunchLogPath(project, system);
    string pid = deckVisualLaunchPidPath(project, system);
    ensureDir(PathTools.dirname(log));
    FileSystem.removeRecursive(pid);
    FileSystem.removeRecursive(log);
    string launcher = commandExists("setsid") ? "setsid sh -c " : "sh -c ";
    string shellCommand = launcher + ShellWords.quote(command)
        + " > " + ShellWords.quote(log)
        + " 2>&1 < /dev/null & echo $! > " + ShellWords.quote(pid);
    ExecResult result = UnixShell().runRaw(shellCommand, false, false, "");
    if (!result.ok() || !FileSystem.isFile(pid)) {
        print("MISSING launch " + system + ": " + log);
        return false;
    }
    string waitSeconds = args.valueAfter("--launch-wait-seconds", Environment.get("SEMU_VISUAL_LAUNCH_WAIT_SECONDS", "10"));
    if (!waitSeconds.equals("0")) {
        UnixShell().runRaw("sleep " + ShellWords.quote(waitSeconds), false, false, "");
    }
    print("OK launch " + system + ": " + log);
    return true;
}

void deckVisualStopLaunchCommand(string project, string system) {
    string pidPath = deckVisualLaunchPidPath(project, system);
    if (!FileSystem.isFile(pidPath)) { return; }
    string pid = FileSystem.readText(pidPath).trim();
    if (pid.len() == 0) { return; }
    UnixShell().runRaw(
        "kill -- -" + ShellWords.quote(pid) + " >/dev/null 2>&1 || kill " + ShellWords.quote(pid) + " >/dev/null 2>&1 || true; "
            + "sleep 1; "
            + "kill -9 -- -" + ShellWords.quote(pid) + " >/dev/null 2>&1 || kill -9 " + ShellWords.quote(pid) + " >/dev/null 2>&1 || true",
        false,
        false,
        ""
    );
}

bool deckVisualCaptureSystemWithRom(CliArgs args, string project, string system, string rom) {
    string stateDir = deckVisualCaptureTapStateDir(args, project);
    string settle = deckVisualCaptureSettleSeconds(args);
    string emulator = deckVisualExpectedEmulator(system);
    bool ok = true;
    print("Capturing visual evidence for " + system);
    print("  tap_state_dir: " + stateDir);
    if (rom.len() > 0) {
        print("  rom: " + rom);
    }

    string launchCommand = deckVisualLaunchCommandForRom(args, project, system, rom);
    bool launched = false;
    if (launchCommand.len() > 0) {
        launched = deckVisualStartLaunchCommand(args, project, system, launchCommand);
        if (!launched) { return false; }
    }

    for priority in deckVisualEvidencePriorities() {
        for variant in deckVisualEvidenceVariants() {
            deckVisualApplyTapState(stateDir, priority, variant);
            if (!settle.equals("0")) {
                UnixShell().runRaw("sleep " + ShellWords.quote(settle), false, false, "");
            }
            string output = deckVisualScreenshotPath(project, system, priority, variant);
            string hook = "visual_" + priority + "_" + variant;
            if (screenshotCaptureTo(project, emulator, hook, output)) {
                print("OK capture " + system + " screenshot " + priority + "/" + variant + ": " + output);
            } else {
                ok = false;
            }
        }
    }

    string duration = args.valueAfter("--duration-seconds", "30");
    if (!deckVisualCaptureClip(project, system, duration)) {
        ok = false;
    }
    if (launched && !args.has("--leave-running")) {
        deckVisualStopLaunchCommand(project, system);
    }
    return ok;
}

bool deckVisualCaptureSystem(CliArgs args, string project, string system) {
    return deckVisualCaptureSystemWithRom(args, project, system, args.valueAfter("--rom", ""));
}

bool deckVisualCaptureAll(CliArgs args, string project, Vector<string> systems) {
    bool ok = true;
    string romRoot = deckVisualRomRoot(args, project);
    print("Capturing visual evidence batch");
    print("  rom_root: " + romRoot);
    for system in systems {
        string rom = deckVisualRepresentativeRom(args, project, system);
        if (rom.len() == 0) {
            print("PENDING " + system + " representative ROM under " + joinPath(romRoot, systemRomDir(system)));
            ok = false;
            continue;
        }
        if (!deckVisualCaptureSystemWithRom(args, project, system, rom)) {
            ok = false;
        }
    }
    return ok;
}

bool deckEvidenceFilePresent(string path) {
    if (!FileSystem.isFile(path)) { return false; }
    ExecResult result = UnixShell().runRaw("test -s " + ShellWords.quote(path), false, false, "");
    return result.ok();
}

string deckVisualExpectedEmulator(string system) {
    string s = renderOptionCanonicalSystem(system);
    if (s.equals("nds")) { return "melonds"; }
    if (s.equals("dreamcast")) { return "flycast"; }
    if (s.equals("ps2")) { return "pcsx2"; }
    if (s.equals("psp")) { return "ppsspp"; }
    if (s.equals("n3ds")) { return "azahar"; }
    if (s.equals("gc") || s.equals("wii")) { return "dolphin"; }
    if (s.equals("wiiu")) { return "cemu"; }
    if (s.equals("switch")) { return "ryujinx"; }
    return "retroarch";
}

Vector<string> deckVisualAnalysisRequiredTokens(string system) {
    string s = renderOptionCanonicalSystem(system);
    Vector<string> tokens = [
        "system=" + s,
        "emulator=" + deckVisualExpectedEmulator(s),
        "visual=ok",
        "input=ok",
        "duration_s=30",
        "viewport_alignment=ok",
        "cutout_mask=ok",
        "controller_input=ok",
        "radial_menu=ok",
        "clip.start_of_gameplay=ok",
        "bezel.A=ok",
        "bezel.B=ok",
        "bezel.C=ok",
        "bezel.Off=ok",
        "shader.A=ok",
        "shader.B=ok",
        "shader.C=ok",
        "shader.Off=ok"
    ];
    for priority in deckVisualEvidencePriorities() {
        for variant in deckVisualEvidenceVariants() {
            tokens.push("screenshot." + priority + "." + variant + "=ok");
        }
    }
    string kind = RenderOptionCatalog.find(s).systemKind;
    if (kind.equals("1")) {
        tokens.push("dual.layout.vertical=ok");
        tokens.push("dual.layout.horizontal=ok");
        tokens.push("dual.primary_scale=ok");
        tokens.push("dual.secondary_scale=ok");
    }
    if (kind.equals("2")) {
        tokens.push("controller_layout.wiimote=ok");
        tokens.push("controller_layout.wiimote_nunchuk=ok");
        tokens.push("controller_layout.pro_controller=ok");
        tokens.push("controller_layout.classic=ok");
    }
    return tokens;
}

Vector<string> deckVisualAnalysisMissingTokens(string path, string system) {
    Vector<string> missing = [];
    Vector<string> required = deckVisualAnalysisRequiredTokens(system);
    if (!deckEvidenceFilePresent(path)) {
        return required;
    }
    string text = FileSystem.readText(path);
    for token in required {
        if (!text.contains(token)) {
            missing.push(token);
        }
    }
    return missing;
}

bool deckVisualAnalysisComplete(string path, string system) {
    return deckVisualAnalysisMissingTokens(path, system).len == 0;
}

bool deckKnownVisualSystem(string system) {
    string wanted = system.toLower();
    for id in declaredSystemIds() {
        if (id.equals(wanted)) { return true; }
    }
    return false;
}

Vector<string> deckRequestedVisualSystems(CliArgs args) {
    string requested = args.valueAfter("--system", "");
    if (requested.len() == 0 && args.count() > 2 && !args.get(2).startsWith("--")) {
        requested = args.get(2);
    }
    if (requested.len() > 0) {
        return [requested.toLower()];
    }
    return declaredSystemIds();
}

bool deckVisualEvidenceComplete(string project, Vector<string> systems) {
    for system in systems {
        for priority in deckVisualEvidencePriorities() {
            for variant in deckVisualEvidenceVariants() {
                if (!deckEvidenceFilePresent(deckVisualScreenshotPath(project, system, priority, variant))) {
                    return false;
                }
            }
        }
        if (!deckEvidenceFilePresent(deckVisualClipPath(project, system))) {
            return false;
        }
        if (!deckVisualAnalysisComplete(deckVisualAnalysisPath(project, system), system)) {
            return false;
        }
    }
    return true;
}

string deckVisualEvidenceChecklistText(string project, Vector<string> systems) {
    Vector<string> lines = [
        "Semu Visual Evidence",
        "",
        "Project: " + project,
        "Visual evidence root: " + deckVisualEvidenceRoot(project),
        "",
        "For each system:",
        "1. Launch a representative game through Semu.",
        "2. Capture screenshots for game-priority and bezel-priority.",
        "3. Capture variants A, B, and C for each priority.",
        "4. Record a 30-second start-of-gameplay clip.",
        "5. Verify the game viewport lands exactly in the bezel cutout.",
        "6. Verify controller input moves/responds in game.",
        "7. Write start-of-gameplay-analysis.txt with the required analysis tokens.",
        "",
        "Expected files:"
    ];
    for system in systems {
        lines.push("");
        lines.push(system + " analysis must include:");
        for token in deckVisualAnalysisRequiredTokens(system) {
            lines.push("  - " + token);
        }
        for priority in deckVisualEvidencePriorities() {
            for variant in deckVisualEvidenceVariants() {
                lines.push("- " + deckVisualScreenshotPath(project, system, priority, variant));
            }
        }
        lines.push("- " + deckVisualClipPath(project, system));
        lines.push("- " + deckVisualAnalysisPath(project, system));
    }
    return textLines(lines);
}

string deckVisualEvidenceManifestJson(string project, Vector<string> systems) {
    Vector<string> screenshots = [];
    Vector<string> clips = [];
    for system in systems {
        for priority in deckVisualEvidencePriorities() {
            for variant in deckVisualEvidenceVariants() {
                screenshots.push(jsonObject([
                    jsonStrField("system", system),
                    jsonStrField("priority", priority),
                    jsonStrField("variant", variant),
                    jsonStrField("path", deckVisualScreenshotPath(project, system, priority, variant))
                ]));
            }
        }
        clips.push(jsonObject([
            jsonStrField("system", system),
            jsonStrField("emulator", deckVisualExpectedEmulator(system)),
            jsonStrField("clip", deckVisualClipPath(project, system)),
            jsonStrField("analysis", deckVisualAnalysisPath(project, system)),
            jsonField("duration_s", "30"),
            jsonField("required_analysis", jsonStringArray(deckVisualAnalysisRequiredTokens(system)))
        ]));
    }
    return jsonObject([
        jsonStrField("schema_version", "1"),
        jsonStrField("project", project),
        jsonStrField("root", deckVisualEvidenceRoot(project)),
        jsonField("systems", jsonStringArray(systems)),
        jsonField("priorities", jsonStringArray(deckVisualEvidencePriorities())),
        jsonField("variants", jsonStringArray(deckVisualEvidenceVariants())),
        jsonField("screenshots", jsonArray(screenshots)),
        jsonField("clips", jsonArray(clips))
    ]);
}

int deckVisualEvidenceCommand(CliArgs args, string project) {
    Vector<string> systems = deckRequestedVisualSystems(args);
    for system in systems {
        if (!deckKnownVisualSystem(system)) {
            print("error 0:0 unknown system '" + system + "'");
            return 1;
        }
    }

    bool prepare = args.has("--prepare");
    bool capture = args.has("--capture");
    bool captureAll = args.has("--capture-all");
    if (capture && captureAll) {
        print("error 0:0 pass only one of --capture or --capture-all");
        return 1;
    }
    if (capture && systems.len != 1) {
        print("error 0:0 --capture requires exactly one visual system; pass --system <id> or a positional system");
        return 1;
    }
    if (args.has("--print-launch-command")) {
        if (systems.len != 1) {
            print("error 0:0 --print-launch-command requires exactly one visual system");
            return 1;
        }
        string command = deckVisualLaunchCommand(args, project, systems.get(0));
        if (command.len() == 0) {
            print("error 0:0 no launch command available; pass --rom PATH or --launch-command CMD");
            return 1;
        }
        print(command);
        return 0;
    }
    bool allowPending = args.has("--allow-pending") || prepare;
    string root = deckVisualEvidenceRoot(project);
    ensureDir(root);

    if (prepare || capture || captureAll) {
        SemuGeneratedFiles.writeProject(project, deckVisualEvidenceChecklistPath(project), deckVisualEvidenceChecklistText(project, systems));
        SemuGeneratedFiles.writeProjectJson(project, deckVisualEvidenceManifestPath(project), deckVisualEvidenceManifestJson(project, systems));
        print("OK prepared visual evidence manifest: " + deckVisualEvidenceManifestPath(project));
    }

    if (capture && !deckVisualCaptureSystem(args, project, systems.get(0))) {
        print("PENDING Semu visual evidence capture");
        return 2;
    }
    bool captureAllOk = true;
    if (captureAll) {
        captureAllOk = deckVisualCaptureAll(args, project, systems);
    }

    print("Semu visual evidence");
    print("  root: " + root);

    bool allOk = true;
    int screenshotOk = 0;
    int screenshotTotal = systems.len * deckVisualEvidencePriorities().len * deckVisualEvidenceVariants().len;
    int clipOk = 0;
    int clipTotal = systems.len;
    int analysisOk = 0;

    for system in systems {
        bool systemOk = true;
        for priority in deckVisualEvidencePriorities() {
            for variant in deckVisualEvidenceVariants() {
                string shot = deckVisualScreenshotPath(project, system, priority, variant);
                if (deckEvidenceFilePresent(shot)) {
                    screenshotOk++;
                } else {
                    print("PENDING " + system + " screenshot " + priority + "/" + variant + ": " + shot);
                    systemOk = false;
                    allOk = false;
                }
            }
        }
        string clip = deckVisualClipPath(project, system);
        if (deckEvidenceFilePresent(clip)) {
            clipOk++;
        } else {
            print("PENDING " + system + " clip: " + clip);
            systemOk = false;
            allOk = false;
        }
        string analysis = deckVisualAnalysisPath(project, system);
        Vector<string> missingAnalysis = deckVisualAnalysisMissingTokens(analysis, system);
        if (missingAnalysis.len == 0) {
            analysisOk++;
        } else {
            print("PENDING " + system + " analysis: " + analysis + " (missing " + missingAnalysis.join(", ") + ")");
            systemOk = false;
            allOk = false;
        }
        if (systemOk) {
            print("OK " + system + ": visual screenshots, 30s clip, and analysis complete");
        }
    }

    print("  screenshots: " + Strings.fromInt(screenshotOk) + "/" + Strings.fromInt(screenshotTotal));
    print("  clips: " + Strings.fromInt(clipOk) + "/" + Strings.fromInt(clipTotal));
    print("  analyses: " + Strings.fromInt(analysisOk) + "/" + Strings.fromInt(clipTotal));

    if (allOk) {
        print("OK Semu visual evidence");
        return 0;
    }
    print("PENDING Semu visual evidence");
    return (allowPending && (!captureAll || captureAllOk)) ? 0 : 2;
}
