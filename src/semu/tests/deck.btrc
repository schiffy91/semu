class SemuDeckTests {
    class int provision(CliArgs args, string project) { return deckProvisionCommand(args, project); }
    class int verifyInput(string project, bool strict) { return deckVerifyInputCommand(project, strict); }
}

void deckMaybeRun(string command) {
    UnixShell().runUnchecked(command + " >/dev/null 2>&1 || true");
}

string deckBrewExecutable() {
    if (commandExists("brew")) { return "brew"; }
    if (FileSystem.exists("/home/linuxbrew/.linuxbrew/bin/brew")) {
        return "/home/linuxbrew/.linuxbrew/bin/brew";
    }
    if (FileSystem.exists("/var/home/linuxbrew/.linuxbrew/bin/brew")) {
        return "/var/home/linuxbrew/.linuxbrew/bin/brew";
    }
    return "";
}

void deckInstallHostPackages() {
    if (commandExists("pacman")) {
        deckMaybeRun("sudo pacman -Sy --needed --noconfirm bash curl jq rsync syncthing flatpak bubblewrap retroarch evtest gcc inputplumber");
    }
    if (commandExists("rpm-ostree")) {
        deckMaybeRun("sudo -n rpm-ostree install -y curl jq syncthing flatpak bubblewrap evtest gcc inputplumber");
    }
    string brew = deckBrewExecutable();
    if (brew.len() > 0) {
        deckMaybeRun(ShellWords.quote(brew) + " install syncthing jq");
    }
    if (commandExists("flatpak")) {
        deckMaybeRun("flatpak remote-add --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo");
    }
}

void deckBuildGeneratedCli(string project) {
    ensureDir(joinPath(project, "build"));
    string generated = joinPath(project, "generated/semu.c");
    string output = joinPath(project, "build/semu");
    if (commandExists("cc") && FileSystem.exists(generated)) {
        ExecResult result = UnixShell().runRaw(
            "cc " + ShellWords.quote(generated) + " -std=c11 -o " + ShellWords.quote(output) + " -lm",
            true,
            false,
            ""
        );
        if (!result.ok()) {
            print(result.stdout());
        }
    }
}

int deckProvisionCommand(CliArgs args, string project) {
    string roms = args.valueAfter("--roms", Environment.get("SEMU_ROMS_DIR", joinPath(project, "ES-DE/ES-DE/ROMs")));
    deckInstallHostPackages();
    deckBuildGeneratedCli(project);
    lifecycleInstall(project, roms);
    syncSetup(project);
    print("OK deck provision");
    return 0;
}

bool deckHasGraphicalSession() {
    return Environment.get("WAYLAND_DISPLAY", "").len() > 0 || Environment.get("DISPLAY", "").len() > 0;
}

bool deckHasScreenshotTool() {
    return commandExists("grim")
        || commandExists("spectacle")
        || commandExists("gnome-screenshot")
        || commandExists("import");
}

bool deckEnvBool(string key, bool fallback) {
    string value = Environment.get(key, "");
    if (value.len() == 0) { return fallback; }
    return value.equals("1") || value.equals("true") || value.equals("yes");
}

bool deckProcessRunning(string pattern) {
    if (!commandExists("pgrep")) { return false; }
    ExecResult result = UnixShell().runRaw("pgrep -f " + ShellWords.quote(pattern) + " >/dev/null 2>&1", false, false, "");
    return result.ok();
}

string deckSessionKind() {
    string sessionOverride = Environment.get("SEMU_DECK_SESSION", "");
    if (sessionOverride.len() > 0) { return sessionOverride; }
    bool gamescope = deckProcessRunning("(^|/)gamescope( |$)") || deckProcessRunning("gamescope-session");
    bool kwin = deckProcessRunning("(^|/)kwin_wayland( |$)") || deckProcessRunning("kwin_wayland_wrapper");
    if (gamescope && !kwin) { return "game_mode"; }
    if (gamescope && kwin) { return "mixed_gamescope_desktop"; }
    if (kwin) { return "desktop_mode"; }
    return "unknown";
}

bool deckSteamRunning() {
    string steamOverride = Environment.get("SEMU_STEAM_RUNNING", "");
    if (steamOverride.len() > 0) { return deckEnvBool("SEMU_STEAM_RUNNING", false); }
    return deckProcessRunning("(^|/)steam( |$)") || deckProcessRunning("steamwebhelper");
}

int deckVerifyEmulatorsCommand(CliArgs args, string project) {
    doctorSteamDeck(project);
    KeymapErrors errors = KeymapErrors();
    compileKeymap(FileSystem.exists(keymapSourcePath(project)) ? FileSystem.readText(keymapSourcePath(project)) : defaultKeymapSource(), errors);
    if (errors.count() > 0) { return 1; }
    KeymapIr ir = compileKeymap(FileSystem.exists(keymapSourcePath(project)) ? FileSystem.readText(keymapSourcePath(project)) : defaultKeymapSource(), KeymapErrors());
    FileSystem.writeText("/tmp/semu-retroarch.cfg", renderRetroArchKeymap(ir));
    doctorScreenshotHooks(project);
    if (deckHasGraphicalSession() && deckHasScreenshotTool()) {
        screenshotCaptureTo(project, "deck_preflight", "manual_visual_checkpoint", screenshotCapturePath(project, "deck_preflight", "manual_visual_checkpoint"));
    } else {
        print("INFO screenshot capture waits for a graphical session and screenshot tool");
    }
    int sandboxStatus = e2eSandboxSmoke();
    if (sandboxStatus != 0) { return sandboxStatus; }
    int launcherStatus = e2eLauncherSmoke(args);
    if (launcherStatus != 0) { return launcherStatus; }
    deckMaybeRun("retroarch --version | head -1");
    deckMaybeRun("flatpak list --app");
    print("OK deck emulator preflight");
    return 0;
}

int deckVerifyInputCommand(string project, bool strict) {
    doctorSteamDeck(project);
    bool ok = true;
    if (FileSystem.exists("/dev/uinput")) {
        print("OK /dev/uinput");
    } else if (strict) {
        print("FAIL /dev/uinput missing; virtual-input automation unavailable");
        ok = false;
    } else {
        print("INFO /dev/uinput unavailable in this environment");
    }
    if (commandExists("inputplumber")) {
        print("OK inputplumber");
    } else if (strict) {
        print("FAIL inputplumber missing; Steam Deck route cannot be verified");
        ok = false;
    } else {
        print("INFO inputplumber verification waits for the Deck environment");
    }
    print(ok ? "OK deck input preflight" : "FAIL deck input preflight");
    return ok ? 0 : 2;
}

string deckQuitEvidenceRoot(string project) {
    return joinPath(semuStateRoot(project), "verification/quit-watch");
}

string deckQuitEvidencePath(string project, string emulator) {
    return joinPath(deckQuitEvidenceRoot(project), emulator.toLower() + ".log");
}

string deckStateEvidenceRoot(string project) {
    return joinPath(semuStateRoot(project), "verification/state-actions");
}

string deckStateEvidencePath(string project, string emulator) {
    return joinPath(deckStateEvidenceRoot(project), emulator.toLower() + ".log");
}

string deckGameModeChecklistPath(string project) {
    return joinPath(semuStateRoot(project), "verification/game-mode-checklist.txt");
}

string deckStateEvidenceChecklistPath(string project) {
    return joinPath(semuStateRoot(project), "verification/state-evidence-checklist.txt");
}

string deckGameModeReadinessPath(string project) {
    return joinPath(semuStateRoot(project), "verification/game-mode-readiness.json");
}

string deckProductionReadinessPath(string project) {
    return joinPath(semuStateRoot(project), "verification/production-readiness.json");
}

bool deckQuitEvidenceHasLifecycle(string text) {
    return text.contains(" start child=") && text.contains(" exit child=");
}

bool deckQuitEvidenceHasQuitReason(string text) {
    return text.contains(" reason=")
        && (text.contains(" terminate child=") || text.contains(" quit child=") || text.contains("quit path="));
}

bool deckQuitEvidenceComplete(string project, Vector<string> emulators) {
    for emulator in emulators {
        string path = deckQuitEvidencePath(project, emulator);
        if (!FileSystem.exists(path)) { return false; }
        if (!deckQuitEvidenceHasQuitReason(FileSystem.readText(path))) { return false; }
    }
    return true;
}

Vector<string> deckStateEvidenceEmulators() {
    return actionCapabilityEmulators("state.save", "generated");
}

bool deckKnownStateEvidenceEmulator(string emulator) {
    string key = emulator.toLower();
    for name in deckStateEvidenceEmulators() {
        if (name.toLower().equals(key)) {
            return true;
        }
    }
    return false;
}

Vector<string> deckRequestedStateEvidenceEmulators(CliArgs args) {
    string requested = args.valueAfter("--emulator", "");
    if (requested.len() == 0 && args.count() > 2 && !args.get(2).startsWith("--")) {
        requested = args.get(2);
    }
    if (requested.len() > 0) {
        return [requested.toLower()];
    }
    return deckStateEvidenceEmulators();
}

bool deckStateEvidenceHasAction(string text, string action) {
    for line in Strings.split(text, "\n") {
        if (line.contains("action=" + action) && line.contains("result=ok")) {
            return true;
        }
    }
    return false;
}

bool deckStateEvidenceComplete(string project, Vector<string> emulators) {
    for emulator in emulators {
        string path = deckStateEvidencePath(project, emulator);
        if (!FileSystem.exists(path)) { return false; }
        string text = FileSystem.readText(path);
        if (!deckStateEvidenceHasAction(text, "state.save")) { return false; }
        if (!deckStateEvidenceHasAction(text, "state.load")) { return false; }
    }
    return true;
}

bool deckKnownEvidenceEmulator(string emulator) {
    string key = emulator.toLower();
    for name in linuxLauncherNames() {
        if (name.toLower().equals(key)) {
            return true;
        }
    }
    return false;
}

Vector<string> deckEvidenceEmulators(CliArgs args) {
    string requested = args.valueAfter("--emulator", "");
    if (requested.len() == 0 && args.count() > 2 && !args.get(2).startsWith("--")) {
        requested = args.get(2);
    }
    if (requested.len() > 0) {
        return [requested.toLower()];
    }
    return lowercaseValues(linuxLauncherNames());
}

string deckGameModeChecklistText(string project, Vector<string> emulators) {
    Vector<string> lines = [
        "Semu Game Mode Verification",
        "",
        "Project: " + project,
        "Quit evidence root: " + deckQuitEvidenceRoot(project),
        "",
        "For each emulator:",
        "1. Launch Semu from Steam Game Mode.",
        "2. Launch a representative game through ES-DE.",
        "3. Confirm fullscreen content and controller movement/buttons.",
        "4. Open the physical left-trackpad radial menu.",
        "5. Press Quit and confirm return to ES-DE.",
        "6. Verify the matching quit-watch log contains reason=select+start.",
        "",
        "Evidence files:"
    ];
    for emulator in emulators {
        lines.push("- " + emulator + ": " + deckQuitEvidencePath(project, emulator));
    }
    return textLines(lines);
}

string deckStateEvidenceChecklistText(string project, Vector<string> emulators) {
    Vector<string> lines = [
        "Semu State Action Verification",
        "",
        "Project: " + project,
        "State evidence root: " + deckStateEvidenceRoot(project),
        "",
        "For each state-capable emulator:",
        "1. Launch Semu from Steam Game Mode.",
        "2. Launch a representative game through ES-DE.",
        "3. Create a visible in-game change.",
        "4. Use the physical left-trackpad radial Save State action.",
        "5. Create a second visible in-game change.",
        "6. Use the physical left-trackpad radial Load State action.",
        "7. Confirm the first saved state is restored.",
        "8. Record action=state.save result=ok and action=state.load result=ok in the matching evidence file.",
        "",
        "Evidence files:"
    ];
    for emulator in emulators {
        lines.push("- " + emulator + ": " + deckStateEvidencePath(project, emulator));
    }
    return textLines(lines);
}

int deckGameModeEvidenceCommand(CliArgs args, string project) {
    Vector<string> emulators = deckEvidenceEmulators(args);
    for emulator in emulators {
        if (!deckKnownEvidenceEmulator(emulator)) {
            print("error 0:0 unknown emulator '" + emulator + "'");
            return 1;
        }
    }

    bool prepare = args.has("--prepare");
    bool allowPending = args.has("--allow-pending") || prepare;
    string root = deckQuitEvidenceRoot(project);
    SemuGeneratedFiles.ensureAdapterStateDir(project, root);

    if (prepare) {
        string checklist = deckGameModeChecklistPath(project);
        SemuGeneratedFiles.writeAdapterState(project, checklist, deckGameModeChecklistText(project, emulators));
        print("OK prepared Game Mode checklist: " + checklist);
    }

    print("Game Mode quit evidence");
    print("  root: " + root);

    bool allOk = true;
    for emulator in emulators {
        string path = deckQuitEvidencePath(project, emulator);
        if (!FileSystem.exists(path)) {
            print("PENDING " + emulator + ": missing " + path);
            allOk = false;
        } else {
            string text = FileSystem.readText(path);
            if (deckQuitEvidenceHasQuitReason(text)) {
                print("OK " + emulator + ": quit evidence " + path);
            } else if (deckQuitEvidenceHasLifecycle(text)) {
                print("PARTIAL " + emulator + ": lifecycle without quit reason " + path);
                allOk = false;
            } else {
                print("PENDING " + emulator + ": no quit-watch lifecycle " + path);
                allOk = false;
            }
        }
    }

    if (allOk) {
        print("OK Game Mode quit evidence");
        return 0;
    }
    print("PENDING Game Mode quit evidence");
    print("  Use the physical left-trackpad Quit action in Game Mode for each pending emulator, then rerun without --allow-pending.");
    return allowPending ? 0 : 2;
}

int deckStateEvidenceCommand(CliArgs args, string project) {
    Vector<string> emulators = deckRequestedStateEvidenceEmulators(args);
    for emulator in emulators {
        if (!deckKnownStateEvidenceEmulator(emulator)) {
            print("error 0:0 state evidence is not generated for emulator '" + emulator + "'");
            return 1;
        }
    }

    bool prepare = args.has("--prepare");
    bool allowPending = args.has("--allow-pending") || prepare;
    string root = deckStateEvidenceRoot(project);
    SemuGeneratedFiles.ensureAdapterStateDir(project, root);

    if (prepare) {
        string checklist = deckStateEvidenceChecklistPath(project);
        SemuGeneratedFiles.writeAdapterState(project, checklist, deckStateEvidenceChecklistText(project, emulators));
        print("OK prepared state evidence checklist: " + checklist);
    }

    print("Game Mode state evidence");
    print("  root: " + root);

    bool allOk = true;
    for emulator in emulators {
        string path = deckStateEvidencePath(project, emulator);
        if (!FileSystem.exists(path)) {
            print("PENDING " + emulator + ": missing " + path);
            allOk = false;
        } else {
            string text = FileSystem.readText(path);
            bool saveOk = deckStateEvidenceHasAction(text, "state.save");
            bool loadOk = deckStateEvidenceHasAction(text, "state.load");
            if (saveOk && loadOk) {
                print("OK " + emulator + ": save/load evidence " + path);
            } else {
                print("PENDING " + emulator + ": save=" + (saveOk ? "ok" : "missing") + " load=" + (loadOk ? "ok" : "missing") + " " + path);
                allOk = false;
            }
        }
    }

    if (allOk) {
        print("OK Game Mode state evidence");
        return 0;
    }
    print("PENDING Game Mode state evidence");
    print("  Use the physical left-trackpad Save State and Load State actions for each pending emulator, then rerun without --allow-pending.");
    return allowPending ? 0 : 2;
}

SteamShortcutRecord deckSemuShortcut(CliArgs args) {
    string appName = args.valueAfter("--app-name", steamDefaultShortcutName());
    string exe = args.valueAfter("--exe", steamDefaultShortcutExe());
    string file = args.valueAfter("--shortcuts-file", "");
    if (file.len() > 0) {
        return steamShortcutFind(steamShortcutsRead(file), appName, exe);
    }
    for candidate in steamShortcutsFiles() {
        SteamShortcutRecord found = steamShortcutFind(steamShortcutsRead(candidate), appName, exe);
        if (found.appid > 0) { return found; }
    }
    return SteamShortcutRecord();
}

bool deckPathExecutable(string path) {
    if (!FileSystem.isFile(path)) { return false; }
    ExecResult result = UnixShell().runRaw("[ -x " + ShellWords.quote(path) + " ]", false, false, "");
    return result.ok();
}

string deckSha256(string path) {
    if (!FileSystem.isFile(path) || !commandExists("sha256sum")) { return ""; }
    ExecResult result = UnixShell().runRaw("sha256sum " + ShellWords.quote(path) + " | awk '{print $1}'", true, false, "");
    if (!result.ok()) { return ""; }
    return result.trimmed();
}

string deckGameModeReadinessJson(
    string project,
    string session,
    bool sessionOk,
    bool steamOk,
    bool shortcutOk,
    string launchUri,
    bool steamInputOk,
    string appImage,
    bool appImageOk,
    string appImageHash,
    bool checklistOk,
    bool evidenceRequired,
    bool evidenceOk
) {
    return jsonObject([
        jsonStrField("schema_version", "1"),
        jsonStrField("project", project),
        jsonStrField("session", session),
        jsonBoolField("session_ok", sessionOk),
        jsonBoolField("steam_running", steamOk),
        jsonBoolField("shortcut_found", shortcutOk),
        jsonStrField("launch_uri", launchUri),
        jsonBoolField("steam_input_selected", steamInputOk),
        jsonStrField("appimage", appImage),
        jsonBoolField("appimage_ok", appImageOk),
        jsonStrField("appimage_sha256", appImageHash),
        jsonStrField("checklist", deckGameModeChecklistPath(project)),
        jsonBoolField("checklist_ok", checklistOk),
        jsonStrField("quit_evidence_root", deckQuitEvidenceRoot(project)),
        jsonBoolField("evidence_required", evidenceRequired),
        jsonBoolField("evidence_ok", evidenceOk)
    ]);
}

int deckGameModeReadinessCommand(CliArgs args, string project) {
    Vector<string> emulators = deckEvidenceEmulators(args);
    for emulator in emulators {
        if (!deckKnownEvidenceEmulator(emulator)) {
            print("error 0:0 unknown emulator '" + emulator + "'");
            return 1;
        }
    }

    if (args.has("--prepare")) {
        SemuGeneratedFiles.writeAdapterState(project, deckGameModeChecklistPath(project), deckGameModeChecklistText(project, emulators));
    }

    string session = deckSessionKind();
    bool allowDesktop = args.has("--allow-desktop");
    bool desktopPreflight = session.equals("desktop_mode") || session.equals("mixed_gamescope_desktop");
    bool sessionOk = session.equals("game_mode") || (allowDesktop && desktopPreflight);
    bool steamOk = deckSteamRunning();
    string appImage = args.valueAfter("--appimage", args.valueAfter("--exe", steamDefaultShortcutExe()));
    bool appImageOk = deckPathExecutable(appImage);
    string appImageHash = deckSha256(appImage);
    SteamShortcutRecord shortcut = deckSemuShortcut(args);
    bool shortcutOk = shortcut.appid > 0;
    bool steamInputOk = steamInputSelectionOk(project, args);
    bool checklistOk = FileSystem.isFile(deckGameModeChecklistPath(project));
    bool evidenceRequired = args.has("--require-evidence");
    bool evidenceOk = deckQuitEvidenceComplete(project, emulators);
    string launchUri = shortcutOk ? shortcut.launchUri() : "";

    string report = deckGameModeReadinessJson(
        project,
        session,
        sessionOk,
        steamOk,
        shortcutOk,
        launchUri,
        steamInputOk,
        appImage,
        appImageOk,
        appImageHash,
        checklistOk,
        evidenceRequired,
        evidenceOk
    );
    SemuGeneratedFiles.writeAdapterState(project, deckGameModeReadinessPath(project), jsonPrettyText(report));

    print("Game Mode readiness");
    if (sessionOk) {
        print("  OK session: " + session);
    } else {
        print("  PENDING session: " + session + " (switch to Steam Game Mode for physical proof)");
    }
    print(steamOk ? "  OK steam: running" : "  MISSING steam: not running");
    if (shortcutOk) {
        print("  OK shortcut: " + shortcut.appName);
        print("       uri: " + launchUri);
    } else {
        print("  MISSING shortcut: " + args.valueAfter("--app-name", steamDefaultShortcutName()));
    }
    print(steamInputOk ? "  OK steam-input: Semu template selected" : "  PENDING steam-input: select Semu template with `semu steam-input install`");
    print(appImageOk ? "  OK appimage: " + appImage : "  MISSING appimage: " + appImage);
    if (appImageHash.len() > 0) {
        print("       sha256: " + appImageHash);
    }
    print(checklistOk ? "  OK checklist: " + deckGameModeChecklistPath(project) : "  MISSING checklist: run with --prepare");
    if (evidenceRequired) {
        print(evidenceOk ? "  OK evidence: physical quit logs complete" : "  PENDING evidence: physical quit logs incomplete");
    } else {
        print(evidenceOk ? "  OK evidence: physical quit logs complete" : "  PENDING evidence: not required for preflight");
    }
    print("  report: " + deckGameModeReadinessPath(project));

    bool ok = sessionOk && steamOk && shortcutOk && steamInputOk && appImageOk && checklistOk && (!evidenceRequired || evidenceOk);
    return ok ? 0 : 2;
}

bool deckSourceConfigOk(string project) {
    return FileSystem.isFile(syncConfigPath(project))
        && FileSystem.isFile(semuSettingsPath(project))
        && FileSystem.isFile(keymapSourcePath(project))
        && FileSystem.isDir(presentationSettingsRoot(project));
}

bool deckPresentationAuditReportOk(string project) {
    string path = presentationAssetAuditPath(project);
    if (!FileSystem.isFile(path)) { return false; }
    JsonObject report = JsonObject.readFile(path);
    return report.getInt("missing_system_count", 1) == 0
        && report.getInt("missing_asset_count", 1) == 0
        && report.getInt("missing_dependency_count", 1) == 0;
}

string deckProductionReadinessJson(
    string project,
    string session,
    bool sessionOk,
    bool steamOk,
    bool shortcutOk,
    bool steamInputOk,
    string launchUri,
    string appImage,
    bool appImageOk,
    string appImageHash,
    bool sourceConfigOk,
    bool presentationOk,
    bool quitEvidenceOk,
    bool stateEvidenceOk,
    bool evidenceRequired
) {
    return jsonObject([
        jsonStrField("schema_version", "1"),
        jsonStrField("project", project),
        jsonStrField("session", session),
        jsonBoolField("session_ok", sessionOk),
        jsonBoolField("steam_running", steamOk),
        jsonBoolField("shortcut_found", shortcutOk),
        jsonBoolField("steam_input_selected", steamInputOk),
        jsonStrField("launch_uri", launchUri),
        jsonStrField("appimage", appImage),
        jsonBoolField("appimage_ok", appImageOk),
        jsonStrField("appimage_sha256", appImageHash),
        jsonBoolField("source_config_ok", sourceConfigOk),
        jsonBoolField("presentation_audit_ok", presentationOk),
        jsonStrField("presentation_audit", presentationAssetAuditPath(project)),
        jsonBoolField("quit_evidence_ok", quitEvidenceOk),
        jsonStrField("quit_evidence_root", deckQuitEvidenceRoot(project)),
        jsonBoolField("state_evidence_ok", stateEvidenceOk),
        jsonStrField("state_evidence_root", deckStateEvidenceRoot(project)),
        jsonBoolField("evidence_required", evidenceRequired)
    ]);
}

int deckProductionReadinessCommand(CliArgs args, string project, bool statusMode) {
    Vector<string> quitEmulators = deckEvidenceEmulators(args);
    for emulator in quitEmulators {
        if (!deckKnownEvidenceEmulator(emulator)) {
            print("error 0:0 unknown emulator '" + emulator + "'");
            return 1;
        }
    }
    Vector<string> stateEmulators = deckStateEvidenceEmulators();

    if (args.has("--prepare")) {
        SemuGeneratedFiles.writeAdapterState(project, deckGameModeChecklistPath(project), deckGameModeChecklistText(project, quitEmulators));
        SemuGeneratedFiles.writeAdapterState(project, deckStateEvidenceChecklistPath(project), deckStateEvidenceChecklistText(project, stateEmulators));
    }

    bool evidenceRequired = args.has("--require-evidence") || !statusMode;
    bool allowDesktop = args.has("--allow-desktop");
    bool allowPending = statusMode || (args.has("--allow-pending") && !evidenceRequired);
    string session = deckSessionKind();
    bool desktopPreflight = session.equals("desktop_mode") || session.equals("mixed_gamescope_desktop");
    bool sessionOk = session.equals("game_mode") || (allowDesktop && desktopPreflight);
    bool steamOk = deckSteamRunning();
    string appImage = args.valueAfter("--appimage", args.valueAfter("--exe", steamDefaultShortcutExe()));
    bool appImageOk = deckPathExecutable(appImage);
    string appImageHash = deckSha256(appImage);
    SteamShortcutRecord shortcut = deckSemuShortcut(args);
    bool shortcutOk = shortcut.appid > 0;
    bool steamInputOk = steamInputSelectionOk(project, args);
    string launchUri = shortcutOk ? shortcut.launchUri() : "";
    bool sourceConfigOk = deckSourceConfigOk(project);

    bool presentationOk = false;
    if (args.has("--audit-visuals")) {
        presentationOk = presentationAudit(project, "", "", true) == 0;
    } else {
        presentationOk = deckPresentationAuditReportOk(project);
    }

    bool quitEvidenceOk = deckQuitEvidenceComplete(project, quitEmulators);
    bool stateEvidenceOk = deckStateEvidenceComplete(project, stateEmulators);
    string report = deckProductionReadinessJson(
        project,
        session,
        sessionOk,
        steamOk,
        shortcutOk,
        steamInputOk,
        launchUri,
        appImage,
        appImageOk,
        appImageHash,
        sourceConfigOk,
        presentationOk,
        quitEvidenceOk,
        stateEvidenceOk,
        evidenceRequired
    );
    SemuGeneratedFiles.writeAdapterState(project, deckProductionReadinessPath(project), jsonPrettyText(report));

    print("Semu production readiness");
    print(sessionOk ? "  OK session: " + session : "  PENDING session: " + session);
    print(steamOk ? "  OK steam: running" : "  MISSING steam: not running");
    print(shortcutOk ? "  OK shortcut: " + launchUri : "  MISSING shortcut: " + args.valueAfter("--app-name", steamDefaultShortcutName()));
    print(steamInputOk ? "  OK steam-input: Semu template selected" : "  PENDING steam-input: Semu template not selected");
    print(appImageOk ? "  OK appimage: " + appImage : "  MISSING appimage: " + appImage);
    if (appImageHash.len() > 0) { print("       sha256: " + appImageHash); }
    print(sourceConfigOk ? "  OK owned config sources" : "  MISSING owned config sources");
    print(presentationOk ? "  OK presentation audit" : "  PENDING presentation audit: run with --audit-visuals or fix missing assets");
    print(quitEvidenceOk ? "  OK quit evidence: physical logs complete" : "  PENDING quit evidence: physical logs incomplete");
    print(stateEvidenceOk ? "  OK state evidence: physical save/load logs complete" : "  PENDING state evidence: physical save/load logs incomplete");
    print("  report: " + deckProductionReadinessPath(project));

    bool ok = sessionOk
        && steamOk
        && shortcutOk
        && steamInputOk
        && appImageOk
        && sourceConfigOk
        && presentationOk
        && (!evidenceRequired || (quitEvidenceOk && stateEvidenceOk));
    return ok ? 0 : (allowPending ? 0 : 2);
}

bool deckWaitForSyncHealth(string project) {
    UnixShell shell = UnixShell();
    for (int i = 0; i < 30; i++) {
        ExecResult result = shell.runUnchecked("curl -fsS http://" + syncGuiAddress(project) + "/rest/noauth/health >/dev/null 2>&1");
        if (result.ok()) { return true; }
        shell.runUnchecked("sleep 1");
    }
    return false;
}

int deckVerifySyncCommand(string project) {
    syncStatus(project);
    if (!syncSetup(project)) { return 1; }
    if (!deckWaitForSyncHealth(project)) {
        print("FAIL deck sync health");
        return 2;
    }
    if (!syncForce(project, "all")) { return 1; }
    if (!FileSystem.isDir(syncthingHome(project))) {
        print("FAIL deck sync home missing");
        return 2;
    }
    print("OK deck sync");
    return 0;
}
