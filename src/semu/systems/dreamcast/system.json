{
  "schema_version": 1,
  "name": "Sega Dreamcast",
  "aliases": [],
  "es_de": {
    "platforms": [
      "dreamcast"
    ],
    "theme": "dreamcast"
  },
  "rom": {
    "dir": "dreamcast",
    "extensions": [
      ".cdi",
      ".chd",
      ".cue",
      ".elf",
      ".gdi",
      ".iso",
      ".lst",
      ".m3u",
      ".7z",
      ".zip"
    ]
  },
  "emulators": [
    {
      "emulator": "retroarch",
      "label": "Flycast",
      "core": "flycast"
    }
  ],
  "bios": {
    "required": false,
    "match": "all",
    "files": [
      {
        "name": "dc_boot.bin"
      },
      {
        "name": "dc_flash.bin"
      }
    ],
    "dir": "bios/dc"
  },
  "display": {
    "screens": [
      {
        "id": "main",
        "native": {
          "w": 640,
          "h": 480
        }
      }
    ],
    "aspect": {
      "w": 4,
      "h": 3
    },
    "widescreen": {
      "aspect": {
        "w": 16,
        "h": 9
      },
      "detect": "emulator_config"
    }
  },
  "render": {
    "style": "console",
    "priority": "game",
    "corner_radius": 0.045,
    "curvature": 0.04,
    "reflect": 0.18,
    "glow": 0.5,
    "bloom": 0.4,
    "vignette": 0.22
  },
  "doc": {
    "hardware": "consumer CRT or VGA monitor",
    "intent": "Prefer 4:3 CRT; swap to 16:9/flat only when config or game profile proves widescreen.",
    "native_note": "256x240 carried over from RenderOptionCatalog (the tap's integer-scale base today), not true Dreamcast output res. Change deliberately, not as a migration side effect.",
    "bios": "Flycast can use HLE for many games, but original BIOS files improve compatibility."
  }
}