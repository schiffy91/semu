  "display": {
    "screens": [ { "id": "main", "native": { "w": 1280, "h": 720 } } ],
    "aspect": { "w": 16, "h": 9 }
  },
  "render": {
    "style": "console",
    "priority": "game",
    "corner_radius": 0.045
  },
  "doc": {
    "hardware": "modern 16:9 handheld/docked display",
    "intent": "Modern system: fullscreen first, optional cosmetic frame only when explicitly enabled.",
    "bios": "Ryujinx needs dumped Switch keys and firmware from the user's console."
  }
