            jsonStrField("joystick", "Left"),
            jsonBoolField("invert_stick_x", false),
            jsonBoolField("invert_stick_y", false),
            jsonStrField("stick_button", "LeftStick")
        ])),
        jsonField("right_joycon_stick", jsonObject([
            jsonStrField("joystick", "Right"),
            jsonBoolField("invert_stick_x", false),
            jsonBoolField("invert_stick_y", false),
            jsonStrField("stick_button", "RightStick")
        ])),
        jsonField("motion", jsonObject([
            jsonField("slot", "0"),
            jsonField("alt_slot", "0"),
            jsonBoolField("mirror_input", false),
            jsonStrField("motion_backend", "CemuHook"),
            jsonField("sensitivity", "100"),
