class SemuEmulatorProfiles {
    class void seed(string project) { seedEmulatorDefaults(project); }
    class KeymapIr keymap(string project) { return projectKeymapIr(project); }
}

string textLines(Vector<string> items) {
    return items.join("\n") + "\n";
}

KeymapIr projectKeymapIr(string project) {
    string source = FileSystem.exists(keymapSourcePath(project)) ? FileSystem.readText(keymapSourcePath(project)) : defaultKeymapSource();
    KeymapErrors errors = KeymapErrors();
    KeymapIr ir = compileKeymap(source, errors);
    if (errors.count() == 0) {
        return ir;
    }
    KeymapErrors fallbackErrors = KeymapErrors();
    return compileKeymap(defaultKeymapSource(), fallbackErrors);
}

string retroArchConfigValue(string key, string value) {
    return key + " = \"" + Strings.replace(value, "\"", "\\\"") + "\"\n";
}

string retroArchShaderDir(string project) {
    string configured = Environment.get("SEMU_RETROARCH_SHADER_DIR", "");
    if (configured.len() > 0 && FileSystem.isDir(configured)) {
        return configured;
    }

    string assetRoot = Environment.get("SEMU_ASSET_ROOT", "");
    string appImageShaders = joinPath(assetRoot, "usr/share/libretro/shaders/shaders_slang");
    if (assetRoot.len() > 0 && FileSystem.isDir(appImageShaders)) {
        return appImageShaders;
    }

    string resultShaders = joinPath(project, "result/share/libretro/shaders/shaders_slang");
    if (FileSystem.isDir(resultShaders)) {
        return resultShaders;
    }
    return "";
}

string retroArchShaderPresetPath(string project) {
    if (!settingsGetValue(project, "visual.crt_shaders").equals("true")
            && !settingsGetValue(project, "visual.bezels").equals("true")) {
        return "";
    }

    string preset = settingsGetValue(project, "visual.retroarch_shader_preset");
    if (preset.len() == 0) {
        return "";
    }
    if (preset.startsWith("/")) {
        return FileSystem.exists(preset) ? preset : "";
    }

    string shaderDir = retroArchShaderDir(project);
    if (shaderDir.len() == 0) {
        return "";
    }
    string path = joinPath(shaderDir, preset);
    return FileSystem.exists(path) ? path : "";
}

string retroArchVisualConfigText(string project) {
    // With our GL frame tap deployed (libsemutap.so, LD_PRELOAD'd by the launcher), RetroArch renders
    // the GAME ONLY at its largest integer scale (centered, core 4:3 aspect); the tap draws the bezel +
    // CRT shader on top of every frame and gates them to gameplay, so RetroArch's own shader/aspect/bezel
    // stay out of the way entirely (it could not fill 16:10 around a 4:3 game anyway). This mirrors the
    // launcher's --set-shader logic (launcherPresetArgsForProject): tap present => raw game, no shader.
    if (launcherTapLib(project).len() > 0) {
        return ""
            + retroArchConfigValue("video_fullscreen", "true")
            + retroArchConfigValue("video_scale_integer", "true")
            + retroArchConfigValue("video_force_aspect", "true")
            + retroArchConfigValue("video_aspect_ratio_auto", "true")
            + retroArchConfigValue("video_shader_enable", "false")
            + retroArchConfigValue("video_vsync", "true");
    }
    // Fallback: no tap .so on this host, so RetroArch's own MegaBezel preset fills the screen.
    string shader = retroArchShaderPresetPath(project);
    string integerScaling = settingsGetValue(project, "visual.integer_scaling").equals("false") ? "false" : "true";
    string config = ""
        + retroArchConfigValue("video_fullscreen", "true")
        + retroArchConfigValue("video_scale_integer", integerScaling)
        + retroArchConfigValue("video_force_aspect", "true")
        + retroArchConfigValue("video_vsync", "true");
    if (shader.len() > 0) {
        config = config
            + retroArchConfigValue("video_shader_enable", "true")
            + retroArchConfigValue("video_shader", shader);
    } else {
        config = config + retroArchConfigValue("video_shader_enable", "false");
    }
    return config;
}

string retroArchProfileText(string project, KeymapIr ir) {
    return textLines([
        "config_save_on_exit = \"true\"",
        "audio_driver = \"pulse\"",
        "input_driver = \"sdl2\"",
        "input_autodetect_enable = \"true\"",
        "input_remap_binds_enable = \"true\"",
        "savestate_directory = \"" + joinPath(contentRoot(project), "states") + "\"",
        "savefile_directory = \"" + joinPath(contentRoot(project), "saves") + "\"",
        "screenshot_directory = \"" + joinPath(contentRoot(project), "screenshots") + "\""
    ]) + retroArchVisualConfigText(project) + renderRetroArchKeymap(ir);
}

Vector<string> dolphinSection(string header, Vector<string> lines) {
    Vector<string> result = [header];
    for line in lines {
        result.push(line);
    }
    return result;
}

