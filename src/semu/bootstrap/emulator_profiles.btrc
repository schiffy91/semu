string azaharConfigTextForDataRoot(string dataRoot) {
    string azaharRoot = joinPath(dataRoot, "azahar-emu");
    return textLines([
        "[Data%20Storage]",
        "nand_directory=" + joinPath(azaharRoot, "nand/"),
        "nand_directory\\default=false",
        "sdmc_directory=" + joinPath(azaharRoot, "sdmc/"),
        "sdmc_directory\\default=false",
        "use_custom_storage=false",
        "use_custom_storage\\default=true",
        "use_virtual_sd=true",
        "use_virtual_sd\\default=true",
        "",
        "[Debugging]",
        "renderer_debug=false",
        "renderer_debug\\default=false",
        "",
        "[Renderer]",
        // Vulkan (2), not OpenGL (1): vkBasalt only hooks the Vulkan swapchain, so the
        // standalone CRT bezel composites only under Vulkan (verified on-Deck: Retro City
        // Rampage renders inside the 3ds bezel with libvkbasalt loaded). Azahar's Vulkan
        // backend works in gamescope.
        "graphics_api=2",
        "graphics_api\\default=false",
        "",
        "[UI]",
        "confirmClose=false",
        "confirmClose\\default=false",
        "firstStart=false",
        "firstStart\\default=false",
        "fullscreen=true",
        "fullscreen\\default=false",
        "saveStateWarning=false",
        "saveStateWarning\\default=false"
    ]);
}

string azaharConfigText(string project) {
    return azaharConfigTextForDataRoot(joinPath(launcherRoutedStateRoot(project, "azahar"), "data"));
}

