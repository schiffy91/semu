    return pcsx2PadBindingsText() + textLines([
        "[Hotkeys]"
    ]) + renderPcsx2Keymap(ir);
}

string pcsx2BiosDir(string project) {
    string external = joinPath(configuredEmulationRoot(project), "PCSX2/config/bios");
    if (FileSystem.isDir(external)) { return external; }
    return joinPath(biosRoot(project), "ps2");
}

