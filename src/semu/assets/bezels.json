{
  "schema_version": 1,
  "doc": {
    "purpose": "Global bezel manifest: the generic fallback table BezelResolver reads, every bezel-art recipe (flatten/recolor/glass over the upstream packs), and the staged vkBasalt pack (bezels-as-ReShade-FX for Vulkan-presenting emulators).",
    "provenance": "Upstream pins, flatten layer stacks, recolor hexes, and slang_wrapper params are migrated verbatim from packaging/nix/visual-assets.nix and packaging/steamdeck/tap/gen-handheld-shells.sh; local sources from config/assets and packaging/steamdeck/tap.",
    "shared_pins": "Upstreams named in both this file and shaders.json must carry identical rev/nar_hash pins; NixPackageContract enforces agreement."
  },
