        jsonField("right_joycon", jsonObject([
            jsonStrField("button_plus", "Start"),
            jsonStrField("button_r", "RightShoulder"),
            jsonStrField("button_zr", "RightTrigger"),
            jsonStrField("button_x", "Y"),
            jsonStrField("button_b", "A"),
            jsonStrField("button_y", "X"),
            jsonStrField("button_a", "B")
        ])),
        jsonField("version", "1"),
        jsonStrField("backend", "GamepadSDL2"),
        jsonStrField("id", "0-f7390003-28de-0000-ff11-000001000000"),
        jsonStrField("controller_type", "ProController"),
        jsonStrField("player_index", "Player1")
    ]) + "\n";
}

void writeProfile(string project, string relative, string text) {
    string target = emulatorProfilePath(project, relative);
    ensureDir(PathTools.dirname(target));
    FileSystem.writeText(target, text);
}

void seedEmulatorDefaults(string project) {
    seedLinuxAssets(project);
    KeymapIr ir = projectKeymapIr(project);
    writeProfile(project, "RetroArch/retroarch.cfg.linux-backup", retroArchProfileText(project, ir));
    writeProfile(project, "RetroArch/retroarch.cfg", retroArchProfileText(project, ir));
    writeProfile(project, "Dolphin/config/Profiles/GCPad/Steam Deck.ini", dolphinGcpadProfileText());
    writeProfile(project, "Dolphin/config/Profiles/Hotkeys/Steam Deck.ini", dolphinHotkeysProfileText(ir));
    writeProfile(project, "Dolphin/config/Profiles/Wiimote/Wiimote (SD).ini", dolphinWiimoteProfileText(false));
    writeProfile(project, "Dolphin/config/Profiles/Wiimote/Wiimote + Classic Controller (SD).ini", dolphinWiimoteProfileText(true));
    writeProfile(project, "Cemu/config/controllerProfiles/SteamInput-P1.xml", cemuProfileText());
    writeProfile(project, "PCSX2/config/inputprofiles/Steam Deck.ini", pcsx2ProfileText(ir));
    writeProfile(project, "Ryujinx/config/profiles/controller/Steam Virtual Controller.json", ryujinxProfileText());
}

void seedKeymapDefaults(string project) {
    ensureDir(keymapsRoot(project));
    string keymapPath = keymapSourcePath(project);
    if (!FileSystem.exists(keymapPath)) {
        FileSystem.writeText(keymapPath, defaultKeymapSource());
    }
}

string syncDefaultConfigText(string project, string romsDir) {
    string roms = romsDir.len() > 0 ? romsDir : "${paths.project_roms}";
    return jsonObject([
        jsonBoolField("enabled", true),
        jsonBoolField("start_at_boot", true),
        jsonBoolField("tray", true),
        jsonStrField("gui_address", "127.0.0.1:8384"),
        jsonStrField("roms_dir", roms),
        jsonBoolField("sync_saves", true),
        jsonBoolField("sync_states", true),
        jsonBoolField("sync_emulator_state", true),
        jsonBoolField("sync_screenshots", true),
        jsonBoolField("sync_gamelists", true),
        jsonBoolField("sync_roms", false),
        jsonBoolField("sync_bios", false),
        jsonField("rescan_saves_s", "900"),
        jsonField("rescan_states_s", "900"),
        jsonField("rescan_emulator_state_s", "900"),
        jsonField("rescan_screenshots_s", "1800"),
        jsonField("rescan_gamelists_s", "1800"),
        jsonField("rescan_roms_s", "3600"),
        jsonField("rescan_bios_s", "3600"),
        jsonBoolField("watch_saves", true),
        jsonBoolField("watch_states", true),
        jsonBoolField("watch_emulator_state", true),
        jsonBoolField("watch_screenshots", true),
        jsonBoolField("watch_gamelists", true),
        jsonBoolField("watch_roms", true),
        jsonBoolField("watch_bios", true)
    ]) + "\n";
}

void writeSyncDefaults(string project, string romsDir) {
    ensureDir(syncRoot(project));
    ensureDir(syncScriptsDir(project));
    ensureDir(syncLogDir(project));
    ensureDir(syncthingConfigDir(project));
    ensureDir(syncthingDataDir(project));
    string path = syncConfigPath(project);
    if (!FileSystem.exists(path)) {
        FileSystem.writeText(path, syncDefaultConfigText(project, romsDir));
        return;
    }
    if (romsDir.len() > 0) {
        JsonObject config = JsonObject.readFile(path);
        config.setString("roms_dir", romsDir);
        config.writeFile(path);
    }
}

void ensureRomDirsAt(string root) {
    ensureDir(root);
    for rom in declaredRomDirs() {
        ensureDir(joinPath(root, rom));
    }
}

string steamInputKeyName(string key) {
    if (key.equals("Ctrl")) { return "LEFT_CONTROL"; }
    if (key.equals("Alt")) { return "LEFT_ALT"; }
    if (key.equals("Shift")) { return "LEFT_SHIFT"; }
    if (key.equals("Meta")) { return "LEFT_GUI"; }
    if (key.equals("Enter")) { return "RETURN"; }
    if (key.equals("Esc")) { return "ESCAPE"; }
    if (key.equals("Tab")) { return "TAB"; }
    if (key.equals("+")) { return "KEYPAD_PLUS"; }
    if (key.equals("-")) { return "KEYPAD_DASH"; }
    return key.toUpper();
}

string steamInputActionLabel(string id) {
    if (id.equals("ui.open")) { return "Open"; }
    if (id.equals("ui.pause")) { return "Pause / Resume"; }
    if (id.equals("ui.screenshot")) { return "Screenshot"; }
    if (id.equals("ui.fullscreen")) { return "Fullscreen"; }
    if (id.equals("ui.menu")) { return "Menu"; }
    if (id.equals("app.quit")) { return "Quit"; }
    if (id.equals("state.prev")) { return "Previous State Slot"; }
    if (id.equals("state.next")) { return "Next State Slot"; }
    if (id.equals("state.load")) { return "Load State"; }
    if (id.equals("state.save")) { return "Save State"; }
    if (id.equals("speed.rewind")) { return "Rewind"; }
    if (id.equals("speed.fast")) { return "Fast Forward"; }
    if (id.equals("screen.swap")) { return "Swap Screens"; }
    if (id.equals("ui.escape")) { return "Escape"; }
    return actionLabel(id);
}

string steamInputKeyBindings(string command, string label) {
    Vector<string> keys = [];
    string modifiers = keymapCommandModifierPart(command);
    if (modifiers.len() > 0) {
        for modifier in Strings.split(modifiers, "+") {
            keys.push(steamInputKeyName(modifier));
        }
    }
    keys.push(steamInputKeyName(keymapCommandKeyPart(command)));

    Vector<string> bindings = [];
    for key in keys {
        bindings.push("\"binding\" \"key_press " + key + ", " + label + ", , \"");
    }
    return bindings.join(" ");
}

string steamInputActionBindings(KeymapIr ir, string actionId) {
    return steamInputKeyBindings(irActionCommand(ir, actionId), steamInputActionLabel(actionId));
}

