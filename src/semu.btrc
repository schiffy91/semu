// semu.btrc — the single transpile entry for the semu CLI.
//
// Build:
//   btrcpy src/semu.btrc -o /tmp/semu.c --strict-imports --no-stdlib
//   gcc /tmp/semu.c -std=c11 -o /tmp/semu -lm
//
// Every module declares its own minimal imports; this entry only wires the
// command surface.

import std.{cli}
import ./semu/cli.btrc

int main(int argc, char** argv) {
    CliArgs arguments = CliArgs(argc, argv);
    return SemuCli.run(arguments, SemuCli.projectRoot(arguments));
}
