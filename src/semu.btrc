string systemEntries() {
    SystemCatalog catalog = systemCatalog();
    return catalog.systemsJson();
}

string buildJson() {
    return jsonObject([
        jsonField("schema_version", "1"),
        jsonField("paths", manifestPaths()),
        jsonField("es_de", esDe()),
        jsonField("input", inputStack()),
        jsonField("controller_profiles", controllerProfiles()),
        jsonField("keymaps", keymapsJson()),
        jsonField("screenshot_verification", screenshotVerificationProfile()),
        jsonField("sync", syncProfile()),
        jsonField("bios", biosEntries()),
        jsonField("launchers", launcherEntries()),
        jsonField("systems", systemEntries())
    ]);
}

string joinPath(string left, string right) {
    return PathTools.join(left, right);
}

string contentRoot(string project) {
    return joinPath(project, "ES-DE/ES-DE");
}

string romsRoot(string project) {
    return joinPath(contentRoot(project), "ROMs");
}

string syncRoot(string project) {
    return joinPath(project, "sync");
}

string syncConfigPath(string project) {
    return joinPath(syncRoot(project), "sync.json");
}

string syncthingHome(string project) {
    return joinPath(syncRoot(project), "syncthing");
}

string syncthingConfigDir(string project) {
    return joinPath(syncthingHome(project), "config");
}

string syncthingDataDir(string project) {
    return joinPath(syncthingHome(project), "data");
}

string syncScriptsDir(string project) {
    return joinPath(syncRoot(project), "bin");
}

string syncLogDir(string project) {
    return joinPath(syncRoot(project), "logs");
}

string biosRoot(string project) {
    return joinPath(contentRoot(project), "bios");
}

string customSystemsRoot(string project) {
    return joinPath(project, "ES-DE/custom_systems");
}

string esDeProfileCustomSystemsRoot(string project) {
    return joinPath(project, "emulators/es-de/custom_systems");
}

string emulatorProfilesRoot(string project) {
    return joinPath(project, "emulators/profiles");
}

string emulatorProfilePath(string project, string relative) {
    return joinPath(emulatorProfilesRoot(project), relative);
}

string linuxPackagingRoot(string project) {
    return joinPath(project, "packaging/linux");
}

string linuxLauncherBin(string project) {
    return joinPath(linuxPackagingRoot(project), "bin");
}

string keymapsRoot(string project) {
    return joinPath(project, "input/keymaps");
}

string keymapSourcePath(string project) {
    return joinPath(keymapsRoot(project), "steam_deck.skm");
}

string homeDir() {
    return Environment.get("SEMU_HOME", Environment.get("HOME", "."));
}

string systemdUserDir() {
    return joinPath(homeDir(), ".config/systemd/user");
}

string applicationsDir() {
    return joinPath(homeDir(), ".local/share/applications");
}

string expandProjectTemplate(string project, string value) {
    string result = Strings.replace(value, "${project}", project);
    result = Strings.replace(result, "${paths.project_roms}", romsRoot(project));
    result = Strings.replace(result, "${paths.project_bios}", biosRoot(project));
    result = Strings.replace(result, "${paths.project_saves}", joinPath(contentRoot(project), "saves"));
    result = Strings.replace(result, "${paths.project_states}", joinPath(contentRoot(project), "states"));
    result = Strings.replace(result, "${paths.project_screenshots}", joinPath(contentRoot(project), "screenshots"));
    result = Strings.replace(result, "${paths.project_gamelists}", joinPath(contentRoot(project), "gamelists"));
    return result;
}

JsonObject syncConfig(string project) {
    string path = syncConfigPath(project);
    if (!FileSystem.exists(path)) {
        return JsonObject.parse("{}");
    }
    return JsonObject.readFile(path);
}

string syncString(string project, string key, string fallback) {
    JsonObject config = syncConfig(project);
    return expandProjectTemplate(project, config.getString(key, fallback));
}

bool syncBool(string project, string key, bool fallback) {
    JsonObject config = syncConfig(project);
    return config.getBool(key, fallback);
}

int syncInt(string project, string key, int fallback) {
    JsonObject config = syncConfig(project);
    return config.getInt(key, fallback);
}

string configuredRomsRoot(string project) {
    return syncString(project, "roms_dir", "${paths.project_roms}");
}

Vector<string> declaredSystemIds() {
    SystemCatalog catalog = systemCatalog();
    return catalog.ids;
}

Vector<string> declaredRomDirs() {
    SystemCatalog catalog = systemCatalog();
    return catalog.romDirs;
}

Vector<string> controllerProfileFiles() {
    return [
        "emulators/profiles/RetroArch/retroarch.cfg.linux-backup",
        "emulators/profiles/Dolphin/config/Profiles/GCPad/Steam Deck.ini",
        "emulators/profiles/Dolphin/config/Profiles/Hotkeys/Steam Deck.ini",
        "emulators/profiles/Dolphin/config/Profiles/Wiimote/Wiimote (SD).ini",
        "emulators/profiles/Dolphin/config/Profiles/Wiimote/Wiimote + Classic Controller (SD).ini",
        "emulators/profiles/Cemu/config/controllerProfiles/SteamInput-P1.xml",
        "emulators/profiles/PCSX2/config/inputprofiles/Steam Deck.ini",
        "emulators/profiles/Ryujinx/config/profiles/controller/Steam Virtual Controller.json"
    ];
}

string esSettingsXmlWithPaths(string roms, string media, string themes) {
    return "<?xml version=\"1.0\"?>\n"
        + "<string name=\"ROMDirectory\" value=\"" + roms + "\" />\n"
        + "<string name=\"MediaDirectory\" value=\"" + media + "\" />\n"
        + "<string name=\"UserThemeDirectory\" value=\"" + themes + "\" />\n"
        + "<string name=\"SaveGamelistsMode\" value=\"always\" />\n"
        + "<string name=\"CreatePlaceholderSystemDirectories\" value=\"false\" />\n"
        + "<string name=\"InputControllerType\" value=\"xbox\" />\n"
        + "<string name=\"Theme\" value=\"slate-es-de\" />\n";
}

string esSettingsXmlForProject(string project) {
    return esSettingsXmlWithPaths(
        configuredRomsRoot(project),
        joinPath(contentRoot(project), "downloaded_media"),
        joinPath(contentRoot(project), "themes")
    );
}

void ensureDir(string path) {
    FileSystem.mkdirp(path);
}

string stripTrailingSlashes(string path) {
    string result = path;
    while (result.len() > 1 && result.charAt(result.len() - 1) == '/') {
        result = result.substring(0, result.len() - 1);
    }
    return result;
}

string sandboxResolveTarget(string scratch, string target) {
    string resolved = Strings.replace(target, "${host}", "$HOME/.config");
    resolved = Strings.replace(resolved, "${portable}", "$HOME/ES-DE");
    if (resolved.startsWith("~/")) {
        resolved = "$HOME/" + Strings.removePrefix(resolved, "~/");
    }
    resolved = stripTrailingSlashes(resolved);
    if (resolved.startsWith("$HOME/")) {
        return joinPath(scratch, Strings.removePrefix(resolved, "$HOME/"));
    }
    return resolved;
}

string sandboxProjectEmulatorDir(string project, string emulator) {
    string wanted = emulator.toLower();
    for name in FileSystem.listDir(project) {
        string candidate = joinPath(project, name);
        if (FileSystem.isDir(candidate) && name.toLower().equals(wanted)) {
            return candidate;
        }
    }
    string profileRoot = emulatorProfilesRoot(project);
    for name in FileSystem.listDir(profileRoot) {
        string candidate = joinPath(profileRoot, name);
        if (FileSystem.isDir(candidate) && name.toLower().equals(wanted)) {
            return candidate;
        }
    }
    return "";
}

void sandboxSymlink(string linkPath, string sourcePath) {
    ensureDir(PathTools.dirname(linkPath));
    FileSystem.removeRecursive(linkPath);
    FileSystem.symlink(sourcePath, linkPath);
}

void sandboxApplyLink(string emuDir, string scratch, string entry, string linuxTarget) {
    string source = joinPath(emuDir, entry);
    if (!FileSystem.exists(source)) {
        return;
    }
    string destDir = sandboxResolveTarget(scratch, linuxTarget);
    if (FileSystem.isDir(source)) {
        ensureDir(destDir);
        for child in FileSystem.listDir(source) {
            sandboxSymlink(joinPath(destDir, child), joinPath(source, child));
        }
        return;
    }
    sandboxSymlink(joinPath(destDir, PathTools.basename(source)), source);
}

bool sandboxApplyKnownLinks(string key, string emuDir, string scratch) {
    if (key.equals("azahar")) {
        sandboxApplyLink(emuDir, scratch, "data", "~/.local/share/azahar-emu/");
        return true;
    }
    if (key.equals("cemu")) {
        sandboxApplyLink(emuDir, scratch, "config", "~/.config/Cemu/");
        sandboxApplyLink(emuDir, scratch, "data", "~/.local/share/Cemu/");
        return true;
    }
    if (key.equals("dolphin")) {
        sandboxApplyLink(emuDir, scratch, "config", "~/.config/dolphin-emu/");
        sandboxApplyLink(emuDir, scratch, "data", "~/.local/share/dolphin-emu/");
        return true;
    }
    if (key.equals("es-de")) {
        sandboxApplyLink(emuDir, scratch, "ES-DE", "${portable}/");
        sandboxApplyLink(emuDir, scratch, "es_settings.xml", "${portable}/settings/");
        sandboxApplyLink(emuDir, scratch, "custom_systems", "${portable}/custom_systems/");
        return true;
    }
    if (key.equals("lime3ds")) {
        sandboxApplyLink(emuDir, scratch, "data", "${host}/lime3ds-emu/");
        return true;
    }
    if (key.equals("pcsx2")) {
        sandboxApplyLink(emuDir, scratch, "config", "${host}/PCSX2/");
        return true;
    }
    if (key.equals("retroarch")) {
        sandboxApplyLink(emuDir, scratch, "config", "${host}/retroarch/");
        sandboxApplyLink(emuDir, scratch, "retroarch.cfg", "${host}/retroarch/");
        return true;
    }
    if (key.equals("ryujinx")) {
        sandboxApplyLink(emuDir, scratch, "config", "~/.config/Ryujinx/");
        return true;
    }
    return false;
}

string currentUid() {
    return Strings.fromInt(Platform.euid());
}

string launchRomsRoot(string project) {
    return Environment.get("SEMU_ROMS_DIR", configuredRomsRoot(project));
}

string xdgRunDir() {
    return Environment.get("XDG_RUNTIME_DIR", "/run/user/" + currentUid());
}

Vector<string> cliTail(CliArgs args, int start) {
    Vector<string> out = [];
    for (int i = start; i < args.count(); i++) {
        string value = args.get(i);
        if (value.equals("--project")) {
            i++;
        } else if (!value.equals("--")) {
            out.push(value);
        }
    }
    return out;
}

Vector<string> vectorTail(Vector<string> values, int start) {
    Vector<string> out = [];
    for (int i = start; i < values.len; i++) {
        out.push(values.get(i));
    }
    return out;
}

Vector<string> launcherPassthroughArgs(CliArgs args) {
    Vector<string> out = [];
    bool skipNext = false;
    for (int i = 0; i < args.count(); i++) {
        string value = args.get(i);
        if (skipNext) {
            skipNext = false;
        } else if (value.equals("--project")) {
            skipNext = true;
        } else {
            out.push(value);
        }
    }
    return out;
}

string shellAppend(string command, string arg) {
    if (command.len() == 0) {
        return ShellWords.quote(arg);
    }
    return command + " " + ShellWords.quote(arg);
}

string shellAppendAll(string command, Vector<string> args) {
    string out = command;
    for arg in args {
        out = shellAppend(out, arg);
    }
    return out;
}

int sandboxLaunch(string project, string emulator, string executable, Vector<string> emulatorArgs) {
    if (emulator.len() == 0 || executable.len() == 0) {
        print("error 0:0 sandbox launch needs EMULATOR EXECUTABLE [ARGS...]");
        return 1;
    }
    if (!FileSystem.isDir(project)) {
        print("sandbox: project dir '" + project + "' missing");
        return 2;
    }
    string scratch = joinPath(homeDir(), ".local/share/semu/scratch/" + emulator);
    FileSystem.removeRecursive(scratch);
    ensureDir(scratch);
    string emuDir = sandboxProjectEmulatorDir(project, emulator);
    if (emuDir.len() == 0) {
        print(f"sandbox: no emulator directory for '{emulator}' under {project}");
        return 3;
    }
    if (!sandboxApplyKnownLinks(emulator.toLower(), emuDir, scratch)) {
        print(f"sandbox: no BTRC symlink spec for '{emulator}'");
        return 3;
    }

    string home = homeDir();
    string runDir = xdgRunDir();
    string shareNet = Environment.get("SEMU_SHARE_NET", "1");
    string command = ShellWords.quote(Environment.get("SEMU_BWRAP", "bwrap"));
    Vector<string> bwrapArgs = [
        "--ro-bind", "/usr", "/usr",
        "--ro-bind", "/etc", "/etc",
        "--ro-bind", "/opt", "/opt",
        "--ro-bind", "/var", "/var",
        "--ro-bind-try", "/lib", "/lib",
        "--ro-bind-try", "/lib64", "/lib64",
        "--ro-bind-try", "/bin", "/bin",
        "--ro-bind-try", "/sbin", "/sbin",
        "--proc", "/proc",
        "--dev", "/dev",
        "--dev-bind", "/dev/dri", "/dev/dri",
        "--dev-bind-try", "/dev/snd", "/dev/snd",
        "--dev-bind-try", "/dev/input", "/dev/input",
        "--dev-bind-try", "/dev/uinput", "/dev/uinput",
        "--ro-bind", "/sys", "/sys",
        "--bind", scratch, home,
        "--tmpfs", "/tmp",
        "--bind", project, project,
        "--ro-bind-try", launchRomsRoot(project), launchRomsRoot(project),
        "--bind", runDir, runDir,
        "--ro-bind-try", "/tmp/.X11-unix", "/tmp/.X11-unix",
        "--unshare-pid",
        "--unshare-uts",
        "--unshare-ipc",
        "--die-with-parent",
        "--new-session",
        "--setenv", "HOME", home,
        "--setenv", "XDG_RUNTIME_DIR", runDir,
        "--setenv", "XDG_DATA_HOME", joinPath(home, ".local/share"),
        "--setenv", "XDG_CONFIG_HOME", joinPath(home, ".config"),
        "--setenv", "XDG_CACHE_HOME", joinPath(home, ".cache"),
        "--setenv", "XDG_SESSION_TYPE", Environment.get("XDG_SESSION_TYPE", "wayland"),
        "--setenv", "WAYLAND_DISPLAY", Environment.get("WAYLAND_DISPLAY", "wayland-0"),
        "--setenv", "DBUS_SESSION_BUS_ADDRESS", Environment.get("DBUS_SESSION_BUS_ADDRESS", "unix:path=" + runDir + "/bus"),
        "--setenv", "QT_QPA_PLATFORM", Environment.get("QT_QPA_PLATFORM", "wayland;xcb"),
        "--setenv", "SDL_VIDEODRIVER", Environment.get("SDL_VIDEODRIVER", "wayland")
    ];
    if (Environment.has("DISPLAY")) {
        bwrapArgs.push("--setenv");
        bwrapArgs.push("DISPLAY");
        bwrapArgs.push(Environment.get("DISPLAY", ""));
        if (Environment.has("XAUTHORITY")) {
            bwrapArgs.push("--setenv");
            bwrapArgs.push("XAUTHORITY");
            bwrapArgs.push(Environment.get("XAUTHORITY", ""));
        }
    } else {
        bwrapArgs.push("--unsetenv");
        bwrapArgs.push("DISPLAY");
        bwrapArgs.push("--unsetenv");
        bwrapArgs.push("XAUTHORITY");
    }
    if (shareNet.equals("1")) {
        bwrapArgs.push("--share-net");
    } else {
        bwrapArgs.push("--unshare-net");
    }
    bwrapArgs.push("--unsetenv");
    bwrapArgs.push("LIBGL_ALWAYS_SOFTWARE");
    bwrapArgs.push("--unsetenv");
    bwrapArgs.push("MESA_LOADER_DRIVER_OVERRIDE");
    bwrapArgs.push("--unsetenv");
    bwrapArgs.push("VK_ICD_FILENAMES");
    bwrapArgs.push("--");
    bwrapArgs.push(executable);
    for arg in emulatorArgs {
        bwrapArgs.push(arg);
    }
    command = shellAppendAll(command, bwrapArgs);
    if (Environment.get("SEMU_DEBUG", "0").equals("1")) {
        print(command);
    }
    UnixShell shell = UnixShell();
    screenshotCaptureHook(project, emulator, "before_launch");
    screenshotScheduleHook(project, emulator, "after_spawn");
    ExecResult result = shell.runRaw(command, false, false, "");
    screenshotCaptureHook(project, emulator, "after_exit");
    return result.code;
}

int sandboxPrepareCommand(CliArgs args, string project) {
    string emulator = args.valueAfter("--emulator", "");
    string scratch = args.valueAfter("--scratch", "");
    if (emulator.len() == 0 || scratch.len() == 0) {
        print("error 0:0 sandbox prepare needs --emulator NAME --scratch PATH");
        return 1;
    }
    string emuDir = sandboxProjectEmulatorDir(project, emulator);
    if (emuDir.len() == 0) {
        print(f"sandbox: no emulator directory for '{emulator}' under {project}");
        return 3;
    }
    ensureDir(scratch);
    bool ok = sandboxApplyKnownLinks(emulator.toLower(), emuDir, scratch);
    if (!ok) {
        print(f"sandbox: no BTRC symlink spec for '{emulator}'");
        return 3;
    }
    return 0;
}

int sandboxCommand(CliArgs args, string project) {
    string mode = "prepare";
    if (args.count() > 1 && !args.get(1).startsWith("--")) {
        mode = args.get(1);
    }
    if (mode.equals("prepare")) {
        return sandboxPrepareCommand(args, project);
    }
    if (mode.equals("launch")) {
        if (args.count() < 4) {
            print("error 0:0 sandbox launch needs EMULATOR EXECUTABLE [ARGS...]");
            return 1;
        }
        return sandboxLaunch(project, args.get(2), args.get(3), cliTail(args, 4));
    }
    printUsage();
    return 1;
}

string launcherFlatpakId(string emulator) {
    string key = emulator.toLower();
    if (key.equals("azahar")) { return "org.azahar_emu.Azahar"; }
    if (key.equals("cemu")) { return "info.cemu.Cemu"; }
    if (key.equals("dolphin")) { return "org.DolphinEmu.dolphin-emu"; }
    if (key.equals("flycast")) { return "org.flycast.Flycast"; }
    if (key.equals("gopher64")) { return "io.github.gopher64.gopher64"; }
    if (key.equals("melonds")) { return "net.kuribo64.melonDS"; }
    if (key.equals("pcsx2")) { return "net.pcsx2.PCSX2"; }
    if (key.equals("ppsspp")) { return "org.ppsspp.PPSSPP"; }
    if (key.equals("ryujinx")) { return "org.ryujinx.Ryujinx"; }
    return "";
}

bool launcherUsesX11(string emulator) {
    string key = emulator.toLower();
    string forceX11 = Environment.get("SEMU_FLATPAK_X11", Environment.get("SEMU_FLATPAK_X11", "0"));
    return key.equals("azahar") || key.equals("dolphin") || forceX11.equals("1");
}

Vector<string> launcherPresetArgs(string emulator) {
    string key = emulator.toLower();
    if (key.equals("dolphin")) {
        return ["-b", "-e"];
    }
    Vector<string> empty = [];
    return empty;
}

string launcherFlatpakStateRoot(string project, string emulator) {
    return joinPath(joinPath(project, ".semu/flatpak-state"), emulator.toLower());
}

string launcherRoutedStateRoot(string project, string emulator) {
    return joinPath(joinPath(project, ".semu/appimage-state"), emulator.toLower());
}

void launcherCopyDirContents(string source, string destination) {
    if (!FileSystem.isDir(source)) {
        return;
    }
    ensureDir(destination);
    UnixShell shell = UnixShell();
    shell.runRaw("cp -a " + ShellWords.quote(joinPath(source, ".")) + " " + ShellWords.quote(destination) + " 2>/dev/null || true", false, false, "");
}

void launcherCopyFile(string source, string destination) {
    if (!FileSystem.isFile(source)) {
        return;
    }
    ensureDir(PathTools.dirname(destination));
    FileSystem.writeText(destination, FileSystem.readText(source));
}

void launcherCopyProfileDir(string project, string relative, string destination) {
    launcherCopyDirContents(joinPath(project, relative), destination);
    launcherCopyDirContents(emulatorProfilePath(project, relative), destination);
}

void launcherCopyProfileFile(string project, string relative, string destination) {
    launcherCopyFile(joinPath(project, relative), destination);
    launcherCopyFile(emulatorProfilePath(project, relative), destination);
}

void launcherSeedRoutedState(string project, string emulator, string configRoot, string dataRoot) {
    string key = emulator.toLower();
    if (key.equals("retroarch")) {
        launcherCopyProfileDir(project, "RetroArch/config", joinPath(configRoot, "retroarch"));
        launcherCopyProfileFile(project, "RetroArch/retroarch.cfg", joinPath(configRoot, "retroarch/retroarch.cfg"));
        return;
    }
    if (key.equals("dolphin")) {
        launcherCopyProfileDir(project, "Dolphin/config", joinPath(configRoot, "dolphin-emu"));
        launcherCopyProfileDir(project, "Dolphin/data", joinPath(dataRoot, "dolphin-emu"));
        return;
    }
    if (key.equals("pcsx2")) {
        launcherCopyProfileDir(project, "PCSX2/config", joinPath(configRoot, "PCSX2"));
        return;
    }
    if (key.equals("cemu")) {
        launcherCopyProfileDir(project, "Cemu/config", joinPath(configRoot, "Cemu"));
        launcherCopyProfileDir(project, "Cemu/data", joinPath(dataRoot, "Cemu"));
        return;
    }
    if (key.equals("azahar")) {
        launcherCopyProfileDir(project, "Azahar/data", joinPath(dataRoot, "azahar-emu"));
        return;
    }
    if (key.equals("ppsspp")) {
        launcherCopyProfileDir(project, "PPSSPP/config", joinPath(configRoot, "ppsspp"));
        launcherCopyProfileDir(project, "PPSSPP/data", joinPath(dataRoot, "ppsspp"));
        return;
    }
    if (key.equals("flycast")) {
        launcherCopyProfileDir(project, "Flycast/config", joinPath(configRoot, "flycast"));
        launcherCopyProfileDir(project, "Flycast/data", joinPath(dataRoot, "flycast"));
        return;
    }
    if (key.equals("gopher64")) {
        launcherCopyProfileDir(project, "Gopher64/config", joinPath(configRoot, "gopher64"));
        return;
    }
    if (key.equals("melonds")) {
        launcherCopyProfileDir(project, "melonDS/config", joinPath(configRoot, "melonDS"));
        launcherCopyProfileDir(project, "melonDS/data", joinPath(dataRoot, "melonDS"));
        return;
    }
    if (key.equals("ryujinx")) {
        launcherCopyProfileDir(project, "Ryujinx/config", joinPath(configRoot, "Ryujinx"));
        return;
    }
}

int launcherRunRouted(string project, string emulator, string executable, Vector<string> emulatorArgs) {
    if (!FileSystem.isDir(project)) {
        print("launcher: project dir '" + project + "' missing");
        return 2;
    }
    string stateRoot = launcherRoutedStateRoot(project, emulator);
    string home = joinPath(stateRoot, "home");
    string configRoot = joinPath(stateRoot, "config");
    string dataRoot = joinPath(stateRoot, "data");
    string cacheRoot = joinPath(stateRoot, "cache");
    ensureDir(home);
    ensureDir(configRoot);
    ensureDir(dataRoot);
    ensureDir(cacheRoot);
    launcherSeedRoutedState(project, emulator, configRoot, dataRoot);

    Vector<string> finalArgs = [];
    if (emulator.toLower().equals("retroarch")) {
        string retroarchConfig = joinPath(configRoot, "retroarch/retroarch.cfg");
        if (FileSystem.exists(retroarchConfig)) {
            finalArgs.push("--config");
            finalArgs.push(retroarchConfig);
        }
    }
    for arg in emulatorArgs {
        finalArgs.push(arg);
    }

    string roms = launchRomsRoot(project);
    string command = "SEMU_PROJECT_DIR=" + ShellWords.quote(project)
        + " SEMU_ROMS_DIR=" + ShellWords.quote(roms)
        + " HOME=" + ShellWords.quote(home)
        + " XDG_CONFIG_HOME=" + ShellWords.quote(configRoot)
        + " XDG_DATA_HOME=" + ShellWords.quote(dataRoot)
        + " XDG_CACHE_HOME=" + ShellWords.quote(cacheRoot)
        + " " + ShellWords.quote(executable);
    command = shellAppendAll(command, finalArgs);
    UnixShell shell = UnixShell();
    screenshotCaptureHook(project, emulator, "before_launch");
    screenshotScheduleHook(project, emulator, "after_spawn");
    ExecResult result = shell.runRaw(command, false, false, "");
    screenshotCaptureHook(project, emulator, "after_exit");
    return result.code;
}

int launcherRunFlatpak(string project, string emulator, string flatpakId, Vector<string> emulatorArgs) {
    if (!FileSystem.isDir(project)) {
        print("launcher: project dir '" + project + "' missing");
        return 2;
    }
    string roms = launchRomsRoot(project);
    string stateRoot = launcherFlatpakStateRoot(project, emulator);
    string uid = currentUid();
    ensureDir(joinPath(stateRoot, "config"));
    ensureDir(joinPath(stateRoot, "data"));
    ensureDir(joinPath(stateRoot, "cache"));
    string command = "unset VK_ICD_FILENAMES LIBGL_ALWAYS_SOFTWARE; ";
    if (launcherUsesX11(emulator)) {
        command = command + "unset MESA_LOADER_DRIVER_OVERRIDE MESA_GL_VERSION_OVERRIDE MESA_GLSL_VERSION_OVERRIDE; "
            + "if [ -z \"${DISPLAY:-}\" ] || [ -z \"${XAUTHORITY:-}\" ]; then "
            + "p=$(pgrep -x plasmashell | head -1 || pgrep -x kwin_wayland | head -1 || true); "
            + "if [ -n \"$p\" ] && [ -r \"/proc/$p/environ\" ]; then "
            + "eval \"$(tr '\\0' '\\n' < /proc/$p/environ | grep -E '^(DISPLAY|XAUTHORITY)=' | sed 's/^/export /')\"; "
            + "fi; fi; "
            + "if [ -z \"${XAUTHORITY:-}\" ]; then for f in /run/user/" + uid + "/xauth_*; do [ -r \"$f\" ] && export XAUTHORITY=\"$f\" && break; done; fi; "
            + "export DISPLAY=\"${DISPLAY:-:1}\"; ";
    }
    command = command + "flatpak run";
    Vector<string> flatpakArgs = [
        "--filesystem=" + project,
        "--filesystem=" + roms,
        "--filesystem=" + stateRoot + ":create",
        "--env=XDG_CONFIG_HOME=" + joinPath(stateRoot, "config"),
        "--env=XDG_DATA_HOME=" + joinPath(stateRoot, "data"),
        "--env=XDG_CACHE_HOME=" + joinPath(stateRoot, "cache")
    ];
    if (launcherUsesX11(emulator)) {
        flatpakArgs.push("--socket=x11");
    } else {
        flatpakArgs.push("--socket=wayland");
        flatpakArgs.push("--env=QT_QPA_PLATFORM=wayland");
        flatpakArgs.push("--env=SDL_VIDEODRIVER=wayland");
        flatpakArgs.push("--env=GDK_BACKEND=wayland");
        flatpakArgs.push("--env=XDG_SESSION_TYPE=wayland");
        flatpakArgs.push("--env=WAYLAND_DISPLAY=" + Environment.get("WAYLAND_DISPLAY", "wayland-0"));
        flatpakArgs.push("--env=DISPLAY=");
        flatpakArgs.push("--env=XAUTHORITY=");
    }
    flatpakArgs.push(flatpakId);
    for arg in launcherPresetArgs(emulator) {
        flatpakArgs.push(arg);
    }
    for arg in emulatorArgs {
        flatpakArgs.push(arg);
    }
    command = shellAppendAll(command, flatpakArgs);
    UnixShell shell = UnixShell();
    screenshotCaptureHook(project, emulator, "before_launch");
    screenshotScheduleHook(project, emulator, "after_spawn");
    ExecResult result = shell.runRaw(command, false, false, "");
    screenshotCaptureHook(project, emulator, "after_exit");
    return result.code;
}

int launcherRunEmulator(string project, string emulator, Vector<string> emulatorArgs) {
    if (emulator.equals("flatpak")) {
        if (emulatorArgs.len == 0) {
            print("error 0:0 launcher flatpak needs FLATPAK_ID [ARGS...]");
            return 1;
        }
        return launcherRunFlatpak(project, "flatpak", emulatorArgs.get(0), vectorTail(emulatorArgs, 1));
    }
    if (emulator.toLower().equals("retroarch")) {
        return sandboxLaunch(project, "retroarch", "/usr/bin/retroarch", emulatorArgs);
    }
    string flatpakId = launcherFlatpakId(emulator);
    if (flatpakId.len() == 0) {
        print("error 0:0 unknown launcher emulator '" + emulator + "'");
        return 1;
    }
    return launcherRunFlatpak(project, emulator, flatpakId, emulatorArgs);
}

int launcherCommand(CliArgs args, string project) {
    if (args.count() < 2) {
        print("error 0:0 launcher needs EMULATOR [ARGS...]");
        return 1;
    }
    string emulator = args.get(1);
    if (emulator.equals("routed")) {
        if (args.count() < 4) {
            print("error 0:0 launcher routed needs EMULATOR EXECUTABLE [ARGS...]");
            return 1;
        }
        return launcherRunRouted(project, args.get(2), args.get(3), cliTail(args, 4));
    }
    return launcherRunEmulator(project, emulator, cliTail(args, 2));
}

void writeGeneratedManifest(string output) {
    FileSystem.writeText(output, buildJson() + "\n");
}

string assetRoot(string project) {
    string configured = Environment.get("SEMU_ASSET_ROOT", "");
    if (configured.len() > 0 && FileSystem.exists(joinPath(configured, "packaging/linux/bin/semu-retroarch"))) {
        return configured;
    }
    if (FileSystem.exists("packaging/linux/bin/semu-retroarch")) {
        return ".";
    }
    if (FileSystem.exists(joinPath(project, "packaging/linux/bin/semu-retroarch"))) {
        return project;
    }
    return project;
}

void seedBundledFileFromRoot(string root, string project, string relative, bool executable) {
    string source = joinPath(root, relative);
    string target = joinPath(project, relative);
    if (source.equals(target)) {
        return;
    }
    if (!FileSystem.isFile(source)) {
        return;
    }
    ensureDir(PathTools.dirname(target));
    FileSystem.writeText(target, FileSystem.readText(source));
    if (executable) {
        FileSystem.chmod(target, 493);
    }
}

void seedBundledFile(string project, string relative, bool executable) {
    seedBundledFileFromRoot(assetRoot(project), project, relative, executable);
}

void seedBundledDirFiles(string project, string relative, bool executable) {
    string root = assetRoot(project);
    string sourceDir = joinPath(root, relative);
    if (!FileSystem.isDir(sourceDir)) {
        return;
    }
    ensureDir(joinPath(project, relative));
    for name in FileSystem.listDir(sourceDir) {
        string source = joinPath(sourceDir, name);
        if (FileSystem.isFile(source)) {
            seedBundledFileFromRoot(root, project, joinPath(relative, name), executable);
        }
    }
}

void seedLinuxAssets(string project) {
    seedBundledFile(project, "packaging/linux/AppRun", true);
    seedBundledFile(project, "packaging/linux/sandbox.sh", true);
    seedBundledFile(project, "packaging/linux/semu.desktop", false);
    seedBundledFile(project, "packaging/linux/ES-DE/es_systems_linux.xml", false);
    seedBundledFile(project, "packaging/linux/ES-DE/es_find_rules_linux.xml", false);
    seedBundledDirFiles(project, "packaging/linux/bin", true);
}

string textLines(Vector<string> items) {
    return items.join("\n") + "\n";
}

KeymapIr projectKeymapIr(string project) {
    string source = FileSystem.exists(keymapSourcePath(project)) ? FileSystem.readText(keymapSourcePath(project)) : defaultKeymapSource();
    KeymapErrors errors = KeymapErrors();
    KeymapIr ir = compileKeymap(source, errors);
    if (errors.count() == 0) {
        return ir;
    }
    KeymapErrors fallbackErrors = KeymapErrors();
    return compileKeymap(defaultKeymapSource(), fallbackErrors);
}

