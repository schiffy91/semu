Vector<string> linuxLauncherNames() {
    return [
        "RETROARCH",
        "DOLPHIN",
        "PPSSPP",
        "FLYCAST",
        "AZAHAR",
        "GOPHER64",
        "MELONDS",
        "PCSX2",
        "CEMU",
        "RYUJINX"
    ];
}

Vector<string> lowercaseValues(Vector<string> values) {
    Vector<string> out = [];
    for value in values {
        out.push(value.toLower());
    }
    return out;
}

string semuLauncherName(string emulator) {
    return "semu-" + emulator.toLower();
}

Vector<string> retroarchCoreSearchPaths() {
    return [
        "/usr/lib/x86_64-linux-gnu/libretro",
        "/usr/lib/aarch64-linux-gnu/libretro",
        "/usr/lib/libretro"
    ];
}

string launcherEntries() {
    Vector<string> linuxEmulatorFields = [];
    for emulator in linuxLauncherNames() {
        linuxEmulatorFields.push(jsonStrField(emulator, "${project}/packaging/linux/bin/" + semuLauncherName(emulator)));
    }
    string linux = jsonObject([
        jsonField("emulators", jsonObject(linuxEmulatorFields)),
        jsonField("cores", jsonObject([
            jsonField("RETROARCH", jsonStringArray(retroarchCoreSearchPaths()))
        ])),
        jsonField("flatpaks", jsonObject([
            jsonStrField("org.DolphinEmu.dolphin-emu", "GameCube/Wii"),
            jsonStrField("org.ppsspp.PPSSPP", "PSP"),
            jsonStrField("org.flycast.Flycast", "Dreamcast"),
            jsonStrField("org.azahar_emu.Azahar", "Nintendo 3DS"),
            jsonStrField("io.github.gopher64.gopher64", "Nintendo 64"),
            jsonStrField("net.kuribo64.melonDS", "Nintendo DS"),
            jsonStrField("net.pcsx2.PCSX2", "PlayStation 2"),
            jsonStrField("info.cemu.Cemu", "Wii U"),
            jsonStrField("org.ryujinx.Ryujinx", "Nintendo Switch")
        ]))
    ]);
    string macos = jsonObject([
        jsonField("emulators", jsonObject([
            jsonStrField("RETROARCH", "${project}/result/bin/retroarch"),
            jsonStrField("AZAHAR", "${project}/result/Applications/azahar.app/Contents/MacOS/azahar"),
            jsonStrField("DOLPHIN", "${project}/result/Applications/Dolphin.app/Contents/MacOS/Dolphin"),
            jsonStrField("PCSX2", "${project}/result/Applications/PCSX2.app/Contents/MacOS/PCSX2"),
            jsonStrField("CEMU", "${project}/result/Applications/Cemu.app/Contents/MacOS/Cemu"),
            jsonStrField("RYUJINX", "~/.local/share/ryujinx-app/Ryujinx.app/Contents/MacOS/Ryujinx"),
            jsonStrField("ARES", "${project}/result/Applications/ares.app/Contents/MacOS/ares")
        ])),
        jsonField("cores", jsonObject([
            jsonField("RETROARCH", jsonStringArray(["${project}/result/cores"]))
        ]))
    ]);
    return jsonObject([
        jsonField("linux", linux),
        jsonField("macos", macos)
    ]);
}

string xmlEscape(string value) {
    string result = Strings.replace(value, "&", "&amp;");
    result = Strings.replace(result, "\"", "&quot;");
    result = Strings.replace(result, "<", "&lt;");
    result = Strings.replace(result, ">", "&gt;");
    return result;
}

string esExtensionList(Vector<string> extensions) {
    Vector<string> values = [];
    for extension in extensions {
        values.push(extension);
        values.push(extension.toUpper());
    }
    return values.join(" ");
}

string esCommandXml(string commandJson) {
    JsonObject command = JsonObject.parse(commandJson);
    return "    <command label=\"" + xmlEscape(command.getString("label", "")) + "\">"
        + xmlEscape(command.getString("command", ""))
        + "</command>\n";
}

string esSystemSpec(
    string id,
    string fullname,
    string platform,
    string theme,
    string romDir,
    Vector<string> extensions,
    Vector<string> linuxCommands
) {
    string result = "  <system>\n"
        + "    <name>" + xmlEscape(id) + "</name>\n"
        + "    <fullname>" + xmlEscape(fullname) + "</fullname>\n"
        + "    <path>%ROMPATH%/" + xmlEscape(romDir) + "</path>\n"
        + "    <extension>" + xmlEscape(esExtensionList(extensions)) + "</extension>\n";
    for command in linuxCommands {
        result = result + esCommandXml(command);
    }
    result = result
        + "    <platform>" + xmlEscape(platform) + "</platform>\n"
        + "    <theme>" + xmlEscape(theme) + "</theme>\n"
        + "  </system>\n";
    return result;
}

class SystemCatalog {
    public Vector<string> ids;
    public Vector<string> romDirs;
    public Vector<string> jsonSpecs;
    public Vector<string> esSystemSpecs;

    public SystemCatalog() {
        self.ids = [];
        self.romDirs = [];
        self.jsonSpecs = [];
        self.esSystemSpecs = [];
    }

    public void addSystem(
        string id,
        string fullname,
        string platform,
        string theme,
        string romDir,
        Vector<string> extensions,
        Vector<string> linuxCommands,
        Vector<string> macosCommands,
        Vector<string> bios,
        string controllerProfile
    ) {
        self.ids.push(id);
        self.romDirs.push(romDir);
        self.jsonSpecs.push(systemSpec(
            id,
            fullname,
            platform,
            theme,
            romDir,
            extensions,
            linuxCommands,
            macosCommands,
            bios,
            controllerProfile
        ));
        self.esSystemSpecs.push(esSystemSpec(id, fullname, platform, theme, romDir, extensions, linuxCommands));
    }

    public string systemsJson() {
        return jsonArray(self.jsonSpecs);
    }

    public string esSystemsXml() {
        return "<?xml version=\"1.0\"?>\n"
            + "<!-- Generated by semu.btrc from the system catalog -->\n"
            + "<systemList>\n"
            + self.esSystemSpecs.join("")
            + "</systemList>\n";
    }
}

SystemCatalog systemCatalog() {
    SystemCatalog catalog = SystemCatalog();
    Vector<string> noBios = [];
    catalog.addSystem(
            "gb",
            "Nintendo Game Boy",
            "gb",
            "gb",
            "gb",
            [".bin", ".dmg", ".gb", ".gbs", ".7z", ".zip"],
            [commandSpec("Gambatte", "%EMULATOR_RETROARCH% -f -L %CORE_RETROARCH%/gambatte_libretro.so %ROM%")],
            [commandSpec("Gambatte", "%EMULATOR_RETROARCH% -f -L %CORE_RETROARCH%/gambatte_libretro.dylib %ROM%")],
            noBios,
            ""
    );
    catalog.addSystem(
            "gbc",
            "Nintendo Game Boy Color",
            "gbc",
            "gbc",
            "gbc",
