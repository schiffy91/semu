string esDe() {
    string settings = jsonObject([
        jsonStrField("ROMDirectory", "~/ES-DE/ROMs"),
        jsonStrField("MediaDirectory", "~/ES-DE/downloaded_media"),
        jsonStrField("UserThemeDirectory", "~/ES-DE/themes"),
        jsonStrField("SaveGamelistsMode", "always"),
        jsonStrField("CreatePlaceholderSystemDirectories", "false"),
        jsonStrField("InputControllerType", "xbox")
    ]);
    return jsonObject([jsonField("settings", settings)]);
}

