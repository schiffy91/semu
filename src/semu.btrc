void writeSteamInputTemplates(string project) {
    ensureDir(joinPath(project, "input/steam-input"));
    KeymapIr ir = projectKeymapIr(project);
    FileSystem.writeText(
        joinPath(project, "input/steam-input/neptune-simple.vdf"),
        steamInputTemplateVdf("Semu: Steam Deck - Neptune SIMPLE", false, ir)
    );
    FileSystem.writeText(
        joinPath(project, "input/steam-input/neptune-full.vdf"),
        steamInputTemplateVdf("Semu: Steam Deck - Neptune FULL", true, ir)
    );
}

string esFindRulesXml(string launcherBin) {
    string result = "<?xml version=\"1.0\"?>\n"
        + "<!-- Generated by semu.btrc from the launcher catalog -->\n"
        + "<ruleList>\n";
    for emulator in linuxLauncherNames() {
        result = result
            + "  <emulator name=\"" + xmlEscape(emulator) + "\">\n"
            + "    <rule type=\"staticpath\">\n"
            + "      <entry>" + xmlEscape(joinPath(launcherBin, semuLauncherName(emulator))) + "</entry>\n"
            + "    </rule>\n"
            + "  </emulator>\n";
    }
    result = result
        + "  <core name=\"RETROARCH\">\n"
        + "    <rule type=\"corepath\">\n";
    for corePath in retroarchCoreSearchPaths() {
        result = result + "      <entry>" + xmlEscape(corePath) + "</entry>\n";
    }
    result = result
        + "    </rule>\n"
        + "  </core>\n"
        + "</ruleList>\n";
    return result;
}

void writeEsDeFiles(string project) {
    ensureDir(customSystemsRoot(project));

    SystemCatalog catalog = systemCatalog();
    string systemsXml = catalog.esSystemsXml();
    FileSystem.writeText(joinPath(customSystemsRoot(project), "es_systems.xml"), systemsXml);

    ensureDir(esDeProfileCustomSystemsRoot(project));
    FileSystem.writeText(joinPath(esDeProfileCustomSystemsRoot(project), "es_systems.xml"), systemsXml);

    string launcherBin = Environment.get("SEMU_LAUNCHER_BIN", linuxLauncherBin(project));
    FileSystem.writeText(joinPath(customSystemsRoot(project), "es_find_rules.xml"), esFindRulesXml(launcherBin));

    FileSystem.writeText(joinPath(project, "ES-DE/es_settings.xml"), esSettingsXmlForProject(project));
}

string esSettingsXmlForRuntime(string project, string romsDir) {
    string roms = romsDir.len() > 0 ? romsDir : configuredRomsRoot(project);
    return esSettingsXmlWithPaths(
        roms,
        joinPath(contentRoot(project), "downloaded_media"),
        joinPath(contentRoot(project), "themes")
    );
}

void writeEsDeRuntimeFiles(string project, string userHome) {
    string customRoot = joinPath(userHome, "ES-DE/custom_systems");
    string settingsRoot = joinPath(userHome, "ES-DE/settings");
    ensureDir(customRoot);
    ensureDir(settingsRoot);

    SystemCatalog catalog = systemCatalog();
    FileSystem.writeText(joinPath(customRoot, "es_systems.xml"), catalog.esSystemsXml());

    string launcherBin = Environment.get("SEMU_LAUNCHER_BIN", linuxLauncherBin(project));
    FileSystem.writeText(joinPath(customRoot, "es_find_rules.xml"), esFindRulesXml(launcherBin));

    string roms = Environment.get("SEMU_ROMS_DIR", configuredRomsRoot(project));
    FileSystem.writeText(joinPath(settingsRoot, "es_settings.xml"), esSettingsXmlForRuntime(project, roms));
}

void bootstrapSteamDeck(string project) {
    writeSyncDefaults(project, "");
    ensureDir(contentRoot(project));
    ensureRomDirsAt(configuredRomsRoot(project));
    if (!configuredRomsRoot(project).equals(romsRoot(project))) {
        ensureRomDirsAt(romsRoot(project));
    }
    ensureDir(biosRoot(project));
    ensureDir(joinPath(contentRoot(project), "saves"));
    ensureDir(joinPath(contentRoot(project), "states"));
    ensureDir(joinPath(contentRoot(project), "screenshots"));
    ensureDir(joinPath(contentRoot(project), "downloaded_media"));
    ensureDir(joinPath(contentRoot(project), "gamelists"));
    ensureDir(joinPath(contentRoot(project), "themes"));
    ensureDir(customSystemsRoot(project));

    Vector<string> ids = declaredSystemIds();
    for id in ids {
        ensureDir(joinPath(joinPath(contentRoot(project), "downloaded_media"), id));
        ensureDir(joinPath(joinPath(contentRoot(project), "gamelists"), id));
    }

    ensureDir(joinPath(biosRoot(project), "ps2"));
    ensureDir(joinPath(biosRoot(project), "switch"));
    ensureDir(joinPath(biosRoot(project), "dc"));
    ensureDir(emulatorProfilePath(project, "Cemu/data"));
    ensureDir(joinPath(project, "input/steam-input"));

    seedKeymapDefaults(project);
    seedEmulatorDefaults(project);
    writeSteamInputTemplates(project);
    writeScreenshotDefaults(project);
    writeGeneratedManifest(joinPath(project, "semu.json"));
    writeEsDeFiles(project);

    print(f"Bootstrapped Steam Deck/Linux content at {contentRoot(project)}");
    print(f"  roms:    {romsRoot(project)}");
    print(f"  bios:    {biosRoot(project)}");
    print(f"  systems: {joinPath(customSystemsRoot(project), \"es_systems.xml\")}");
}

bool allPresent(string target, Vector<string> files) {
    for file in files {
        if (!FileSystem.exists(joinPath(target, file))) {
            return false;
        }
    }
    return true;
}

bool anyPresent(string target, Vector<string> files) {
    for file in files {
        if (FileSystem.exists(joinPath(target, file))) {
            return true;
        }
    }
    return false;
}

void reportPath(string label, string path) {
    string mark = FileSystem.isDir(path) ? "OK" : "MISSING";
    print(f"  {mark} {label}: {path}");
}

void reportBios(string id, string target, Vector<string> files, bool required, bool anyMatch) {
    bool ok = anyMatch ? anyPresent(target, files) : allPresent(target, files);
    string mark = ok ? "OK" : (required ? "MISSING" : "optional");
    string requiredText = required ? "required" : "optional";
    print(f"  {mark} {id} ({requiredText}) -> {target}");
    if (!ok && required) {
        print(f"       expected: {files.join(\", \")}");
    }
}

void reportFile(string label, string path) {
    string mark = FileSystem.exists(path) ? "OK" : "MISSING";
    print(f"  {mark} {label}: {path}");
}

int braceBalance(string text) {
    int balance = 0;
    for (int i = 0; i < text.len(); i++) {
        char c = text.charAt(i);
        if (c == '{') {
            balance++;
        } else if (c == '}') {
            balance--;
        }
    }
    return balance;
}

void reportSteamInputTemplate(string label, string path) {
    if (!FileSystem.exists(path)) {
        print(f"  MISSING {label}: {path}");
        return;
    }
    string text = FileSystem.readText(path);
    Vector<string> missing = [];
    if (!text.contains("\"controller_mappings\"")) { missing.push("controller_mappings"); }
    if (!text.contains("\"controller_type\"\t\t\"controller_neptune\"")) { missing.push("controller_neptune"); }
    if (!text.contains("left_trackpad active")) { missing.push("left_trackpad"); }
    if (!text.contains("right_trackpad active")) { missing.push("right_trackpad"); }
    if (!text.contains("key_press LEFT_CONTROL, Save State")) { missing.push("save_state"); }
    if (!text.contains("key_press A, Load State")) { missing.push("load_state"); }
    if (!text.contains("key_press Q, Quit")) { missing.push("quit"); }
    if (text.contains("\"mode\" \"gyro") || text.contains("gyro_")) { missing.push("no_gyro_policy"); }
    int balance = braceBalance(text);
    if (balance != 0) { missing.push(f"brace_balance={balance}"); }
    if (missing.len == 0) {
        print(f"  OK {label}: controller_neptune, trackpads, save/load/quit");
    } else {
        print(f"  INVALID {label}: {missing.join(\", \")}");
    }
}

class BinaryReader {
    private FILE* handle;
    private bool opened;

    public BinaryReader(string path) {
        self.handle = fopen(path, "rb");
        self.opened = self.handle != NULL;
    }

    public bool ok() {
        return self.opened;
    }

    public bool seek(long offset) {
        if (!self.opened) { return false; }
        return fseek(self.handle, offset, SEEK_SET) == 0;
    }

    public int readU8(long offset) {
        if (!self.seek(offset)) { return -1; }
        byte buf[1];
        size_t n = fread(buf, 1, 1, self.handle);
        if (n != 1) { return -1; }
        return (int)buf[0];
    }

    public long readLe32(long offset) {
        if (!self.seek(offset)) { return -1; }
        byte buf[4];
        size_t n = fread(buf, 1, 4, self.handle);
        if (n != 4) { return -1; }
        return (long)buf[0]
            + ((long)buf[1] * 256)
            + ((long)buf[2] * 65536)
            + ((long)buf[3] * 16777216);
    }

    public string readAscii(long offset, int count) {
        if (!self.seek(offset)) { return ""; }
        char* buf = (char*)malloc(count + 1);
        size_t n = fread(buf, 1, count, self.handle);
        buf[n] = '\0';
        return buf;
    }

    public void close() {
        if (self.opened) {
            fclose(self.handle);
            self.opened = false;
        }
    }

    public void __del__() {
        self.close();
    }
}

class BinaryEditor {
    private FILE* handle;
    private bool opened;

    public BinaryEditor(string path, string mode = "r+b") {
        self.handle = fopen(path, mode);
        self.opened = self.handle != NULL;
    }

    public bool ok() {
        return self.opened;
    }

    public bool seek(long offset) {
        if (!self.opened) { return false; }
        return fseek(self.handle, offset, SEEK_SET) == 0;
    }

    public int readU8(long offset) {
        if (!self.seek(offset)) { return -1; }
        byte buf[1];
        size_t n = fread(buf, 1, 1, self.handle);
        if (n != 1) { return -1; }
        return (int)buf[0];
    }

    public long readLe32(long offset) {
        if (!self.seek(offset)) { return -1; }
        byte buf[4];
        size_t n = fread(buf, 1, 4, self.handle);
        if (n != 4) { return -1; }
        return (long)buf[0]
            + ((long)buf[1] * 256)
            + ((long)buf[2] * 65536)
            + ((long)buf[3] * 16777216);
    }

    public string readAscii(long offset, int count) {
        if (!self.seek(offset)) { return ""; }
        char* buf = (char*)malloc(count + 1);
        size_t n = fread(buf, 1, count, self.handle);
        buf[n] = '\0';
        return buf;
    }

    public bool writeU8(long offset, int value) {
        if (!self.seek(offset)) { return false; }
        byte buf[1];
        buf[0] = (byte)value;
        size_t n = fwrite(buf, 1, 1, self.handle);
        return n == 1;
    }

    public bool writeLe32(long offset, long value) {
        if (!self.seek(offset)) { return false; }
        byte buf[4];
        buf[0] = (byte)(value % 256);
        buf[1] = (byte)((value / 256) % 256);
        buf[2] = (byte)((value / 65536) % 256);
        buf[3] = (byte)((value / 16777216) % 256);
        size_t n = fwrite(buf, 1, 4, self.handle);
        return n == 4;
    }

    public bool writeAscii(long offset, string text) {
        if (!self.seek(offset)) { return false; }
        size_t n = fwrite(text, 1, text.len(), self.handle);
        return n == (size_t)text.len();
    }

    public void close() {
        if (self.opened) {
            fclose(self.handle);
            self.opened = false;
        }
    }

    public void __del__() {
        self.close();
    }
}

class N3dsRomCheck {
    public string status;
    public string note;
    public int partitions;

    public N3dsRomCheck() {
        self.status = "UNKNOWN";
        self.note = "";
        self.partitions = 0;
    }
}

bool n3dsRomName(string name) {
    string lower = name.toLower();
    return lower.endsWith(".3ds") || lower.endsWith(".cci");
}

bool n3dsArchiveName(string name) {
    string lower = name.toLower();
    return lower.endsWith(".zip") || lower.endsWith(".7z");
}

bool exefsLooksDecrypted(string text) {
    return text.startsWith(".code") || text.startsWith("icon") || text.startsWith("banner");
}

N3dsRomCheck checkN3dsRom(string path) {
    N3dsRomCheck result = N3dsRomCheck();
    BinaryReader reader = BinaryReader(path);
    if (!reader.ok()) {
        result.status = "INVALID";
        result.note = "cannot open";
        return result;
    }
    if (!reader.readAscii(0x100, 4).equals("NCSD")) {
        result.status = "INVALID";
        result.note = "missing NCSD header";
        return result;
    }

    bool sawNoCrypto = false;
    bool sawNeedsFix = false;
    bool sawEncrypted = false;
    bool sawInvalidPartition = false;
    for (int i = 0; i < 8; i++) {
        long entry = 0x120 + (i * 8);
        long offsetMu = reader.readLe32(entry);
        long sizeMu = reader.readLe32(entry + 4);
        if (offsetMu < 0 || sizeMu < 0) {
            sawInvalidPartition = true;
        } else if (sizeMu > 0) {
            long partOffset = offsetMu * 0x200;
            if (!reader.readAscii(partOffset + 0x100, 4).equals("NCCH")) {
                sawInvalidPartition = true;
            } else {
                result.partitions++;
                int flags = reader.readU8(partOffset + 0x100 + 0x8f);
                bool noCrypto = ((flags / 4) % 2) == 1;
                if (noCrypto) {
                    sawNoCrypto = true;
                } else {
                    long exefsOffsetMu = reader.readLe32(partOffset + 0x100 + 0xa0);
                    string exefs = exefsOffsetMu > 0 ? reader.readAscii(partOffset + (exefsOffsetMu * 0x200), 8) : "";
                    if (exefsLooksDecrypted(exefs)) {
                        sawNeedsFix = true;
                    } else {
                        sawEncrypted = true;
                    }
                }
            }
        }
    }

    if (result.partitions == 0) {
        result.status = "INVALID";
        result.note = sawInvalidPartition ? "no valid NCCH partitions" : "no NCSD partitions";
    } else if (sawEncrypted) {
        result.status = "ENCRYPTED";
        result.note = "Azahar will reject encrypted dumps; provide decrypted/NoCrypto content";
    } else if (sawNeedsFix) {
        result.status = "NEEDS_FIX";
        result.note = "decrypted content is missing NoCrypto flags";
    } else if (sawNoCrypto) {
        result.status = "OK";
        result.note = f"{result.partitions} NoCrypto partition(s)";
    } else {
        result.status = "UNKNOWN";
        result.note = "could not classify NCCH encryption flags";
    }
    return result;
}

Vector<string> n3dsInputFiles(string input) {
    Vector<string> files = [];
    if (FileSystem.isDir(input)) {
        for name in FileSystem.listDir(input) {
            if (n3dsRomName(name)) {
                files.push(joinPath(input, name));
            }
        }
        files.sort();
    } else if (FileSystem.isFile(input) && n3dsRomName(input)) {
        files.push(input);
    }
    return files;
}

bool copyFilePath(string source, string destination) {
    ensureDir(PathTools.dirname(destination));
    UnixShell shell = UnixShell();
    ExecResult result = shell.runCommand(Command("cp").arg("-p").arg(source).arg(destination).check(false));
    return result.ok();
}

bool n3dsNoCryptoFlag(int flags) {
    return ((flags / 4) % 2) == 1;
}

int patchN3dsNoCryptoFlags(string path) {
    BinaryEditor editor = BinaryEditor(path);
    if (!editor.ok()) { return -1; }
    if (!editor.readAscii(0x100, 4).equals("NCSD")) {
        editor.close();
        return -1;
    }

    int patched = 0;
    for (int i = 0; i < 8; i++) {
        long entry = 0x120 + (i * 8);
        long offsetMu = editor.readLe32(entry);
        long sizeMu = editor.readLe32(entry + 4);
        if (offsetMu < 0 || sizeMu <= 0) {
            continue;
        }
        long partOffset = offsetMu * 0x200;
        if (!editor.readAscii(partOffset + 0x100, 4).equals("NCCH")) {
            continue;
        }
        long flagsOffset = partOffset + 0x100 + 0x8f;
        int flags = editor.readU8(flagsOffset);
        if (flags < 0) {
            editor.close();
            return -1;
        }
        if (!n3dsNoCryptoFlag(flags)) {
            if (!editor.writeU8(flagsOffset, flags + 4)) {
                editor.close();
                return -1;
            }
            if (!editor.writeU8(partOffset + 0x100 + 0x8b, 0)) {
                editor.close();
                return -1;
            }
            patched++;
        }
    }
    editor.close();
    return patched;
}

bool fixN3dsNoCryptoFile(string input, string output) {
    if (!copyFilePath(input, output)) {
        return false;
    }
    int patched = patchN3dsNoCryptoFlags(output);
    if (patched < 0) {
        removePath(output);
        return false;
    }
    return true;
}

string n3dsNoCryptoInputArg(CliArgs args, int startIndex) {
    int i = startIndex;
    while (i < args.count()) {
        string value = args.get(i);
        if (value.equals("-o") || value.equals("--output")) {
            i = i + 2;
        } else if (value.startsWith("--")) {
            i = i + 1;
        } else {
            return value;
        }
    }
    return "";
}

void printN3dsNoCryptoCheckSummary(int total, int ok, int needsFix, int encrypted, int invalid, int unknown) {
    print("");
    print(f"Summary: {total} files");
    print(f"  Already OK (NoCrypto set):    {ok}");
    print(f"  Needs fix (flag missing):     {needsFix}");
    print(f"  Truly encrypted (need keys):  {encrypted}");
    print(f"  Invalid/errors:               {invalid}");
    if (unknown > 0) {
        print(f"  Unknown:                      {unknown}");
    }
}

int n3dsNoCryptoCommand(CliArgs args, int startIndex) {
    string input = n3dsNoCryptoInputArg(args, startIndex);
    if (input.len() == 0) {
        print("error 0:0 n3ds-nocrypto needs an input .3ds/.cci file or directory");
        return 1;
    }
    Vector<string> files = n3dsInputFiles(input);
    if (files.len == 0) {
        print("error 0:0 no .3ds/.cci files found");
        return 1;
    }

    if (args.has("--check")) {
        int ok = 0;
        int needsFix = 0;
        int encrypted = 0;
        int invalid = 0;
        int unknown = 0;
        for file in files {
            N3dsRomCheck result = checkN3dsRom(file);
            string name = PathTools.basename(file);
            if (result.status.equals("OK")) {
                print(f"  OK:        {name}");
                ok++;
            } else if (result.status.equals("NEEDS_FIX")) {
                print(f"  NEEDS FIX: {name}");
                needsFix++;
            } else if (result.status.equals("ENCRYPTED")) {
                print(f"  ENCRYPTED: {name} (truly encrypted, cannot fix with flag flip)");
                encrypted++;
            } else if (result.status.equals("INVALID")) {
                print(f"  ERROR:     {name}: {result.note}");
                invalid++;
            } else {
                print(f"  UNKNOWN:   {name}: {result.note}");
                unknown++;
            }
        }
        printN3dsNoCryptoCheckSummary(files.len, ok, needsFix, encrypted, invalid, unknown);
        return invalid > 0 ? 1 : 0;
    }

    string outputDir = args.valueAfter("--output", args.valueAfter("-o", ""));
    if (outputDir.len() == 0) {
        print("error 0:0 n3ds-nocrypto fix mode needs -o/--output DIR");
        return 1;
    }
    ensureDir(outputDir);

    int fixed = 0;
    int copied = 0;
    int failed = 0;
    for (int i = 0; i < files.len; i++) {
        string file = files.get(i);
        string name = PathTools.basename(file);
        string output = joinPath(outputDir, name);
        print(f"[{i + 1}/{files.len}] {name}");
        N3dsRomCheck result = checkN3dsRom(file);
        if (result.status.equals("OK")) {
            print("  Already OK, copying as-is");
            if (copyFilePath(file, output)) {
                copied++;
            } else {
                print("  FAILED");
                failed++;
            }
        } else if (result.status.equals("NEEDS_FIX")) {
            print("  Fixing NoCrypto flag...");
            if (fixN3dsNoCryptoFile(file, output)) {
                print("  Done");
                fixed++;
            } else {
                print("  FAILED");
                failed++;
            }
        } else if (result.status.equals("ENCRYPTED")) {
            print("  Truly encrypted, skipping (needs full decryption)");
            failed++;
        } else if (result.status.equals("INVALID")) {
            print(f"  ERROR: {result.note}");
            failed++;
        } else {
            print("  Unknown state, copying as-is");
            if (copyFilePath(file, output)) {
                copied++;
            } else {
                print("  FAILED");
                failed++;
            }
        }
    }
    print("");
    print(f"Done: {fixed} fixed, {copied} copied as-is, {failed} failed");
    return failed == 0 ? 0 : 1;
}

int utilitiesCommand(CliArgs args) {
    string mode = "";
    if (args.count() > 1 && !args.get(1).startsWith("--")) {
        mode = args.get(1);
    }
    if (mode.equals("n3ds-nocrypto") || mode.equals("3ds-nocrypto")) {
        return n3dsNoCryptoCommand(args, 2);
    }
    printUsage();
    return 1;
}

void reportN3dsRomPreflight(string project) {
    string n3dsDir = joinPath(romsRoot(project), "n3ds");
    if (!FileSystem.isDir(n3dsDir)) {
        print(f"  MISSING n3ds rom dir: {n3dsDir}");
        return;
    }
    Vector<string> entries = FileSystem.listDir(n3dsDir);
    int checked = 0;
    int archives = 0;
    for name in entries {
        string path = joinPath(n3dsDir, name);
        if (FileSystem.isFile(path) && n3dsRomName(name)) {
            checked++;
            N3dsRomCheck result = checkN3dsRom(path);
            print(f"  {result.status} n3ds/{name}: {result.note}");
        } else if (FileSystem.isFile(path) && n3dsArchiveName(name)) {
            archives++;
        }
    }
    if (checked == 0) {
        print("  OK n3ds: no top-level .3ds/.cci files to preflight");
    }
    if (archives > 0) {
        print(f"  WARN n3ds archives unchecked: {archives} zip/7z file(s)");
    }
}

bool commandExists(string name) {
    UnixShell shell = UnixShell();
    ExecResult result = shell.runUnchecked(f"command -v {ShellWords.quote(name)} >/dev/null 2>&1");
    return result.ok();
}

string verificationRoot(string project) {
    return joinPath(project, "verification");
}

string screenshotConfigPath(string project) {
    return joinPath(verificationRoot(project), "screenshots.json");
}

string screenshotDefaultConfigText() {
    return jsonObject([
        jsonField("schema_version", "1"),
        jsonBoolField("enabled", false),
        jsonStrField("tool", "auto"),
        jsonStrField("command", ""),
        jsonField("delay_seconds", "2"),
        jsonBoolField("capture_before_launch", true),
        jsonBoolField("capture_after_spawn", true),
        jsonBoolField("capture_after_exit", true),
        jsonStrField("output_pattern", "${paths.project_screenshots}/verification/${emulator}/${hook}.png")
    ]) + "\n";
}

void writeScreenshotDefaults(string project) {
    ensureDir(verificationRoot(project));
    ensureDir(joinPath(contentRoot(project), "screenshots/verification"));
    string path = screenshotConfigPath(project);
    if (!FileSystem.exists(path)) {
        FileSystem.writeText(path, screenshotDefaultConfigText());
    }
}

JsonObject screenshotConfig(string project) {
    string path = screenshotConfigPath(project);
    if (!FileSystem.exists(path)) {
        return JsonObject.parse("{}");
    }
    return JsonObject.readFile(path);
}

string screenshotString(string project, string key, string fallback) {
    JsonObject config = screenshotConfig(project);
    return expandProjectTemplate(project, config.getString(key, fallback));
}

bool screenshotBool(string project, string key, bool fallback) {
    JsonObject config = screenshotConfig(project);
    return config.getBool(key, fallback);
}

int screenshotInt(string project, string key, int fallback) {
    JsonObject config = screenshotConfig(project);
    return config.getInt(key, fallback);
}

bool envEnabled(string value) {
    string normalized = value.toLower();
    return normalized.equals("1") || normalized.equals("true") || normalized.equals("yes") || normalized.equals("on");
}

bool screenshotHooksEnabled(string project) {
    string value = Environment.get("SEMU_SCREENSHOT_HOOKS", "");
    if (value.len() > 0) {
        return envEnabled(value);
    }
    return screenshotBool(project, "enabled", false);
}

bool screenshotHookEnabled(string project, string hook) {
    if (!screenshotHooksEnabled(project)) {
        return false;
    }
    if (hook.equals("before_launch")) {
        return screenshotBool(project, "capture_before_launch", true);
    }
    if (hook.equals("after_spawn")) {
        return screenshotBool(project, "capture_after_spawn", true);
    }
    if (hook.equals("after_exit")) {
        return screenshotBool(project, "capture_after_exit", true);
    }
    return true;
}

string screenshotDelaySeconds(string project) {
    int delay = screenshotInt(project, "delay_seconds", 2);
    return Environment.get("SEMU_SCREENSHOT_DELAY_SECONDS", f"{delay}");
}

string screenshotSafeName(string value) {
    string result = value.toLower();
    result = Strings.replace(result, "/", "_");
    result = Strings.replace(result, " ", "_");
    result = Strings.replace(result, ":", "_");
    if (result.len() == 0) {
        return "unknown";
    }
    return result;
}

string screenshotExpandPathTemplate(string project, string value, string emulator, string hook) {
    string result = expandProjectTemplate(project, value);
    result = Strings.replace(result, "${emulator}", screenshotSafeName(emulator));
    result = Strings.replace(result, "${hook}", screenshotSafeName(hook));
    return result;
}

string screenshotExpandCommandTemplate(string project, string value, string emulator, string hook, string output) {
    string result = Strings.replace(value, "${project}", ShellWords.quote(project));
    result = Strings.replace(result, "${paths.project_screenshots}", ShellWords.quote(joinPath(contentRoot(project), "screenshots")));
    result = Strings.replace(result, "${emulator}", ShellWords.quote(screenshotSafeName(emulator)));
    result = Strings.replace(result, "${hook}", ShellWords.quote(screenshotSafeName(hook)));
    result = Strings.replace(result, "${output}", ShellWords.quote(output));
    return result;
}

string screenshotCapturePath(string project, string emulator, string hook) {
    string configured = Environment.get(
        "SEMU_SCREENSHOT_OUTPUT",
        screenshotString(project, "output_pattern", "${paths.project_screenshots}/verification/${emulator}/${hook}.png")
    );
    return screenshotExpandPathTemplate(project, configured, emulator, hook);
}

string screenshotAutoTool() {
    Vector<string> candidates = ["grim", "spectacle", "gnome-screenshot", "import"];
    for candidate in candidates {
        if (commandExists(candidate)) {
            return candidate;
        }
    }
    return "";
}

string screenshotConfiguredTool(string project) {
    string envTool = Environment.get("SEMU_SCREENSHOT_TOOL", "");
    if (envTool.len() > 0 && !envTool.equals("auto")) {
        return envTool;
    }
    string configured = screenshotString(project, "tool", "auto");
    if (configured.len() > 0 && !configured.equals("auto")) {
        return configured;
    }
    return screenshotAutoTool();
}

string screenshotCaptureCommand(string project, string emulator, string hook, string output) {
    string template = Environment.get("SEMU_SCREENSHOT_CMD", screenshotString(project, "command", ""));
    if (template.len() > 0) {
        if (template.contains("${output}")) {
            return screenshotExpandCommandTemplate(project, template, emulator, hook, output);
        }
        return shellAppend(ShellWords.quote(template), output);
    }
    string tool = screenshotConfiguredTool(project);
    if (tool.len() == 0) {
        return "";
    }
    string command = ShellWords.quote(tool);
    string base = PathTools.basename(tool);
    if (base.equals("spectacle")) {
        return shellAppendAll(command, ["-b", "-n", "-o", output]);
    }
    if (base.equals("gnome-screenshot")) {
        return shellAppendAll(command, ["-f", output]);
    }
    if (base.equals("import")) {
        return shellAppendAll(command, ["-window", "root", output]);
    }
    return shellAppend(command, output);
}

bool screenshotCaptureTo(string project, string emulator, string hook, string output) {
    ensureDir(PathTools.dirname(output));
    string command = screenshotCaptureCommand(project, emulator, hook, output);
    if (command.len() == 0) {
        print("MISSING screenshot_tool: install grim/spectacle/gnome-screenshot/ImageMagick import or set SEMU_SCREENSHOT_CMD");
        return false;
    }
    UnixShell shell = UnixShell();
    ExecResult result = shell.runRaw(command, false, false, "");
    if (result.ok() && FileSystem.isFile(output)) {
        print(f"OK screenshot {emulator}:{hook}: {output}");
        return true;
    }
    print(f"MISSING screenshot {emulator}:{hook}: {output}");
    return false;
}

bool screenshotCapture(string project, string emulator, string hook) {
    return screenshotCaptureTo(project, emulator, hook, screenshotCapturePath(project, emulator, hook));
}

void screenshotCaptureHook(string project, string emulator, string hook) {
    if (screenshotHookEnabled(project, hook)) {
        screenshotCapture(project, emulator, hook);
    }
}

void screenshotScheduleHook(string project, string emulator, string hook) {
    if (!screenshotHookEnabled(project, hook)) {
        return;
    }
    string output = screenshotCapturePath(project, emulator, hook);
    ensureDir(PathTools.dirname(output));
    string command = screenshotCaptureCommand(project, emulator, hook, output);
    if (command.len() == 0) {
        print("MISSING screenshot_tool: install grim/spectacle/gnome-screenshot/ImageMagick import or set SEMU_SCREENSHOT_CMD");
        return;
    }
    string delay = screenshotDelaySeconds(project);
    UnixShell shell = UnixShell();
    shell.runRaw("(sleep " + ShellWords.quote(delay) + "; " + command + ") >/dev/null 2>&1 &", false, false, "");
    print(f"OK screenshot scheduled {emulator}:{hook}: {output}");
}

void doctorScreenshotHooks(string project) {
    print("");
    print("Screenshot verification hooks");
    reportFile("screenshot_config", screenshotConfigPath(project));
    print(screenshotHooksEnabled(project) ? "  OK launcher_hooks: enabled" : "  optional launcher_hooks: disabled (set SEMU_SCREENSHOT_HOOKS=1)");
    print("  OK hooks: before_launch, after_spawn, after_exit, manual_visual_checkpoint");
    string tool = screenshotConfiguredTool(project);
    if (tool.len() > 0) {
        print(f"  OK screenshot_tool: {tool}");
    } else {
        print("  MISSING screenshot_tool: install grim/spectacle/gnome-screenshot/ImageMagick import or set SEMU_SCREENSHOT_CMD");
    }
    print("  output_pattern: " + screenshotString(project, "output_pattern", "${paths.project_screenshots}/verification/${emulator}/${hook}.png"));
}

string syncFolderPath(string project, string id) {
    if (id.equals("saves")) { return joinPath(contentRoot(project), "saves"); }
    if (id.equals("states")) { return joinPath(contentRoot(project), "states"); }
    if (id.equals("emulator_state")) { return joinPath(semuStateRoot(project), "appimage-state"); }
    if (id.equals("screenshots")) { return joinPath(contentRoot(project), "screenshots"); }
    if (id.equals("gamelists")) { return joinPath(contentRoot(project), "gamelists"); }
    if (id.equals("roms")) { return configuredRomsRoot(project); }
    if (id.equals("bios")) { return biosRoot(project); }
    return project;
}

Vector<string> syncFolderIds() {
    return ["saves", "states", "emulator_state", "screenshots", "gamelists", "roms", "bios"];
}

string syncFolderLabel(string id) {
    if (id.equals("saves")) { return "Semu Saves"; }
    if (id.equals("states")) { return "Semu States"; }
    if (id.equals("emulator_state")) { return "Semu Emulator State"; }
    if (id.equals("screenshots")) { return "Semu Screenshots"; }
    if (id.equals("gamelists")) { return "Semu Gamelists"; }
    if (id.equals("roms")) { return "Semu ROMs"; }
    if (id.equals("bios")) { return "Semu BIOS"; }
    return "Semu";
}

bool syncFolderEnabled(string project, string id) {
    return syncBool(project, "sync_" + id, false);
}

bool syncFolderWatch(string project, string id) {
    return syncBool(project, "watch_" + id, true);
}

int syncFolderRescan(string project, string id) {
    return syncInt(project, "rescan_" + id + "_s", 900);
}

string syncGuiAddress(string project) {
    return syncString(project, "gui_address", "127.0.0.1:8384");
}

string serviceExecutable() {
    return Environment.get("SEMU_BIN", "semu");
}

string syncServiceText(string project) {
    return "[Unit]\n"
        + "Description=Semu Syncthing\n"
        + "After=network-online.target\n\n"
        + "[Service]\n"
        + "Type=simple\n"
        + "ExecStart=syncthing serve -H " + ShellWords.quote(syncthingHome(project)) + " --no-browser --no-restart\n"
        + "Restart=on-failure\n"
        + "RestartSec=5\n\n"
        + "[Install]\n"
        + "WantedBy=default.target\n";
}

string syncForceScriptText(string project) {
    return "#!/usr/bin/env bash\n"
        + "set -euo pipefail\n"
        + "exec " + ShellWords.quote(serviceExecutable()) + " sync force all --project " + ShellWords.quote(project) + "\n";
}

string syncForceServiceText(string project) {
    return "[Unit]\n"
        + "Description=Semu force Syncthing scan\n\n"
        + "[Service]\n"
        + "Type=oneshot\n"
        + "ExecStart=" + ShellWords.quote(joinPath(syncScriptsDir(project), "sync-force.sh")) + "\n";
}

string syncTimerText() {
    return "[Unit]\n"
        + "Description=Semu scheduled Syncthing scan\n\n"
        + "[Timer]\n"
        + "OnBootSec=5min\n"
        + "OnUnitActiveSec=15min\n"
        + "Persistent=true\n\n"
        + "[Install]\n"
        + "WantedBy=timers.target\n";
}

void writeSyncSystemdUnits(string project) {
    ensureDir(systemdUserDir());
    ensureDir(syncScriptsDir(project));
    string script = joinPath(syncScriptsDir(project), "sync-force.sh");
    FileSystem.writeText(script, syncForceScriptText(project));
    FileSystem.chmod(script, 493);
    FileSystem.writeText(joinPath(systemdUserDir(), "semu-syncthing.service"), syncServiceText(project));
    FileSystem.writeText(joinPath(systemdUserDir(), "semu-sync-force.service"), syncForceServiceText(project));
    FileSystem.writeText(joinPath(systemdUserDir(), "semu-sync-force.timer"), syncTimerText());
}

string deckDesktopText(string project) {
    string exe = serviceExecutable();
    return "[Desktop Entry]\n"
        + "Type=Application\n"
        + "Name=Semu\n"
        + "Comment=Steam Deck emulation frontend\n"
        + "Exec=" + exe + " deck launch --project " + ShellWords.quote(project) + "\n"
        + "Terminal=false\n"
        + "Categories=Game;Emulator;\n"
        + "Actions=ForceSync;SyncStatus;OpenSyncthing;OpenSyncTray;\n\n"
        + "[Desktop Action ForceSync]\n"
        + "Name=Force Sync\n"
        + "Exec=" + exe + " sync force all --project " + ShellWords.quote(project) + "\n\n"
        + "[Desktop Action SyncStatus]\n"
        + "Name=Sync Status\n"
        + "Exec=" + exe + " sync status --project " + ShellWords.quote(project) + "\n\n"
        + "[Desktop Action OpenSyncthing]\n"
        + "Name=Open Syncthing\n"
        + "Exec=" + exe + " sync open --project " + ShellWords.quote(project) + "\n\n"
        + "[Desktop Action OpenSyncTray]\n"
        + "Name=Open Sync Tray\n"
        + "Exec=" + exe + " sync tray --project " + ShellWords.quote(project) + "\n";
}

void writeDeckDesktopEntry(string project) {
    ensureDir(applicationsDir());
    FileSystem.writeText(joinPath(applicationsDir(), "semu.desktop"), deckDesktopText(project));
}

string semuStateRoot(string project) {
    return joinPath(project, ".semu");
}

string lifecycleStatePath(string project) {
    return joinPath(semuStateRoot(project), "lifecycle.json");
}

string lifecycleBackupsRoot(string project) {
    return joinPath(semuStateRoot(project), "backups");
}

string upgradeBackupPath(string project) {
    return joinPath(lifecycleBackupsRoot(project), "pre-upgrade-semu.json");
}

void removePath(string path) {
    if (FileSystem.exists(path)) {
        FileSystem.removeRecursive(path);
    }
}

void writeLifecycleState(string project, string action) {
    ensureDir(semuStateRoot(project));
    FileSystem.writeText(
        lifecycleStatePath(project),
        jsonObject([
            jsonStrField("schema_version", "1"),
            jsonStrField("action", action),
            jsonStrField("project", project),
            jsonStrField("roms_dir", configuredRomsRoot(project)),
            jsonStrField("source", "src/semu.btrc")
        ]) + "\n"
    );
}

void lifecycleReconfigure(string project, string romsDir) {
    writeSyncDefaults(project, romsDir);
    ensureRomDirsAt(configuredRomsRoot(project));
    if (!configuredRomsRoot(project).equals(romsRoot(project))) {
        ensureRomDirsAt(romsRoot(project));
    }
    seedKeymapDefaults(project);
    seedEmulatorDefaults(project);
    writeSteamInputTemplates(project);
    writeScreenshotDefaults(project);
    writeGeneratedManifest(joinPath(project, "semu.json"));
    writeEsDeFiles(project);
    writeSyncSystemdUnits(project);
    writeDeckDesktopEntry(project);
    writeLifecycleState(project, "reconfigure");
}

void lifecycleInstall(string project, string romsDir) {
    lifecycleReconfigure(project, romsDir);
    if (syncBool(project, "enabled", true)) {
        syncSetup(project);
    }
    writeLifecycleState(project, "install");
    doctorSteamDeck(project);
}

void lifecycleUninstall(string project, bool purgeGenerated, bool purgeState) {
    syncStop(project);
    syncAutostart(project, false);
    removePath(joinPath(systemdUserDir(), "semu-syncthing.service"));
    removePath(joinPath(systemdUserDir(), "semu-sync-force.service"));
    removePath(joinPath(systemdUserDir(), "semu-sync-force.timer"));
    removePath(joinPath(applicationsDir(), "semu.desktop"));
    removePath(joinPath(syncScriptsDir(project), "sync-force.sh"));
    removePath(joinPath(semuStateRoot(project), "appimage-state"));
    if (purgeGenerated) {
        removePath(joinPath(project, "ES-DE/custom_systems"));
        removePath(joinPath(project, "ES-DE/es_settings.xml"));
        removePath(joinPath(project, "semu.json"));
    }
    if (purgeState) {
        removePath(semuStateRoot(project));
    } else {
        writeLifecycleState(project, "uninstall");
    }
    print("OK lifecycle uninstall");
}

bool lifecycleChangeKeymap(string project, string actionId, string command) {
    seedKeymapDefaults(project);
    string path = keymapSourcePath(project);
    string source = FileSystem.readText(path);
    Vector<string> lines = Strings.split(source, "\n");
    Vector<string> out = [];
    bool changed = false;
    string prefix = "action " + actionId + " = ";
    for line in lines {
        if (line.startsWith(prefix)) {
            out.push(prefix + command);
            changed = true;
        } else if (line.len() > 0) {
            out.push(line);
        }
    }
    if (!changed) {
        print(f"error 0:0 unknown keymap action '{actionId}'");
        return false;
    }
    string next = out.join("\n") + "\n";
    KeymapErrors errors = KeymapErrors();
    compileKeymap(next, errors);
    if (errors.count() > 0) {
        for (int i = 0; i < errors.count(); i++) {
            print(f"{errors.levels.get(i)} {errors.lines.get(i)}:{errors.columns.get(i)} {errors.messages.get(i)}");
        }
        return false;
    }
    FileSystem.writeText(path, next);
    lifecycleReconfigure(project, "");
    writeLifecycleState(project, "change");
    print(f"OK lifecycle change: {actionId}={command}");
    return true;
}

void lifecycleUpgrade(string project) {
    ensureDir(lifecycleBackupsRoot(project));
    if (FileSystem.exists(joinPath(project, "semu.json"))) {
        FileSystem.writeText(upgradeBackupPath(project), FileSystem.readText(joinPath(project, "semu.json")));
    }
    lifecycleReconfigure(project, "");
    writeLifecycleState(project, "upgrade");
    print(f"OK lifecycle upgrade: backup {upgradeBackupPath(project)}");
}

void lifecycleStatus(string project) {
    print("Semu lifecycle");
    reportFile("state", lifecycleStatePath(project));
    reportFile("manifest", joinPath(project, "semu.json"));
    reportFile("sync_config", syncConfigPath(project));
    reportFile("desktop_entry", joinPath(applicationsDir(), "semu.desktop"));
    reportFile("systemd_service", joinPath(systemdUserDir(), "semu-syncthing.service"));
    print(f"  roms_dir: {configuredRomsRoot(project)}");
}

string syncConfigXmlPath(string project) {
    return joinPath(syncthingHome(project), "config.xml");
}

string findXmlValue(string text, string startTag, string endTag) {
    int start = text.indexOf(startTag);
    if (start < 0) { return ""; }
    start = start + startTag.len();
    int end = Strings.find(text, endTag, start);
    if (end < 0) { return ""; }
    return text.substring(start, end - start);
}

string syncApiKey(string project) {
    string path = syncConfigXmlPath(project);
    if (!FileSystem.exists(path)) { return ""; }
    return findXmlValue(FileSystem.readText(path), "<apikey>", "</apikey>");
}

string syncScanUrl(string project, string target) {
    string url = "http://" + syncGuiAddress(project) + "/rest/db/scan";
    if (!target.equals("all") && target.len() > 0) {
        url = url + "?folder=semu-" + target;
    }
    return url;
}

void syncGenerateIfNeeded(string project) {
    if (FileSystem.exists(syncConfigXmlPath(project))) {
        return;
    }
    UnixShell shell = UnixShell();
    shell.runUnchecked("syncthing generate -H " + ShellWords.quote(syncthingHome(project)) + " --no-port-probing >/dev/null 2>&1");
}

bool syncSystemctl(string verb, string unit) {
    UnixShell shell = UnixShell();
    ExecResult result = shell.runUnchecked("systemctl --user " + verb + " " + unit + " >/dev/null 2>&1");
    return result.ok();
}

bool syncWaitForApi(string project) {
    UnixShell shell = UnixShell();
    string url = "http://" + syncGuiAddress(project) + "/rest/noauth/health";
    for (int i = 0; i < 20; i++) {
        ExecResult result = shell.runUnchecked("curl -fsS " + ShellWords.quote(url) + " >/dev/null 2>&1");
        if (result.ok()) { return true; }
        shell.runUnchecked("sleep 1");
    }
    return false;
}

bool syncAddFolder(string project, string id) {
    if (!syncFolderEnabled(project, id)) { return true; }
    ensureDir(syncFolderPath(project, id));
    string apiKey = syncApiKey(project);
    if (apiKey.len() == 0) { return false; }
    UnixShell shell = UnixShell();
    string folderId = "semu-" + id;
    string cliPrefix = "syncthing cli -H " + ShellWords.quote(syncthingHome(project))
        + " --gui-address " + ShellWords.quote(syncGuiAddress(project))
        + " --gui-apikey " + ShellWords.quote(apiKey);
    ExecResult existing = shell.runUnchecked(
        cliPrefix + " config folders list | grep -Fx " + ShellWords.quote(folderId) + " >/dev/null 2>&1"
    );
    if (existing.ok()) { return true; }
    string command = "syncthing cli -H " + ShellWords.quote(syncthingHome(project))
        + " --gui-address " + ShellWords.quote(syncGuiAddress(project))
        + " --gui-apikey " + ShellWords.quote(apiKey)
        + " config folders add"
        + " --id " + ShellWords.quote(folderId)
        + " --label " + ShellWords.quote(syncFolderLabel(id))
        + " --path " + ShellWords.quote(syncFolderPath(project, id))
        + " --type sendreceive"
        + " --rescan-intervals " + Strings.fromInt(syncFolderRescan(project, id));
    if (syncFolderWatch(project, id)) {
        command = command + " --fswatcher-enabled";
    }
    ExecResult result = shell.runUnchecked(command + " >/dev/null 2>&1");
    return result.ok();
}

bool syncConfigureFolders(string project) {
    bool ok = true;
    for id in syncFolderIds() {
        if (!syncAddFolder(project, id)) { ok = false; }
    }
    return ok;
}

bool syncSetup(string project) {
    writeSyncDefaults(project, "");
    writeSyncSystemdUnits(project);
    if (!commandExists("syncthing")) {
        print("MISSING syncthing: install package or use bundled Semu");
        return false;
    }
    syncGenerateIfNeeded(project);
    bool ok = syncSystemctl("daemon-reload", "");
    if (syncBool(project, "start_at_boot", true)) {
        if (!syncSystemctl("enable", "semu-syncthing.service")) { ok = false; }
        if (!syncSystemctl("enable", "semu-sync-force.timer")) { ok = false; }
    }
    if (syncBool(project, "enabled", true)) {
        if (!syncSystemctl("start", "semu-syncthing.service")) { ok = false; }
        if (!syncSystemctl("start", "semu-sync-force.timer")) { ok = false; }
        if (!syncWaitForApi(project)) { ok = false; }
        if (!syncConfigureFolders(project)) { ok = false; }
    }
    if (ok) {
        print(f"OK sync setup: {syncConfigPath(project)}");
    } else {
        print(f"MISSING sync setup incomplete: {syncConfigPath(project)}");
    }
    return ok;
}

bool syncStart(string project) {
    bool ok = syncSetup(project);
    if (!syncSystemctl("start", "semu-syncthing.service")) { ok = false; }
    print(ok ? "OK sync start" : "MISSING sync start failed");
    return ok;
}

bool syncStop(string project) {
    bool ok = true;
    if (!syncSystemctl("stop", "semu-sync-force.timer")) { ok = false; }
    if (!syncSystemctl("stop", "semu-syncthing.service")) { ok = false; }
    print(ok ? "OK sync stop" : "MISSING sync stop incomplete");
    return ok;
}

bool syncAutostart(string project, bool enabled) {
    writeSyncSystemdUnits(project);
    bool ok = syncSystemctl("daemon-reload", "");
    if (enabled) {
        if (!syncSystemctl("enable", "semu-syncthing.service")) { ok = false; }
        if (!syncSystemctl("enable", "semu-sync-force.timer")) { ok = false; }
        print(ok ? "OK sync autostart enabled" : "MISSING sync autostart enable incomplete");
    } else {
        if (!syncSystemctl("disable", "semu-syncthing.service")) { ok = false; }
        if (!syncSystemctl("disable", "semu-sync-force.timer")) { ok = false; }
        print(ok ? "OK sync autostart disabled" : "MISSING sync autostart disable incomplete");
    }
    return ok;
}

bool syncForce(string project, string target) {
    string apiKey = syncApiKey(project);
    if (apiKey.len() == 0) {
        print("MISSING syncthing API key; run sync setup/start first");
        return false;
    }
    UnixShell shell = UnixShell();
    string command = "curl -fsS -X POST -H " + ShellWords.quote("X-API-Key: " + apiKey)
        + " " + ShellWords.quote(syncScanUrl(project, target));
    ExecResult result = shell.runUnchecked(command);
    if (result.ok()) {
        print(f"OK sync force: {target}");
        return true;
    } else {
        print(f"MISSING sync force failed: {target}");
    }
    return false;
}

void syncStatus(string project) {
    print("Semu sync");
    reportFile("sync_config", syncConfigPath(project));
    reportFile("syncthing_config", syncConfigXmlPath(project));
    reportFile("systemd_service", joinPath(systemdUserDir(), "semu-syncthing.service"));
    reportFile("systemd_timer", joinPath(systemdUserDir(), "semu-sync-force.timer"));
    print(commandExists("syncthing") ? "  OK syncthing: executable found" : "  MISSING syncthing: executable not found");
    print(commandExists("syncthingtray") ? "  OK syncthingtray: executable found" : "  optional syncthingtray: executable not found");
    print(commandExists("curl") ? "  OK curl: executable found" : "  MISSING curl: executable not found");
    for id in syncFolderIds() {
        string mark = syncFolderEnabled(project, id) ? "OK" : "optional";
        print(f"  {mark} {id}: {syncFolderPath(project, id)}");
    }
}

void syncTray(string project) {
    UnixShell shell = UnixShell();
    if (commandExists("syncthingtray")) {
        shell.runUnchecked("syncthingtray >/dev/null 2>&1 &");
        print("OK sync tray");
    } else if (commandExists("flatpak")) {
        shell.runUnchecked("flatpak run io.github.martchus.syncthingtray >/dev/null 2>&1 &");
        print("OK sync tray flatpak");
    } else {
        print("MISSING syncthingtray");
    }
}

void syncOpen(string project) {
    UnixShell shell = UnixShell();
    shell.runUnchecked("xdg-open " + ShellWords.quote("http://" + syncGuiAddress(project)) + " >/dev/null 2>&1 &");
    print("OK sync open");
}

void doctorSync(string project) {
    print("");
    print("Sync");
    reportFile("sync_config", syncConfigPath(project));
    print(commandExists("syncthing") ? "  OK syncthing: executable found" : "  MISSING syncthing: executable not found");
    print(commandExists("curl") ? "  OK curl: executable found" : "  MISSING curl: executable not found");
    print(syncBool(project, "start_at_boot", true) ? "  OK start_at_boot: enabled" : "  optional start_at_boot: disabled");
    print(syncBool(project, "tray", true) ? "  OK tray: enabled" : "  optional tray: disabled");
    for id in syncFolderIds() {
        string mark = syncFolderEnabled(project, id) ? "OK" : "optional";
        string watch = syncFolderWatch(project, id) ? "watch" : "scan";
        int interval = syncFolderRescan(project, id);
        print(f"  {mark} {id}: {watch}, {interval}s, {syncFolderPath(project, id)}");
    }
}

void doctorSteamDeck(string project) {
    print("Semu doctor (BTRC)");
    print("");
    print("Paths");
    reportPath("project_roms", romsRoot(project));
    reportPath("configured_roms", configuredRomsRoot(project));
    reportPath("project_bios", biosRoot(project));
    reportPath("project_saves", joinPath(contentRoot(project), "saves"));
    reportPath("project_states", joinPath(contentRoot(project), "states"));
    reportPath("project_media", joinPath(contentRoot(project), "downloaded_media"));
    reportPath("project_gamelists", joinPath(contentRoot(project), "gamelists"));

    print("");
    print("BIOS / firmware");
    reportBios("psx", biosRoot(project), ["scph5500.bin", "scph5501.bin", "scph5502.bin"], true, false);
    reportBios("ps2", joinPath(biosRoot(project), "ps2"), ["ps2-0230a-20080220.bin", "ps2-0230e-20080220.bin", "ps2-0230j-20080220.bin"], true, true);
    reportBios("switch_keys", joinPath(biosRoot(project), "switch"), ["prod.keys", "title.keys"], true, false);
    reportBios("wiiu_keys", emulatorProfilePath(project, "Cemu/data"), ["keys.txt"], true, false);
    reportBios("dreamcast", joinPath(biosRoot(project), "dc"), ["dc_boot.bin", "dc_flash.bin"], false, false);

    print("");
    print("Controller profiles");
    bool controllersOk = true;
    for profile in controllerProfileFiles() {
        if (!FileSystem.exists(joinPath(project, profile))) {
            controllersOk = false;
            print(f"  MISSING {profile}");
        }
    }
    if (controllersOk) {
        print("  OK steam_deck");
    }

    print("");
    print("Steam Deck defaults");
    print("  OK gyro: disabled");
    print("  OK right_trackpad: mouse");
    print("  OK left_trackpad: radial_hotkeys");
    print("  OK hotkeys: HKB+L1 load, HKB+R1 save, HKB+Start quit");

    print("");
    print("Input abstraction");
    print("  OK layers: controller_model -> emulation_backend -> emitted_input -> emulator_keymap");
    print("  OK backends: uinput, evemu, uhid, inputplumber, steam_input");
    print("  OK controller_models: steam_deck, steam_controller, xbox_xinput, dualshock4, dualsense, switch_pro");
    print("  OK steam_deck verification: linux_virtual_input, deck_route, steam_deck_game_mode");

    string keymapPath = keymapSourcePath(project);
    string keymapSource = FileSystem.exists(keymapPath) ? FileSystem.readText(keymapPath) : defaultKeymapSource();
    KeymapErrors errors = KeymapErrors();
    compileKeymap(keymapSource, errors);
    print("");
    print("Keymap compiler");
    if (errors.count() == 0) {
        print(f"  OK steam_deck: {keymapPath}");
    } else {
        for (int i = 0; i < errors.count(); i++) {
            print(f"  {errors.levels.get(i)} {errors.lines.get(i)}:{errors.columns.get(i)} {errors.messages.get(i)}");
        }
    }

    print("");
    print("Steam Input templates");
    reportSteamInputTemplate("neptune_simple", joinPath(project, "input/steam-input/neptune-simple.vdf"));
    reportSteamInputTemplate("neptune_full", joinPath(project, "input/steam-input/neptune-full.vdf"));

    print("");
    print("ROM preflight");
    reportN3dsRomPreflight(project);

    doctorScreenshotHooks(project);

    doctorSync(project);

    print("");
    print("linux launchers");
    for emulator in linuxLauncherNames() {
        reportFile(emulator, joinPath(linuxLauncherBin(project), semuLauncherName(emulator)));
    }
}

bool e2eOk(bool condition, string message) {
    if (condition) { return true; }
    print("E2E FAIL " + message);
    return false;
}

bool e2eContains(string text, string expected, string message) {
    return e2eOk(text.contains(expected), message + ": missing " + expected);
}

string e2eTempDir(string label) {
    string tmp = FileSystem.tempDir(label);
    if (tmp.len() > 0) { return tmp; }
    string fallback = joinPath(Environment.get("TMPDIR", "/tmp"), label + "-fallback");
    FileSystem.removeRecursive(fallback);
    ensureDir(fallback);
    return fallback;
}

void e2eSeedFile(string path) {
    ensureDir(PathTools.dirname(path));
    FileSystem.writeText(path, "seed " + path + "\n");
}

bool e2eAssertLink(string linkPath, string targetPath) {
    if (!e2eOk(FileSystem.isSymlink(linkPath), "expected symlink " + linkPath)) {
        return false;
    }
    string target = FileSystem.readLink(linkPath);
    if (!e2eOk(target.len() > 0, "readlink failed " + linkPath)) {
        return false;
    }
    return e2eOk(target.equals(targetPath), "bad symlink target for " + linkPath);
}

bool e2ePrepareSandbox(string project, string scratchRoot, string emulator) {
    string scratch = joinPath(scratchRoot, emulator);
    FileSystem.removeRecursive(scratch);
    string emuDir = sandboxProjectEmulatorDir(project, emulator);
    if (!e2eOk(emuDir.len() > 0, "missing emulator dir " + emulator)) {
        return false;
    }
    ensureDir(scratch);
    if (!e2eOk(sandboxApplyKnownLinks(emulator.toLower(), emuDir, scratch), "missing sandbox spec " + emulator)) {
        return false;
    }
    if (!e2eOk(sandboxApplyKnownLinks(emulator.toLower(), emuDir, scratch), "sandbox idempotency failed " + emulator)) {
        return false;
    }
    return true;
}

int e2eSandboxSmoke() {
    string tmp = e2eTempDir("semu-sandbox-smoke");
    string project = joinPath(tmp, "project");
    string scratchRoot = joinPath(tmp, "scratch");
    ensureDir(project);
    ensureDir(scratchRoot);

    e2eSeedFile(emulatorProfilePath(project, "Azahar/data/qt-config.ini"));
    if (!e2ePrepareSandbox(project, scratchRoot, "azahar")) { return 1; }
    if (!e2eAssertLink(joinPath(scratchRoot, "azahar/.local/share/azahar-emu/qt-config.ini"), emulatorProfilePath(project, "Azahar/data/qt-config.ini"))) { return 1; }

    e2eSeedFile(emulatorProfilePath(project, "Cemu/config/settings.xml"));
    e2eSeedFile(emulatorProfilePath(project, "Cemu/data/keys.txt"));
    if (!e2ePrepareSandbox(project, scratchRoot, "cemu")) { return 1; }
    if (!e2eAssertLink(joinPath(scratchRoot, "cemu/.config/Cemu/settings.xml"), emulatorProfilePath(project, "Cemu/config/settings.xml"))) { return 1; }
    if (!e2eAssertLink(joinPath(scratchRoot, "cemu/.local/share/Cemu/keys.txt"), emulatorProfilePath(project, "Cemu/data/keys.txt"))) { return 1; }

    e2eSeedFile(emulatorProfilePath(project, "Dolphin/config/Dolphin.ini"));
    e2eSeedFile(emulatorProfilePath(project, "Dolphin/data/Wii/title.dat"));
    if (!e2ePrepareSandbox(project, scratchRoot, "dolphin")) { return 1; }
    if (!e2eAssertLink(joinPath(scratchRoot, "dolphin/.config/dolphin-emu/Dolphin.ini"), emulatorProfilePath(project, "Dolphin/config/Dolphin.ini"))) { return 1; }
    if (!e2eAssertLink(joinPath(scratchRoot, "dolphin/.local/share/dolphin-emu/Wii"), emulatorProfilePath(project, "Dolphin/data/Wii"))) { return 1; }

    e2eSeedFile(joinPath(project, "ES-DE/ES-DE/ROMs/.keep"));
    e2eSeedFile(joinPath(project, "ES-DE/es_settings.xml"));
    e2eSeedFile(joinPath(project, "ES-DE/custom_systems/es_find_rules.xml"));
    if (!e2ePrepareSandbox(project, scratchRoot, "es-de")) { return 1; }
    if (!e2eAssertLink(joinPath(scratchRoot, "es-de/ES-DE/ROMs"), joinPath(project, "ES-DE/ES-DE/ROMs"))) { return 1; }
    if (!e2eAssertLink(joinPath(scratchRoot, "es-de/ES-DE/settings/es_settings.xml"), joinPath(project, "ES-DE/es_settings.xml"))) { return 1; }
    if (!e2eAssertLink(joinPath(scratchRoot, "es-de/ES-DE/custom_systems/es_find_rules.xml"), joinPath(project, "ES-DE/custom_systems/es_find_rules.xml"))) { return 1; }

    e2eSeedFile(emulatorProfilePath(project, "Lime3DS/data/qt-config.ini"));
    if (!e2ePrepareSandbox(project, scratchRoot, "lime3ds")) { return 1; }
    if (!e2eAssertLink(joinPath(scratchRoot, "lime3ds/.config/lime3ds-emu/qt-config.ini"), emulatorProfilePath(project, "Lime3DS/data/qt-config.ini"))) { return 1; }

    e2eSeedFile(emulatorProfilePath(project, "PCSX2/config/PCSX2.ini"));
    if (!e2ePrepareSandbox(project, scratchRoot, "pcsx2")) { return 1; }
    if (!e2eAssertLink(joinPath(scratchRoot, "pcsx2/.config/PCSX2/PCSX2.ini"), emulatorProfilePath(project, "PCSX2/config/PCSX2.ini"))) { return 1; }

    e2eSeedFile(emulatorProfilePath(project, "RetroArch/config/input.cfg"));
    e2eSeedFile(emulatorProfilePath(project, "RetroArch/retroarch.cfg"));
    if (!e2ePrepareSandbox(project, scratchRoot, "retroarch")) { return 1; }
    if (!e2eAssertLink(joinPath(scratchRoot, "retroarch/.config/retroarch/input.cfg"), emulatorProfilePath(project, "RetroArch/config/input.cfg"))) { return 1; }
    if (!e2eAssertLink(joinPath(scratchRoot, "retroarch/.config/retroarch/retroarch.cfg"), emulatorProfilePath(project, "RetroArch/retroarch.cfg"))) { return 1; }

    e2eSeedFile(emulatorProfilePath(project, "Ryujinx/config/Config.json"));
    if (!e2ePrepareSandbox(project, scratchRoot, "ryujinx")) { return 1; }
    if (!e2eAssertLink(joinPath(scratchRoot, "ryujinx/.config/Ryujinx/Config.json"), emulatorProfilePath(project, "Ryujinx/config/Config.json"))) { return 1; }

    if (!e2eOk(sandboxProjectEmulatorDir(project, "missing").len() == 0, "missing emulator unexpectedly resolved")) { return 1; }
    ensureDir(joinPath(project, "Foo"));
    if (!e2eOk(!sandboxApplyKnownLinks("foo", joinPath(project, "Foo"), joinPath(scratchRoot, "foo")), "unknown emulator spec unexpectedly succeeded")) { return 1; }

    print("OK BTRC sandbox smoke");
    return 0;
}

ExecResult e2eRunLifecycle(string exe, string home, string mode, string project, string romsDir) {
    Command command = Command(exe)
        .envVar("SEMU_HOME", home)
        .envVar("SEMU_BIN", exe)
        .envVar("PATH", "/usr/bin:/bin")
        .arg("lifecycle")
        .arg(mode)
        .flag("--project", project)
        .capture(true)
        .check(false);
    if (romsDir.len() > 0) {
        command.flag("--roms", romsDir);
    }
    UnixShell shell = UnixShell();
    ExecResult result = shell.runCommand(command);
    return result;
}

ExecResult e2eRunLifecycleChange(string exe, string home, string project, string actionId, string commandText) {
    Command command = Command(exe)
        .envVar("SEMU_HOME", home)
        .envVar("SEMU_BIN", exe)
        .envVar("PATH", "/usr/bin:/bin")
        .arg("lifecycle")
        .arg("change")
        .flag("--project", project)
        .flag("--action", actionId)
        .flag("--command", commandText)
        .capture(true)
        .check(false);
    UnixShell shell = UnixShell();
    ExecResult result = shell.runCommand(command);
    return result;
}

ExecResult e2eRunLifecycleArgs(string exe, string home, string project, Vector<string> lifecycleArgs) {
    Command command = Command(exe)
        .envVar("SEMU_HOME", home)
        .envVar("SEMU_BIN", exe)
        .envVar("PATH", "/usr/bin:/bin")
        .arg("lifecycle")
        .capture(true)
        .check(false);
    for arg in lifecycleArgs {
        command.arg(arg);
    }
    command.flag("--project", project);
    UnixShell shell = UnixShell();
    ExecResult result = shell.runCommand(command);
    return result;
}

ExecResult e2eRunSync(string exe, string home, string binDir, string project, Vector<string> syncArgs) {
    Command command = Command(exe)
        .envVar("SEMU_HOME", home)
        .envVar("SEMU_BIN", exe)
        .envVar("PATH", binDir + ":/usr/bin:/bin")
        .envVar("SEMU_CAPTURE", joinPath(PathTools.dirname(binDir), "capture"))
        .arg("sync")
        .capture(true)
        .check(false);
    for arg in syncArgs {
        command.arg(arg);
    }
    command.flag("--project", project);
    UnixShell shell = UnixShell();
    ExecResult result = shell.runCommand(command);
    return result;
}

ExecResult e2eRunSteamInput(string exe, string home, string project, Vector<string> steamInputArgs) {
    Command command = Command(exe)
        .envVar("SEMU_HOME", home)
        .envVar("SEMU_BIN", exe)
        .envVar("PATH", "/usr/bin:/bin")
        .arg("steam-input")
        .capture(true)
        .check(false);
    for arg in steamInputArgs {
        command.arg(arg);
    }
    command.flag("--project", project);
    UnixShell shell = UnixShell();
    ExecResult result = shell.runCommand(command);
    return result;
}

ExecResult e2eRunLauncher(string exe, string home, string project, string roms, string binDir, string captureDir, string bwrapPath, string emulator, Vector<string> emulatorArgs) {
    Command command = Command(exe)
        .envVar("SEMU_HOME", home)
        .envVar("SEMU_BIN", exe)
        .envVar("SEMU_PROJECT_DIR", project)
        .envVar("SEMU_ROMS_DIR", roms)
        .envVar("SEMU_FLATPAK_CAPTURE", captureDir)
        .envVar("SEMU_BWRAP", bwrapPath)
        .envVar("SEMU_SCREENSHOT_HOOKS", "1")
        .envVar("SEMU_SCREENSHOT_DELAY_SECONDS", "0")
        .envVar("PATH", binDir + ":/usr/bin:/bin")
        .envVar("WAYLAND_DISPLAY", "wayland-test")
        .arg("launcher")
        .arg(emulator)
        .capture(true)
        .check(false);
    for arg in emulatorArgs {
        command.arg(arg);
    }
    UnixShell shell = UnixShell();
    ExecResult result = shell.runCommand(command);
    return result;
}

bool e2eRunOk(ExecResult result, string label) {
    if (result.ok()) { return true; }
    print("E2E FAIL " + label);
    print(result.stdout());
    return false;
}

bool e2eWaitForFile(string path, string label) {
    UnixShell shell = UnixShell();
    ExecResult result = shell.runRaw("for i in 1 2 3 4 5; do [ -f " + ShellWords.quote(path) + " ] && exit 0; sleep 0.1; done; exit 1", false, false, "");
    return e2eOk(result.ok(), label + ": missing " + path);
}

bool e2eCatalogConsistency(string project, string launcherBin) {
    string systems = FileSystem.readText(joinPath(customSystemsRoot(project), "es_systems.xml"));
    string rules = FileSystem.readText(joinPath(customSystemsRoot(project), "es_find_rules.xml"));
    for id in declaredSystemIds() {
        if (!e2eContains(systems, "<name>" + id + "</name>", "ES-DE system catalog " + id)) { return false; }
    }
    for emulator in linuxLauncherNames() {
        string launcher = joinPath(launcherBin, semuLauncherName(emulator));
        if (!e2eContains(rules, "<emulator name=\"" + emulator + "\">", "ES-DE find rule " + emulator)) { return false; }
        if (!e2eContains(rules, launcher, "ES-DE launcher path " + emulator)) { return false; }
        if (!e2eOk(FileSystem.exists(launcher), "launcher missing " + launcher)) { return false; }
    }
    return true;
}

int e2eLifecycleSmoke(CliArgs args) {
    string tmp = e2eTempDir("semu-lifecycle-smoke");
    string project = joinPath(tmp, "project");
    string home = joinPath(tmp, "home");
    string romsOne = joinPath(tmp, "roms-one");
    string romsTwo = joinPath(tmp, "roms-two");
    string exe = Environment.get("SEMU_BIN", args.program);
    ensureDir(project);
    ensureDir(home);

    if (!e2eRunOk(e2eRunLifecycle(exe, home, "install", project, romsOne), "install")) { return 1; }
    if (!e2eRunOk(e2eRunLifecycle(exe, home, "install", project, romsOne), "install idempotent")) { return 1; }
    if (!e2eCatalogConsistency(project, linuxLauncherBin(project))) { return 1; }
    if (!e2eOk(FileSystem.isDir(joinPath(romsOne, "gba")), "install did not create configured ROM dirs")) { return 1; }
    if (!e2eContains(FileSystem.readText(syncConfigPath(project)), romsOne, "sync config after install")) { return 1; }
    if (!e2eContains(FileSystem.readText(screenshotConfigPath(project)), "output_pattern", "screenshot config after install")) { return 1; }
    if (!e2eOk(FileSystem.exists(joinPath(home, ".local/share/applications/semu.desktop")), "desktop entry missing after install")) { return 1; }
    if (!e2eOk(FileSystem.exists(joinPath(home, ".config/systemd/user/semu-syncthing.service")), "systemd service missing after install")) { return 1; }
    string steamTemplates = joinPath(home, "steam-templates");
    if (!e2eRunOk(e2eRunSteamInput(exe, home, project, ["install", "--dest", steamTemplates]), "steam-input install")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(steamTemplates, "neptune-simple.vdf")), "\"controller_type\"\t\t\"controller_neptune\"", "installed Steam Input simple template")) { return 1; }

    e2eSeedFile(joinPath(contentRoot(project), "saves/gba/game.sav"));
    e2eSeedFile(joinPath(biosRoot(project), "ps2/ps2-0230a-20080220.bin"));
    if (!e2eRunOk(e2eRunLifecycle(exe, home, "reconfigure", project, romsTwo), "reconfigure")) { return 1; }
    if (!e2eContains(FileSystem.readText(syncConfigPath(project)), romsTwo, "sync config after reconfigure")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(project, "ES-DE/es_settings.xml")), romsTwo, "ES-DE settings after reconfigure")) { return 1; }
    if (!e2eOk(FileSystem.exists(joinPath(romsOne, "gba")), "old ROM root should not be deleted")) { return 1; }
    if (!e2eOk(FileSystem.exists(joinPath(contentRoot(project), "saves/gba/game.sav")), "save should survive reconfigure")) { return 1; }
    if (!e2eOk(FileSystem.exists(joinPath(biosRoot(project), "ps2/ps2-0230a-20080220.bin")), "BIOS should survive reconfigure")) { return 1; }

    if (!e2eRunOk(e2eRunLifecycleChange(exe, home, project, "state.save", "Ctrl+V"), "change keymap")) { return 1; }
    if (!e2eContains(FileSystem.readText(keymapSourcePath(project)), "action state.save = Ctrl+V", "keymap source after change")) { return 1; }
    if (!e2eContains(FileSystem.readText(emulatorProfilePath(project, "RetroArch/retroarch.cfg")), "input_save_state = \"v\"", "RetroArch keymap after change")) { return 1; }
    if (!e2eContains(FileSystem.readText(emulatorProfilePath(project, "Dolphin/config/Profiles/Hotkeys/Steam Deck.ini")), "Save State/Save State Slot 1 = @(Ctrl+V)", "Dolphin keymap after change")) { return 1; }
    if (!e2eContains(FileSystem.readText(emulatorProfilePath(project, "PCSX2/config/inputprofiles/Steam Deck.ini")), "SaveStateToSlot = Keyboard/Control & Keyboard/V", "PCSX2 keymap after change")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(project, "input/steam-input/neptune-full.vdf")), "key_press V, Save State", "Steam Input keymap after change")) { return 1; }

    string keymapBeforeFailure = FileSystem.readText(keymapSourcePath(project));
    string retroarchBeforeFailure = FileSystem.readText(emulatorProfilePath(project, "RetroArch/retroarch.cfg"));
    if (!e2eOk(!e2eRunLifecycleArgs(exe, home, project, ["change", "--action", "state.save"]).ok(), "lifecycle change without command unexpectedly succeeded")) { return 1; }
    if (!e2eOk(!e2eRunLifecycleChange(exe, home, project, "missing.action", "Ctrl+B").ok(), "unknown keymap action unexpectedly succeeded")) { return 1; }
    if (!e2eOk(!e2eRunLifecycleChange(exe, home, project, "state.save", "Ctrl").ok(), "invalid keymap command unexpectedly succeeded")) { return 1; }
    if (!e2eOk(!e2eRunLifecycleArgs(exe, home, project, ["definitely-not-a-mode"]).ok(), "unknown lifecycle mode unexpectedly succeeded")) { return 1; }
    if (!e2eOk(FileSystem.readText(keymapSourcePath(project)).equals(keymapBeforeFailure), "failed keymap change mutated source")) { return 1; }
    if (!e2eOk(FileSystem.readText(emulatorProfilePath(project, "RetroArch/retroarch.cfg")).equals(retroarchBeforeFailure), "failed keymap change mutated RetroArch config")) { return 1; }

    if (!e2eRunOk(e2eRunLifecycle(exe, home, "uninstall", project, ""), "uninstall")) { return 1; }
    if (!e2eOk(!FileSystem.exists(joinPath(home, ".local/share/applications/semu.desktop")), "desktop entry should be removed by uninstall")) { return 1; }
    if (!e2eOk(!FileSystem.exists(joinPath(home, ".config/systemd/user/semu-syncthing.service")), "systemd service should be removed by uninstall")) { return 1; }
    if (!e2eOk(FileSystem.exists(syncConfigPath(project)), "sync config should survive uninstall")) { return 1; }
    if (!e2eOk(FileSystem.exists(joinPath(contentRoot(project), "saves/gba/game.sav")), "save should survive uninstall")) { return 1; }
    if (!e2eOk(FileSystem.exists(joinPath(biosRoot(project), "ps2/ps2-0230a-20080220.bin")), "BIOS should survive uninstall")) { return 1; }

    if (!e2eRunOk(e2eRunLifecycle(exe, home, "reinstall", project, ""), "reinstall")) { return 1; }
    if (!e2eOk(FileSystem.exists(joinPath(home, ".local/share/applications/semu.desktop")), "desktop entry missing after reinstall")) { return 1; }
    if (!e2eContains(FileSystem.readText(syncConfigPath(project)), romsTwo, "sync config after reinstall")) { return 1; }

    FileSystem.writeText(joinPath(project, "semu.json"), "{\"legacy\": true}\n");
    if (!e2eRunOk(e2eRunLifecycle(exe, home, "upgrade", project, ""), "upgrade")) { return 1; }
    if (!e2eContains(FileSystem.readText(upgradeBackupPath(project)), "\"legacy\": true", "upgrade backup")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(project, "semu.json")), "\"schema_version\": 1", "regenerated manifest")) { return 1; }
    if (!e2eContains(FileSystem.readText(keymapSourcePath(project)), "action state.save = Ctrl+V", "keymap should survive upgrade")) { return 1; }

    if (!e2eRunOk(e2eRunLifecycleArgs(exe, home, project, ["uninstall", "--purge-generated", "--purge-state"]), "purge uninstall")) { return 1; }
    if (!e2eOk(!FileSystem.exists(joinPath(project, "ES-DE/custom_systems")), "custom systems should be purged")) { return 1; }
    if (!e2eOk(!FileSystem.exists(lifecycleStatePath(project)), "lifecycle state should be purged")) { return 1; }

    print("OK BTRC lifecycle smoke");
    return 0;
}

int e2eLauncherSmoke(CliArgs args) {
    string tmp = e2eTempDir("semu-launcher-smoke");
    string project = joinPath(tmp, "project");
    string roms = joinPath(tmp, "roms");
    string home = joinPath(tmp, "home");
    string capture = joinPath(tmp, "capture");
    string binDir = joinPath(tmp, "bin");
    string exe = Environment.get("SEMU_BIN", args.program);
    ensureDir(project);
    ensureDir(roms);
    ensureDir(home);
    ensureDir(capture);
    ensureDir(binDir);

    string fakeFlatpak = joinPath(binDir, "flatpak");
    FileSystem.writeText(fakeFlatpak,
        "#!/usr/bin/env sh\n"
        + "set -eu\n"
        + "capture=\"${SEMU_FLATPAK_CAPTURE:?}\"\n"
        + "mkdir -p \"$capture\"\n"
        + "idx=\"$(find \"$capture\" -type f -name 'flatpak-*.args' | wc -l | tr -d ' ')\"\n"
        + "idx=\"$((idx + 1))\"\n"
        + "printf '%s\\n' \"$@\" > \"$capture/flatpak-$idx.args\"\n"
    );
    FileSystem.chmod(fakeFlatpak, 493);

    string fakeBwrap = joinPath(binDir, "bwrap");
    FileSystem.writeText(fakeBwrap,
        "#!/usr/bin/env sh\n"
        + "set -eu\n"
        + "printf '%s\\n' \"$@\" > \"${SEMU_FLATPAK_CAPTURE:?}/retroarch.args\"\n"
    );
    FileSystem.chmod(fakeBwrap, 493);

    string fakeGrim = joinPath(binDir, "grim");
    FileSystem.writeText(fakeGrim,
        "#!/usr/bin/env sh\n"
        + "set -eu\n"
        + "out=\"${1:?}\"\n"
        + "mkdir -p \"$(dirname \"$out\")\"\n"
        + "printf 'fake screenshot %s\\n' \"$out\" > \"$out\"\n"
        + "printf '%s\\n' \"$out\" >> \"${SEMU_FLATPAK_CAPTURE:?}/grim.log\"\n"
    );
    FileSystem.chmod(fakeGrim, 493);

    if (!e2eRunOk(e2eRunLauncher(exe, home, project, roms, binDir, capture, fakeBwrap, "cemu", ["game.wua"]), "launcher cemu")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-1.args")), "run", "cemu flatpak args")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-1.args")), "--filesystem=" + project, "cemu project grant")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-1.args")), "--filesystem=" + roms, "cemu rom grant")) { return 1; }
    string cemuState = launcherFlatpakStateRoot(project, "cemu");
    if (!e2eOk(FileSystem.isDir(joinPath(cemuState, "config")), "cemu flatpak config state missing")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-1.args")), "--filesystem=" + cemuState + ":create", "cemu state grant")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-1.args")), "--env=XDG_CONFIG_HOME=" + joinPath(cemuState, "config"), "cemu config env")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-1.args")), "--socket=wayland", "cemu wayland")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-1.args")), "info.cemu.Cemu", "cemu flatpak id")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-1.args")), "game.wua", "cemu rom arg")) { return 1; }
    string cemuScreens = joinPath(contentRoot(project), "screenshots/verification/cemu");
    if (!e2eOk(FileSystem.exists(joinPath(cemuScreens, "before_launch.png")), "cemu before_launch screenshot missing")) { return 1; }
    if (!e2eWaitForFile(joinPath(cemuScreens, "after_spawn.png"), "cemu after_spawn screenshot")) { return 1; }
    if (!e2eOk(FileSystem.exists(joinPath(cemuScreens, "after_exit.png")), "cemu after_exit screenshot missing")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(cemuScreens, "after_exit.png")), "fake screenshot", "cemu screenshot content")) { return 1; }

    if (!e2eRunOk(e2eRunLauncher(exe, home, project, roms, binDir, capture, fakeBwrap, "dolphin", ["game.iso"]), "launcher dolphin")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-2.args")), "--socket=x11", "dolphin x11")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-2.args")), "org.DolphinEmu.dolphin-emu", "dolphin flatpak id")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-2.args")), "-b", "dolphin boot flag")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-2.args")), "-e", "dolphin execute flag")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-2.args")), "game.iso", "dolphin rom arg")) { return 1; }

    if (!e2eRunOk(e2eRunLauncher(exe, home, project, roms, binDir, capture, fakeBwrap, "azahar", ["game.3ds"]), "launcher azahar")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-3.args")), "--socket=x11", "azahar x11")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-3.args")), "org.azahar_emu.Azahar", "azahar flatpak id")) { return 1; }

    if (!e2eRunOk(e2eRunLauncher(exe, home, project, roms, binDir, capture, fakeBwrap, "pcsx2", ["game.iso"]), "launcher pcsx2")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-4.args")), "--socket=wayland", "pcsx2 wayland")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-4.args")), "net.pcsx2.PCSX2", "pcsx2 flatpak id")) { return 1; }

    if (!e2eRunOk(e2eRunLauncher(exe, home, project, roms, binDir, capture, fakeBwrap, "ryujinx", ["game.nsp"]), "launcher ryujinx")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-5.args")), "org.ryujinx.Ryujinx", "ryujinx flatpak id")) { return 1; }

    if (!e2eRunOk(e2eRunLauncher(exe, home, project, roms, binDir, capture, fakeBwrap, "ppsspp", ["game.iso"]), "launcher ppsspp")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-6.args")), "org.ppsspp.PPSSPP", "ppsspp flatpak id")) { return 1; }

    if (!e2eRunOk(e2eRunLauncher(exe, home, project, roms, binDir, capture, fakeBwrap, "flycast", ["game.chd"]), "launcher flycast")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-7.args")), "org.flycast.Flycast", "flycast flatpak id")) { return 1; }

    if (!e2eRunOk(e2eRunLauncher(exe, home, project, roms, binDir, capture, fakeBwrap, "gopher64", ["game.z64"]), "launcher gopher64")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-8.args")), "io.github.gopher64.gopher64", "gopher64 flatpak id")) { return 1; }

    if (!e2eRunOk(e2eRunLauncher(exe, home, project, roms, binDir, capture, fakeBwrap, "melonds", ["game.nds"]), "launcher melonds")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "flatpak-9.args")), "net.kuribo64.melonDS", "melonds flatpak id")) { return 1; }

    e2eSeedFile(emulatorProfilePath(project, "RetroArch/config/input.cfg"));
    e2eSeedFile(emulatorProfilePath(project, "RetroArch/retroarch.cfg"));
    if (!e2eRunOk(e2eRunLauncher(exe, home, project, roms, binDir, capture, fakeBwrap, "retroarch", ["-L", "core.so", "game.gba"]), "launcher retroarch")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "retroarch.args")), "/usr/bin/retroarch", "retroarch executable")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "retroarch.args")), "-L", "retroarch core flag")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "retroarch.args")), "core.so", "retroarch core arg")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "retroarch.args")), "game.gba", "retroarch rom arg")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "retroarch.args")), "--ro-bind-try", "retroarch rom bind")) { return 1; }
    string retroScreens = joinPath(contentRoot(project), "screenshots/verification/retroarch");
    if (!e2eOk(FileSystem.exists(joinPath(retroScreens, "before_launch.png")), "retroarch before_launch screenshot missing")) { return 1; }
    if (!e2eWaitForFile(joinPath(retroScreens, "after_spawn.png"), "retroarch after_spawn screenshot")) { return 1; }
    if (!e2eOk(FileSystem.exists(joinPath(retroScreens, "after_exit.png")), "retroarch after_exit screenshot missing")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "grim.log")), "screenshots/verification/retroarch/after_exit.png", "retroarch screenshot hook log")) { return 1; }

    print("OK BTRC launcher smoke");
    return 0;
}

void e2eWriteSyncFakes(string binDir) {
    string fakeSystemctl = joinPath(binDir, "systemctl");
    FileSystem.writeText(fakeSystemctl,
        "#!/usr/bin/env sh\n"
        + "set -eu\n"
        + "mkdir -p \"${SEMU_CAPTURE:?}\"\n"
        + "printf '%s\\n' \"$*\" >> \"$SEMU_CAPTURE/systemctl.log\"\n"
    );
    FileSystem.chmod(fakeSystemctl, 493);

    string fakeCurl = joinPath(binDir, "curl");
    FileSystem.writeText(fakeCurl,
        "#!/usr/bin/env sh\n"
        + "set -eu\n"
        + "mkdir -p \"${SEMU_CAPTURE:?}\"\n"
        + "printf '%s\\n' \"$*\" >> \"$SEMU_CAPTURE/curl.log\"\n"
    );
    FileSystem.chmod(fakeCurl, 493);

    string fakeSyncthing = joinPath(binDir, "syncthing");
    FileSystem.writeText(fakeSyncthing,
        "#!/usr/bin/env sh\n"
        + "set -eu\n"
        + "mkdir -p \"${SEMU_CAPTURE:?}\"\n"
        + "printf '%s\\n' \"$*\" >> \"$SEMU_CAPTURE/syncthing.log\"\n"
        + "if [ \"${1:-}\" = generate ]; then\n"
        + "  home=\"\"\n"
        + "  while [ $# -gt 0 ]; do\n"
        + "    if [ \"$1\" = -H ]; then home=\"$2\"; shift 2; else shift; fi\n"
        + "  done\n"
        + "  mkdir -p \"$home\"\n"
        + "  printf '<configuration><gui><apikey>test-key</apikey></gui></configuration>\\n' > \"$home/config.xml\"\n"
        + "  exit 0\n"
        + "fi\n"
        + "exit 0\n"
    );
    FileSystem.chmod(fakeSyncthing, 493);
}

int e2eSyncSmoke(CliArgs args) {
    string tmp = e2eTempDir("semu-sync-smoke");
    string project = joinPath(tmp, "project");
    string missingProject = joinPath(tmp, "missing-project");
    string home = joinPath(tmp, "home");
    string binDir = joinPath(tmp, "bin");
    string capture = joinPath(tmp, "capture");
    string exe = Environment.get("SEMU_BIN", args.program);
    ensureDir(project);
    ensureDir(missingProject);
    ensureDir(home);
    ensureDir(binDir);
    ensureDir(capture);
    e2eWriteSyncFakes(binDir);

    if (!e2eRunOk(e2eRunSync(exe, home, binDir, project, ["setup"]), "sync setup")) { return 1; }
    string systemctlLog = FileSystem.readText(joinPath(capture, "systemctl.log"));
    if (!e2eContains(systemctlLog, "--user daemon-reload", "sync daemon-reload")) { return 1; }
    if (!e2eContains(systemctlLog, "--user enable semu-syncthing.service", "sync enable service")) { return 1; }
    if (!e2eContains(systemctlLog, "--user enable semu-sync-force.timer", "sync enable timer")) { return 1; }
    if (!e2eContains(systemctlLog, "--user start semu-syncthing.service", "sync start service")) { return 1; }
    if (!e2eContains(FileSystem.readText(joinPath(capture, "syncthing.log")), "semu-emulator_state", "sync emulator state folder")) { return 1; }

    if (!e2eRunOk(e2eRunSync(exe, home, binDir, project, ["force", "all"]), "sync force all")) { return 1; }
    if (!e2eRunOk(e2eRunSync(exe, home, binDir, project, ["force", "saves"]), "sync force saves")) { return 1; }
    string curlLog = FileSystem.readText(joinPath(capture, "curl.log"));
    if (!e2eContains(curlLog, "/rest/db/scan", "sync force all url")) { return 1; }
    if (!e2eContains(curlLog, "?folder=semu-saves", "sync force saves url")) { return 1; }
    if (!e2eContains(curlLog, "X-API-Key: test-key", "sync force api key")) { return 1; }

    if (!e2eRunOk(e2eRunSync(exe, home, binDir, project, ["autostart", "disable"]), "sync autostart disable")) { return 1; }
    if (!e2eRunOk(e2eRunSync(exe, home, binDir, project, ["autostart", "enable"]), "sync autostart enable")) { return 1; }
    systemctlLog = FileSystem.readText(joinPath(capture, "systemctl.log"));
    if (!e2eContains(systemctlLog, "--user disable semu-syncthing.service", "sync disable service")) { return 1; }
    if (!e2eContains(systemctlLog, "--user enable semu-syncthing.service", "sync re-enable service")) { return 1; }

    if (!e2eOk(!e2eRunSync(exe, home, binDir, missingProject, ["force", "all"]).ok(), "sync force without API key unexpectedly succeeded")) { return 1; }

    print("OK BTRC sync smoke");
    return 0;
}

bool e2eWriteFakeN3dsRom(string path, bool noCrypto, bool decrypted) {
    ensureDir(PathTools.dirname(path));
    BinaryEditor editor = BinaryEditor(path, "w+b");
    if (!editor.ok()) { return false; }
    bool ok = true;
    long partOffset = 0x200;
    ok = ok && editor.writeAscii(0x100, "NCSD");
    ok = ok && editor.writeLe32(0x120, 1);
    ok = ok && editor.writeLe32(0x124, 4);
    ok = ok && editor.writeAscii(partOffset + 0x100, "NCCH");
    ok = ok && editor.writeU8(partOffset + 0x100 + 0x8b, noCrypto ? 0 : 1);
    ok = ok && editor.writeU8(partOffset + 0x100 + 0x8f, noCrypto ? 4 : 0);
    ok = ok && editor.writeLe32(partOffset + 0x100 + 0xa0, 1);
    ok = ok && editor.writeAscii(partOffset + 0x200, decrypted ? ".code" : "cipher");
    editor.close();
    return ok;
}

ExecResult e2eRunN3dsNoCrypto(string exe, string input, string outputDir, Vector<string> extraArgs) {
    Command command = Command(exe)
        .envVar("SEMU_BIN", exe)
        .envVar("PATH", "/usr/bin:/bin")
        .arg("utils")
        .arg("n3ds-nocrypto")
        .arg(input)
        .capture(true)
        .check(false);
    if (outputDir.len() > 0) {
        command.flag("-o", outputDir);
    }
    for arg in extraArgs {
        command.arg(arg);
    }
    UnixShell shell = UnixShell();
    ExecResult result = shell.runCommand(command);
    return result;
}

int e2eN3dsNoCryptoSmoke(CliArgs args) {
    string tmp = e2eTempDir("semu-n3ds-nocrypto-smoke");
    string input = joinPath(tmp, "input");
    string output = joinPath(tmp, "output");
    string exe = Environment.get("SEMU_BIN", args.program);
    ensureDir(input);
    ensureDir(output);
    string needsPath = joinPath(input, "needs.3ds");
    string okPath = joinPath(input, "already-ok.3ds");
    if (!e2eOk(e2eWriteFakeN3dsRom(needsPath, false, true), "fake needs-fix 3DS ROM")) { return 1; }
    if (!e2eOk(e2eWriteFakeN3dsRom(okPath, true, true), "fake OK 3DS ROM")) { return 1; }

    ExecResult check = e2eRunN3dsNoCrypto(exe, input, "", ["--check"]);
    if (!e2eRunOk(check, "n3ds-nocrypto check")) { return 1; }
    if (!e2eContains(check.stdout(), "NEEDS FIX: needs.3ds", "n3ds-nocrypto check output")) { return 1; }
    if (!e2eContains(check.stdout(), "OK:        already-ok.3ds", "n3ds-nocrypto OK output")) { return 1; }

    Vector<string> noArgs = [];
    if (!e2eRunOk(e2eRunN3dsNoCrypto(exe, input, output, noArgs), "n3ds-nocrypto fix")) { return 1; }
    string fixedPath = joinPath(output, "needs.3ds");
    N3dsRomCheck fixed = checkN3dsRom(fixedPath);
    if (!e2eOk(fixed.status.equals("OK"), "fixed fake ROM should be OK")) { return 1; }
    BinaryReader reader = BinaryReader(fixedPath);
    int flags = reader.readU8(0x200 + 0x100 + 0x8f);
    int cryptoMethod = reader.readU8(0x200 + 0x100 + 0x8b);
    reader.close();
    if (!e2eOk(n3dsNoCryptoFlag(flags), "fixed fake ROM NoCrypto flag missing")) { return 1; }
    if (!e2eOk(cryptoMethod == 0, "fixed fake ROM crypto method not cleared")) { return 1; }
    if (!e2eOk(checkN3dsRom(joinPath(output, "already-ok.3ds")).status.equals("OK"), "already OK fake ROM copy")) { return 1; }

    print("OK BTRC n3ds-nocrypto smoke");
    return 0;
}

void e2eFatal(string message) {
    print("error 0:0 " + message);
    exit(1);
}

string e2eExpandArgs(string text, Map<string, string> args) {
    return JsonText.expand(text, args);
}

class SemuE2eOperation {
    public string kind;
    public string command;
    public string expect;
    public string name;
    public string path;
    public int timeout;

    public SemuE2eOperation() {
        self.kind = "";
        self.command = "";
        self.expect = "";
        self.name = "";
        self.path = "";
        self.timeout = 300;
    }

    public void expandArgs(Map<string, string> args) {
        self.kind = e2eExpandArgs(self.kind, args);
        self.command = e2eExpandArgs(self.command, args);
        self.expect = e2eExpandArgs(self.expect, args);
        self.name = e2eExpandArgs(self.name, args);
        self.path = e2eExpandArgs(self.path, args);
    }
}

class SemuE2eSpec {
    public string name;
    public string state;
    public string parentState;
    public string stateRoot;
    public string stateMaterial;
    public string parentHash;
    public string stateHash;
    public string stateHashShort;
    public Map<string, string> args;
    public Vector<SemuE2eOperation> operations;

    public SemuE2eSpec() {
        self.name = "semu-e2e";
        self.state = "semu-e2e";
        self.parentState = "root";
        self.stateRoot = "tests/vms/e2e-state";
        self.stateMaterial = "";
        self.parentHash = "root";
        self.stateHash = "";
        self.stateHashShort = "";
        self.args = {};
        self.operations = [];
    }

    public void setArg(string key, string value) {
        self.args.put(key, value);
    }

    public void setArgPair(string pair) {
        int pos = Strings.find(pair, "=", 0);
        if (pos <= 0) { e2eFatal("Expected --arg key=value, got " + pair); }
        self.args.put(pair.substring(0, pos), pair.substring(pos + 1, pair.len() - pos - 1));
    }

    public string stateDir() {
        return joinPath(self.stateRoot, self.state);
    }

    public string stateHashFile() {
        return joinPath(self.stateDir(), "hash");
    }

    public string parentHashFile() {
        return joinPath(joinPath(self.stateRoot, self.parentState), "hash");
    }

    public string resolveParentHash() {
        if (self.parentState.equals("root") || self.parentState.len() == 0) {
            return "root";
        }
        if (FileSystem.exists(self.parentHashFile())) {
            return FileSystem.readText(self.parentHashFile()).trim();
        }
        return "missing:" + self.parentState;
    }

    public string operationsMaterial() {
        Vector<string> lines = [];
        for op in self.operations {
            lines.push("op=" + op.kind);
            lines.push("name=" + op.name);
            lines.push("command=" + op.command);
            lines.push("expect=" + op.expect);
            lines.push("path=" + op.path);
            lines.push("timeout=" + Strings.fromInt(op.timeout));
        }
        return lines.join("\n");
    }

    public string hashMaterial() {
        string material = self.stateMaterial;
        if (material.len() == 0) {
            material = self.name;
        }
        return "parent=" + self.parentHash
            + "\nstate=" + self.state
            + "\nmaterial=" + material
            + "\noperations=\n" + self.operationsMaterial()
            + "\n";
    }

    public void computeStateHash() {
        self.parentHash = self.resolveParentHash();
        string command = "printf %s " + ShellWords.quote(self.hashMaterial())
            + " | (if command -v sha256sum >/dev/null 2>&1; then sha256sum; else shasum -a 256; fi)"
            + " | awk '{print $1}'";
        ExecResult result = UnixShell().runRaw(command, true, false, "");
        if (!result.ok()) { e2eFatal("Failed to compute E2E state hash for " + self.state); }
        self.stateHash = result.trimmed();
        self.stateHashShort = self.stateHash.substring(0, 12);
    }

    public void setDerivedArgs() {
        self.args.putIfAbsent("name", self.name);
        self.args.putIfAbsent("state", self.state);
        self.args.putIfAbsent("parentState", self.parentState);
        self.args.putIfAbsent("stateRoot", self.stateRoot);
        self.args.putIfAbsent("stateMaterial", self.stateMaterial);
        self.args.putIfAbsent("parentHash", self.parentHash);
        self.args.putIfAbsent("stateHash", self.stateHash);
        self.args.putIfAbsent("stateHashShort", self.stateHashShort);
    }

    public void refreshDerivedArgs() {
        self.args.put("name", self.name);
        self.args.put("state", self.state);
        self.args.put("parentState", self.parentState);
        self.args.put("stateRoot", self.stateRoot);
        self.args.put("stateMaterial", self.stateMaterial);
        self.args.put("parentHash", self.parentHash);
        self.args.put("stateHash", self.stateHash);
        self.args.put("stateHashShort", self.stateHashShort);
    }

    public void expandArgs() {
        self.setDerivedArgs();
        self.name = e2eExpandArgs(self.name, self.args);
        self.state = e2eExpandArgs(self.state, self.args);
        self.parentState = e2eExpandArgs(self.parentState, self.args);
        self.stateRoot = e2eExpandArgs(self.stateRoot, self.args);
        self.stateMaterial = e2eExpandArgs(self.stateMaterial, self.args);
        self.refreshDerivedArgs();
        self.computeStateHash();
        self.refreshDerivedArgs();
        for op in self.operations {
            op.expandArgs(self.args);
        }
    }

    public void recordState() {
        ensureDir(self.stateDir());
        FileSystem.writeText(self.stateHashFile(), self.stateHash + "\n");
        FileSystem.writeText(
            joinPath(self.stateDir(), "metadata.json"),
            jsonObject([
                jsonStrField("state", self.state),
                jsonStrField("parentState", self.parentState),
                jsonStrField("parentHash", self.parentHash),
                jsonStrField("hash", self.stateHash),
                jsonStrField("hashShort", self.stateHashShort)
            ]) + "\n"
        );
    }
}

class SemuE2eParser {
    class int skipSpaces(string text, int i) {
        return JsonText.skipSpaces(text, i);
    }

    class int keyPosition(string text, string key) {
        return JsonText.keyPosition(text, key);
    }

    class string parseStringValue(string text, int i, string fallback) {
        return JsonText.parseStringValue(text, i, fallback);
    }

    class string field(string text, string key, string fallback) {
        return JsonText.field(text, key, fallback);
    }

    class int intField(string text, string key, int fallback) {
        return JsonText.intField(text, key, fallback);
    }

    class string objectField(string text, string key) {
        return JsonText.objectField(text, key);
    }

    class Vector<string> stringArray(string text, string key) {
        return JsonText.stringArray(text, key);
    }

    class Vector<string> objectArray(string text, string key) {
        return JsonText.objectArray(text, key);
    }

    class Map<string, string> argsObject(string text) {
        return JsonText.argsObject(text);
    }

    class SemuE2eOperation operation(string objectText) {
        SemuE2eOperation op = SemuE2eOperation();
        op.kind = SemuE2eParser.field(objectText, "op", "");
        if (op.kind.len() == 0) {
            op.kind = SemuE2eParser.field(objectText, "kind", "");
        }
        op.command = SemuE2eParser.field(objectText, "command", "");
        op.expect = SemuE2eParser.field(objectText, "expect", "");
        op.name = SemuE2eParser.field(objectText, "name", "");
        op.path = SemuE2eParser.field(objectText, "path", "");
        op.timeout = SemuE2eParser.intField(objectText, "timeout", 300);
        return op;
    }

    class Vector<SemuE2eOperation> operations(string text) {
        Vector<SemuE2eOperation> result = [];
        for objectText in SemuE2eParser.objectArray(text, "operations") {
            result.push(SemuE2eParser.operation(objectText));
        }
        return result;
    }

    class SemuE2eSpec readSpecFile(string path) {
        string text = FileSystem.readText(path);
        SemuE2eSpec spec = SemuE2eSpec();
        spec.name = SemuE2eParser.field(text, "name", spec.name);
        spec.state = SemuE2eParser.field(text, "state", spec.name);
        spec.parentState = SemuE2eParser.field(text, "parentState", spec.parentState);
        spec.stateRoot = SemuE2eParser.field(text, "stateRoot", spec.stateRoot);
        spec.stateMaterial = SemuE2eParser.field(text, "stateMaterial", spec.stateMaterial);
        spec.args = SemuE2eParser.argsObject(text);
        spec.operations = SemuE2eParser.operations(text);
        return spec;
    }

    class ExecutionGraph readGraphFile(string path) {
        return GraphParser.readFile(path);
    }
}

Vector<string> semuE2eOperationCatalog() {
    Vector<string> kinds = [];
    kinds.push("require-command");
    kinds.push("artifact");
    kinds.push("host");
    kinds.push("make");
    kinds.push("payload-audit");
    return kinds;
}

int e2ePayloadAudit(string project) {
    string forbidden = "'^(Azahar|Cemu|Dolphin|ES-DE|Lime3DS|PCSX2|RetroArch|Ryujinx)(/|$)|(^|/)(ROMs|bios|BIOS|saves|states|nand|sdmc|sdcard|mlc01|originals)(/|$)|\\.(3ds|3dz|cia|cci|cxi|nds|nsp|xci|iso|chd|rvz|wad|wua|wud|ciso|gcz|wbfs|elf|dol|bin|cue|img|qcow2|fd|pkg|rap|z64|n64|v64|sfc|smc|gba|gbc|gb|nes|7z|zip|rar|appimage|AppImage|dmg|keys)$'";
    string command = "cd " + ShellWords.quote(project)
        + " && bad=$(git ls-files | LC_ALL=C grep -E " + forbidden + " || true)"
        + " && if [ -n \"$bad\" ]; then printf 'Forbidden tracked payloads:\\n%s\\n' \"$bad\"; exit 1; fi";
    ExecResult result = UnixShell().runRaw(command, true, false, "");
    if (!result.ok()) {
        print(result.stdout());
        return 1;
    }
    print("OK payload audit");
    return 0;
}

class SemuE2eRunner {
    public SemuE2eSpec spec;
    public string workspaceRoot;
    public string program;
    public int failures;

    public SemuE2eRunner(SemuE2eSpec spec, string workspaceRoot, string program) {
        self.spec = spec;
        self.workspaceRoot = workspaceRoot;
        self.program = program;
        self.failures = 0;
    }

    public void fail(string message) {
        self.failures++;
        print("E2E FAIL " + self.spec.name + ": " + message);
    }

    public bool outputMatches(ExecResult result, string expect) {
        if (expect.len() == 0) { return true; }
        return result.stdout().contains(expect);
    }

    public void assertResult(string label, ExecResult result, string expect) {
        if (!result.ok()) {
            print(result.stdout());
            self.fail(label + " failed with exit code " + Strings.fromInt(result.code));
            return;
        }
        if (!self.outputMatches(result, expect)) {
            print(result.stdout());
            self.fail(label + " output did not contain expected text: " + expect);
        }
    }

    public ExecResult runWorkspaceCommand(string command) {
        string rendered = "cd " + ShellWords.quote(self.workspaceRoot) + " && " + command + " 2>&1";
        return UnixShell().runRaw(rendered, true, false, "");
    }

    public void runOperation(SemuE2eOperation op) {
        print("e2e " + self.spec.name + ": " + op.kind);
        if (op.kind.equals("require-command")) {
            ExecResult result = self.runWorkspaceCommand("command -v " + ShellWords.quote(op.command));
            self.assertResult("require command " + op.command, result, op.expect);
            return;
        }
        if (op.kind.equals("artifact")) {
            ExecResult result = self.runWorkspaceCommand("test -e " + ShellWords.quote(op.path) + " && printf exists");
            self.assertResult("artifact " + op.path, result, op.expect.len() > 0 ? op.expect : "exists");
            return;
        }
        if (op.kind.equals("host")) {
            ExecResult result = self.runWorkspaceCommand(op.command);
            self.assertResult("host command", result, op.expect);
            return;
        }
        if (op.kind.equals("make")) {
            ExecResult result = self.runWorkspaceCommand("make " + op.command);
            self.assertResult("make " + op.command, result, op.expect);
            return;
        }
        if (op.kind.equals("payload-audit")) {
            int status = e2ePayloadAudit(self.workspaceRoot);
            if (status != 0) { self.fail("payload audit failed"); }
            return;
        }
        self.fail("Unknown E2E operation: " + op.kind);
    }

    public int run() {
        if (self.spec.operations.isEmpty()) {
            e2eFatal("E2E spec has no operations: " + self.spec.name);
        }
        for op in self.spec.operations {
            if (self.failures > 0) { break; }
            self.runOperation(op);
        }
        if (self.failures > 0) { return 1; }
        self.spec.recordState();
        return 0;
    }
}

class SemuE2eGraphRunner {
    public ExecutionGraph graph;
    public Map<string, string> args;
    public string sourceHashValue;
    public string program;

    public SemuE2eGraphRunner(ExecutionGraph graph, Map<string, string> args, string program) {
        self.graph = graph;
        self.args = args;
        self.sourceHashValue = "";
        self.program = program;
    }

    public string sourceHash() {
        if (self.sourceHashValue.len() > 0) { return self.sourceHashValue; }
        string root = self.graph.resolvedWorkspaceRoot();
        string command = "cd " + ShellWords.quote(root)
            + " && find . -type f"
            + " ! -path './.git/*'"
            + " ! -path './.semu/*'"
            + " ! -path './.venv/*'"
            + " ! -path './.pytest_cache/*'"
            + " ! -path './.stfolder/*'"
            + " ! -path './tests/vms/*'"
            + " ! -path './build/*'"
            + " ! -path './backups/*'"
            + " ! -path './result/*'"
            + " ! -path './result-*/*'"
            + " ! -path './Azahar/*'"
            + " ! -path './Cemu/*'"
            + " ! -path './Dolphin/*'"
            + " ! -path './ES-DE/*'"
            + " ! -path './Lime3DS/*'"
            + " ! -path './PCSX2/*'"
            + " ! -path './RetroArch/*'"
            + " ! -path './Ryujinx/*'"
            + " ! -path './ES-DE/ES-DE/ROMs/*'"
            + " ! -path './ES-DE/ES-DE/bios/*'"
            + " ! -path './ES-DE/ES-DE/saves/*'"
            + " ! -path './ES-DE/ES-DE/states/*'"
            + " ! -path './ES-DE/ES-DE/downloaded_media/*'"
            + " ! -path './ES-DE/ES-DE/screenshots/*'"
            + " ! -path './sync/bin/*'"
            + " ! -path './sync/logs/*'"
            + " ! -path './sync/syncthing/*'"
            + " ! -name '.DS_Store'"
            + " ! -name '._*'"
            + " \\( -name '*.btrc' -o -name '*.nix' -o -name '*.json' -o -name '*.sh' -o -name '*.md' -o -name '*.xml' -o -name '*.ini' -o -name '*.cfg' -o -name '*.desktop' -o -name '*.vdf' -o -name '*.skm' -o -name '*.c' -o -name 'Makefile' -o -name 'Dockerfile' -o -name 'flake.lock' \\)"
            + " -print0 | LC_ALL=C sort -z | xargs -0 shasum -a 256 | shasum -a 256 | awk '{print $1}'";
        ExecResult result = UnixShell().runRaw(command, true, false, "");
        if (!result.ok()) { e2eFatal("Failed to compute workspace source hash for " + root); }
        string toolHash = "missing";
        if (self.program.len() > 0 && FileSystem.exists(self.program)) {
            ExecResult tool = UnixShell().runRaw("shasum -a 256 " + ShellWords.quote(self.program) + " | awk '{print $1}'", true, false, "");
            if (tool.ok()) { toolHash = tool.trimmed(); }
        }
        self.sourceHashValue = result.trimmed() + ":semu=" + toolHash;
        return self.sourceHashValue;
    }

    public void applyStructuralOverrides(SemuE2eSpec spec, Map<string, string> overrides) {
        if (overrides.has("name")) { spec.name = overrides.get("name"); }
        if (overrides.has("state")) { spec.state = overrides.get("state"); }
        if (overrides.has("parentState")) { spec.parentState = overrides.get("parentState"); }
        if (overrides.has("stateRoot")) { spec.stateRoot = overrides.get("stateRoot"); }
        if (overrides.has("stateMaterial")) { spec.stateMaterial = overrides.get("stateMaterial"); }
    }

    public SemuE2eSpec specFor(GraphNode node) {
        SemuE2eSpec spec = SemuE2eParser.readSpecFile(self.graph.resolvedSpecPath(node));
        spec.setArg("graphName", self.graph.name);
        spec.setArg("nodeId", node.id);
        spec.setArg("workspaceRoot", self.graph.resolvedWorkspaceRoot());
        spec.setArg("sourceHash", self.sourceHash());
        spec.setArg("program", self.program);
        self.applyStructuralOverrides(spec, node.args);
        self.applyStructuralOverrides(spec, self.args);
        for key, value in node.args {
            spec.setArg(key, value);
        }
        for key, value in self.args {
            spec.setArg(key, value);
        }
        spec.expandArgs();
        return spec;
    }

    public bool force() {
        return self.args.getOrDefault("force", "false").equals("true");
    }

    public bool ready(SemuE2eSpec spec) {
        if (!FileSystem.exists(spec.stateHashFile())) { return false; }
        return FileSystem.readText(spec.stateHashFile()).trim().equals(spec.stateHash);
    }

    public void list() {
        GraphReport.list(self.graph);
    }

    public void status() {
        for node in self.graph.nodes {
            SemuE2eSpec spec = self.specFor(node);
            string recorded = "missing";
            if (FileSystem.exists(spec.stateHashFile())) {
                string saved = FileSystem.readText(spec.stateHashFile()).trim();
                recorded = saved.equals(spec.stateHash) ? "ready" : "stale";
            }
            print(node.id + " " + recorded + " " + spec.stateHashShort + " " + spec.stateDir());
        }
    }

    public int operationCoverage() {
        Vector<string> covered = [];
        for node in self.graph.nodes {
            SemuE2eSpec spec = SemuE2eParser.readSpecFile(self.graph.resolvedSpecPath(node));
            for op in spec.operations {
                if (op.kind.len() > 0 && !covered.contains(op.kind)) {
                    covered.push(op.kind);
                }
            }
        }
        Vector<string> missing = [];
        Vector<string> catalog = semuE2eOperationCatalog();
        for kind in catalog {
            if (!covered.contains(kind)) {
                missing.push(kind);
            }
        }
        if (!missing.isEmpty()) {
            print("Missing e2e operation coverage: " + missing.join(", "));
            return 1;
        }
        print("E2E operation coverage: " + Strings.fromInt(covered.len) + "/" + Strings.fromInt(catalog.len));
        return 0;
    }

    public int run(Vector<string> targets) {
        GraphTraversal traversal = GraphTraversal(self.graph);
        Vector<string> order = traversal.order(targets);
        if (!traversal.ok()) { e2eFatal(traversal.error); }

        for id in order {
            GraphNode node = self.graph.node(id);
            SemuE2eSpec spec = self.specFor(node);
            if (!self.force() && self.ready(spec)) {
                print("graph " + self.graph.name + ": skip " + node.id + " -> " + spec.state + "@" + spec.stateHashShort);
                continue;
            }
            print("graph " + self.graph.name + ": run " + node.id + " -> " + spec.state + "@" + spec.stateHashShort);
            SemuE2eRunner runner = SemuE2eRunner(spec, self.graph.resolvedWorkspaceRoot(), self.program);
            int result = runner.run();
            if (result != 0) { return result; }
        }
        return 0;
    }
}

Map<string, string> e2eGraphArgs(CliArgs args, int startIndex) {
    return GraphCli.args(args, startIndex);
}

Vector<string> e2eGraphTargets(CliArgs args, int startIndex) {
    return GraphCli.targets(args, startIndex);
}

int e2eGraphCommand(CliArgs args) {
    if (args.count() < 4) {
        print("Usage: semu e2e graph <graph.json> <list|status|coverage|run> [node ...] [--arg key=value]");
        return 1;
    }
    ExecutionGraph graph = SemuE2eParser.readGraphFile(args.get(2));
    string action = args.get(3);
    Map<string, string> overrides = e2eGraphArgs(args, 4);
    SemuE2eGraphRunner runner = SemuE2eGraphRunner(graph, overrides, args.program);
    if (action.equals("list")) {
        runner.list();
        return 0;
    }
    if (action.equals("status")) {
        runner.status();
        return 0;
    }
    if (action.equals("coverage")) {
        return runner.operationCoverage();
    }
    if (action.equals("run")) {
        return runner.run(e2eGraphTargets(args, 4));
    }
    print("Usage: semu e2e graph <graph.json> <list|status|coverage|run> [node ...] [--arg key=value]");
    return 1;
}

int e2eCommand(CliArgs args) {
    string mode = "all";
    if (args.count() > 1 && !args.get(1).startsWith("--")) {
        mode = args.get(1);
    }
    if (mode.equals("graph")) {
        return e2eGraphCommand(args);
    }
    if (mode.equals("payload-audit")) {
        return e2ePayloadAudit(args.valueAfter("--project", "."));
    }
    if (mode.equals("sandbox")) {
        return e2eSandboxSmoke();
    }
    if (mode.equals("lifecycle")) {
        return e2eLifecycleSmoke(args);
    }
    if (mode.equals("launcher")) {
        return e2eLauncherSmoke(args);
    }
    if (mode.equals("sync")) {
        return e2eSyncSmoke(args);
    }
    if (mode.equals("n3ds-nocrypto") || mode.equals("utils")) {
        return e2eN3dsNoCryptoSmoke(args);
    }
    if (mode.equals("all")) {
        int sandboxStatus = e2eSandboxSmoke();
        if (sandboxStatus != 0) { return sandboxStatus; }
        int launcherStatus = e2eLauncherSmoke(args);
        if (launcherStatus != 0) { return launcherStatus; }
        int syncStatus = e2eSyncSmoke(args);
        if (syncStatus != 0) { return syncStatus; }
        int n3dsStatus = e2eN3dsNoCryptoSmoke(args);
        if (n3dsStatus != 0) { return n3dsStatus; }
        return e2eLifecycleSmoke(args);
    }
    printUsage();
    return 1;
}

void printUsage() {
    print("semu [manifest|bootstrap|doctor|deck|lifecycle|sync|config|apprun|steam-input|keymap|screenshot|sandbox|launcher|utils|e2e] [graph|payload-audit|n3ds-nocrypto|validate|render|install|setup|reconfigure|change|uninstall|reinstall|upgrade|status|force|capture|prepare|launch] [--project PATH] [--roms PATH] [--source PATH] [--output PATH] [--dest PATH] [--target manifest|retroarch|dolphin|pcsx2|steam-input] [--emulator NAME] [--hook HOOK] [--scratch PATH] [--action ID] [--command KEYS]");
}

string retroarchKeyName(string key) {
    if (key.equals("+")) { return "add"; }
    if (key.equals("-")) { return "subtract"; }
    return key.toLower();
}

string keymapCommandKey(KeymapIr ir, string actionId) {
    return retroarchKeyName(keymapCommandKeyPart(irActionCommand(ir, actionId)));
}

string renderRetroArchKeymap(KeymapIr ir) {
    return "input_enable_hotkey = \"ctrl\"\n"
        + "input_exit_emulator = " + jsonQ(keymapCommandKey(ir, "app.quit")) + "\n"
        + "input_load_state = " + jsonQ(keymapCommandKey(ir, "state.load")) + "\n"
        + "input_menu_toggle = " + jsonQ(keymapCommandKey(ir, "ui.menu")) + "\n"
        + "input_save_state = " + jsonQ(keymapCommandKey(ir, "state.save")) + "\n"
        + "input_screenshot = " + jsonQ(keymapCommandKey(ir, "ui.screenshot")) + "\n"
        + "input_state_slot_decrease = " + jsonQ(keymapCommandKey(ir, "state.prev")) + "\n"
        + "input_state_slot_increase = " + jsonQ(keymapCommandKey(ir, "state.next")) + "\n"
        + "input_toggle_fast_forward = " + jsonQ(keymapCommandKey(ir, "speed.fast")) + "\n"
        + "input_toggle_fullscreen = " + jsonQ(keymapCommandKey(ir, "ui.fullscreen")) + "\n";
}

string dolphinChord(KeymapIr ir, string actionId) {
    string command = irActionCommand(ir, actionId);
    if (command.equals("Esc")) { return "Escape"; }
    return "@(" + command + ")";
}

string renderDolphinKeymap(KeymapIr ir) {
    return "General/Open = " + dolphinChord(ir, "ui.open") + "\n"
        + "General/Toggle Pause = " + dolphinChord(ir, "ui.pause") + "\n"
        + "General/Stop = " + dolphinChord(ir, "app.quit") + "\n"
        + "General/Toggle Fullscreen = " + dolphinChord(ir, "ui.fullscreen") + "\n"
        + "General/Take Screenshot = " + dolphinChord(ir, "ui.screenshot") + "\n"
        + "Load State/Load State Slot 1 = " + dolphinChord(ir, "state.load") + "\n"
        + "Save State/Save State Slot 1 = " + dolphinChord(ir, "state.save") + "\n";
}

string pcsx2KeyName(string key) {
    if (key.equals("+")) { return "Plus"; }
    if (key.equals("-")) { return "Minus"; }
    return key;
}

string pcsx2Chord(KeymapIr ir, string actionId) {
    string command = irActionCommand(ir, actionId);
    Vector<string> parts = [];
    string modifiers = keymapCommandModifierPart(command);
    if (modifiers.len() > 0) {
        Vector<string> modifierParts = Strings.split(modifiers, "+");
        for modifier in modifierParts {
            if (modifier.equals("Ctrl")) {
                parts.push("Keyboard/Control");
            } else {
                parts.push("Keyboard/" + modifier);
            }
        }
    }
    parts.push("Keyboard/" + pcsx2KeyName(keymapCommandKeyPart(command)));
    return parts.join(" & ");
}

string renderPcsx2Keymap(KeymapIr ir) {
    return "OpenPauseMenu = " + pcsx2Chord(ir, "ui.menu") + "\n"
        + "TogglePause = " + pcsx2Chord(ir, "ui.pause") + "\n"
        + "ToggleFullscreen = " + pcsx2Chord(ir, "ui.fullscreen") + "\n"
        + "PreviousSaveStateSlot = " + pcsx2Chord(ir, "state.prev") + "\n"
        + "NextSaveStateSlot = " + pcsx2Chord(ir, "state.next") + "\n"
        + "SaveStateToSlot = " + pcsx2Chord(ir, "state.save") + "\n"
        + "LoadStateFromSlot = " + pcsx2Chord(ir, "state.load") + "\n"
        + "Screenshot = " + pcsx2Chord(ir, "ui.screenshot") + "\n"
        + "ToggleTurbo = " + pcsx2Chord(ir, "speed.fast") + "\n"
        + "ToggleSlowMotion = " + pcsx2Chord(ir, "speed.rewind") + "\n";
}

string renderKeymap(KeymapIr ir, string target) {
    if (target.equals("manifest")) { return keymapIrJson(ir) + "\n"; }
    if (target.equals("retroarch")) { return renderRetroArchKeymap(ir); }
    if (target.equals("dolphin")) { return renderDolphinKeymap(ir); }
    if (target.equals("pcsx2")) { return renderPcsx2Keymap(ir); }
    if (target.equals("steam-input")) { return steamInputTemplateVdf("Semu: Steam Deck - Neptune FULL", true, ir); }
    return f"unknown keymap target: {target}\n";
}

bool isKeymapTarget(string target) {
    return target.equals("manifest") || target.equals("retroarch") || target.equals("dolphin") || target.equals("pcsx2") || target.equals("steam-input");
}

int keymapCommand(CliArgs args) {
    string mode = "validate";
    if (args.count() > 1 && !args.get(1).startsWith("--")) {
        mode = args.get(1);
    }
    string sourcePath = args.valueAfter("--source", "");
    string project = args.valueAfter("--project", "");
    string source = defaultKeymapSource();
    if (sourcePath.len() > 0) {
        if (!FileSystem.exists(sourcePath)) {
            print(f"error 0:0 keymap source not found: {sourcePath}");
            return 1;
        }
        source = FileSystem.readText(sourcePath);
    } else if (project.len() > 0 && FileSystem.exists(keymapSourcePath(project))) {
        source = FileSystem.readText(keymapSourcePath(project));
    }
    KeymapErrors errors = KeymapErrors();
    KeymapIr ir = compileKeymap(source, errors);
    if (mode.equals("validate")) {
        if (errors.count() == 0) {
            print("OK keymap steam_deck");
            return 0;
        }
        for (int i = 0; i < errors.count(); i++) {
            print(f"{errors.levels.get(i)} {errors.lines.get(i)}:{errors.columns.get(i)} {errors.messages.get(i)}");
        }
        return 1;
    }
    if (mode.equals("render")) {
        if (errors.count() > 0) {
            for (int i = 0; i < errors.count(); i++) {
                print(f"{errors.levels.get(i)} {errors.lines.get(i)}:{errors.columns.get(i)} {errors.messages.get(i)}");
            }
            return 1;
        }
        string target = args.valueAfter("--target", "manifest");
        if (!isKeymapTarget(target)) {
            print(f"error 0:0 unknown keymap target '{target}'");
            return 1;
        }
        string rendered = renderKeymap(ir, target);
        string output = args.valueAfter("--output", "");
        if (output.len() > 0) {
            FileSystem.writeText(output, rendered);
        } else {
            print(rendered);
        }
        return 0;
    }
    printUsage();
    return 1;
}

int screenshotCommand(CliArgs args, string project) {
    string mode = "status";
    if (args.count() > 1 && !args.get(1).startsWith("--")) {
        mode = args.get(1);
    }
    if (mode.equals("setup") || mode.equals("defaults")) {
        writeScreenshotDefaults(project);
        print(f"OK screenshot defaults: {screenshotConfigPath(project)}");
        return 0;
    }
    if (mode.equals("status")) {
        doctorScreenshotHooks(project);
        return 0;
    }
    if (mode.equals("validate")) {
        doctorScreenshotHooks(project);
        return screenshotConfiguredTool(project).len() > 0 ? 0 : 1;
    }
    if (mode.equals("capture")) {
        string emulator = args.valueAfter("--emulator", "");
        if (emulator.len() == 0 && args.count() > 2 && !args.get(2).startsWith("--")) {
            emulator = args.get(2);
        }
        if (emulator.len() == 0) {
            print("error 0:0 screenshot capture needs --emulator NAME");
            return 1;
        }
        string hook = args.valueAfter("--hook", "manual_visual_checkpoint");
        string output = args.valueAfter("--output", screenshotCapturePath(project, emulator, hook));
        return screenshotCaptureTo(project, emulator, hook, output) ? 0 : 1;
    }
    printUsage();
    return 1;
}

int syncCommand(CliArgs args, string project) {
    string mode = "status";
    if (args.count() > 1 && !args.get(1).startsWith("--")) {
        mode = args.get(1);
    }
    if (mode.equals("setup")) {
        return syncSetup(project) ? 0 : 1;
    }
    if (mode.equals("start")) {
        return syncStart(project) ? 0 : 1;
    }
    if (mode.equals("stop")) {
        return syncStop(project) ? 0 : 1;
    }
    if (mode.equals("status")) {
        syncStatus(project);
        return 0;
    }
    if (mode.equals("force") || mode.equals("now")) {
        string target = "all";
        if (args.count() > 2 && !args.get(2).startsWith("--")) {
            target = args.get(2);
        }
        return syncForce(project, target) ? 0 : 1;
    }
    if (mode.equals("tray")) {
        syncTray(project);
        return 0;
    }
    if (mode.equals("open")) {
        syncOpen(project);
        return 0;
    }
    if (mode.equals("autostart")) {
        string action = args.count() > 2 ? args.get(2) : "enable";
        return syncAutostart(project, !action.equals("disable")) ? 0 : 1;
    }
    printUsage();
    return 1;
}

int appRunCommand(CliArgs args, string project) {
    string mode = "prepare";
    if (args.count() > 1 && !args.get(1).startsWith("--")) {
        mode = args.get(1);
    }
    if (mode.equals("prepare")) {
        writeEsDeRuntimeFiles(project, homeDir());
        print("OK apprun prepare");
        return 0;
    }
    printUsage();
    return 1;
}

string steamInputTemplateDir(CliArgs args) {
    return args.valueAfter(
        "--dest",
        Environment.get("SEMU_STEAM_INPUT_DIR", joinPath(homeDir(), ".steam/steam/controller_base/templates"))
    );
}

void copySteamInputTemplate(string project, string destination, string name) {
    string source = joinPath(project, "input/steam-input/" + name);
    FileSystem.writeText(joinPath(destination, name), FileSystem.readText(source));
}

int steamInputCommand(CliArgs args, string project) {
    string mode = "status";
    if (args.count() > 1 && !args.get(1).startsWith("--")) {
        mode = args.get(1);
    }
    if (mode.equals("install") || mode.equals("copy")) {
        string destination = steamInputTemplateDir(args);
        writeSteamInputTemplates(project);
        ensureDir(destination);
        copySteamInputTemplate(project, destination, "neptune-simple.vdf");
        copySteamInputTemplate(project, destination, "neptune-full.vdf");
        print(f"OK steam-input templates: {destination}");
        return 0;
    }
    if (mode.equals("status") || mode.equals("validate")) {
        writeSteamInputTemplates(project);
        reportSteamInputTemplate("neptune_simple", joinPath(project, "input/steam-input/neptune-simple.vdf"));
        reportSteamInputTemplate("neptune_full", joinPath(project, "input/steam-input/neptune-full.vdf"));
        return 0;
    }
    printUsage();
    return 1;
}

int configCommand(CliArgs args, string project) {
    string mode = "show";
    if (args.count() > 1 && !args.get(1).startsWith("--")) {
        mode = args.get(1);
    }
    if (mode.equals("env")) {
        print("export SEMU_PROJECT_DIR=" + ShellWords.quote(project));
        print("export SEMU_ROMS_DIR=" + ShellWords.quote(configuredRomsRoot(project)));
        print("export SEMU_BIN=" + ShellWords.quote(serviceExecutable()));
        return 0;
    }
    if (mode.equals("set-roms")) {
        string roms = args.valueAfter("--roms", "");
        if (roms.len() == 0 && args.count() > 2) {
            roms = args.get(2);
        }
        if (roms.len() == 0) {
            print("error 0:0 set-roms needs --roms PATH");
            return 1;
        }
        writeSyncDefaults(project, roms);
        ensureRomDirsAt(roms);
        writeEsDeFiles(project);
        print(f"OK roms_dir: {roms}");
        return 0;
    }
    if (mode.equals("show")) {
        reportFile("sync_config", syncConfigPath(project));
        print(f"  roms_dir: {configuredRomsRoot(project)}");
        return 0;
    }
    printUsage();
    return 1;
}

int lifecycleCommand(CliArgs args, string project) {
    string mode = "status";
    if (args.count() > 1 && !args.get(1).startsWith("--")) {
        mode = args.get(1);
    }
    if (mode.equals("install") || mode.equals("setup")) {
        lifecycleInstall(project, args.valueAfter("--roms", ""));
        return 0;
    }
    if (mode.equals("reconfigure")) {
        lifecycleReconfigure(project, args.valueAfter("--roms", ""));
        writeLifecycleState(project, "reconfigure");
        print("OK lifecycle reconfigure");
        return 0;
    }
    if (mode.equals("change")) {
        string actionId = args.valueAfter("--action", "");
        string command = args.valueAfter("--command", "");
        if (actionId.len() == 0 || command.len() == 0) {
            print("error 0:0 lifecycle change needs --action ID --command KEYS");
            return 1;
        }
        return lifecycleChangeKeymap(project, actionId, command) ? 0 : 1;
    }
    if (mode.equals("uninstall")) {
        lifecycleUninstall(project, args.has("--purge-generated"), args.has("--purge-state"));
        return 0;
    }
    if (mode.equals("reinstall")) {
        lifecycleUninstall(project, false, false);
        lifecycleInstall(project, args.valueAfter("--roms", ""));
        writeLifecycleState(project, "reinstall");
        return 0;
    }
    if (mode.equals("upgrade")) {
        lifecycleUpgrade(project);
        return 0;
    }
    if (mode.equals("status")) {
        lifecycleStatus(project);
        return 0;
    }
    printUsage();
    return 1;
}

int deckLaunch(string project) {
    if (!FileSystem.exists(syncConfigPath(project))) {
        print("MISSING setup: run lifecycle install --project " + ShellWords.quote(project));
        return 2;
    }
    writeEsDeRuntimeFiles(project, homeDir());
    UnixShell shell = UnixShell();
    string env = "SEMU_PROJECT_DIR=" + ShellWords.quote(project)
        + " SEMU_ROMS_DIR=" + ShellWords.quote(configuredRomsRoot(project));
    if (commandExists("es-de")) {
        shell.runRaw(env + " es-de", false, false, "");
        return 0;
    } else {
        print("MISSING es-de: use the bundled AppImage or install ES-DE");
    }
    return 127;
}

int deckCommand(CliArgs args, string project) {
    string mode = "install";
    if (args.count() > 1 && !args.get(1).startsWith("--")) {
        mode = args.get(1);
    }
    if (mode.equals("install")) {
        string roms = args.valueAfter("--roms", "");
        lifecycleInstall(project, roms);
        return 0;
    }
    if (mode.equals("setup") || mode.equals("reconfigure") || mode.equals("change") || mode.equals("uninstall") || mode.equals("reinstall") || mode.equals("upgrade") || mode.equals("status")) {
        return lifecycleCommand(args, project);
    }
    if (mode.equals("verify")) {
        doctorSteamDeck(project);
        KeymapErrors errors = KeymapErrors();
        compileKeymap(FileSystem.exists(keymapSourcePath(project)) ? FileSystem.readText(keymapSourcePath(project)) : defaultKeymapSource(), errors);
        if (errors.count() > 0) {
            return 1;
        }
        return 0;
    }
    if (mode.equals("launch")) {
        return deckLaunch(project);
    }
    printUsage();
    return 1;
}

string launcherNameFromProgram(string program) {
    string base = PathTools.basename(program);
    if (!base.startsWith("semu-")) {
        return "";
    }
    if (base.equals("semu-btrc") || base.equals("semu-flatpak") || base.equals("semu")) {
        return "";
    }
    return Strings.removePrefix(base, "semu-");
}

int main(int argc, char** argv) {
    CliArgs args = CliArgs(argc, argv);
    string command = args.command();
    string project = args.valueAfter("--project", Environment.get("SEMU_PROJECT_DIR", "."));
    string programLauncher = launcherNameFromProgram(args.program);
    if (programLauncher.len() > 0) {
        return launcherRunEmulator(project, programLauncher, launcherPassthroughArgs(args));
    }
    if (command.equals("") || command.equals("manifest")) {
        string output = args.valueAfter("--output", "semu.json");
        writeGeneratedManifest(output);
        return 0;
    }
    if (command.equals("bootstrap")) {
        bootstrapSteamDeck(project);
        return 0;
    }
    if (command.equals("doctor")) {
        doctorSteamDeck(project);
        return 0;
    }
    if (command.equals("deck")) {
        int status = deckCommand(args, project);
        return status;
    }
    if (command.equals("lifecycle")) {
        int status = lifecycleCommand(args, project);
        return status;
    }
    if (command.equals("sync")) {
        int status = syncCommand(args, project);
        return status;
    }
    if (command.equals("config")) {
        int status = configCommand(args, project);
        return status;
    }
    if (command.equals("apprun")) {
        int status = appRunCommand(args, project);
        return status;
    }
    if (command.equals("steam-input")) {
        int status = steamInputCommand(args, project);
        return status;
    }
    if (command.equals("keymap")) {
        int status = keymapCommand(args);
        return status;
    }
    if (command.equals("screenshot")) {
        int status = screenshotCommand(args, project);
        return status;
    }
    if (command.equals("sandbox")) {
        int status = sandboxCommand(args, project);
        return status;
    }
    if (command.equals("launcher")) {
        int status = launcherCommand(args, project);
        return status;
    }
    if (command.equals("utils") || command.equals("util")) {
        int status = utilitiesCommand(args);
        return status;
    }
    if (command.equals("n3ds-nocrypto") || command.equals("3ds-nocrypto")) {
        int status = n3dsNoCryptoCommand(args, 1);
        return status;
    }
    if (command.equals("e2e")) {
        int status = e2eCommand(args);
        return status;
    }
    printUsage();
    return 1;
}
