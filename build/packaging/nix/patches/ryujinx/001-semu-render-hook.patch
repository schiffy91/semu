+            string config = SemuRenderHookReadConfig(plan.ConfigPath);
+            if (!string.IsNullOrEmpty(config))
+            {
+                if (!SemuRenderHookConfigHasSystem(config, plan.System))
+                {
+                    plan.Active = false;
+                    return plan;
+                }
+                if (SemuRenderHookConfigBoolIsFalse(config, "\"shaders_enabled\""))
+                {
