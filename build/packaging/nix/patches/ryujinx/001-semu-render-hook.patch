+                System = Environment.GetEnvironmentVariable("SEMU_SYSTEM") ?? string.Empty,
+                ConfigPath = Environment.GetEnvironmentVariable("SEMU_RENDER_HOOK_CONFIG") ?? string.Empty,
+            };
+
+            if (!plan.Active)
+            {
+                return plan;
