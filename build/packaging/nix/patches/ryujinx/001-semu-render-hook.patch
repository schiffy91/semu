+                    File.AppendAllText(proof, string.Format(
+                        "semu-render-hook:{0}:game_framebuffer:config={1}{2}",
+                        emulator, config ?? "", Environment.NewLine));
+                }
+                catch
+                {
+                }
+            }
+
+            _semuRenderHookLogged = true;
+        }
