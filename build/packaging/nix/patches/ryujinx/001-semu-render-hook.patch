+        private static bool SemuRenderHookConfigBoolIsFalse(string config, string key)
+        {
+            int cursor = config.IndexOf(key, StringComparison.Ordinal);
+            if (cursor < 0)
+            {
+                return false;
+            }
+
+            cursor = config.IndexOf(':', cursor);
+            if (cursor < 0)
+            {
+                return false;
+            }
+
+            cursor++;
+            while (cursor < config.Length && char.IsWhiteSpace(config[cursor]))
+            {
+                cursor++;
+            }
+
+            return cursor + 5 <= config.Length && string.Compare(config, cursor, "false", 0, 5, StringComparison.Ordinal) == 0;
+        }
