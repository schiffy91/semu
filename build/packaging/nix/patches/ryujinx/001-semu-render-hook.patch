+            g = SemuRenderHookClamp(g);
+            b = SemuRenderHookClamp(b);
+            a = SemuRenderHookClamp(a);
+
+            if (SemuRenderHookFormatIsBgra(format))
+            {
+                data[index] = (byte)b;
+                data[index + 1] = (byte)g;
+                data[index + 2] = (byte)r;
+                data[index + 3] = (byte)a;
+            }
+            else
+            {
+                data[index] = (byte)r;
+                data[index + 1] = (byte)g;
+                data[index + 2] = (byte)b;
+                data[index + 3] = (byte)a;
+            }
+        }
