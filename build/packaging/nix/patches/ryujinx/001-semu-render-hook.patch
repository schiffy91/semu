+        private static void SemuRenderHookFramePixel(Span<byte> data, int index, Format format, int x, int y, int width, int height)
+        {
+            int shade = 88 + x * 12 / Math.Max(width, 1) - y * 8 / Math.Max(height, 1);
+            int r = 24 * shade / 100;
+            int g = 24 * shade / 100;
+            int b = 28 * shade / 100;
+
+            if (x < width / 32 || y < height / 32 || x + width / 32 >= width || y + height / 32 >= height)
+            {
+                r = 7;
+                g = 8;
+                b = 10;
+            }
+
+            SemuRenderHookWritePixel(data, index, format, r, g, b, 255);
+        }
