+        private static void SemuRenderHookApplyShader(ref int r, ref int g, ref int b, int x, int y)
+        {
+            int luma = (r * 77 + g * 150 + b * 29) >> 8;
+            int scanline = (y & 1) == 0 ? 100 : 78;
+
+            r = (r * 92 + luma * 8) / 100;
+            g = (g * 92 + luma * 8) / 100;
+            b = (b * 92 + luma * 8) / 100;
+
+            switch (x % 3)
+            {
+                case 0:
+                    g = g * 88 / 100;
+                    b = b * 88 / 100;
+                    break;
+                case 1:
+                    r = r * 90 / 100;
+                    b = b * 90 / 100;
+                    break;
+                default:
+                    r = r * 88 / 100;
+                    g = g * 88 / 100;
+                    break;
+            }
+
+            r = r * scanline / 100;
+            g = g * scanline / 100;
+            b = b * scanline / 100;
+        }
