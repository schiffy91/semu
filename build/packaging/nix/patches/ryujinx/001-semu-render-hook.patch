+        private static void SemuRenderHookReadPixel(ReadOnlySpan<byte> data, int index, Format format, out int r, out int g, out int b, out int a)
+        {
+            if (SemuRenderHookFormatIsBgra(format))
+            {
+                b = data[index];
+                g = data[index + 1];
+                r = data[index + 2];
+                a = data[index + 3];
+            }
+            else
+            {
+                r = data[index];
+                g = data[index + 1];
+                b = data[index + 2];
+                a = data[index + 3];
+            }
+        }
