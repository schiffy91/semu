+        private bool SemuRenderHookComposeFrame(Image.Texture texture, ImageCrop crop, out ITexture outputTexture, out ImageCrop outputCrop)
+        {
+            outputTexture = texture.HostTexture;
+            outputCrop = crop;
+
+            SemuRenderHookPlan plan = SemuRenderHookPlanForFrame();
+            Format format = texture.Info.FormatInfo.Format;
+            if (!plan.Active)
+            {
+                return false;
+            }
+            if (!plan.Shaders && !plan.Bezels)
+            {
+                return true;
+            }
+            if (texture.Info.FormatInfo.BytesPerPixel != 4 || texture.Info.FormatInfo.IsCompressed || !SemuRenderHookFormatSupported(format))
+            {
+                return false;
+            }
+
+            int width = texture.HostTexture.Width;
+            int height = texture.HostTexture.Height;
+            if (width <= 0 || height <= 0 || (long)width * height * 4 > int.MaxValue)
+            {
+                return false;
+            }
+
+            int srcX0 = crop.Left == 0 && crop.Right == 0 ? 0 : Math.Clamp(crop.Left, 0, width - 1);
+            int srcX1 = crop.Left == 0 && crop.Right == 0 ? width : Math.Clamp(crop.Right, 1, width);
+            int srcY0 = crop.Top == 0 && crop.Bottom == 0 ? 0 : Math.Clamp(crop.Top, 0, height - 1);
+            int srcY1 = crop.Top == 0 && crop.Bottom == 0 ? height : Math.Clamp(crop.Bottom, 1, height);
+            if (srcX1 <= srcX0 || srcY1 <= srcY0)
+            {
+                return false;
+            }
+
+            int size = checked(width * height * 4);
+            MemoryOwner<byte> output = null;
+
+            try
+            {
+                using (PinnedSpan<byte> sourceData = texture.HostTexture.GetData())
+                {
+                    ReadOnlySpan<byte> source = sourceData.Get();
+                    if (source.Length < size)
+                    {
+                        return false;
+                    }
+
+                    output = MemoryOwner<byte>.Rent(size);
+                    Span<byte> destination = output.Span;
+                    SemuRenderHookRect content = SemuRenderHookContentRect(width, height, plan.Bezels);
+
+                    for (int y = 0; y < height; y++)
+                    {
+                        for (int x = 0; x < width; x++)
+                        {
+                            int dstIndex = (y * width + x) * 4;
+                            if (x >= content.X && y >= content.Y && x < content.X + content.Width && y < content.Y + content.Height)
+                            {
+                                int sourceX = srcX0 + (int)((long)(x - content.X) * (srcX1 - srcX0) / content.Width);
+                                int sourceY = srcY0 + (int)((long)(y - content.Y) * (srcY1 - srcY0) / content.Height);
+                                sourceX = Math.Clamp(sourceX, srcX0, srcX1 - 1);
+                                sourceY = Math.Clamp(sourceY, srcY0, srcY1 - 1);
+
+                                SemuRenderHookReadPixel(source, (sourceY * width + sourceX) * 4, format, out int r, out int g, out int b, out int a);
+                                if (plan.Shaders)
+                                {
+                                    SemuRenderHookApplyShader(ref r, ref g, ref b, x, y);
+                                }
+                                SemuRenderHookWritePixel(destination, dstIndex, format, r, g, b, a);
+                            }
+                            else
+                            {
+                                SemuRenderHookFramePixel(destination, dstIndex, format, x, y, width, height);
+                            }
+                        }
+                    }
+                }
+
+                ITexture composedTexture = SemuRenderHookEnsureTexture(width, height, format);
+                composedTexture.SetData(output);
+                output = null;
+
+                outputTexture = composedTexture;
+                outputCrop = new ImageCrop(0, width, 0, height, crop.FlipX, crop.FlipY, crop.IsStretched, crop.AspectRatioX, crop.AspectRatioY);
+                return true;
+            }
+            catch
+            {
+                return false;
+            }
+            finally
+            {
+                output?.Dispose();
+            }
+        }
