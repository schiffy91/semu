+        private static SemuRenderHookRect SemuRenderHookContentRect(int width, int height, bool bezels)
+        {
+            if (!bezels || width < 32 || height < 32)
+            {
+                return new SemuRenderHookRect(0, 0, width, height);
+            }
+
+            int marginX = width / 18;
+            int marginY = height / 16;
+            if (marginX <= 0 || marginY <= 0 || width - marginX * 2 < 16 || height - marginY * 2 < 16)
+            {
+                return new SemuRenderHookRect(0, 0, width, height);
+            }
+
+            return new SemuRenderHookRect(marginX, marginY, width - marginX * 2, height - marginY * 2);
+        }
