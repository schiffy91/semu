+static const char* semuRenderHookProfileName(int profile)
+{
+    if (profile == SEMU_RENDER_PROFILE_NDS)
+        return "nds_dual_lcd";
+    if (profile == SEMU_RENDER_PROFILE_N3DS)
+        return "n3ds_dual_lcd";
+    return "none";
+}
