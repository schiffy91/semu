+static bool semuRenderHookEnvBool(const char* name, bool fallback)
+{
+    const char* value = std::getenv(name);
+    if (value == nullptr || value[0] == '\0')
+        return fallback;
+    return value[0] != '0' && value[0] != 'f' && value[0] != 'F'
+        && value[0] != 'n' && value[0] != 'N';
+}
+
+static int semuRenderHookProfileForSystem(const char* system)
+{
+    if (system == nullptr)
+        return SEMU_RENDER_PROFILE_NONE;
+    if (std::strcmp(system, "nds") == 0)
+        return SEMU_RENDER_PROFILE_NDS;
+    if (std::strcmp(system, "n3ds") == 0)
+        return SEMU_RENDER_PROFILE_N3DS;
+    return SEMU_RENDER_PROFILE_NONE;
+}
