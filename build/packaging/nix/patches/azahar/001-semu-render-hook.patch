+static size_t semuRenderHookReadConfig(const char* path, char* buffer, size_t size)
+{
+    if (path == nullptr || path[0] == '\0' || buffer == nullptr || size < 2)
+        return 0;
+
+    std::FILE* file = std::fopen(path, "rb");
+    if (file == nullptr)
+        return 0;
+
+    size_t used = std::fread(buffer, 1, size - 1, file);
+    buffer[used] = '\0';
+    std::fclose(file);
+    return used;
+}
+
+static bool semuRenderHookConfigBoolIsFalse(const char* config, const char* key)
+{
+    const char* cursor = config != nullptr ? std::strstr(config, key) : nullptr;
+    if (cursor == nullptr)
+        return false;
+
+    cursor = std::strchr(cursor, ':');
+    if (cursor == nullptr)
+        return false;
+    cursor++;
+
+    while (*cursor == ' ' || *cursor == '\t' || *cursor == '\r' || *cursor == '\n')
+        cursor++;
+    return std::strncmp(cursor, "false", 5) == 0;
+}
+
+static bool semuRenderHookConfigHasSystem(const char* config, const char* system)
+{
+    char needle[64];
+    if (config == nullptr || system == nullptr || system[0] == '\0' || std::strlen(system) > 32)
+        return true;
+
+    std::snprintf(needle, sizeof(needle), "\"id\": \"%s\"", system);
+    if (std::strstr(config, needle) != nullptr)
+        return true;
+
+    std::snprintf(needle, sizeof(needle), "\"id\":\"%s\"", system);
+    return std::strstr(config, needle) != nullptr;
+}
+
+static bool semuRenderHookConfigNativeSize(const char* config, int* width, int* height)
+{
+    const char* cursor = config != nullptr ? std::strstr(config, "\"native_size\"") : nullptr;
+    if (cursor == nullptr)
+        return false;
+
+    while (*cursor != '\0' && (*cursor < '0' || *cursor > '9'))
+        cursor++;
+    if (*cursor == '\0')
+        return false;
+
+    char* end = nullptr;
+    long parsedWidth = std::strtol(cursor, &end, 10);
+    if (end == cursor || (*end != 'x' && *end != 'X'))
+        return false;
+
+    cursor = end + 1;
+    long parsedHeight = std::strtol(cursor, &end, 10);
+    if (end == cursor || parsedWidth <= 0 || parsedHeight <= 0 || parsedWidth > 8192 || parsedHeight > 8192)
+        return false;
+
+    *width = static_cast<int>(parsedWidth);
+    *height = static_cast<int>(parsedHeight);
+    return true;
+}
+
+static bool semuRenderHookLoadPlan(SemuRenderHookPlan* plan)
+{
+    const char* system = std::getenv("SEMU_SYSTEM");
+    const char* configPath = std::getenv("SEMU_RENDER_HOOK_CONFIG");
+    char config[65536];
+    size_t configSize;
+
+    plan->profile = semuRenderHookProfileForSystem(system);
+    if (plan->profile == SEMU_RENDER_PROFILE_NONE)
+        return false;
+
+    semuRenderHookDefaultNativeSize(plan->profile, &plan->nativeWidth, &plan->nativeHeight);
+    plan->shaders = semuRenderHookEnvBool("SEMU_RENDER_SHADERS", true);
+    plan->bezels = semuRenderHookEnvBool("SEMU_RENDER_BEZELS", true);
+
+    configSize = semuRenderHookReadConfig(configPath, config, sizeof(config));
+    if (configSize > 0)
+    {
+        if (!semuRenderHookConfigHasSystem(config, system))
+            return false;
+        if (semuRenderHookConfigBoolIsFalse(config, "\"shaders_enabled\""))
+            plan->shaders = false;
+        if (semuRenderHookConfigBoolIsFalse(config, "\"bezels_enabled\""))
+            plan->bezels = false;
+        if (std::strstr(config, "dual_vertical_asymmetric") != nullptr)
+            plan->profile = SEMU_RENDER_PROFILE_N3DS;
+        else if (std::strstr(config, "dual_vertical") != nullptr)
+            plan->profile = SEMU_RENDER_PROFILE_NDS;
+        semuRenderHookConfigNativeSize(config, &plan->nativeWidth, &plan->nativeHeight);
+    }
+
+    return plan->shaders || plan->bezels;
+}
