+static void semuRenderHookDefaultNativeSize(int profile, int* width, int* height)
+{
+    if (profile == SEMU_RENDER_PROFILE_N3DS)
+    {
+        *width = 400;
+        *height = 480;
+        return;
+    }
+    *width = 256;
+    *height = 384;
