+static int semuRenderHookMaxInt(int left, int right)
+{
+    return left > right ? left : right;
+}
+
+static SemuRenderHookRect semuRenderHookFitRect(int width, int height, int nativeWidth,
+    int nativeHeight, int marginX, int marginY)
+{
+    SemuRenderHookRect rect = {0, 0, width, height};
+    int availableWidth = width - marginX * 2;
+    int availableHeight = height - marginY * 2;
+
+    if (width <= 0 || height <= 0 || nativeWidth <= 0 || nativeHeight <= 0
+        || availableWidth <= 4 || availableHeight <= 4)
+        return rect;
+
+    rect.w = availableWidth;
+    rect.h = static_cast<int>((static_cast<long long>(rect.w) * nativeHeight) / nativeWidth);
+    if (rect.h > availableHeight)
+    {
+        rect.h = availableHeight;
+        rect.w = static_cast<int>((static_cast<long long>(rect.h) * nativeWidth) / nativeHeight);
+    }
+
+    if (rect.w <= 0 || rect.h <= 0)
+        return {0, 0, width, height};
+
+    rect.x = (width - rect.w) / 2;
+    rect.y = (height - rect.h) / 2;
+    return rect;
+}
