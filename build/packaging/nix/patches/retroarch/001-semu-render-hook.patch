+typedef enum semu_render_hook_profile
+{
+   SEMU_RENDER_PROFILE_NONE = 0,
+   SEMU_RENDER_PROFILE_DMG_LCD,
+   SEMU_RENDER_PROFILE_GBC_LCD,
+   SEMU_RENDER_PROFILE_GBA_LCD,
+   SEMU_RENDER_PROFILE_CRT
+} semu_render_hook_profile_t;
+
+typedef struct semu_render_hook_rgb
+{
+   unsigned r;
+   unsigned g;
+   unsigned b;
+} semu_render_hook_rgb_t;
