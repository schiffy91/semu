#!/usr/bin/env bash
set -euo pipefail

if [ -w /dev/ttyS0 ]; then
  exec >/dev/ttyS0 2>&1
else
  exec >/dev/console 2>&1
fi

echo "SEMU E2E install starting"
lsblk -o NAME,TYPE,SIZE,MODEL || true

ks_path=""
for candidate in /run/initramfs/live/ks.cfg /run/install/repo/ks.cfg /run/media/iso/ks.cfg; do
  if [ -f "$candidate" ]; then
    ks_path="$candidate"
    break
  fi
done

if [ -z "$ks_path" ]; then
  echo "SEMU E2E install missing kickstart"
  systemctl poweroff --no-block || true
  exit 2
fi

default_ks=/usr/share/anaconda/interactive-defaults.ks
saved_default_ks=/run/semu-interactive-defaults.ks
runtime_ks=/run/semu-e2e.ks
cp "$default_ks" "$saved_default_ks"
sed "s|%include /usr/share/anaconda/interactive-defaults.ks|%include $saved_default_ks|" "$ks_path" > "$runtime_ks"
echo "SEMU E2E kickstart installed at $runtime_ks"

export XDG_RUNTIME_DIR=/run/user/0
install -d -m 0700 "$XDG_RUNTIME_DIR"

if [ -d /usr/share/cockpit/anaconda-webui ]; then
  mv /usr/share/cockpit/anaconda-webui /run/anaconda-webui.disabled
fi

if command -v setenforce >/dev/null 2>&1; then
  setenforce 0 || true
fi

anaconda_cmd=(anaconda --cmdline --kickstart "$runtime_ks")
set +e
if command -v dbus-run-session >/dev/null 2>&1; then
  dbus-run-session -- "${anaconda_cmd[@]}"
else
  "${anaconda_cmd[@]}"
fi
status=$?
set -e
echo "SEMU E2E install complete: $status"

for log in /tmp/anaconda.log /tmp/storage.log /tmp/program.log /tmp/packaging.log /tmp/semu-ssh.log; do
  if [ -f "$log" ]; then
    echo "SEMU E2E log tail: $log"
    tail -n 160 "$log" || true
  fi
done

systemctl poweroff --no-block || true

exit "$status"
