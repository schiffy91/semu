// package_contract_test.btrc — proof harness for packaging + system emission.
//
// Covers: es_systems.xml structural comparison against the golden Deck
// config (system count + exact command lines for gb/n64/dreamcast on linux
// and the ares n64 command on macos), portable es_find_rules coverage
// (systempath shim names + %ESPATH% entries, no bootstrap-machine paths) for
// every linux emulator plus the RetroArch corepath rules, AppRun /
// semu.desktop template emission (content + exec bit), the semu.json
// manifest artifact, and NixPackage.verify == 0 hard issues. Returns the
// violation count (0 = pass); no main() — the entry composes it.
//
// Artifacts are emitted under $SEMU_PKG_TEST_DIR when set (CI/scratch runs),
// else <repoRoot>/src/generated/test/pkg-test (the same policy as the
// Makefile's manifest-smoke writing src/generated/test/).

import std.{vector, strings, platform, process, fs, json}
import ../../src/semu/core/parse_log.btrc
import ../../src/semu/systems/system_parser.btrc
import ../../src/semu/systems/system_emitter.btrc
import ../../src/semu/platforms/platform_registry.btrc
import ../../src/semu/packaging/nix_package.btrc

class PackageContractTest {
    class int fail(string message) {
        print("  FAIL " + message);
        return 1;
    }

    class int require(string text, string needle, string what) {
        if (!text.contains(needle)) {
            return PackageContractTest.fail(what + " missing: " + needle);
        }
        return 0;
    }

    class int occurrenceCount(string text, string needle) {
        Vector<string> segments = Strings.split(text, needle);
        return segments.size() - 1;
    }

    class bool isExecutable(string path) {
        UnixShell shell = UnixShell();
        ExecResult result = shell.run("test -x " + ShellWords.quote(path),
            CommandOutput.suppress(), CommandOutput.suppress(), false, false);
        return result.code == 0;
    }

    // es_systems.xml vs the golden structure (garbage/generated/packaging/
    // es-de/custom_systems/es_systems.xml). Deviations under test: the
    // retired semu-settings synthetic system must NOT come back, and the
    // dreamcast command carries flycast's fullscreen platform args (the
    // frozen emulator.json moved them out of the old hardcoded command).
    class int checkEsSystems(SemuContracts contracts) {
        int failures = 0;
        string xml = SystemEmitter.esSystemsXml(contracts, "linux");
        int systemCount = PackageContractTest.occurrenceCount(xml, "  <system>\n");
        if (systemCount != contracts.systems.size()) {
            failures = failures + PackageContractTest.fail(
                f"es_systems block count {systemCount} != {contracts.systems.size()} systems");
        }
        if (contracts.systems.size() != 17) {
            failures = failures + PackageContractTest.fail(
                f"expected 17 system contracts, got {contracts.systems.size()}");
        }
        failures = failures + PackageContractTest.require(xml,
            "<command label=\"Gambatte\">%EMULATOR_RETROARCH% -f -L %CORE_RETROARCH%/gambatte_libretro.so %ROM%</command>",
            "gb linux command");
        failures = failures + PackageContractTest.require(xml,
            "<command label=\"Mupen64Plus-Next\">%EMULATOR_RETROARCH% -f -L %CORE_RETROARCH%/mupen64plus_next_libretro.so %ROM%</command>",
            "n64 linux command");
        failures = failures + PackageContractTest.require(xml,
            "<command label=\"Flycast\">%EMULATOR_FLYCAST% -config window:fullscreen=yes %ROM%</command>",
            "dreamcast linux command");
        failures = failures + PackageContractTest.require(xml,
            "<name>gb</name>", "gb system entry");
        failures = failures + PackageContractTest.require(xml,
            "<path>%ROMPATH%/gb</path>", "gb rompath");
        failures = failures + PackageContractTest.require(xml,
            "<extension>.bin .BIN .dmg .DMG .gb .GB .gbs .GBS .7z .7Z .zip .ZIP</extension>",
            "gb both-case extension list");
        failures = failures + PackageContractTest.require(xml,
            "<platform>genesis,megadrive</platform>", "genesis multi-platform join");
        if (xml.contains("%EMULATOR_ARES%")) {
            failures = failures + PackageContractTest.fail(
                "macos-only ares binding leaked into linux es_systems");
        }
        if (xml.contains("semu-settings")) {
            failures = failures + PackageContractTest.fail(
                "retired semu-settings synthetic system was emitted");
        }
        string macosXml = SystemEmitter.esSystemsXml(contracts, "macos");
        failures = failures + PackageContractTest.require(macosXml,
            "<command label=\"ares\">%EMULATOR_ARES% --fullscreen --system &quot;Nintendo 64&quot; %ROM%</command>",
            "n64 macos ares command");
        return failures;
    }

    // Find rules must be PORTABLE: the tree is bootstrapped on one machine
    // and deployed on another, so every launcher resolves by shim name
    // (systempath via AppRun's PATH export) or %ESPATH%-relative staticpath,
    // and the corepath leads with the bundled AppImage core directory.
    class int checkFindRules(SemuContracts contracts, string repoRoot) {
        int failures = 0;
        string rules = SystemEmitter.esFindRulesXml(contracts.emulators, "linux");
        int linuxEmulatorCount = 0;
        for emulatorDefinition in contracts.emulators {
            if (emulatorDefinition.hasOperatingSystem("linux")) {
                linuxEmulatorCount = linuxEmulatorCount + 1;
                failures = failures + PackageContractTest.require(rules,
                    "<emulator name=\"" + emulatorDefinition.id.toUpper() + "\">",
                    emulatorDefinition.id + " find rule");
                failures = failures + PackageContractTest.require(rules,
                    "<rule type=\"systempath\">\n      <entry>semu-" + emulatorDefinition.id
                        + "</entry>",
                    emulatorDefinition.id + " systempath entry");
                failures = failures + PackageContractTest.require(rules,
                    "<entry>%ESPATH%/semu-" + emulatorDefinition.id + "</entry>",
                    emulatorDefinition.id + " %ESPATH% staticpath entry");
            }
        }
        if (linuxEmulatorCount != 9) {
            failures = failures + PackageContractTest.fail(
                f"expected 9 linux emulators, got {linuxEmulatorCount}");
        }
        if (rules.contains("<emulator name=\"ARES\">")) {
            failures = failures + PackageContractTest.fail(
                "macos-only ares got a linux find rule");
        }
        if (rules.contains(repoRoot)) {
            failures = failures + PackageContractTest.fail(
                "find rules leaked a bootstrap-machine absolute path");
        }
        failures = failures + PackageContractTest.require(rules,
            "<core name=\"RETROARCH\">", "retroarch corepath rule");
        failures = failures + PackageContractTest.require(rules,
            "<entry>%ESPATH%/../lib/retroarch/cores</entry>", "corepath bundled AppImage dir");
        failures = failures + PackageContractTest.require(rules,
            "<entry>/usr/lib/x86_64-linux-gnu/libretro</entry>", "corepath x86_64");
        failures = failures + PackageContractTest.require(rules,
            "<entry>/usr/lib/aarch64-linux-gnu/libretro</entry>", "corepath aarch64");
        failures = failures + PackageContractTest.require(rules,
            "<entry>/usr/lib/libretro</entry>", "corepath generic");
        if (rules.contains("${env:") || rules.contains("${nix_result}")) {
            failures = failures + PackageContractTest.fail(
                "find rules leaked unexpandable semu tokens into corepath entries");
        }
        return failures;
    }

    class int checkAppImage(SemuContracts contracts, string repoRoot, string outputRoot) {
        int failures = 0;
        for platformId in PlatformRegistry.registeredIds() {
            string launcherSummary = PlatformRegistry.emitLaunchers(platformId,
                contracts.emulators, repoRoot, outputRoot);
        }
        string appRunPath = PathTools.join(outputRoot, "packaging/linux/AppRun");
        if (!FileSystem.isFile(appRunPath)) {
            failures = failures + PackageContractTest.fail("AppRun not emitted at " + appRunPath);
        } else {
            string appRun = Path.readAll(appRunPath);
            if (!appRun.startsWith("#!")) {
                failures = failures + PackageContractTest.fail("AppRun lacks a shebang");
            }
            failures = failures + PackageContractTest.require(appRun, "APPDIR=",
                "AppRun APPDIR resolution");
            failures = failures + PackageContractTest.require(appRun, "SEMU_PROJECT_DIR",
                "AppRun project-dir wiring");
            if (!PackageContractTest.isExecutable(appRunPath)) {
                failures = failures + PackageContractTest.fail("AppRun is not executable");
            }
        }
        string desktopPath = PathTools.join(outputRoot, "packaging/linux/semu.desktop");
        if (!FileSystem.isFile(desktopPath)) {
            failures = failures + PackageContractTest.fail(
                "semu.desktop not emitted at " + desktopPath);
        } else {
            string desktop = Path.readAll(desktopPath);
            failures = failures + PackageContractTest.require(desktop, "[Desktop Entry]",
                "desktop entry header");
            failures = failures + PackageContractTest.require(desktop, "Exec=AppRun",
                "desktop Exec line");
        }
        string shimPath = PathTools.join(outputRoot, "packaging/linux/bin/semu-retroarch");
        if (!FileSystem.isFile(shimPath)) {
            failures = failures + PackageContractTest.fail(
                "retroarch shim not emitted at " + shimPath);
        } else if (!PackageContractTest.isExecutable(shimPath)) {
            failures = failures + PackageContractTest.fail("retroarch shim is not executable");
        }
        return failures;
    }

    class int checkManifest(SemuContracts contracts) {
        int failures = 0;
        JsonValue parsed = JsonValue.parse(SystemEmitter.manifestJson(contracts));
        if (parsed.isError() || !parsed.isObject()) {
            return PackageContractTest.fail("SystemEmitter.manifestJson is not valid JSON");
        }
        if (parsed.get("systems").size() != contracts.systems.size()) {
            failures = failures + PackageContractTest.fail("manifest systems count mismatch");
        }
        if (parsed.get("emulators").size() != contracts.emulators.size()) {
            failures = failures + PackageContractTest.fail("manifest emulators count mismatch");
        }
        if (!parsed.get("schema_version").isInt() || parsed.get("schema_version").asInt() != 1) {
            failures = failures + PackageContractTest.fail("manifest schema_version != 1");
        }
        return failures;
    }

    class int checkNixLayer(string repoRoot) {
        int failures = 0;
        ParseLog nixLog = ParseLog();
        int issues = NixPackage.verify(repoRoot, nixLog);
        for entry in nixLog.errors {
            if (entry.contains("warning:")) {
                print("  WARN " + entry);
            } else {
                print("  " + entry);
            }
        }
        if (issues != 0) {
            failures = failures + PackageContractTest.fail(
                f"NixPackage.verify reported {issues} issues (see above)");
        }
        return failures;
    }

    class int run(string repoRoot) {
        int failures = 0;
        ParseLog log = ParseLog();
        SemuContracts contracts = SystemParser.loadAll(PathTools.join(repoRoot, "src/semu"),
            log);
        if (!log.ok()) {
            for error in log.errors {
                failures = failures + PackageContractTest.fail("parse: " + error);
            }
            return failures;
        }
        string outputRoot = Environment.get("SEMU_PKG_TEST_DIR",
            PathTools.join(repoRoot, "src/generated/test/pkg-test"));
        failures = failures + PackageContractTest.checkEsSystems(contracts);
        failures = failures + PackageContractTest.checkFindRules(contracts, repoRoot);
        failures = failures + PackageContractTest.checkAppImage(contracts, repoRoot, outputRoot);
        failures = failures + PackageContractTest.checkManifest(contracts);
        failures = failures + PackageContractTest.checkNixLayer(repoRoot);
        if (failures > 0) {
            print(f"package contract: FAIL ({failures} violations)");
            return failures;
        }
        print("package contract: es-de xml + appimage + manifest + nix pins valid");
        return 0;
    }
}
