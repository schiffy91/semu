// system_contract_test.btrc — proof harness for the JSON contract set.
//
// Loads every system/emulator contract under <repoRoot>/src/semu (override:
// $SEMU_SRC_ROOT), runs the full validation pass, prints a per-system summary,
// and returns the number of contract violations (0 = pass). The CLI routes
// `semu test core` here — no main().

import std.{vector, platform, fs}
import ../../src/semu/core/parse_log.btrc
import ../../src/semu/systems/system_parser.btrc
import ../../src/semu/systems/model/semu_contracts.btrc
import ../../src/semu/systems/model/system_definition.btrc
import ../../src/semu/systems/model/emulator_binding.btrc

class SystemContractTest {
    class string aspectLabel(SystemDefinition systemDefinition) {
        if (systemDefinition.display.screens.size() > 1) {
            return f"dual/{systemDefinition.display.arrangement}";
        }
        if (systemDefinition.display.aspect.set) {
            string base = f"{systemDefinition.display.aspect.w}:{systemDefinition.display.aspect.h}";
            if (systemDefinition.display.widescreen.set) {
                return base + f"+wide {systemDefinition.display.widescreen.aspect.w}:{systemDefinition.display.widescreen.aspect.h}";
            }
            return base;
        }
        return "?";
    }

    class string defaultEmulatorLabel(SystemDefinition systemDefinition) {
        if (systemDefinition.emulators.size() == 0) {
            return "?";
        }
        EmulatorBinding firstBinding = systemDefinition.emulators.get(0);
        if (firstBinding.core.isEmpty()) {
            return firstBinding.emulator;
        }
        return firstBinding.emulator + "/" + firstBinding.core;
    }

    class int run(string repoRoot) {
        string sourceRoot = Environment.get("SEMU_SRC_ROOT",
            PathTools.join(repoRoot, "src/semu"));
        ParseLog log = ParseLog();
        SemuContracts contracts = SystemParser.loadAll(sourceRoot, log);

        print(f"emulators: {contracts.emulators.size()}");
        for emulatorDefinition in contracts.emulators {
            string platformList = "";
            for platform in emulatorDefinition.platforms {
                platformList = platformList.isEmpty()
                    ? platform.operatingSystem : platformList + "," + platform.operatingSystem;
            }
            string defaultLabel = emulatorDefinition.defaultSystem.isEmpty()
                ? "" : " default=" + emulatorDefinition.defaultSystem;
            print(f"  {emulatorDefinition.id}: {emulatorDefinition.kind} [{platformList}]{defaultLabel}");
        }

        print(f"systems: {contracts.systems.size()}");
        for systemDefinition in contracts.systems {
            string aspect = SystemContractTest.aspectLabel(systemDefinition);
            string bezelLabel = systemDefinition.bezels.enabled
                ? f"{systemDefinition.bezels.variants.size()} bezel variants" : "bezels off";
            string shaderLabel = systemDefinition.shaders.enabled
                ? (systemDefinition.shaders.composite.isEmpty()
                    ? "screen shader" : "screen+composite shaders")
                : "shaders off";
            print(f"  {systemDefinition.id}: {SystemContractTest.defaultEmulatorLabel(systemDefinition)} {aspect} | {bezelLabel} | {shaderLabel}");
        }

        if (!log.ok()) {
            print(f"FAIL: {log.errors.size()} contract violations");
            for error in log.errors {
                print("  " + error);
            }
            return log.errors.size();
        }
        print("system_parser: all contracts valid");
        return 0;
    }
}
