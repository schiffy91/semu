// emulator_contract_test.btrc — proof harness for the emulator stack.
//
// Covers: full-fidelity parse of all 10 emulator.json contracts, launch-plan
// assembly for the Deck-proven paths (flatpak x11 forcing under gamescope,
// the patched-RA runtime/command tap override, nix/native argument vectors on
// macos, the verbatim ES-DE tail with add-only-when-absent platform
// defaults), the ES-DE command grammar against the golden es_systems
// strings, PCSX2 profile emission against the golden Deck inis, the GL-tap
// launch wiring (rom-path system inference + LinuxTap environment merging
// with the flatpak --env grants and LD_PRELOAD), the macos overlay-tap
// wiring (MacosTap environment merging + the /bin/sh overlay spawn wrap,
// never an injection), the SemuEmitter/SemuRenderer duty contract (every
// registered emulator id answers both duties; profile directories appear at
// write time only), and the
// platform contract: the macos axis validation (now routed through the
// platform classes) still rejects display_server and its sibling linux-only
// concepts, and the registry rejects unknown platforms keys. Returns
// the violation count (0 = pass); no main() — the CLI routes
// `semu test core` here.

import std.{vector, strings, platform, fs}
import ../../src/semu/core/parse_log.btrc
import ../../src/semu/core/settings.btrc
import ../../src/semu/platforms/platform_registry.btrc
import ../../src/semu/emulators/emulator_parser.btrc
import ../../src/semu/systems/system_parser.btrc
import ../../src/semu/emulators/semu_emulator.btrc
import ../../src/semu/emulators/emulator_process.btrc
import ../../src/semu/emulators/emulator_emitter.btrc
import ../../src/semu/emulators/emulator_execution.btrc
import ../../src/semu/emulators/emulator_registry.btrc
import ../../src/semu/emulators/retroarch/retroarch_rendering.btrc
import ../../src/semu/platforms/linux/linux_tap.btrc
import ../../src/semu/platforms/macos/macos_tap.btrc
import ../../src/semu/input/input_parser.btrc
import ../../src/semu/input/controllers/steamdeck/steam_input.btrc

class EmulatorContractTest {
    class int fail(string message) {
        print("  FAIL " + message);
        return 1;
    }

    class bool argumentVectorHas(LaunchPlan launchPlan, string expected) {
        return launchPlan.argumentVector.contains(expected);
    }

    class string environmentValue(LaunchPlan launchPlan, string key) {
        for (int keyIndex = 0; keyIndex < launchPlan.environmentSetKeys.size(); keyIndex++) {
            if (launchPlan.environmentSetKeys.get(keyIndex).equals(key)) {
                return launchPlan.environmentSetValues.get(keyIndex);
            }
        }
        return "";
    }

    class EmulatorDefinition findEmulator(SemuContracts contracts, string emulatorId) {
        for emulatorDefinition in contracts.emulators {
            if (emulatorDefinition.id.equals(emulatorId)) {
                return emulatorDefinition;
            }
        }
        return EmulatorDefinition();
    }

    class SystemDefinition findSystem(SemuContracts contracts, string systemId) {
        for systemDefinition in contracts.systems {
            if (systemDefinition.id.equals(systemId)) {
                return systemDefinition;
            }
        }
        return SystemDefinition();
    }

    class EmulatorBinding findBinding(SystemDefinition systemDefinition, string emulatorId) {
        for binding in systemDefinition.emulators {
            if (binding.emulator.equals(emulatorId)) {
                return binding;
            }
        }
        return EmulatorBinding();
    }

    class int checkDolphinPlan(SemuContracts contracts) {
        int failures = 0;
        EmulatorDefinition dolphin = EmulatorContractTest.findEmulator(contracts, "dolphin");
        Vector<string> noArguments = [];
        LaunchPlan dolphinPlan = EmulatorLauncher.plan(dolphin, "linux", "gamescope",
            "/roms/gc/game.iso", noArguments);
        if (!dolphinPlan.backend.equals("flatpak")) {
            failures = failures + EmulatorContractTest.fail(
                "dolphin linux backend: got '" + dolphinPlan.backend + "'");
        }
        if (!EmulatorContractTest.argumentVectorHas(dolphinPlan, "--socket=x11")) {
            failures = failures + EmulatorContractTest.fail(
                "dolphin gamescope plan lacks --socket=x11");
        }
        if (!dolphinPlan.environmentUnset.contains("WAYLAND_DISPLAY")) {
            failures = failures + EmulatorContractTest.fail(
                "dolphin gamescope plan does not unset WAYLAND_DISPLAY");
        }
        if (!EmulatorContractTest.argumentVectorHas(dolphinPlan, "--unset-env=WAYLAND_DISPLAY")) {
            failures = failures + EmulatorContractTest.fail(
                "dolphin gamescope plan lacks --unset-env=WAYLAND_DISPLAY");
        }
        if (!EmulatorContractTest.environmentValue(dolphinPlan, "DISPLAY").equals(":1")) {
            failures = failures + EmulatorContractTest.fail("dolphin gamescope DISPLAY: got '"
                + EmulatorContractTest.environmentValue(dolphinPlan, "DISPLAY")
                + "' (want ':1')");
        }
        if (!EmulatorContractTest.argumentVectorHas(dolphinPlan, "org.DolphinEmu.dolphin-emu")) {
            failures = failures + EmulatorContractTest.fail(
                "dolphin plan lacks the flatpak app id");
        }
        if (!EmulatorContractTest.argumentVectorHas(dolphinPlan, "/roms/gc/game.iso")) {
            failures = failures + EmulatorContractTest.fail("dolphin plan lacks the rom path");
        }
        return failures;
    }

    class int countInArgumentVector(LaunchPlan launchPlan, string expected) {
        int count = 0;
        for argument in launchPlan.argumentVector {
            if (argument.equals(expected)) {
                count++;
            }
        }
        return count;
    }

    // The ES-DE shim path: the emitted es_systems command already carries the
    // platform arguments, so a plan built from that verbatim tail must not
    // re-apply them — args appear exactly once and the ROM stays last.
    class int checkDolphinEsDeTailPlan(SemuContracts contracts) {
        int failures = 0;
        EmulatorDefinition dolphin = EmulatorContractTest.findEmulator(contracts, "dolphin");
        Vector<string> esDeTail = ["--config", "Dolphin.Display.Fullscreen=True",
                                   "-b", "-e", "/roms/wii/game.rvz"];
        LaunchPlan tailPlan = EmulatorLauncher.plan(dolphin, "linux", "gamescope",
            "", esDeTail);
        if (EmulatorContractTest.countInArgumentVector(tailPlan, "--config") != 1
            || EmulatorContractTest.countInArgumentVector(tailPlan, "-b") != 1
            || EmulatorContractTest.countInArgumentVector(tailPlan, "-e") != 1) {
            failures = failures + EmulatorContractTest.fail(
                "dolphin es-de tail plan duplicated platform arguments");
        }
        int lastIndex = tailPlan.argumentVector.size() - 1;
        if (lastIndex < 0
            || !tailPlan.argumentVector.get(lastIndex).equals("/roms/wii/game.rvz")) {
            failures = failures + EmulatorContractTest.fail(
                "dolphin es-de tail plan must keep the rom as the final argument");
        }
        if (EmulatorContractTest.countInArgumentVector(tailPlan,
                "Dolphin.Display.Fullscreen=True") != 1) {
            failures = failures + EmulatorContractTest.fail(
                "dolphin es-de tail plan duplicated the --config value");
        }
        return failures;
    }

    class int checkRetroArchLinuxPlan(SemuContracts contracts) {
        int failures = 0;
        EmulatorDefinition retroArch = EmulatorContractTest.findEmulator(contracts, "retroarch");
        Vector<string> noArguments = [];
        LaunchPlan retroArchPlan = EmulatorLauncher.plan(retroArch, "linux", "gamescope",
            "", noArguments);
        if (!EmulatorContractTest.argumentVectorHas(retroArchPlan,
                "--command=${asset_root}/bin/retroarch-semu")) {
            failures = failures + EmulatorContractTest.fail(
                "retroarch linux plan lacks the tap --command override");
        }
        // The KDE Application PLATFORM runtime (not the Sdk): it carries the
        // Qt 6.10 the tap-patched build links against, it is what semu's own
        // provisioning installs, and it is proven on the Deck.
        if (!EmulatorContractTest.argumentVectorHas(retroArchPlan,
                "org.kde.Platform//6.10")) {
            failures = failures + EmulatorContractTest.fail(
                "retroarch linux plan does not run in the KDE Platform runtime");
        }
        if (EmulatorContractTest.argumentVectorHas(retroArchPlan, "org.libretro.RetroArch")) {
            failures = failures + EmulatorContractTest.fail(
                "retroarch linux plan must replace the stock app id with the runtime");
        }
        if (!EmulatorContractTest.argumentVectorHas(retroArchPlan, "--devel")
            || !EmulatorContractTest.argumentVectorHas(retroArchPlan, "--socket=pulseaudio")
            || !EmulatorContractTest.argumentVectorHas(retroArchPlan, "--share=ipc")
            || !EmulatorContractTest.argumentVectorHas(retroArchPlan, "--filesystem=host")) {
            failures = failures + EmulatorContractTest.fail(
                "retroarch linux plan lacks the sandbox grants (devel/pulseaudio/ipc/host)");
        }
        if (!EmulatorContractTest.environmentValue(retroArchPlan, "DISPLAY").equals(":1")) {
            failures = failures + EmulatorContractTest.fail("retroarch gamescope DISPLAY: got '"
                + EmulatorContractTest.environmentValue(retroArchPlan, "DISPLAY")
                + "' (want ':1')");
        }
        return failures;
    }

    class int checkRetroArchMacosPlan(SemuContracts contracts) {
        int failures = 0;
        EmulatorDefinition retroArch = EmulatorContractTest.findEmulator(contracts, "retroarch");
        Vector<string> noArguments = [];
        LaunchPlan retroArchMacPlan = EmulatorLauncher.plan(retroArch, "macos", "",
            "/roms/gb/game.gb", noArguments);
        if (!retroArchMacPlan.backend.equals("nix")) {
            failures = failures + EmulatorContractTest.fail(
                "retroarch macos backend: got '" + retroArchMacPlan.backend + "'");
        }
        if (retroArchMacPlan.argumentVector.size() < 4
            || !retroArchMacPlan.argumentVector.get(0).equals("sandbox-exec")
            || !retroArchMacPlan.argumentVector.get(1).equals("-p")) {
            failures = failures + EmulatorContractTest.fail(
                "retroarch macos plan must be wrapped in sandbox-exec -p <profile>");
        } else {
            string sandboxProfile = retroArchMacPlan.argumentVector.get(2);
            if (!sandboxProfile.contains("(deny file-write*)")
                || !sandboxProfile.contains("${home}/.config/retroarch")) {
                failures = failures + EmulatorContractTest.fail(
                    "retroarch macos sandbox profile must deny writes and carry the declared grants");
            }
            if (!retroArchMacPlan.argumentVector.get(3).equals("${nix_result}/bin/retroarch")) {
                failures = failures + EmulatorContractTest.fail(
                    "retroarch macos argv after the sandbox wrap must be the nix executable");
            }
        }
        if (!EmulatorContractTest.argumentVectorHas(retroArchMacPlan, "-f")) {
            failures = failures + EmulatorContractTest.fail(
                "retroarch macos plan lacks the -f platform arg");
        }
        if (retroArchMacPlan.argumentVector.size() == 0
            || !retroArchMacPlan.argumentVector.get(retroArchMacPlan.argumentVector.size() - 1)
                .equals("/roms/gb/game.gb")) {
            failures = failures + EmulatorContractTest.fail(
                "retroarch macos plan must end with the rom path");
        }
        if (EmulatorContractTest.argumentVectorHas(retroArchMacPlan, "--socket=x11")) {
            failures = failures + EmulatorContractTest.fail(
                "retroarch macos plan must not carry linux display sockets");
        }
        return failures;
    }

    class int checkEsDeCommands(SemuContracts contracts) {
        int failures = 0;
        EmulatorDefinition retroArch = EmulatorContractTest.findEmulator(contracts, "retroarch");
        SystemDefinition gameBoy = EmulatorContractTest.findSystem(contracts, "gb");
        EmulatorBinding gameBoyBinding = EmulatorContractTest.findBinding(gameBoy, "retroarch");
        string gameBoyCommand = EmulatorEmitter.esDeCommand(gameBoyBinding, retroArch, "linux");
        string gameBoyExpected =
            "%EMULATOR_RETROARCH% -f -L %CORE_RETROARCH%/gambatte_libretro.so %ROM%";
        if (!gameBoyCommand.equals(gameBoyExpected)) {
            failures = failures + EmulatorContractTest.fail("gb esde command: got '"
                + gameBoyCommand + "' want '" + gameBoyExpected + "'");
        }

        SystemDefinition nintendo64 = EmulatorContractTest.findSystem(contracts, "n64");
        EmulatorBinding nintendo64Binding = EmulatorContractTest.findBinding(nintendo64, "retroarch");
        string nintendo64Command = EmulatorEmitter.esDeCommand(nintendo64Binding, retroArch, "macos");
        string nintendo64Expected =
            "%EMULATOR_RETROARCH% -f -L %CORE_RETROARCH%/mupen64plus_next_libretro.dylib %ROM%";
        if (!nintendo64Command.equals(nintendo64Expected)) {
            failures = failures + EmulatorContractTest.fail("n64 esde command: got '"
                + nintendo64Command + "' want '" + nintendo64Expected + "'");
        }
        return failures;
    }

    // Golden-parity comparison for one emitted PCSX2 ini: byte-per-line
    // against the Deck-proven golden, with two principled exceptions — the
    // golden Bios line carries the golden machine's absolute project path
    // (the emitted line must carry the same project-relative tail), and the
    // ToggleSlowMotion hotkey renders only when the frozen contract declares
    // speed.rewind.
    class int comparePcsx2GoldenFile(string emittedPath, string goldenPath,
                                     EmulatorDefinition pcsx2, string name) {
        if (!FileSystem.isFile(emittedPath)) {
            return EmulatorContractTest.fail(name + " was not emitted: " + emittedPath);
        }
        if (!FileSystem.isFile(goldenPath)) {
            // The Deck goldens were burned with garbage/ after parity was
            // proven (git history holds them); structural assertions below
            // carry the regression coverage.
            print("  SKIP " + name + " golden byte-parity (golden not on disk)");
            return 0;
        }
        int failures = 0;
        Vector<string> emittedLines = Strings.split(Path.readAll(emittedPath), "\n");
        int emittedIndex = 0;
        for goldenLine in Strings.split(Path.readAll(goldenPath), "\n") {
            bool slowMotionGated = goldenLine.startsWith("ToggleSlowMotion")
                && !pcsx2.input.actions.contains("speed.rewind");
            if (!slowMotionGated) {
                string emittedLine = emittedIndex < emittedLines.size()
                    ? emittedLines.get(emittedIndex) : "(missing)";
                emittedIndex++;
                if (goldenLine.startsWith("Bios = ")) {
                    if (!emittedLine.startsWith("Bios = ")
                        || !emittedLine.endsWith("src/generated/runtime/content/bios/ps2")) {
                        failures = failures + EmulatorContractTest.fail(
                            name + " bios folder line: got '" + emittedLine + "'");
                    }
                } else if (!emittedLine.equals(goldenLine)) {
                    failures = failures + EmulatorContractTest.fail(name + " line "
                        + f"{emittedIndex}" + ": got '" + emittedLine + "' want '"
                        + goldenLine + "'");
                }
            }
        }
        if (emittedIndex != emittedLines.size()) {
            failures = failures + EmulatorContractTest.fail(
                name + f" carries {emittedLines.size() - emittedIndex} extra lines");
        }
        return failures;
    }

    // PCSX2 profile emission vs the Deck goldens — a silent no-op emitter
    // (the gap that dropped the PS2 input fix) can never pass again.
    class int checkPcsx2Profiles(SemuContracts contracts, string repoRoot) {
        ParseLog log = ParseLog();
        string targetDirectory = PathTools.join(repoRoot,
            "src/semu/input/controllers/steamdeck");
        Keymap keymap = KeymapParser.parse(
            Path.readAll(PathTools.join(targetDirectory, "steamdeck.skm")), log);
        SteamInputTarget steamInput = SteamInputParser.parse(
            PathTools.join(targetDirectory, "steam_input.json"), log);
        EmulatorDefinition pcsx2 = EmulatorContractTest.findEmulator(contracts, "pcsx2");
        string outputRoot = PathTools.join(
            Environment.get("SEMU_TEST_TMP", "/tmp/semu-core-tests"), "pcsx2-profiles");
        EmulatorRegistry.emitProfiles(pcsx2.id, pcsx2, steamInput, keymap, outputRoot);
        string goldenRoot = PathTools.join(repoRoot,
            "garbage/generated/packaging/emulators/profiles/PCSX2/config");
        int failures = EmulatorContractTest.comparePcsx2GoldenFile(
            PathTools.join(outputRoot, "PCSX2/config/inis/PCSX2.ini"),
            PathTools.join(goldenRoot, "inis/PCSX2.ini"), pcsx2, "pcsx2 base ini");
        failures = failures + EmulatorContractTest.comparePcsx2GoldenFile(
            PathTools.join(outputRoot, "PCSX2/config/inputprofiles/Steam Deck.ini"),
            PathTools.join(goldenRoot, "inputprofiles/Steam Deck.ini"), pcsx2,
            "pcsx2 input profile");

        // Data-driven structure (independent of golden availability): the pad
        // identity comes from the steamdeck target, every declared hotkey
        // action lands in the base ini as this emulator's chord grammar, and
        // the bios folder points at the runtime content root.
        string baseIni = Path.readAll(PathTools.join(outputRoot, "PCSX2/config/inis/PCSX2.ini"));
        string inputProfile = Path.readAll(
            PathTools.join(outputRoot, "PCSX2/config/inputprofiles/Steam Deck.ini"));
        if (!inputProfile.contains(steamInput.deviceIdentity("pcsx2_pad"))) {
            failures = failures + EmulatorContractTest.fail(
                "pcsx2 input profile lacks the contract pad identity");
        }
        // The Bios folder must be RESOLVED (no template tokens) — the
        // concrete path is environment truth: the SD firmware dir when the
        // contract's ${emulation_root} exists (the Deck), the project's
        // runtime content fallback otherwise (CI, the Mac).
        if (!baseIni.contains("Bios = /") || baseIni.contains("Bios = ${")) {
            failures = failures + EmulatorContractTest.fail(
                "pcsx2 base ini lacks a resolved bios folder");
        }
        // Hotkey chords live in the input profile ([Hotkeys] section; the
        // base ini delegates via UseProfileHotkeyBindings). app.quit is the
        // one declared action with no PCSX2 hotkey line: quitting binds at
        // the Steam Input layer (quit_extra_bindings), matching the Deck
        // golden.
        for keymapAction in keymap.actions {
            if (pcsx2.input.actions.contains(keymapAction.id)
                && !keymapAction.id.equals("app.quit")) {
                string chordToken = EmulatorRegistry.translateChord(pcsx2.id,
                    keymapAction.chord);
                if (!inputProfile.contains(chordToken)) {
                    failures = failures + EmulatorContractTest.fail(
                        "pcsx2 input profile lacks hotkey chord for " + keymapAction.id
                        + " (" + chordToken + ")");
                }
            }
        }
        return failures;
    }

    // Empty directories in an emitted profile tree are litter: directories
    // are created at write time only, so a no-op emitter leaves nothing.
    class int countEmptyDirectories(string root) {
        if (!FileSystem.isDir(root)) {
            return 0;
        }
        int emptyCount = 0;
        int entryCount = 0;
        for entry in Directory(root).entries() {
            entryCount++;
            string childPath = PathTools.join(root, entry);
            if (FileSystem.isDir(childPath)) {
                emptyCount = emptyCount
                    + EmulatorContractTest.countEmptyDirectories(childPath);
            }
        }
        if (entryCount == 0) {
            emptyCount++;
        }
        return emptyCount;
    }

    class EmulatorPlatform probePlatform(SemuContracts contracts, string emulatorId) {
        EmulatorDefinition definition = EmulatorContractTest.findEmulator(contracts,
            emulatorId);
        if (definition.platforms.size() > 0) {
            return definition.platforms.get(0);
        }
        return EmulatorPlatform();
    }

    // One renderer-duty answer: recording it proves the concrete class
    // computed both surfaces; the invariant checked here holds for every
    // emulator — graphics force arguments exist only where the contract
    // declares a cli graphics method.
    class int recordRendererAnswer(Vector<string> answeredIds, string emulatorId,
                                   EmulatorPlatform probePlatform,
                                   Vector<string> forceArguments, string overlayText) {
        answeredIds.push(emulatorId);
        bool declaresCliGraphics = probePlatform.graphics.present
            && probePlatform.graphics.method.equals("cli");
        if (!declaresCliGraphics && forceArguments.size() != 0) {
            return EmulatorContractTest.fail(emulatorId
                + " answers graphics force arguments without a cli graphics contract");
        }
        return 0;
    }

    // Both SemuEmulator duties across the whole registry. Enforcement is at
    // COMPILE time: every concrete emulator class declares
    // `extends SemuEmulator implements SemuEmitter, SemuRenderer`
    // (semu_emulator.btrc), so a class that forgets emitProfiles or
    // graphicsForceArguments/overlayConfiguration fails the BUILD via the
    // interface-satisfaction and abstract-method checks — a new emulator can
    // never reach this test as a silent no-op. What runtime adds on top:
    // every registered id ANSWERS the emitter duty through the registry (the
    // one shared-code route) creating directories at write time only — the
    // deliberate no-op emitters leave NO directory, the emitting ones leave
    // no empty one — and every registered id answers the renderer duty
    // (btrc dispatch is static, so the concrete classes answer through
    // their own declared types; tests may name them).
    class int checkEmulatorDutyContract(SemuContracts contracts, string repoRoot) {
        int failures = 0;
        ParseLog log = ParseLog();
        string targetDirectory = PathTools.join(repoRoot,
            "src/semu/input/controllers/steamdeck");
        Keymap keymap = KeymapParser.parse(
            Path.readAll(PathTools.join(targetDirectory, "steamdeck.skm")), log);
        SteamInputTarget steamInput = SteamInputParser.parse(
            PathTools.join(targetDirectory, "steam_input.json"), log);
        string dutyRoot = PathTools.join(
            Environment.get("SEMU_TEST_TMP", "/tmp/semu-core-tests"), "duty-contract");

        int emittingCount = 0;
        for emulatorId in EmulatorRegistry.registeredIds() {
            EmulatorDefinition definition = EmulatorContractTest.findEmulator(contracts,
                emulatorId);
            if (definition.id.isEmpty()) {
                failures = failures + EmulatorContractTest.fail("registered emulator '"
                    + emulatorId + "' has no parsed contract");
            } else {
                string outputRoot = PathTools.join(dutyRoot, emulatorId);
                EmulatorRegistry.emitProfiles(emulatorId, definition, steamInput, keymap,
                    outputRoot);
                if (EmulatorContractTest.countEmptyDirectories(outputRoot) != 0) {
                    failures = failures + EmulatorContractTest.fail("emitter duty for '"
                        + emulatorId + "' littered an empty profile directory under "
                        + outputRoot);
                }
                if (FileSystem.isDir(outputRoot)) {
                    emittingCount++;
                }
            }
        }
        if (emittingCount == 0) {
            failures = failures + EmulatorContractTest.fail(
                "no registered emulator emitted a profile — the emitter routing is dead");
        }

        Vector<string> rendererAnsweredIds = [];
        EmulatorPlatform cemuPlatform = EmulatorContractTest.probePlatform(contracts,
            CemuEmulator().id());
        failures = failures + EmulatorContractTest.recordRendererAnswer(rendererAnsweredIds,
            CemuEmulator().id(), cemuPlatform,
            CemuEmulator().graphicsForceArguments(cemuPlatform, "opengl"),
            CemuEmulator().overlayConfiguration(cemuPlatform));
        EmulatorPlatform dolphinPlatform = EmulatorContractTest.probePlatform(contracts,
            DolphinEmulator().id());
        failures = failures + EmulatorContractTest.recordRendererAnswer(rendererAnsweredIds,
            DolphinEmulator().id(), dolphinPlatform,
            DolphinEmulator().graphicsForceArguments(dolphinPlatform, "opengl"),
            DolphinEmulator().overlayConfiguration(dolphinPlatform));
        EmulatorPlatform pcsx2Platform = EmulatorContractTest.probePlatform(contracts,
            Pcsx2Emulator().id());
        failures = failures + EmulatorContractTest.recordRendererAnswer(rendererAnsweredIds,
            Pcsx2Emulator().id(), pcsx2Platform,
            Pcsx2Emulator().graphicsForceArguments(pcsx2Platform, "opengl"),
            Pcsx2Emulator().overlayConfiguration(pcsx2Platform));
        EmulatorPlatform retroArchPlatform = EmulatorContractTest.probePlatform(contracts,
            RetroArchEmulator().id());
        failures = failures + EmulatorContractTest.recordRendererAnswer(rendererAnsweredIds,
            RetroArchEmulator().id(), retroArchPlatform,
            RetroArchEmulator().graphicsForceArguments(retroArchPlatform, "opengl"),
            RetroArchEmulator().overlayConfiguration(retroArchPlatform));
        EmulatorPlatform ryujinxPlatform = EmulatorContractTest.probePlatform(contracts,
            RyujinxEmulator().id());
        failures = failures + EmulatorContractTest.recordRendererAnswer(rendererAnsweredIds,
            RyujinxEmulator().id(), ryujinxPlatform,
            RyujinxEmulator().graphicsForceArguments(ryujinxPlatform, "opengl"),
            RyujinxEmulator().overlayConfiguration(ryujinxPlatform));

        for registeredId in EmulatorRegistry.registeredIds() {
            if (!rendererAnsweredIds.contains(registeredId)) {
                failures = failures + EmulatorContractTest.fail(
                    "renderer duty unanswered for registered emulator '"
                    + registeredId + "'");
            }
        }
        if (rendererAnsweredIds.size() != EmulatorRegistry.registeredIds().size()) {
            failures = failures + EmulatorContractTest.fail(
                "renderer duty answered by a class the registry does not route");
        }

        // The one contract-declared cli graphics grammar today: dolphin's
        // linux block pins method 'cli', so its force arguments must carry
        // the --config backend pair.
        EmulatorDefinition dolphin = EmulatorContractTest.findEmulator(contracts,
            DolphinEmulator().id());
        EmulatorPlatform dolphinLinux = dolphin.platformFor("linux");
        Vector<string> dolphinForceArguments = DolphinEmulator().graphicsForceArguments(
            dolphinLinux, "opengl");
        if (dolphinForceArguments.size() != 2
            || !dolphinForceArguments.contains("--config")) {
            failures = failures + EmulatorContractTest.fail(
                "dolphin's cli graphics contract must answer the --config backend pair");
        }

        if (failures == 0) {
            print("  OK emulator duty contract (emitter + renderer across the registry)");
        }
        return failures;
    }

    class int argumentPosition(LaunchPlan launchPlan, string expected) {
        for (int argumentIndex = 0; argumentIndex < launchPlan.argumentVector.size();
             argumentIndex++) {
            if (launchPlan.argumentVector.get(argumentIndex).equals(expected)) {
                return argumentIndex;
            }
        }
        return -1;
    }

    class bool carriesTapEnvironment(LaunchPlan launchPlan) {
        for key in launchPlan.environmentSetKeys {
            if (key.startsWith("SEMU_TAP_") || key.equals("SEMU_RETRO_START")
                || key.equals("LD_PRELOAD")) {
                return true;
            }
        }
        return false;
    }

    // System inference from the rom path is pure contract data: rom.dir
    // segments infer, flag values and rom-less tails never do.
    class int checkSystemInference(SemuContracts contracts) {
        int failures = 0;
        if (!contracts.systemForRomPath("/roms/gc/game.iso").equals("gc")) {
            failures = failures + EmulatorContractTest.fail(
                "systemForRomPath(/roms/gc/game.iso): got '"
                + contracts.systemForRomPath("/roms/gc/game.iso") + "' (want 'gc')");
        }
        if (!contracts.systemForRomPath("/library/gb/nested/gbc/game.gbc").equals("gbc")) {
            failures = failures + EmulatorContractTest.fail(
                "systemForRomPath must prefer the deepest matching segment, got '"
                + contracts.systemForRomPath("/library/gb/nested/gbc/game.gbc") + "'");
        }
        if (!contracts.systemForRomPath("Dolphin.Display.Fullscreen=True").isEmpty()) {
            failures = failures + EmulatorContractTest.fail(
                "systemForRomPath must not infer a system from a flag value");
        }
        if (!contracts.systemForRomPath("").isEmpty()
            || !contracts.systemForRomPath("game.iso").isEmpty()) {
            failures = failures + EmulatorContractTest.fail(
                "systemForRomPath must return '' for empty/bare tails");
        }
        return failures;
    }

    // The launch-time tap-binary refinement: the first tap_binary candidate
    // that exists on disk replaces the plan's --command= argument; with no
    // candidate on disk the plan keeps the contract default. Hermetic: a
    // synthetic platform carries literal candidate paths under the test
    // scratch, so no environment or host state participates.
    class int checkRetroArchTapBinaryRefinement() {
        int failures = 0;
        string scratchRoot = PathTools.join(
            Environment.get("SEMU_TEST_TMP", "/tmp/semu-core-tests"), "tap-binary");
        string stagedBinary = PathTools.join(scratchRoot, "bin/retroarch-semu");
        string missingBinary = PathTools.join(scratchRoot, "bin/absent-retroarch");
        UnixFileSystem.mkdirp(PathTools.dirname(stagedBinary));
        Path.writeAll(stagedBinary, "fake patched retroarch");

        EmulatorPlatform syntheticPlatform = EmulatorPlatform();
        syntheticPlatform.operatingSystem = "linux";
        syntheticPlatform.backend = "flatpak";
        syntheticPlatform.extensionJson = JsonValue.parse("{\"tap_binary\": [\""
            + missingBinary + "\", \"" + stagedBinary + "\"]}");
        TemplateContext refinementContext = TemplateContext();
        refinementContext.project = scratchRoot;
        refinementContext.platformId = "linux";
        refinementContext.emulatorId = "retroarch";
        refinementContext.backend = "flatpak";

        LaunchPlan refinablePlan = LaunchPlan();
        refinablePlan.backend = "flatpak";
        refinablePlan.argumentVector.push("flatpak");
        refinablePlan.argumentVector.push("run");
        refinablePlan.argumentVector.push("--command=/contract/default");
        refinablePlan.argumentVector.push("org.kde.Platform//6.10");
        RetroArchRendering.refineLaunchPlanWithContext(refinablePlan, syntheticPlatform,
            refinementContext);
        if (EmulatorContractTest.argumentPosition(refinablePlan,
                "--command=" + stagedBinary) != 2) {
            failures = failures + EmulatorContractTest.fail(
                "tap-binary refinement must rewrite --command= to the first"
                + " on-disk candidate (missing candidates are skipped)");
        }

        LaunchPlan untouchedPlan = LaunchPlan();
        untouchedPlan.backend = "flatpak";
        untouchedPlan.argumentVector.push("flatpak");
        untouchedPlan.argumentVector.push("run");
        untouchedPlan.argumentVector.push("--command=/contract/default");
        untouchedPlan.argumentVector.push("org.kde.Platform//6.10");
        EmulatorPlatform absentPlatform = EmulatorPlatform();
        absentPlatform.operatingSystem = "linux";
        absentPlatform.backend = "flatpak";
        absentPlatform.extensionJson = JsonValue.parse("{\"tap_binary\": [\""
            + missingBinary + "\"]}");
        RetroArchRendering.refineLaunchPlanWithContext(untouchedPlan, absentPlatform,
            refinementContext);
        if (EmulatorContractTest.argumentPosition(untouchedPlan,
                "--command=/contract/default") != 2) {
            failures = failures + EmulatorContractTest.fail(
                "tap-binary refinement must keep the contract default when no"
                + " candidate exists on disk");
        }

        // The live-configuration install: a bootstrap-emitted profile under
        // the scratch project lands in the state root's retroarch.cfg with
        // upsert semantics — the app.quit combo pin is the proof key.
        string profilePath = PathTools.join(scratchRoot,
            "src/generated/packaging/emulators/profiles/RetroArch/retroarch.cfg");
        UnixFileSystem.mkdirp(PathTools.dirname(profilePath));
        Path.writeAll(profilePath, "input_quit_gamepad_combo = \"4\"\n"
            + "input_driver = \"sdl2\"\n");
        string livePath = RetroArchRendering.liveConfigurationPath(refinementContext);
        UnixFileSystem.mkdirp(PathTools.dirname(livePath));
        Path.writeAll(livePath, "input_quit_gamepad_combo = \"0\"\n"
            + "user_kept_setting = \"yes\"\n");
        ParseLog installLog = ParseLog();
        RetroArchRendering.installLiveConfiguration(
            RetroArchEmulator().parseConfiguration(syntheticPlatform, installLog),
            refinementContext);
        string liveText = Path.readAll(livePath);
        if (!liveText.contains("input_quit_gamepad_combo = \"4\"")) {
            failures = failures + EmulatorContractTest.fail(
                "live-configuration install must upsert the emitted app.quit combo");
        }
        if (!liveText.contains("user_kept_setting = \"yes\"")) {
            failures = failures + EmulatorContractTest.fail(
                "live-configuration install must preserve settings it does not own");
        }
        if (failures == 0) {
            print("  OK retroarch launch refinement (tap binary + live configuration)");
        }
        return failures;
    }

    // The GL-tap launch wiring: a dolphin linux plan for a gc rom gains the
    // contract SEMU_TAP_* bundle, the exec-edge keys and LD_PRELOAD (with
    // the flatpak --env grant BEFORE the app id) when a tap library exists
    // under a SEMU_TEST_TMP-staged asset root; disabled visuals skip
    // everything; a missing library degrades to a plan note.
    // The graphics-force ini upsert (pure): replace inside the declared
    // section, insert under an existing header, create the section when the
    // file lacks it — the emulator only reads the pin INSIDE its section.
    class int checkGraphicsForceUpsert() {
        int failures = 0;
        string replaced = EmulatorExecution.upsertIniValue(
            "[UI]\nConfirmShutdown = false\n[EmuCore/GS]\nRenderer = -1\nfilter = 0\n",
            "EmuCore/GS", "Renderer", "12");
        if (!replaced.contains("[EmuCore/GS]\nRenderer = 12")
            || replaced.contains("Renderer = -1")) {
            failures = failures + EmulatorContractTest.fail(
                "graphics-force upsert must replace the key inside its section");
        }
        string inserted = EmulatorExecution.upsertIniValue(
            "[Graphics]\nFullScreen = True\n[Sound]\nEnable = True\n",
            "Graphics", "GPUBackend", "0");
        int graphicsIndex = inserted.indexOf("[Graphics]");
        int soundIndex = inserted.indexOf("[Sound]");
        int keyIndex = inserted.indexOf("GPUBackend = 0");
        if (keyIndex < graphicsIndex || keyIndex > soundIndex) {
            failures = failures + EmulatorContractTest.fail(
                "graphics-force upsert must insert the key inside the existing section");
        }
        string created = EmulatorExecution.upsertIniValue("", "EmuCore/GS", "Renderer", "12");
        if (!created.contains("[EmuCore/GS]\nRenderer = 12")) {
            failures = failures + EmulatorContractTest.fail(
                "graphics-force upsert must create the missing section");
        }
        if (failures == 0) {
            print("  OK graphics-force section-aware ini upsert");
        }
        return failures;
    }

    class int checkLinuxTapWiring(SemuContracts contracts, string repoRoot) {
        int failures = 0;
        EmulatorDefinition dolphin = EmulatorContractTest.findEmulator(contracts, "dolphin");
        SystemDefinition gameCube = EmulatorContractTest.findSystem(contracts, "gc");
        Vector<string> noArguments = [];
        SemuSettings settings = SemuSettings();

        string fakeAssetRoot = PathTools.join(
            Environment.get("SEMU_TEST_TMP", "/tmp/semu-core-tests"), "tap-asset-root");
        string fakeLibraryPath = PathTools.join(fakeAssetRoot, "lib/semu/libsemutap.so");
        UnixFileSystem.mkdirp(PathTools.dirname(fakeLibraryPath));
        Path.writeAll(fakeLibraryPath, "fake tap library");

        LaunchPlan dolphinPlan = EmulatorLauncher.plan(dolphin, "linux", "gamescope",
            "/roms/gc/game.iso", noArguments);
        if (EmulatorContractTest.carriesTapEnvironment(dolphinPlan)) {
            failures = failures + EmulatorContractTest.fail(
                "an assembled plan must carry no tap environment before LinuxTap.apply");
        }
        LinuxTap.applyWithAssetRoot(dolphinPlan, dolphin, gameCube, settings, repoRoot,
            fakeAssetRoot);
        if (!EmulatorContractTest.environmentValue(dolphinPlan, "SEMU_TAP_ART")
                .endsWith("assets/bezels/gc/tv.png")) {
            failures = failures + EmulatorContractTest.fail(
                "tap plan SEMU_TAP_ART: got '"
                + EmulatorContractTest.environmentValue(dolphinPlan, "SEMU_TAP_ART")
                + "' (want the gc tv art)");
        }
        if (!EmulatorContractTest.environmentValue(dolphinPlan, "SEMU_TAP_STYLE")
                .equals("console")
            || !EmulatorContractTest.environmentValue(dolphinPlan, "SEMU_TAP_NATIVE_W")
                .equals("640")
            || !EmulatorContractTest.environmentValue(dolphinPlan, "SEMU_TAP_NATIVE_H")
                .equals("480")) {
            failures = failures + EmulatorContractTest.fail(
                "tap plan lacks the gc contract wire values (STYLE/NATIVE_W/NATIVE_H)");
        }
        if (!EmulatorContractTest.environmentValue(dolphinPlan, "SEMU_RETRO_START")
                .equals("0")) {
            failures = failures + EmulatorContractTest.fail(
                "tap plan SEMU_RETRO_START: gc declares no retro_default, want '0'");
        }
        if (!EmulatorContractTest.environmentValue(dolphinPlan, "SEMU_TAP_STANDALONE")
                .equals("1")) {
            failures = failures + EmulatorContractTest.fail(
                "tap plan SEMU_TAP_STANDALONE: dolphin is kind standalone, want '1'");
        }
        if (!EmulatorContractTest.environmentValue(dolphinPlan, "SEMU_TAP_STATE_DIR")
                .equals("${state_root}")) {
            failures = failures + EmulatorContractTest.fail(
                "tap plan SEMU_TAP_STATE_DIR must be the ${state_root} template token");
        }
        if (!EmulatorContractTest.environmentValue(dolphinPlan, "SEMU_TAP_MENUFONT")
                .endsWith("assets/fonts/menu-font.png")) {
            failures = failures + EmulatorContractTest.fail(
                "tap plan SEMU_TAP_MENUFONT must resolve the canonical menu font");
        }
        if (!EmulatorContractTest.environmentValue(dolphinPlan, "LD_PRELOAD")
                .equals(fakeLibraryPath)) {
            failures = failures + EmulatorContractTest.fail(
                "tap plan LD_PRELOAD: got '"
                + EmulatorContractTest.environmentValue(dolphinPlan, "LD_PRELOAD")
                + "' (want the staged fake library)");
        }
        int preloadGrantPosition = EmulatorContractTest.argumentPosition(dolphinPlan,
            "--env=LD_PRELOAD=" + fakeLibraryPath);
        int applicationIdPosition = EmulatorContractTest.argumentPosition(dolphinPlan,
            "org.DolphinEmu.dolphin-emu");
        if (preloadGrantPosition < 2 || applicationIdPosition < 0
            || preloadGrantPosition > applicationIdPosition) {
            failures = failures + EmulatorContractTest.fail(
                "flatpak tap plan must bundle --env=LD_PRELOAD before the app id");
        }
        int libraryGrantPosition = EmulatorContractTest.argumentPosition(dolphinPlan,
            "--filesystem=" + PathTools.dirname(fakeLibraryPath) + ":ro");
        if (libraryGrantPosition < 2 || libraryGrantPosition > applicationIdPosition) {
            failures = failures + EmulatorContractTest.fail(
                "flatpak tap plan must grant the tap library directory read-only");
        }
        string expectedAssetGrant = "--filesystem="
            + BezelResolver.assetRootFrom(fakeAssetRoot, repoRoot) + ":ro";
        int assetGrantPosition = EmulatorContractTest.argumentPosition(dolphinPlan,
            expectedAssetGrant);
        if (assetGrantPosition < 2 || assetGrantPosition > applicationIdPosition) {
            failures = failures + EmulatorContractTest.fail(
                "flatpak tap plan must grant the asset root read-only ("
                + expectedAssetGrant + ")");
        }

        LaunchPlan disabledPlan = EmulatorLauncher.plan(dolphin, "linux", "gamescope",
            "/roms/gc/game.iso", noArguments);
        SemuSettings disabledSettings = SemuSettings();
        disabledSettings.visual.bezels = false;
        disabledSettings.visual.crtShaders = false;
        LinuxTap.applyWithAssetRoot(disabledPlan, dolphin, gameCube, disabledSettings,
            repoRoot, fakeAssetRoot);
        if (EmulatorContractTest.carriesTapEnvironment(disabledPlan)) {
            failures = failures + EmulatorContractTest.fail(
                "bezels+crt_shaders off must skip the tap entirely");
        }

        LaunchPlan notePlan = EmulatorLauncher.plan(dolphin, "linux", "gamescope",
            "/roms/gc/game.iso", noArguments);
        LinuxTap.applyWithAssetRoot(notePlan, dolphin, gameCube, settings,
            "/nonexistent-semu-project", PathTools.join(fakeAssetRoot, "missing"));
        if (!EmulatorContractTest.environmentValue(notePlan, "LD_PRELOAD").isEmpty()
            || !notePlan.note.contains("tap library not found")) {
            failures = failures + EmulatorContractTest.fail(
                "a missing tap library must skip LD_PRELOAD and note the plan");
        }
        if (EmulatorContractTest.environmentValue(notePlan, "SEMU_TAP_ART").isEmpty()) {
            failures = failures + EmulatorContractTest.fail(
                "a missing tap library must still merge the tap environment");
        }

        return failures;
    }

    // The macos overlay-tap wiring: an assembled macos plan carries no tap
    // environment until MacosTap.apply; with bezels on it gains the contract
    // SEMU_TAP_* bundle (never LD_PRELOAD — nothing is injected on macos)
    // and the vector is wrapped /bin/sh -c <script> <vector...> so the
    // overlay compositor spawns alongside the emulator with its pid; bezels
    // off skips everything; a missing overlay binary degrades to a plan note
    // with the environment still merged.
    class int checkMacosTapWiring(SemuContracts contracts, string repoRoot) {
        int failures = 0;
        EmulatorDefinition dolphin = EmulatorContractTest.findEmulator(contracts, "dolphin");
        SystemDefinition gameCube = EmulatorContractTest.findSystem(contracts, "gc");
        Vector<string> noArguments = [];
        SemuSettings settings = SemuSettings();

        string fakeAssetRoot = PathTools.join(
            Environment.get("SEMU_TEST_TMP", "/tmp/semu-core-tests"), "overlay-asset-root");
        string fakeOverlayPath = PathTools.join(fakeAssetRoot, "lib/semu/semu-overlay");
        UnixFileSystem.mkdirp(PathTools.dirname(fakeOverlayPath));
        Path.writeAll(fakeOverlayPath, "fake overlay binary");

        LaunchPlan macosPlan = EmulatorLauncher.plan(dolphin, "macos", "",
            "/roms/gc/game.iso", noArguments);
        if (EmulatorContractTest.carriesTapEnvironment(macosPlan)) {
            failures = failures + EmulatorContractTest.fail(
                "an assembled macos plan must carry no tap environment before"
                + " MacosTap.apply");
        }
        int argumentCountBefore = macosPlan.argumentVector.size();
        MacosTap.applyWithAssetRoot(macosPlan, gameCube, settings, repoRoot, fakeAssetRoot);
        if (!EmulatorContractTest.environmentValue(macosPlan, "SEMU_TAP_ART")
                .endsWith("assets/bezels/gc/tv.png")) {
            failures = failures + EmulatorContractTest.fail(
                "macos tap plan SEMU_TAP_ART: got '"
                + EmulatorContractTest.environmentValue(macosPlan, "SEMU_TAP_ART")
                + "' (want the gc tv art)");
        }
        if (!EmulatorContractTest.environmentValue(macosPlan, "SEMU_TAP_STYLE")
                .equals("console")
            || !EmulatorContractTest.environmentValue(macosPlan, "SEMU_TAP_NATIVE_W")
                .equals("640")
            || !EmulatorContractTest.environmentValue(macosPlan, "SEMU_TAP_NATIVE_H")
                .equals("480")) {
            failures = failures + EmulatorContractTest.fail(
                "macos tap plan lacks the gc contract wire values (STYLE/NATIVE_W/NATIVE_H)");
        }
        if (!EmulatorContractTest.environmentValue(macosPlan, "LD_PRELOAD").isEmpty()) {
            failures = failures + EmulatorContractTest.fail(
                "macos tap plans must never carry LD_PRELOAD");
        }
        if (macosPlan.argumentVector.size() != argumentCountBefore + 3
            || !macosPlan.argumentVector.get(0).equals("/bin/sh")
            || !macosPlan.argumentVector.get(1).equals("-c")) {
            failures = failures + EmulatorContractTest.fail(
                "macos tap plan must wrap the vector as /bin/sh -c <script> <vector...>");
        } else {
            string wrapperScript = macosPlan.argumentVector.get(2);
            if (!wrapperScript.contains("SEMU_TAP_TARGET_PID")
                || !wrapperScript.contains(fakeOverlayPath)) {
                failures = failures + EmulatorContractTest.fail(
                    "the overlay wrapper script must hand the emulator pid to the"
                    + " staged overlay binary");
            }
        }
        if (!macosPlan.note.contains("macos overlay: " + fakeOverlayPath)) {
            failures = failures + EmulatorContractTest.fail(
                "macos tap plan note must record the resolved overlay binary");
        }

        LaunchPlan disabledPlan = EmulatorLauncher.plan(dolphin, "macos", "",
            "/roms/gc/game.iso", noArguments);
        int disabledArgumentCount = disabledPlan.argumentVector.size();
        SemuSettings disabledSettings = SemuSettings();
        disabledSettings.visual.bezels = false;
        MacosTap.applyWithAssetRoot(disabledPlan, gameCube, disabledSettings,
            repoRoot, fakeAssetRoot);
        if (EmulatorContractTest.carriesTapEnvironment(disabledPlan)
            || disabledPlan.argumentVector.size() != disabledArgumentCount) {
            failures = failures + EmulatorContractTest.fail(
                "bezels off must skip the macos overlay entirely");
        }

        LaunchPlan notePlan = EmulatorLauncher.plan(dolphin, "macos", "",
            "/roms/gc/game.iso", noArguments);
        int noteArgumentCount = notePlan.argumentVector.size();
        MacosTap.applyWithAssetRoot(notePlan, gameCube, settings,
            "/nonexistent-semu-project", PathTools.join(fakeAssetRoot, "missing"));
        if (notePlan.argumentVector.size() != noteArgumentCount
            || !notePlan.note.contains("overlay binary not found")) {
            failures = failures + EmulatorContractTest.fail(
                "a missing overlay binary must skip the spawn wrap and note the plan");
        }
        if (EmulatorContractTest.environmentValue(notePlan, "SEMU_TAP_ART").isEmpty()) {
            failures = failures + EmulatorContractTest.fail(
                "a missing overlay binary must still merge the tap environment");
        }
        return failures;
    }

    class bool logContains(ParseLog log, string fragment) {
        for error in log.errors {
            if (error.contains(fragment)) {
                return true;
            }
        }
        return false;
    }

    class int requireLogError(ParseLog log, string fragment, string what) {
        if (!EmulatorContractTest.logContains(log, fragment)) {
            return EmulatorContractTest.fail(what + " — no log entry contains '"
                + fragment + "'");
        }
        return 0;
    }

    class string platformProbeDirectory() {
        return PathTools.join(Environment.get("SEMU_TEST_TMP", "/tmp/semu-core-tests"),
            "platform-probe");
    }

    // The platform axis contract, now routed through platforms/: a macos
    // block carrying linux-only concepts (display_server, sessions,
    // flatpak_id, a flatpak backend, sandbox runtime, a ${flatpak_home}
    // executable) is rejected field by field — the same assertions the
    // generic parser used to own.
    class int checkPlatformAxisValidation() {
        string probeDirectory = EmulatorContractTest.platformProbeDirectory();
        UnixFileSystem.mkdirp(probeDirectory);
        string probeFile = PathTools.join(probeDirectory, "emulator.json");
        string probeJson = "{\n"
            + "  \"schema_version\": 1,\n"
            + "  \"name\": \"Probe\",\n"
            + "  \"kind\": \"standalone\",\n"
            + "  \"default_system\": \"gb\",\n"
            + "  \"input\": { \"actions\": [\"app.quit\"] },\n"
            + "  \"platforms\": {\n"
            + "    \"macos\": {\n"
            + "      \"backend\": \"flatpak\",\n"
            + "      \"flatpak_id\": \"org.probe.Probe\",\n"
            + "      \"display_server\": \"x11\",\n"
            + "      \"sessions\": { \"gamescope\": { \"display_server\": \"x11\" } },\n"
            + "      \"executable\": \"${flatpak_home}/bin/probe\",\n"
            + "      \"sandbox\": { \"runtime\": \"org.probe.Sdk\" }\n"
            + "    }\n"
            + "  }\n"
            + "}\n";
        Path.writeAll(probeFile, probeJson);
        ParseLog log = ParseLog();
        EmulatorParser.parseFile("probe", probeFile, log);
        int failures = 0;
        failures = failures + EmulatorContractTest.requireLogError(log,
            "'flatpak' is a linux-only backend", "macos block must reject the flatpak backend");
        failures = failures + EmulatorContractTest.requireLogError(log,
            "platforms.macos.flatpak_id: linux-only field",
            "macos block must reject flatpak_id");
        failures = failures + EmulatorContractTest.requireLogError(log,
            "platforms.macos.display_server: linux-only field",
            "macos block must reject display_server");
        failures = failures + EmulatorContractTest.requireLogError(log,
            "platforms.macos.sessions: linux-only field", "macos block must reject sessions");
        failures = failures + EmulatorContractTest.requireLogError(log,
            "linux-only sandbox field (macos sandbox-exec takes filesystems grants only)",
            "macos block must reject linux-only sandbox fields");
        failures = failures + EmulatorContractTest.requireLogError(log,
            "template token '${flatpak_home}' is not a macos concept",
            "macos block must reject the flatpak_home token");
        return failures;
    }

    // PlatformRegistry owns the platforms-key whitelist: an unknown key like
    // "windows" in a platforms object is a hard contract error.
    class int checkUnknownPlatformRejection() {
        int failures = 0;
        if (PlatformRegistry.isRegistered("windows")) {
            failures = failures + EmulatorContractTest.fail(
                "PlatformRegistry must not register 'windows'");
        }
        if (!PlatformRegistry.isRegistered("linux") || !PlatformRegistry.isRegistered("macos")) {
            failures = failures + EmulatorContractTest.fail(
                "PlatformRegistry must register linux and macos");
        }
        string probeDirectory = EmulatorContractTest.platformProbeDirectory();
        UnixFileSystem.mkdirp(probeDirectory);
        string probeFile = PathTools.join(probeDirectory, "unknown-os-emulator.json");
        string probeJson = "{\n"
            + "  \"schema_version\": 1,\n"
            + "  \"name\": \"Probe\",\n"
            + "  \"kind\": \"standalone\",\n"
            + "  \"default_system\": \"gb\",\n"
            + "  \"input\": { \"actions\": [\"app.quit\"] },\n"
            + "  \"platforms\": {\n"
            + "    \"windows\": { \"backend\": \"native\", \"executable\": \"probe.exe\" }\n"
            + "  }\n"
            + "}\n";
        Path.writeAll(probeFile, probeJson);
        ParseLog log = ParseLog();
        EmulatorParser.parseFile("probe", probeFile, log);
        failures = failures + EmulatorContractTest.requireLogError(log,
            "platforms.windows: unknown platform (allowed: linux, macos)",
            "platforms.windows must be rejected");
        return failures;
    }

    class int run(string repoRoot) {
        string sourceRoot = PathTools.join(repoRoot, "src/semu");
        int failures = 0;
        ParseLog log = ParseLog();
        SemuContracts contracts = SystemParser.loadAll(sourceRoot, log);
        if (!log.ok()) {
            for error in log.errors {
                failures = failures + EmulatorContractTest.fail("parse: " + error);
            }
        }
        if (contracts.emulators.size() != 5) {
            failures = failures + EmulatorContractTest.fail(
                f"expected 5 emulator contracts, got {contracts.emulators.size()}");
        }
        Vector<string> expectedIds = ["cemu", "dolphin", "pcsx2", "retroarch",
                                      "ryujinx"];
        for emulatorId in expectedIds {
            if (!contracts.hasEmulator(emulatorId)) {
                failures = failures + EmulatorContractTest.fail(
                    "missing emulator contract '" + emulatorId + "'");
            }
        }

        failures = failures + EmulatorContractTest.checkDolphinPlan(contracts);
        failures = failures + EmulatorContractTest.checkDolphinEsDeTailPlan(contracts);
        failures = failures + EmulatorContractTest.checkRetroArchLinuxPlan(contracts);
        failures = failures + EmulatorContractTest.checkRetroArchMacosPlan(contracts);
        failures = failures + EmulatorContractTest.checkEsDeCommands(contracts);
        failures = failures + EmulatorContractTest.checkPcsx2Profiles(contracts, repoRoot);
        failures = failures + EmulatorContractTest.checkEmulatorDutyContract(contracts,
            repoRoot);
        failures = failures + EmulatorContractTest.checkSystemInference(contracts);
        failures = failures + EmulatorContractTest.checkGraphicsForceUpsert();
        failures = failures + EmulatorContractTest.checkLinuxTapWiring(contracts, repoRoot);
        failures = failures + EmulatorContractTest.checkMacosTapWiring(contracts, repoRoot);
        failures = failures + EmulatorContractTest.checkPlatformAxisValidation();
        failures = failures + EmulatorContractTest.checkUnknownPlatformRejection();

        EmulatorDefinition dolphin = EmulatorContractTest.findEmulator(contracts, "dolphin");
        string shim = EmulatorEmitter.shimScript(dolphin);
        if (!shim.startsWith("#!/usr/bin/env sh\n") || !shim.contains("launcher dolphin")) {
            failures = failures + EmulatorContractTest.fail(
                "dolphin shim script malformed: " + shim);
        }

        if (failures > 0) {
            print(f"emulator contract: FAIL ({failures} violations)");
            return failures;
        }
        print("emulator contract: parse + launch plans + esde commands valid");
        return 0;
    }
}
