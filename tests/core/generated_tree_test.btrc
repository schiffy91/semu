// generated_tree_test.btrc — end-to-end emission into src/generated/.
//
// Runs the real emission pass (SystemEmitter.emitAll + the per-platform
// launcher emission via PlatformRegistry) into <repoRoot>/src/generated,
// asserts the expected artifact tree exists, proves 'semu run --prepare-only'
// installs the ES-DE runtime configuration (against a scratch frontend home
// under $SEMU_TEST_TMP) with the current platform's resolved roms root in
// ROMDirectory, then runs `make -f tests/Makefile tree-audit` to prove the
// emission never escapes the approved repository shape. Returns the
// violation count (0 = pass); no main() — the entry composes it.

import std.{vector, process, fs, platform}
import ../../src/semu/core/parse_log.btrc
import ../../src/semu/core/settings.btrc
import ../../src/semu/core/settings_parser.btrc
import ../../src/semu/systems/system_parser.btrc
import ../../src/semu/systems/system_emitter.btrc
import ../../src/semu/platforms/platform_registry.btrc
import ../../src/semu/packaging/es_de_runtime.btrc

class GeneratedTreeTest {
    class int fail(string message) {
        print("  FAIL " + message);
        return 1;
    }

    class int requireFile(string root, string relativePath) {
        if (!FileSystem.isFile(PathTools.join(root, relativePath))) {
            return GeneratedTreeTest.fail("expected generated file missing: " + relativePath);
        }
        return 0;
    }

    class int checkArtifactTree(SemuContracts contracts, string generatedRoot) {
        int failures = 0;
        failures = failures + GeneratedTreeTest.requireFile(generatedRoot, "semu.json");
        failures = failures + GeneratedTreeTest.requireFile(generatedRoot,
            "packaging/es-de/custom_systems/es_systems.xml");
        failures = failures + GeneratedTreeTest.requireFile(generatedRoot,
            "packaging/es-de/custom_systems/es_find_rules.xml");
        failures = failures + GeneratedTreeTest.requireFile(generatedRoot,
            "packaging/linux/AppRun");
        failures = failures + GeneratedTreeTest.requireFile(generatedRoot,
            "packaging/linux/semu.desktop");
        for emulatorDefinition in contracts.emulators {
            failures = failures + GeneratedTreeTest.requireFile(generatedRoot,
                "packaging/linux/bin/semu-" + emulatorDefinition.id);
        }
        return failures;
    }

    class int checkTreeAudit(string repoRoot) {
        UnixShell shell = UnixShell();
        ExecResult makeAvailable = shell.run("command -v make",
            CommandOutput.collect(), CommandOutput.combine(), false, true, false,
            "", "", repoRoot);
        if (makeAvailable.code != 0) {
            // Target devices (immutable SteamOS/Bazzite) ship no make; the
            // tree audit is a development-host gate and already ran before
            // the tree was synced here.
            print("  SKIP tree-audit (no make on this host)");
            return 0;
        }
        ExecResult audit = shell.run("make -f tests/Makefile tree-audit",
            CommandOutput.collect(), CommandOutput.combine(), false, true, false,
            "", "", repoRoot);
        if (audit.code != 0) {
            int failures = GeneratedTreeTest.fail(f"tree-audit failed (exit {audit.code}):");
            print(audit.out);
            return failures;
        }
        return 0;
    }

    // The settings contract round-trip: defaults parse strictly, materialize
    // into the runtime store, and the reloaded store matches the defaults.
    class int checkSettings(string repoRoot) {
        int failures = 0;
        ParseLog log = ParseLog();
        SettingsParser.materialize(repoRoot, log);
        SemuSettings settings = SettingsParser.load(repoRoot, log);
        if (!log.ok()) {
            for error in log.errors {
                failures = failures + GeneratedTreeTest.fail("settings: " + error);
            }
            return failures;
        }
        if (!settings.file.endsWith("src/generated/runtime/settings.json")) {
            failures = failures + GeneratedTreeTest.fail(
                "settings store was not materialized: " + settings.file);
        }
        if (!settings.visual.renderMode.equals("1x") && Environment.get("SEMU_RENDER_MODE", "").isEmpty()) {
            failures = failures + GeneratedTreeTest.fail(
                "settings default render_mode expected '1x', got " + settings.visual.renderMode);
        }
        if (settings.sync.folders.size() != 7) {
            failures = failures + GeneratedTreeTest.fail(
                f"settings expected 7 sync folders, got {settings.sync.folders.size()}");
        }
        if (settings.screenshots.tools.size() != 4) {
            failures = failures + GeneratedTreeTest.fail(
                f"settings expected 4 screenshot tools, got {settings.screenshots.tools.size()}");
        }
        return failures;
    }

    // The run-prepare contract: EsDeRuntime.prepare against a scratch
    // frontend home installs the custom_systems pair + es_settings.xml, the
    // ROMDirectory value is the current platform's fully resolved roms root,
    // and no ${...} template token survives into the installed find rules.
    class int checkRunPrepare(SemuContracts contracts, string repoRoot) {
        int failures = 0;
        ParseLog log = ParseLog();
        SemuSettings settings = SettingsParser.load(repoRoot, log);
        if (!log.ok()) {
            for error in log.errors {
                failures = failures + GeneratedTreeTest.fail("run-prepare settings: " + error);
            }
            return failures;
        }
        string platformId = PlatformRegistry.currentId();
        string esDeHome = PathTools.join(
            Environment.get("SEMU_TEST_TMP", "/tmp/semu-core-tests"), "es-de-home");
        int prepareResult = EsDeRuntime.prepare(contracts, settings, repoRoot,
            platformId, esDeHome);
        if (prepareResult != 0) {
            return GeneratedTreeTest.fail(f"run-prepare returned {prepareResult}");
        }
        failures = failures + GeneratedTreeTest.requireFile(esDeHome,
            "custom_systems/es_systems.xml");
        failures = failures + GeneratedTreeTest.requireFile(esDeHome,
            "custom_systems/es_find_rules.xml");
        failures = failures + GeneratedTreeTest.requireFile(esDeHome,
            "settings/es_settings.xml");
        if (failures > 0) {
            return failures;
        }
        string expectedRomsRoot = EsDeRuntime.resolvedRomsRoot(settings, repoRoot, platformId);
        if (expectedRomsRoot.isEmpty() || expectedRomsRoot.contains("${")) {
            failures = failures + GeneratedTreeTest.fail(
                "run-prepare roms root did not resolve: '" + expectedRomsRoot + "'");
        }
        string settingsXml = Path.readAll(PathTools.join(esDeHome,
            "settings/es_settings.xml"));
        if (!settingsXml.contains("<string name=\"ROMDirectory\" value=\""
            + expectedRomsRoot + "\" />")) {
            failures = failures + GeneratedTreeTest.fail(
                "es_settings.xml ROMDirectory is not the resolved '" + platformId
                + "' roms root " + expectedRomsRoot);
        }
        string findRules = Path.readAll(PathTools.join(esDeHome,
            "custom_systems/es_find_rules.xml"));
        if (findRules.contains("${")) {
            failures = failures + GeneratedTreeTest.fail(
                "installed es_find_rules.xml carries unresolved template tokens");
        }
        if (failures == 0) {
            print("  OK run-prepare installed es-de runtime (ROMDirectory "
                + expectedRomsRoot + ")");
        }
        return failures;
    }

    // The adoption contract: a frontend home whose es_settings.xml already
    // points at an on-disk library keeps that library; the configured
    // settings.json value is only a first-run seed, and SEMU_ROMS_ROOT
    // always wins. Pure-method checks — no environment dependence.
    class int checkRomsRootAdoption(string repoRoot) {
        int failures = 0;
        string existingDirectory = repoRoot;
        string settingsText = "<?xml version=\"1.0\"?>\n"
            + "<string name=\"ROMDirectory\" value=\"" + existingDirectory + "\" />\n";
        if (!EsDeRuntime.adoptedRomsRoot("/configured/default", settingsText, false)
                .equals(existingDirectory)) {
            failures = failures + GeneratedTreeTest.fail(
                "adoption: existing on-disk ROMDirectory was not adopted");
        }
        if (!EsDeRuntime.adoptedRomsRoot("/configured/default", settingsText, true)
                .equals("/configured/default")) {
            failures = failures + GeneratedTreeTest.fail(
                "adoption: SEMU_ROMS_ROOT override must beat the existing value");
        }
        string vanishedText = "<string name=\"ROMDirectory\" value=\"/vanished/library\" />\n";
        if (!EsDeRuntime.adoptedRomsRoot("/configured/default", vanishedText, false)
                .equals("/configured/default")) {
            failures = failures + GeneratedTreeTest.fail(
                "adoption: a vanished ROMDirectory must fall back to the seed");
        }
        if (!EsDeRuntime.adoptedRomsRoot("/configured/default", "", false)
                .equals("/configured/default")) {
            failures = failures + GeneratedTreeTest.fail(
                "adoption: an absent es_settings.xml must install the seed");
        }
        if (failures == 0) {
            print("  OK roms-root adoption (existing kept, override wins, seed on absence)");
        }
        return failures;
    }

    class int run(string repoRoot) {
        int failures = 0;
        ParseLog log = ParseLog();
        SemuContracts contracts = SystemParser.loadAll(PathTools.join(repoRoot, "src/semu"),
            log);
        if (!log.ok()) {
            for error in log.errors {
                failures = failures + GeneratedTreeTest.fail("parse: " + error);
            }
            return failures;
        }

        string generatedRoot = PathTools.join(repoRoot, "src/generated");
        SystemEmitter.emitAll(contracts, generatedRoot);
        for platformId in PlatformRegistry.registeredIds() {
            string launcherSummary = PlatformRegistry.emitLaunchers(platformId,
                contracts.emulators, repoRoot, generatedRoot);
        }

        failures = failures + GeneratedTreeTest.checkArtifactTree(contracts, generatedRoot);
        failures = failures + GeneratedTreeTest.checkSettings(repoRoot);
        failures = failures + GeneratedTreeTest.checkRunPrepare(contracts, repoRoot);
        failures = failures + GeneratedTreeTest.checkRomsRootAdoption(repoRoot);
        failures = failures + GeneratedTreeTest.checkTreeAudit(repoRoot);

        if (failures > 0) {
            print(f"generated tree: FAIL ({failures} violations)");
            return failures;
        }
        print("generated tree: emission + tree-audit clean");
        return 0;
    }
}
