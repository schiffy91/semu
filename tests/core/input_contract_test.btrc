// input_contract_test.btrc — proof harness for the input subsystem.
//
// Parses the real steamdeck keymap (14 actions, 13 bindings) and steam-input
// target contract, checks ChordTranslator's VDF token grammar against the
// Deck-proven forms, emits both steam-input VDF templates into
// $SEMU_TEST_TMP (default /tmp/semu-core-tests)/input-test, and structurally
// compares them to the goldens under
// garbage/generated/packaging/input/steam-input/: the gamepad passthrough
// layer verbatim, the radial slots and quit bindings as label-independent
// binding sets, every HKB binding's exact VDF key tokens + label, and the
// preset wiring. Returns the violation count (0 = pass), no main() — the CLI
// routes `semu test core` here.

import std.{vector, strings, platform, fs}
import ../../src/semu/core/parse_log.btrc
import ../../src/semu/input/input_parser.btrc
import ../../src/semu/input/targets/steamdeck/steam_input.btrc
import ../../src/semu/input/input_emitter.btrc
import ../../src/semu/input/targets/steamdeck/steamdeck_input_emitter.btrc

class InputContractTest {
    class int check(bool condition, string what) {
        if (condition) {
            return 0;
        }
        print("  FAIL: " + what);
        return 1;
    }

    class int checkEquals(string got, string want, string what) {
        if (got.equals(want)) {
            return 0;
        }
        print("  FAIL: " + what + ": got '" + got + "' want '" + want + "'");
        return 1;
    }

    // The generic VDF grammar must reproduce the proven token forms.
    class int checkChordTokens(SteamInputTarget target) {
        int violations = 0;
        violations += InputContractTest.checkEquals(
            ChordTranslator.vdfTokens("Ctrl+P", target), "LEFT_CONTROL P", "vdf Ctrl+P");
        violations += InputContractTest.checkEquals(
            ChordTranslator.vdfTokens("Ctrl+-", target), "LEFT_CONTROL KEYPAD_DASH", "vdf Ctrl+-");
        violations += InputContractTest.checkEquals(
            ChordTranslator.vdfTokens("Ctrl++", target), "LEFT_CONTROL KEYPAD_PLUS", "vdf Ctrl++");
        violations += InputContractTest.checkEquals(
            ChordTranslator.vdfTokens("Ctrl+Tab", target), "LEFT_CONTROL TAB", "vdf Ctrl+Tab");
        violations += InputContractTest.checkEquals(
            ChordTranslator.vdfTokens("Ctrl+Enter", target), "LEFT_CONTROL RETURN", "vdf Ctrl+Enter");
        violations += InputContractTest.checkEquals(
            ChordTranslator.vdfTokens("Esc", target), "ESCAPE", "vdf Esc");
        violations += InputContractTest.checkEquals(
            ChordTranslator.vdfTokens("Alt+F4", target), "LEFT_ALT F4", "vdf Alt+F4");
        return violations;
    }

    // The binding heads of one VDF line, label-stripped: '"binding"
    // "key_press LEFT_CONTROL, Save State, , "' -> "key_press LEFT_CONTROL".
    class Vector<string> normalizedBindings(string line) {
        Vector<string> heads = [];
        Vector<string> parts = Strings.split(line, "\"binding\" \"");
        for (int partIndex = 1; partIndex < parts.size(); partIndex++) {
            string tail = parts.get(partIndex);
            int quoteIndex = tail.indexOf("\"");
            string content = quoteIndex < 0 ? tail : tail.substring(0, quoteIndex);
            int commaIndex = content.indexOf(",");
            string head = commaIndex < 0 ? content : content.substring(0, commaIndex);
            heads.push(head.trim());
        }
        return heads;
    }

    class int countOf(Vector<string> values, string value) {
        int count = 0;
        for candidate in values {
            if (candidate.equals(value)) {
                count++;
            }
        }
        return count;
    }

    // Label-independent binding-set equality between one golden line and the
    // matching emitted line.
    class int checkBindingSets(string emittedLine, string goldenLine, string what) {
        Vector<string> emittedHeads = InputContractTest.normalizedBindings(emittedLine);
        Vector<string> goldenHeads = InputContractTest.normalizedBindings(goldenLine);
        int violations = InputContractTest.check(
            emittedHeads.size() == goldenHeads.size(), what + ": binding count");
        for goldenHead in goldenHeads {
            violations += InputContractTest.check(
                InputContractTest.countOf(emittedHeads, goldenHead)
                    == InputContractTest.countOf(goldenHeads, goldenHead),
                what + ": binding '" + goldenHead + "'");
        }
        return violations;
    }

    class string lineContaining(string text, string needle) {
        for line in Strings.split(text, "\n") {
            if (line.contains(needle)) {
                return line;
            }
        }
        return "";
    }

    // Structural comparison against a Deck-proven golden VDF: the gamepad
    // passthrough layer (everything before hotkey group 10, minus the
    // template title), the preset-0 and settings lines verbatim, and each
    // radial slot's binding set (label-independent — the goldens predate
    // some label renames; the radial quit slot also proves the quit extra
    // bindings against the golden shape).
    class int compareGolden(string emittedVdf, string goldenVdf, string name) {
        int violations = 0;
        for goldenLine in Strings.split(goldenVdf, "\n") {
            if (goldenLine.contains("\"id\" \"10\"")) {
                break;
            }
            if (!goldenLine.trim().isEmpty() && !goldenLine.startsWith("\t\"title\"")) {
                violations += InputContractTest.check(emittedVdf.contains(goldenLine),
                    name + ": missing passthrough line: " + goldenLine.trim());
            }
        }
        violations += InputContractTest.check(
            emittedVdf.contains(InputContractTest.lineContaining(goldenVdf,
                "\"preset\" { \"id\" \"0\"")),
            name + ": gamepad preset line matches golden");
        violations += InputContractTest.check(
            emittedVdf.contains(InputContractTest.lineContaining(goldenVdf,
                "\"settings\"")),
            name + ": settings line matches golden");
        for (int slotIndex = 0; slotIndex < 6; slotIndex++) {
            string slotKey = f"\"touch_menu_button_{slotIndex}\"";
            string goldenLine = InputContractTest.lineContaining(goldenVdf, slotKey);
            string emittedLine = InputContractTest.lineContaining(emittedVdf, slotKey);
            if (goldenLine.isEmpty() || emittedLine.isEmpty()) {
                violations += InputContractTest.check(false,
                    name + f": radial slot {slotIndex} present in golden and emitted");
            } else {
                violations += InputContractTest.checkBindingSets(emittedLine, goldenLine,
                    name + f": radial slot {slotIndex}");
            }
        }
        return violations;
    }

    // Contract-driven structure of one emitted VDF: every HKB binding's exact
    // key tokens + label, the quit extra bindings, and the preset wiring.
    class int checkVdfStructure(string vdfText, string name, SteamInputTarget target,
                                Keymap keymap, string title, string radialName) {
        int violations = 0;
        violations += InputContractTest.check(!vdfText.isEmpty(), name + ": emitted file is empty");
        violations += InputContractTest.check(vdfText.contains("\"title\"\t\t\"" + title + "\""),
            name + ": title");
        violations += InputContractTest.check(vdfText.contains("\"name\" \"" + radialName + "\""),
            name + ": radial name");
        violations += InputContractTest.check(
            vdfText.contains("\"controller_type\"\t\t\"controller_neptune\""),
            name + ": controller type");

        // Radial: exactly the declared slot count (touch_menu_button_0..5).
        for (int slotIndex = 0; slotIndex < target.radialSlots.size(); slotIndex++) {
            violations += InputContractTest.check(
                vdfText.contains(f"\"touch_menu_button_{slotIndex}\""),
                name + f": radial slot {slotIndex}");
        }
        int slotCount = target.radialSlots.size();
        violations += InputContractTest.check(
            !vdfText.contains(f"touch_menu_button_{slotCount}"),
            name + ": unexpected extra radial slot");

        // Every HKB binding is reflected: each VDF key token of its chord
        // appears with the action's label.
        for binding in keymap.bindings {
            string label = target.actionLabel(binding.actionId);
            string tokens = ChordTranslator.vdfTokens(keymap.chordFor(binding.actionId), target);
            for keyName in Strings.split(tokens, " ") {
                violations += InputContractTest.check(
                    vdfText.contains("\"binding\" \"key_press " + keyName + ", " + label + ", , \""),
                    name + ": binding '" + binding.button + "' key token '" + keyName
                        + "' (" + label + ")");
            }
        }

        // app.quit carries the quit extra bindings on top of its chord.
        string quitLabel = target.actionLabel("app.quit");
        violations += InputContractTest.check(
            vdfText.contains("\"xinput_button SELECT, " + quitLabel + ", , \""),
            name + ": quit extra xinput_select");
        violations += InputContractTest.check(
            vdfText.contains("\"xinput_button START, " + quitLabel + ", , \""),
            name + ": quit extra xinput_start");
        violations += InputContractTest.check(
            vdfText.contains("\"key_press ESCAPE, " + quitLabel + ", , \""),
            name + ": quit extra escape");
        violations += InputContractTest.check(
            vdfText.contains("\"key_press LEFT_ALT, " + quitLabel + ", , \""),
            name + ": quit extra alt_f4 (alt)");
        violations += InputContractTest.check(
            vdfText.contains("\"key_press F4, " + quitLabel + ", , \""),
            name + ": quit extra alt_f4 (f4)");

        // Preset wiring: gamepad preset 0, hotkey preset 1 with the switch
        // layer, View long-press entry + release return.
        violations += InputContractTest.check(
            vdfText.contains("\"preset\" { \"id\" \"0\" \"name\" \"Default\""),
            name + ": gamepad preset");
        violations += InputContractTest.check(
            vdfText.contains("\"preset\" { \"id\" \"1\" \"name\" \"Preset_1000001\""),
            name + ": hotkey preset");
        violations += InputContractTest.check(vdfText.contains("\"14\" \"switch active\""),
            name + ": hotkey switch layer");
        violations += InputContractTest.check(
            vdfText.contains("controller_action CHANGE_PRESET 2 0 0, Hotkey, , "),
            name + ": view long-press preset switch");
        violations += InputContractTest.check(
            vdfText.contains("controller_action CHANGE_PRESET 1 0 0, , "),
            name + ": preset return");
        return violations;
    }

    class int run(string repoRoot) {
        string sourceRoot = Environment.get("SEMU_SRC_ROOT",
            PathTools.join(repoRoot, "src/semu"));
        string targetDirectory = PathTools.join(sourceRoot, "input/targets/steamdeck");
        string goldenDirectory = PathTools.join(repoRoot,
            "garbage/generated/packaging/input/steam-input");
        ParseLog log = ParseLog();

        Keymap keymap = KeymapParser.parse(
            Path.readAll(PathTools.join(targetDirectory, "steamdeck.skm")), log);
        SteamInputTarget target = SteamInputParser.parse(
            PathTools.join(targetDirectory, "steam_input.json"), log);

        int violations = 0;
        print(f"keymap: {keymap.actions.size()} actions, {keymap.bindings.size()} bindings");
        print(f"steam-input: {target.actionIds.size()} vocabulary actions, "
            + f"{target.radialSlots.size()} radial slots, "
            + f"{target.templateIds.size()} templates (default {target.defaultTemplateId})");
        violations += InputContractTest.check(keymap.actions.size() == 14,
            "expected 14 keymap actions");
        violations += InputContractTest.check(keymap.bindings.size() == 13,
            "expected 13 keymap bindings");
        violations += InputContractTest.check(target.actionIds.size() == 14,
            "expected 14 vocabulary actions");
        violations += InputContractTest.check(target.radialSlots.size() == 6,
            "expected 6 radial slots");
        violations += InputContractTest.check(target.quitExtraBindings.size() == 4,
            "expected 4 quit extra bindings");
        violations += InputContractTest.check(target.templateIds.size() == 2,
            "expected 2 templates");
        violations += InputContractTest.checkEquals(target.defaultTemplateId, "neptune_full",
            "default template");
        violations += InputContractTest.check(!target.templatesDirectory.isEmpty(),
            "expected a linux templates_dir");
        violations += InputContractTest.checkEquals(
            target.deviceIdentity("retroarch_input_driver"), "sdl2", "device identity lookup");

        violations += InputContractTest.checkChordTokens(target);

        string outputDirectory = PathTools.join(
            Environment.get("SEMU_TEST_TMP", "/tmp/semu-core-tests"), "input-test");
        SteamdeckInputEmitter.emitTemplates(target, keymap, outputDirectory);
        for (int templateIndex = 0; templateIndex < target.templateIds.size(); templateIndex++) {
            string outputName = target.templateOutputs.get(templateIndex);
            string vdfPath = PathTools.join(outputDirectory, outputName);
            string vdfText = Path.readAll(vdfPath);
            violations += InputContractTest.checkVdfStructure(vdfText, outputName, target,
                keymap, target.templateTitles.get(templateIndex),
                target.templateRadialNames.get(templateIndex));
            string goldenPath = PathTools.join(goldenDirectory, outputName);
            if (FileSystem.isFile(goldenPath)) {
                violations += InputContractTest.compareGolden(vdfText,
                    Path.readAll(goldenPath), outputName);
            } else {
                violations += InputContractTest.check(false,
                    outputName + ": golden missing: " + goldenPath);
            }
            print("emitted " + vdfPath);
        }

        if (!log.ok()) {
            print(f"FAIL: {log.errors.size()} input contract violations");
            for error in log.errors {
                print("  " + error);
            }
            violations += log.errors.size();
        }
        if (violations == 0) {
            print("input: keymap + steam-input target + VDF emission valid");
        }
        return violations;
    }
}
