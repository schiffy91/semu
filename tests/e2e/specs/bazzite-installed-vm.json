{
  "name": "bazzite-installed-vm",
  "state": "bazzite-installed-vm",
  "parentState": "bazzite-deck-live",
  "stateMaterial": "{{sourceHash}}:{{bazziteSshPort}}",
  "args": {
    "bazziteSshPort": "2224"
  },
  "operations": [
    {
      "op": "require-command",
      "command": "qemu-system-x86_64"
    },
    {
      "op": "require-command",
      "command": "qemu-img"
    },
    {
      "op": "require-command",
      "command": "nix"
    },
    {
      "op": "make",
      "command": "bazzite-e2e-install BAZZITE_E2E_SSH_PORT={{bazziteSshPort}}",
      "expect": "OK Bazzite installed VM",
      "timeout": 14400
    }
  ]
}
