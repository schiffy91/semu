// Local verification of receipts and collected visual/input evidence. This
// module never controls the Deck; it evaluates artifacts produced by the
// exact-shortcut Game Mode helper.

#define STB_IMAGE_IMPLEMENTATION
#include "stb_image.h"
#include <limits.h>
#include <string.h>

extern unsigned char* stbi_load(const char* filename, int* width,
                                int* height, int* channels,
                                int requestedChannels);
extern void stbi_image_free(void* pixels);

import std.{fs, image, json, strings, vector}
import ../../../src/generators/input/action_abi.btrc
import ./acceptance_plan.btrc
import ./deck_transport.btrc
import ./game_mode.btrc
import ./run_evidence.btrc

class DeckScreenshotDecoder {
    class unsigned char* load(string path, int* width, int* height,
                              int* channels) {
        if (path.isEmpty() || path.len() >= PATH_MAX
                || width == null || height == null || channels == null) {
            return null;
        }
        char nativePath[PATH_MAX];
        memcpy(nativePath, path, (size_t)path.len());
        nativePath[path.len()] = 0;
        return stbi_load(nativePath, width, height, channels, 4);
    }
}

class DeckEvidenceRectangle {
    public int x;
    public int y;
    public int width;
    public int height;
    public bool valid;

    public DeckEvidenceRectangle() {
        self.x = 0;
        self.y = 0;
        self.width = 0;
        self.height = 0;
        self.valid = false;
    }

    class DeckEvidenceRectangle parse(string value) {
        DeckEvidenceRectangle result = DeckEvidenceRectangle();
        Vector<string> fields = Strings.split(value, ",");
        if (fields.size() != 4) { return result; }
        result.x = fields.get(0).toInt();
        result.y = fields.get(1).toInt();
        result.width = fields.get(2).toInt();
        result.height = fields.get(3).toInt();
        result.valid = result.x >= 0 && result.y >= 0
            && result.width > 0 && result.height > 0;
        return result;
    }

    public bool inside(int outerWidth, int outerHeight) {
        return self.valid && self.x + self.width <= outerWidth
            && self.y + self.height <= outerHeight;
    }

    public bool overlaps(DeckEvidenceRectangle other) {
        return self.x < other.x + other.width
            && other.x < self.x + self.width
            && self.y < other.y + other.height
            && other.y < self.y + self.height;
    }
}

class DeckEvidenceImage {
    class bool meaningful(Image image, DeckEvidenceRectangle rectangle) {
        if (image == null || image.isEmpty()
                || !rectangle.inside(image.width, image.height)) {
            return false;
        }
        long long sampled = 0LL;
        long long lit = 0LL;
        int minimum = 765;
        int maximum = 0;
        int stepX = rectangle.width > 512 ? rectangle.width / 512 : 1;
        int stepY = rectangle.height > 512 ? rectangle.height / 512 : 1;
        for (int y = rectangle.y; y < rectangle.y + rectangle.height;
                y += stepY) {
            int row = image.height - y - 1;
            for (int x = rectangle.x; x < rectangle.x + rectangle.width;
                    x += stepX) {
                RGBA pixel = image.pixel(x, row);
                int level = pixel.red + pixel.green + pixel.blue;
                sampled++;
                if (level >= 12) { lit++; }
                if (level < minimum) { minimum = level; }
                if (level > maximum) { maximum = level; }
            }
        }
        long long required = sampled / 1000LL;
        if (required < 64LL) { required = 64LL; }
        if (required > sampled) { required = sampled; }
        return sampled > 0LL && lit >= required && maximum - minimum >= 16;
    }
}

class DeckScreenshotProbe {
    public bool valid;
    public int width;
    public int height;

    public DeckScreenshotProbe() {
        self.valid = false;
        self.width = 0;
        self.height = 0;
    }

    class bool meaningful(unsigned char* pixels, int imageWidth,
                          int imageHeight,
                          DeckEvidenceRectangle rectangle) {
        if (pixels == null || !rectangle.inside(
                imageWidth, imageHeight)) {
            return false;
        }
        long long sampled = 0LL;
        long long lit = 0LL;
        int minimum = 765;
        int maximum = 0;
        int stepX = rectangle.width > 512 ? rectangle.width / 512 : 1;
        int stepY = rectangle.height > 512 ? rectangle.height / 512 : 1;
        for (int y = rectangle.y; y < rectangle.y + rectangle.height;
                y += stepY) {
            int row = imageHeight - y - 1;
            for (int x = rectangle.x; x < rectangle.x + rectangle.width;
                    x += stepX) {
                unsigned char* pixel = pixels
                    + ((size_t)row * (size_t)imageWidth + (size_t)x)
                        * (size_t)4;
                int level = (int)pixel[0] + (int)pixel[1] + (int)pixel[2];
                sampled++;
                if (level >= 12) { lit++; }
                if (level < minimum) { minimum = level; }
                if (level > maximum) { maximum = level; }
            }
        }
        long long required = sampled / 1000LL;
        if (required < 64LL) { required = 64LL; }
        if (required > sampled) { required = sampled; }
        return sampled > 0LL && lit >= required && maximum - minimum >= 16;
    }

    class DeckScreenshotProbe load(string path,
                                   Vector<DeckEvidenceRectangle> regions) {
        DeckScreenshotProbe result = DeckScreenshotProbe();
        if (!FileSystem.isFile(path) || FileSystem.isSymlink(path)) {
            return result;
        }
        int width = 0;
        int height = 0;
        int channels = 0;
        unsigned char* pixels = DeckScreenshotDecoder.load(
            path, &width, &height, &channels);
        result.width = width;
        result.height = height;
        if (pixels == null || result.width < 1 || result.height < 1) {
            if (pixels != null) { stbi_image_free((void*)pixels); }
            return result;
        }
        if (regions.isEmpty()) {
            DeckEvidenceRectangle full = DeckEvidenceRectangle();
            full.width = result.width;
            full.height = result.height;
            full.valid = true;
            regions.push(full);
        }
        result.valid = true;
        for region in regions {
            if (!DeckScreenshotProbe.meaningful(
                    pixels, result.width, result.height, region)) {
                result.valid = false;
            }
        }
        stbi_image_free((void*)pixels);
        return result;
    }

    class bool inAny(int x, int y,
                     Vector<DeckEvidenceRectangle> regions) {
        for region in regions {
            if (region.valid && x >= region.x && x < region.x + region.width
                    && y >= region.y && y < region.y + region.height) {
                return true;
            }
        }
        return false;
    }

    class bool radialOverlay(string baselinePath, string candidatePath,
                             Vector<DeckEvidenceRectangle> content) {
        int baselineWidth = 0;
        int baselineHeight = 0;
        int baselineChannels = 0;
        int candidateWidth = 0;
        int candidateHeight = 0;
        int candidateChannels = 0;
        unsigned char* baseline = DeckScreenshotDecoder.load(
            baselinePath, &baselineWidth, &baselineHeight,
            &baselineChannels);
        unsigned char* candidate = DeckScreenshotDecoder.load(
            candidatePath, &candidateWidth, &candidateHeight,
            &candidateChannels);
        if (baseline == null || candidate == null
                || baselineWidth != candidateWidth
                || baselineHeight != candidateHeight
                || baselineWidth < 1 || baselineHeight < 1) {
            if (baseline != null) { stbi_image_free((void*)baseline); }
            if (candidate != null) { stbi_image_free((void*)candidate); }
            return false;
        }
        long long outside = 0LL;
        long long changed = 0LL;
        for (int y = 0; y < baselineHeight; y++) {
            int rendererY = baselineHeight - y - 1;
            for (int x = 0; x < baselineWidth; x++) {
                if (DeckScreenshotProbe.inAny(x, rendererY, content)) {
                    continue;
                }
                outside++;
                size_t offset = ((size_t)y * (size_t)baselineWidth
                    + (size_t)x) * (size_t)4;
                int difference = abs((int)baseline[offset]
                        - (int)candidate[offset])
                    + abs((int)baseline[offset + (size_t)1]
                        - (int)candidate[offset + (size_t)1])
                    + abs((int)baseline[offset + (size_t)2]
                        - (int)candidate[offset + (size_t)2]);
                if (difference >= 48) { changed++; }
            }
        }
        stbi_image_free((void*)baseline);
        stbi_image_free((void*)candidate);
        long long required = outside / 500LL;
        if (required < 64LL) { required = 64LL; }
        return outside >= 256LL && changed >= required;
    }
}

class DeckAcceptanceEvidence {
    class string runtimePath(string root, string name) {
        return PathTools.join(root, "runtime/" + name);
    }

    class string safeText(string path) {
        return FileSystem.isFile(path) && !FileSystem.isSymlink(path)
            ? FileSystem.readText(path) : "";
    }

    class Vector<string> bound(DeckGameModeRequest request,
                               Vector<string> fields) {
        Vector<string> result = [
            "run_id=" + request.runId,
            "harness_revision=" + request.harnessRevision,
            "artifact_sha256=" + request.releaseSha256
        ];
        for field in fields { result.push(field); }
        return result;
    }

    class bool dimensions(string value, int* width, int* height) {
        Vector<string> fields = Strings.split(value, "x");
        if (fields.size() != 2) { return false; }
        *width = fields.get(0).toInt();
        *height = fields.get(1).toInt();
        return *width > 0 && *height > 0;
    }

    class bool validBezelRectangle(string value) {
        Vector<string> fields = Strings.split(value, ",");
        if (fields.size() != 4) { return false; }
        for field in fields {
            JsonValue number = JsonValue.parse(field);
            if (number.isError() || !number.isNumber()
                    || number.asFloat() < 0.0) {
                return false;
            }
        }
        return JsonValue.parse(fields.get(2)).asFloat() > 0.0
            && JsonValue.parse(fields.get(3)).asFloat() > 0.0;
    }

    class string capturedRendererLine(string log, DeckSystemCase system,
                                      DeckGameModeRequest request) {
        for line in DeckHarnessStrings.lines(log) {
            if (!DeckHarnessStrings.lineHasFields(line,
                    DeckAcceptanceEvidence.bound(request,
                        ["schema=3", "phase=post_ui",
                         "system_id=" + system.id,
                         "emulator_id=" + system.emulator, "matched=1",
                         "status=1", "nonblank=1",
                         "capture_exhausted=0"]))) {
                continue;
            }
            string frame = DeckHarnessStrings.field(line, "frame_id");
            string captured = DeckHarnessStrings.field(
                line, "capture_frame_id");
            if (!frame.isEmpty() && frame.equals(captured)
                    && !frame.equals("0")
                    && DeckHarnessStrings.field(
                        line, "capture_target").toInt()
                        == request.captureFrame
                    && DeckHarnessStrings.field(
                        line, "capture_count").toInt() >= 1) {
                return line;
            }
        }
        return "";
    }

    class DeckHarnessResult renderer(DeckSystemCase system,
                                     DeckGameModeRequest request,
                                     string root) {
        string logPath = DeckAcceptanceEvidence.runtimePath(
            root, "semu-render-evidence.log");
        string imagePath = DeckAcceptanceEvidence.runtimePath(
            root, "semu-render-final.ppm");
        string log = DeckAcceptanceEvidence.safeText(logPath);
        ImageLoad loaded = ImageIO.loadPpm(imagePath);
        string line = DeckAcceptanceEvidence.capturedRendererLine(
            log, system, request);
        int framebufferWidth = 0;
        int framebufferHeight = 0;
        if (!loaded.ok() || line.isEmpty()
                || !DeckAcceptanceEvidence.dimensions(
                    DeckHarnessStrings.field(line, "framebuffer_size"),
                    &framebufferWidth, &framebufferHeight)
                || loaded.image.width != framebufferWidth
                || loaded.image.height != framebufferHeight
                || DeckHarnessStrings.field(
                    line, "surface_count").toInt() != system.surfaces.size()
                || !DeckHarnessStrings.lowerHex(
                    DeckHarnessStrings.field(line, "frame_hash"), 16)
                || DeckHarnessStrings.field(
                    line, "frame_hash").equals("0000000000000000")
                || !DeckHarnessStrings.lineHasFields(line,
                    ["shader_actual=" + (system.shaderExpected ? "1" : "0"),
                     "bezel_actual=" + (system.bezelExpected ? "1" : "0")])) {
            return DeckHarnessResult.failure(system.id
                + ": captured frame is absent, blank, or not renderer-bound");
        }
        Vector<DeckEvidenceRectangle> content = [];
        for (int index = 0; index < system.surfaces.size(); index++) {
            DeckSurfaceContract expected = system.surfaces.get(index);
            string prefix = "surface" + f"{index}";
            int nativeWidth = 0;
            int nativeHeight = 0;
            DeckEvidenceRectangle source = DeckEvidenceRectangle.parse(
                DeckHarnessStrings.field(line, prefix + "_source"));
            DeckEvidenceRectangle output = DeckEvidenceRectangle.parse(
                DeckHarnessStrings.field(line, prefix + "_content"));
            if (!DeckAcceptanceEvidence.dimensions(
                    DeckHarnessStrings.field(line, prefix + "_native"),
                    &nativeWidth, &nativeHeight)
                    || nativeWidth != expected.nativeWidth
                    || nativeHeight != expected.nativeHeight
                    || !DeckHarnessStrings.field(line, prefix + "_origin")
                        .equals(expected.origin)
                    || DeckHarnessStrings.field(
                        line, prefix + "_rotation").toInt() != expected.rotation
                    || !source.inside(framebufferWidth, framebufferHeight)
                    || !output.inside(framebufferWidth, framebufferHeight)
                    || !DeckEvidenceImage.meaningful(loaded.image, output)) {
                return DeckHarnessResult.failure(system.id
                    + f": surface {index} geometry/orientation/pixels are invalid");
            }
            for previous in content {
                if (output.overlaps(previous)) {
                    return DeckHarnessResult.failure(system.id
                        + ": independent screen rectangles overlap");
                }
            }
            content.push(output);
        }
        if (system.shaderExpected
                && (!DeckHarnessStrings.field(line, "shader_preset")
                        .endsWith(system.shaderPath)
                    || !DeckHarnessStrings.field(
                        line, "shader_preset_sha256")
                        .equals(system.shaderSha256))) {
            return DeckHarnessResult.failure(system.id
                + ": shader path/hash differs from compiler declarations");
        }
        if (system.bezelExpected) {
            int variant = DeckHarnessStrings.field(
                line, "selected_variant").toInt() - 1;
            if (variant < 0 || variant >= system.bezelPaths.size()
                    || !DeckHarnessStrings.field(line, "bezel_art")
                        .endsWith(system.bezelPaths.get(variant))
                    || !DeckHarnessStrings.field(
                        line, "bezel_art_sha256")
                        .equals(system.bezelSha256.get(variant))
                    || !DeckAcceptanceEvidence.validBezelRectangle(
                        DeckHarnessStrings.field(line, "bezel_rect"))) {
                return DeckHarnessResult.failure(system.id
                    + ": bezel identity/geometry differs from declarations");
            }
        }
        return DeckHarnessResult.success();
    }

    class int matchingCount(string log, Vector<string> fields) {
        int result = 0;
        for line in DeckHarnessStrings.lines(log) {
            if (DeckHarnessStrings.lineHasFields(line, fields)) { result++; }
        }
        return result;
    }

    class bool immediate(string log, DeckGameModeRequest request,
                         string source, string reason, int expected) {
        int count = 0;
        for line in DeckHarnessStrings.lines(log) {
            if (!DeckHarnessStrings.lineHasFields(line,
                    DeckAcceptanceEvidence.bound(request,
                        ["schema=1", "event=process-group-terminate",
                         "source=" + source, "reason=" + reason,
                         "reaped=1"]))) {
                continue;
            }
            int elapsed = DeckHarnessStrings.field(line, "elapsed_ms").toInt();
            int bound = DeckHarnessStrings.field(line, "bound_ms").toInt();
            if (elapsed >= 0 && elapsed <= 250 && bound == 250) { count++; }
        }
        return count >= expected;
    }

    class bool radialAction(string log, DeckGameModeRequest request,
                            string source, string action, int radial,
                            int slot) {
        int code = SemuActions.code(action);
        if (code == SemuActions.none()) { return false; }
        string edge = DeckHarnessStrings.matchingLine(log,
            DeckAcceptanceEvidence.bound(request,
                ["schema=1", "event=action-edge", "source=" + source,
                 "action=" + f"{code}", "radial=" + f"{radial}",
                 "slot=" + f"{slot}",
                 "quit=" + (action.equals("app.quit") ? "1" : "0")]));
        return !edge.isEmpty() && (radial == 3
            || !DeckHarnessStrings.matchingLine(log,
                DeckAcceptanceEvidence.bound(request,
                    ["schema=1", "event=radial-edge", "source=" + source,
                     "radial=" + f"{radial}",
                     "slot=" + f"{slot}"])).isEmpty());
    }

    class DeckHarnessResult gameplay(DeckSystemCase system,
                                     DeckGameModeRequest request,
                                     JsonValue receipt, string log,
                                     string source) {
        string romSha256 = request.protectedInputs.get(0).sha256;
        JsonValue gameplay = receipt.get("phases").get("gameplay");
        int gamePidValue = gameplay.get("game_pid").isInt()
            ? gameplay.get("game_pid").asInt() : 0;
        string gamePid = gamePidValue > 0 ? f"{gamePidValue}" : "";
        string gameStart = gameplay.get("game_start").isString()
            ? gameplay.get("game_start").asString() : "";
        for control in ["directional", "face"] {
            string line = DeckHarnessStrings.matchingLine(log,
                DeckAcceptanceEvidence.bound(request,
                    ["schema=1", "event=gameplay-input",
                     "system_id=" + system.id,
                     "emulator_id=" + system.emulator,
                     "rom_sha256=" + romSha256, "source=" + source,
                     "control=" + control, "consumed=1",
                     "game_pid=" + gamePid,
                     "game_start=" + gameStart]));
            string before = DeckHarnessStrings.field(line, "frame_before");
            string after = DeckHarnessStrings.field(line, "frame_after");
            string screenshotBefore = DeckHarnessStrings.field(
                line, "screenshot_before_sha256");
            string screenshotAfter = DeckHarnessStrings.field(
                line, "screenshot_after_sha256");
            if (line.isEmpty() || !DeckHarnessStrings.lowerHex(before, 16)
                    || !DeckHarnessStrings.lowerHex(after, 16)
                    || before.equals("0000000000000000")
                    || after.equals("0000000000000000")
                    || before.equals(after)
                    || !DeckHarnessStrings.lowerHex(screenshotBefore, 64)
                    || !DeckHarnessStrings.lowerHex(screenshotAfter, 64)
                    || screenshotBefore.equals(screenshotAfter)) {
                return DeckHarnessResult.failure(system.id
                    + ": gameplay control was not consumed: " + control);
            }
        }
        return DeckHarnessResult.success();
    }

    class DeckHarnessResult saveLoad(DeckSystemCase system,
                                     DeckGameModeRequest request,
                                     JsonValue receipt, string log) {
        if (!system.savestateExpected) { return DeckHarnessResult.success(); }
        JsonValue gameplay = receipt.get("phases").get("gameplay");
        int gamePidValue = gameplay.get("game_pid").isInt()
            ? gameplay.get("game_pid").asInt() : 0;
        string gamePid = gamePidValue > 0 ? f"{gamePidValue}" : "";
        string gameStart = gameplay.get("game_start").isString()
            ? gameplay.get("game_start").asString() : "";
        string saved = DeckHarnessStrings.matchingLine(log,
            DeckAcceptanceEvidence.bound(request,
                ["schema=1", "event=state-save", "system_id=" + system.id,
                 "emulator_id=" + system.emulator, "consumed=1",
                 "game_pid=" + gamePid, "game_start=" + gameStart,
                 "state_changed=1"]));
        string loaded = DeckHarnessStrings.matchingLine(log,
            DeckAcceptanceEvidence.bound(request,
                ["schema=1", "event=state-load", "system_id=" + system.id,
                 "emulator_id=" + system.emulator, "consumed=1",
                 "restored=1", "game_pid=" + gamePid,
                 "game_start=" + gameStart]));
        string digest = DeckHarnessStrings.field(saved, "state_sha256");
        string name = DeckHarnessStrings.field(saved, "state_name_sha256");
        string bytes = DeckHarnessStrings.field(saved, "state_bytes");
        string modified = DeckHarnessStrings.field(saved, "state_modified_ns");
        string savedFrame = DeckHarnessStrings.field(saved, "frame_saved");
        string changedFrame = DeckHarnessStrings.field(
            loaded, "frame_changed");
        string loadedSavedFrame = DeckHarnessStrings.field(
            loaded, "frame_saved");
        string restoredFrame = DeckHarnessStrings.field(
            loaded, "frame_restored");
        if (saved.isEmpty() || loaded.isEmpty()
                || !DeckHarnessStrings.lowerHex(digest, 64)
                || !DeckHarnessStrings.lowerHex(name, 64)
                || !DeckRunEvidence.positiveDecimal(bytes)
                || !DeckRunEvidence.notBefore(
                    modified, DeckRunEvidence.started(receipt))
                || !["0", "1"].contains(
                    DeckHarnessStrings.field(saved, "state_created"))
                || !DeckHarnessStrings.lowerHex(savedFrame, 16)
                || !DeckHarnessStrings.lowerHex(changedFrame, 16)
                || !DeckHarnessStrings.lowerHex(restoredFrame, 16)
                || savedFrame.equals(changedFrame)
                || !loadedSavedFrame.equals(savedFrame)
                || !restoredFrame.equals(savedFrame)
                || !DeckHarnessStrings.field(
                    loaded, "state_sha256").equals(digest)
                || !DeckHarnessStrings.field(
                    loaded, "state_name_sha256").equals(name)
                || !DeckHarnessStrings.field(
                    loaded, "state_bytes").equals(bytes)
                || !DeckHarnessStrings.field(loaded, "slot").equals(
                    DeckHarnessStrings.field(saved, "slot"))
                || !DeckHarnessStrings.lowerHex(
                    DeckHarnessStrings.field(
                        saved, "screenshot_saved_sha256"), 64)
                || !DeckHarnessStrings.field(
                    loaded, "screenshot_saved_sha256").equals(
                        DeckHarnessStrings.field(
                            saved, "screenshot_saved_sha256"))
                || !DeckHarnessStrings.lowerHex(
                    DeckHarnessStrings.field(
                        loaded, "screenshot_changed_sha256"), 64)
                || DeckHarnessStrings.field(
                    loaded, "screenshot_changed_sha256").equals(
                        DeckHarnessStrings.field(
                            saved, "screenshot_saved_sha256"))
                || !DeckHarnessStrings.lowerHex(
                    DeckHarnessStrings.field(
                        loaded, "screenshot_restored_sha256"), 64)) {
            return DeckHarnessResult.failure(system.id
                + ": save/load restoration is unproven");
        }
        return DeckHarnessResult.success();
    }

    class DeckHarnessResult input(DeckSystemCase system,
                                  DeckAcceptancePlan plan,
                                  DeckGameModeRequest request,
                                  JsonValue receipt, string root) {
        string input = DeckAcceptanceEvidence.safeText(
            DeckAcceptanceEvidence.runtimePath(
                root, "semu-input-evidence.log"));
        string emulator = DeckAcceptanceEvidence.safeText(
            DeckAcceptanceEvidence.runtimePath(
                root, "semu-emulator-evidence.log"));
        bool automated = request.operation.equals("automated-game-mode");
        string source = automated ? "virtual" : "hardware";
        string gameplaySource = automated
            ? "steam-virtual-gamepad" : "hardware";
        if (!request.operation.equals("operator-start-select")) {
            DeckHarnessResult controls = DeckAcceptanceEvidence.gameplay(
                system, request, receipt, emulator, gameplaySource);
            if (!controls.ok()) { return controls; }
        }
        if (!request.operation.equals("operator-start-select")) {
            for (int slot = 0; slot < plan.quickRadial.size(); slot++) {
                if (!DeckAcceptanceEvidence.radialAction(input, request,
                        source, plan.quickRadial.get(slot), 1, slot)) {
                    return DeckHarnessResult.failure(system.id
                        + f": quick radial slot {slot} is unproven");
                }
            }
            for (int slot = 0; slot < plan.menuRadial.size(); slot++) {
                if (!DeckAcceptanceEvidence.radialAction(input, request,
                        source, plan.menuRadial.get(slot), 2, slot)) {
                    return DeckHarnessResult.failure(system.id
                        + f": menu radial slot {slot} is unproven");
                }
            }
            DeckHarnessResult state = DeckAcceptanceEvidence.saveLoad(
                system, request, receipt, emulator);
            if (!state.ok()) { return state; }
            if (!DeckAcceptanceEvidence.immediate(
                    input, request, source, "action-chord", 1)) {
                return DeckHarnessResult.failure(system.id
                    + ": radial quit was not immediate");
            }
            if (system.id.equals("wii")) {
                string modes = DeckAcceptanceEvidence.safeText(
                    DeckAcceptanceEvidence.runtimePath(
                        root, "semu-wii-controller-evidence.log"));
                for (int slot = 0; slot < plan.wiiModes.size(); slot++) {
                    string mode = plan.wiiModes.get(slot);
                    if (!DeckAcceptanceEvidence.radialAction(
                            input, request, source, mode, 3, slot)
                            || DeckAcceptanceEvidence.matchingCount(modes,
                                DeckAcceptanceEvidence.bound(request,
                                    ["schema=1",
                                     "event=wii-controller-mode",
                                     "system_id=wii",
                                     "emulator_id=dolphin",
                                     "action=" + mode, "applied=1",
                                     "consumer=dolphin"])) < 1) {
                        return DeckHarnessResult.failure(
                            "wii: controller mode is unproven: " + mode);
                    }
                }
            }
        }
        if (!request.operation.equals("operator-radial")
                && !DeckAcceptanceEvidence.immediate(
                    input, request, source, "select+start", 2)) {
            return DeckHarnessResult.failure(system.id
                + ": both Start+Select press orders are unproven");
        }
        return DeckHarnessResult.success();
    }

    class DeckHarnessResult artifacts(JsonValue receipt, string root) {
        JsonValue artifacts = receipt.get("artifacts");
        if (!artifacts.isArray()) {
            return DeckHarnessResult.failure(
                "run artifact manifest is absent after collection");
        }
        for (int index = 0; index < artifacts.size(); index++) {
            JsonValue artifact = artifacts.at(index);
            string name = DeckGameModeContract.text(artifact, "name");
            string expected = DeckGameModeContract.text(
                artifact, "sha256");
            string path = PathTools.join(root, name);
            if (!DeckRunEvidence.safeRelative(name)
                    || !DeckHostDigest.file(path).equals(expected)) {
                return DeckHarnessResult.failure(
                    "collected run artifact is absent, linked, or mismatched: "
                    + name);
            }
        }
        return DeckHarnessResult.success();
    }

    class DeckHarnessResult screenshots(DeckSystemCase system,
                                        DeckGameModeRequest request,
                                        JsonValue receipt, string root) {
        JsonValue launch = receipt.get("launch");
        Vector<string> names = ["frontend-game-mode.png", "game-running.png",
            "esde-return.png"];
        Vector<string> fields = ["frontend_screenshot_sha256",
            "game_screenshot_sha256", "return_screenshot_sha256"];
        for (int index = 0; index < names.size(); index++) {
            string path = PathTools.join(root, names.get(index));
            string expected = launch.get(fields.get(index)).isString()
                ? launch.get(fields.get(index)).asString() : "";
            if (!DeckHostDigest.file(path).equals(expected)
                    || !DeckRunEvidence.artifactDigest(
                        receipt, names.get(index)).equals(expected)) {
                return DeckHarnessResult.failure(
                    "Game Mode screenshot digest is absent or mismatched: "
                    + names.get(index));
            }
        }

        if (request.operation.equals("operator-start-select")) {
            Vector<DeckEvidenceRectangle> full = [];
            DeckScreenshotProbe frontend = DeckScreenshotProbe.load(
                PathTools.join(root, "frontend-game-mode.png"), full);
            Vector<DeckEvidenceRectangle> gameRegions = [];
            DeckScreenshotProbe game = DeckScreenshotProbe.load(
                PathTools.join(root, "game-running.png"), gameRegions);
            Vector<DeckEvidenceRectangle> returnedRegions = [];
            DeckScreenshotProbe returned = DeckScreenshotProbe.load(
                PathTools.join(root, "esde-return.png"), returnedRegions);
            if (!frontend.valid || !game.valid || !returned.valid
                    || frontend.width < 640 || frontend.height < 400
                    || game.width != frontend.width
                    || game.height != frontend.height
                    || returned.width != frontend.width
                    || returned.height != frontend.height
                    || launch.get("game_screenshot_sha256").asString().equals(
                        launch.get("frontend_screenshot_sha256").asString())
                    || launch.get("game_screenshot_sha256").asString().equals(
                        launch.get("return_screenshot_sha256").asString())) {
                return DeckHarnessResult.failure(system.id
                    + ": Start+Select screenshots are blank, stale, or cross-session");
            }
            return DeckHarnessResult.success();
        }

        string rendererLog = DeckAcceptanceEvidence.safeText(
            DeckAcceptanceEvidence.runtimePath(
                root, "semu-render-evidence.log"));
        string rendererLine = DeckAcceptanceEvidence.capturedRendererLine(
            rendererLog, system, request);
        int framebufferWidth = 0;
        int framebufferHeight = 0;
        Vector<DeckEvidenceRectangle> content = [];
        if (rendererLine.isEmpty()
                || !DeckAcceptanceEvidence.dimensions(
                    DeckHarnessStrings.field(
                        rendererLine, "framebuffer_size"),
                    &framebufferWidth, &framebufferHeight)) {
            return DeckHarnessResult.failure(
                system.id + ": screenshots have no run-bound renderer geometry");
        }
        for (int index = 0; index < system.surfaces.size(); index++) {
            DeckEvidenceRectangle rectangle = DeckEvidenceRectangle.parse(
                DeckHarnessStrings.field(rendererLine,
                    "surface" + f"{index}" + "_content"));
            if (!rectangle.inside(framebufferWidth, framebufferHeight)) {
                return DeckHarnessResult.failure(system.id
                    + ": screenshot content rectangle is invalid");
            }
            content.push(rectangle);
        }

        Vector<DeckEvidenceRectangle> full = [];
        DeckScreenshotProbe frontend = DeckScreenshotProbe.load(
            PathTools.join(root, "frontend-game-mode.png"), full);
        DeckScreenshotProbe game = DeckScreenshotProbe.load(
            PathTools.join(root, "game-running.png"), content);
        Vector<DeckEvidenceRectangle> returnedRegions = [];
        DeckScreenshotProbe returned = DeckScreenshotProbe.load(
            PathTools.join(root, "esde-return.png"), returnedRegions);
        if (!frontend.valid || frontend.width < 640 || frontend.height < 400
                || !game.valid || game.width != framebufferWidth
                || game.height != framebufferHeight
                || !returned.valid || returned.width < 640
                || returned.height < 400
                || launch.get("game_screenshot_sha256").asString().equals(
                    launch.get("frontend_screenshot_sha256").asString())
                || launch.get("game_screenshot_sha256").asString().equals(
                    launch.get("return_screenshot_sha256").asString())) {
            return DeckHarnessResult.failure(system.id
                + ": Game Mode screenshots are blank, stale, or lack meaningful game-region pixels");
        }

        int checkedOperator = 0;
        Vector<string> operatorDigests = [];
        JsonValue artifacts = receipt.get("artifacts");
        for (int index = 0; index < artifacts.size()
                && checkedOperator < 8; index++) {
            string name = DeckGameModeContract.text(
                artifacts.at(index), "name");
            if (!DeckRunEvidence.operatorScreenshot(name)) { continue; }
            Vector<DeckEvidenceRectangle> operatorRegions = [];
            DeckScreenshotProbe probe = DeckScreenshotProbe.load(
                PathTools.join(root, name), operatorRegions);
            if (!probe.valid || probe.width != game.width
                    || probe.height != game.height
                    || !DeckScreenshotProbe.radialOverlay(
                        PathTools.join(root, "game-running.png"),
                        PathTools.join(root, name), content)) {
                return DeckHarnessResult.failure(system.id
                    + ": operator radial screenshot does not show a radial/menu overlay");
            }
            string digest = DeckRunEvidence.artifactDigest(receipt, name);
            if (!DeckHarnessStrings.lowerHex(digest, 64)
                    || operatorDigests.contains(digest)) {
                return DeckHarnessResult.failure(system.id
                    + ": operator radial screenshots are stale or duplicated");
            }
            operatorDigests.push(digest);
            checkedOperator++;
        }
        if (request.operation.equals("operator-radial")
                && checkedOperator < 2) {
            return DeckHarnessResult.failure(system.id
                + ": quick and menu radial screenshots are not both evidenced");
        }
        return DeckHarnessResult.success();
    }

    class DeckHarnessResult verify(DeckSystemCase system,
                                   DeckAcceptancePlan plan,
                                   DeckGameModeRequest request,
                                   DeckTransportReceipt collected) {
        if (!collected.valid) {
            return DeckHarnessResult.failure(collected.error);
        }
        string policy = DeckGameModeReceiptPolicy.verify(
            collected.document, request);
        if (!policy.isEmpty()) { return DeckHarnessResult.failure(policy); }
        DeckHarnessResult artifacts = DeckAcceptanceEvidence.artifacts(
            collected.document, collected.localRoot);
        if (!artifacts.ok()) { return artifacts; }
        DeckHarnessResult screenshots = DeckAcceptanceEvidence.screenshots(
            system, request, collected.document, collected.localRoot);
        if (!screenshots.ok()) { return screenshots; }
        if (!request.operation.equals("operator-start-select")) {
            DeckHarnessResult renderer = DeckAcceptanceEvidence.renderer(
                system, request, collected.localRoot);
            if (!renderer.ok()) { return renderer; }
        }
        return DeckAcceptanceEvidence.input(
            system, plan, request, collected.document, collected.localRoot);
    }
}
