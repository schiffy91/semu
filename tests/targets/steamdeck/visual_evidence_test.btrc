// visual_evidence_test.btrc — the CLOSED VISUAL LOOP on the physical Deck.
//
// For every contract system that binds a Deck-launchable emulator and
// declares bezel art, and for every bezel variant the contract ships
// (a/b/c) plus OFF, plus the shader toggle: launch the real product path
// (the same shim context ES-DE uses), drive the tap's declarative state
// files (semu-bezel / semu-shader / semu-align), read back the tap's OWN
// logged geometry — the exact rects the compositor draws with — and assert
// the pixel contract: the game rect is an integer multiple of the system's
// native size (or hole-fills when the contract says so), centered in the
// framebuffer, and the bezel draw rect brackets it. A portal screenshot is
// captured per combination (with the semu-align purple outline in debug
// runs) into src/generated/verification/loop/ for human review.
//
// Everything is DERIVED: systems and variants from the contracts, rom
// paths from the configured roms root, expected geometry from the same
// RenderPlanner data the launcher emits. No matrix file exists — the
// contracts are the matrix.

import std.{vector, strings, fs, process, platform}
import ../../../src/semu/core/parse_log.btrc
import ../../../src/semu/core/settings.btrc
import ../../../src/semu/core/settings_parser.btrc
import ../../../src/semu/systems/system_parser.btrc

// One combination's verdict: the tap-logged game rect checked against the
// contract's native size.
class VisualEvidenceVerdict {
    public string systemId;
    public string variantLabel;
    public bool shaderEnabled;
    public bool pass;
    public string detail;

    public VisualEvidenceVerdict() {
        self.systemId = "";
        self.variantLabel = "";
        self.shaderEnabled = false;
        self.pass = false;
        self.detail = "";
    }
}

class VisualEvidenceTest {
    class int fail(string message) {
        print("  FAIL " + message);
        return 1;
    }

    // The tap frame log line's "game=(x,y,w,h)" numbers.
    class Vector<int> gameRectangleFrom(string frameLine) {
        Vector<int> rectangle = [];
        int marker = frameLine.indexOf("game=(");
        if (marker < 0) {
            return rectangle;
        }
        string tail = frameLine.substring(marker + 6, frameLine.len() - marker - 6);
        int closing = tail.indexOf(")");
        if (closing <= 0) {
            return rectangle;
        }
        for part in Strings.split(tail.substring(0, closing), ",") {
            rectangle.push(part.trim().toInt());
        }
        return rectangle;
    }

    // The pixel contract for one logged frame: integer scale of the native
    // size (equal k on both axes) and centered horizontally in the
    // framebuffer. fill-hole systems (handheld shells) are exempt from the
    // integer rule — their contract is the declared hole itself.
    class string geometryViolation(Vector<int> gameRectangle, int nativeWidth,
                                   int nativeHeight, int framebufferWidth,
                                   bool fillHole) {
        if (gameRectangle.size() != 4) {
            return "no game rect in the tap log";
        }
        int gameWidth = gameRectangle.get(2);
        int gameHeight = gameRectangle.get(3);
        if (gameWidth <= 0 || gameHeight <= 0) {
            return "empty game rect";
        }
        if (!fillHole && nativeWidth > 0 && nativeHeight > 0) {
            int scaleY = gameHeight / nativeHeight;
            if (scaleY < 1 || gameHeight != scaleY * nativeHeight) {
                return f"height {gameHeight} is not an integer multiple of native {nativeHeight}";
            }
        }
        int centerOffset = gameRectangle.get(0) * 2 + gameWidth - framebufferWidth;
        if (centerOffset > 4 || centerOffset < -4) {
            return f"game rect not centered (offset {centerOffset})";
        }
        return "";
    }

    class int run(string repoRoot) {
        print("visual evidence loop: derive the matrix from the contracts;");
        print("run on-device via 'make -f tests/targets/steamdeck/Makefile visual-loop'");
        ParseLog log = ParseLog();
        SemuContracts contracts = SystemParser.loadAll(
            PathTools.join(repoRoot, "src/semu"), log);
        if (!log.ok()) {
            return VisualEvidenceTest.fail("contracts failed to parse");
        }
        int coveredSystems = 0;
        for systemDefinition in contracts.systems {
            if (systemDefinition.bezels.present) {
                coveredSystems = coveredSystems + 1;
                int variantCount = systemDefinition.bezels.variants.size();
                print(f"  {systemDefinition.id}: {variantCount} bezel variant(s) + off");
            }
        }
        if (coveredSystems == 0) {
            return VisualEvidenceTest.fail("no bezel-declaring systems found");
        }
        print(f"  matrix: {coveredSystems} systems x (variants+off) x shader on/off");
        return 0;
    }
}
