// Strict-import Linux entrypoint deployed by the host harness. All durable
// remote behavior is represented here; SSH only invokes this binary with one
// Semu-owned JSON request.

#define STB_IMAGE_IMPLEMENTATION
#include "../../src/generators/rendering/native/stb_image.h"

import std.{cli, fs, json, process, strings, vector}
import ./evidence.btrc
import ./game_mode.btrc
import ./remote_system.btrc
import ./run_evidence.btrc
import ./steam_shortcuts.btrc

class DeckRemoteSnapshot {
    public Vector<DeckProtectedInput> inputs;
    public bool valid;

    public DeckRemoteSnapshot() {
        self.inputs = [];
        self.valid = false;
    }

    class DeckRemoteSnapshot capture(Vector<DeckProtectedInput> requested,
                                     Vector<string> roots,
                                     bool requireExpected) {
        DeckRemoteSnapshot snapshot = DeckRemoteSnapshot();
        for request in requested {
            if (!request.validPath(roots)) { return snapshot; }
            DeckProtectedInput input = DeckProtectedInput();
            input.kind = request.kind;
            input.path = UnixFileSystem.realPath(request.path);
            if (!input.path.equals(request.path)
                    || !FileSystem.isFile(input.path)
                    || FileSystem.isSymlink(input.path)) {
                return snapshot;
            }
            input.sha256 = DeckRemoteHash.file(input.path);
            if (!DeckGameModeContract.sha256(input.sha256)
                    || (requireExpected
                        && !input.sha256.equals(request.sha256))) {
                return snapshot;
            }
            snapshot.inputs.push(input);
        }
        snapshot.valid = !snapshot.inputs.isEmpty();
        return snapshot;
    }

    public bool equals(DeckRemoteSnapshot other) {
        if (!self.valid || !other.valid
                || self.inputs.size() != other.inputs.size()) {
            return false;
        }
        for (int index = 0; index < self.inputs.size(); index++) {
            DeckProtectedInput left = self.inputs.get(index);
            DeckProtectedInput right = other.inputs.get(index);
            if (!left.kind.equals(right.kind)
                    || !left.path.equals(right.path)
                    || !left.sha256.equals(right.sha256)) {
                return false;
            }
        }
        return true;
    }

    public JsonValue json() {
        JsonValue result = JsonValue.makeArray();
        for input in self.inputs { result.push(input.json()); }
        return result;
    }
}

class DeckGeneratedSnapshot {
    public Vector<string> paths;
    public Vector<string> digests;
    public bool valid;

    public DeckGeneratedSnapshot() {
        self.paths = [];
        self.digests = [];
        self.valid = false;
    }

    class DeckGeneratedSnapshot capture(Vector<string> paths) {
        DeckGeneratedSnapshot snapshot = DeckGeneratedSnapshot();
        for path in paths {
            if (!DeckGameModeContract.absolute(path)
                    || !FileSystem.isFile(path)
                    || FileSystem.isSymlink(path)) {
                return snapshot;
            }
            string canonical = UnixFileSystem.realPath(path);
            string digest = DeckRemoteHash.file(path);
            if (!canonical.equals(path)
                    || !DeckGameModeContract.sha256(digest)) {
                return snapshot;
            }
            snapshot.paths.push(path);
            snapshot.digests.push(digest);
        }
        snapshot.valid = !snapshot.paths.isEmpty();
        return snapshot;
    }

    public bool equals(DeckGeneratedSnapshot other) {
        return self.valid && other.valid
            && self.paths.join("\n").equals(other.paths.join("\n"))
            && self.digests.join("\n").equals(other.digests.join("\n"));
    }

    public JsonValue json() {
        JsonValue result = JsonValue.makeArray();
        for (int index = 0; index < self.paths.size(); index++) {
            JsonValue entry = JsonValue.makeObject();
            entry.set("path", JsonValue.makeString(self.paths.get(index)));
            entry.set("sha256",
                JsonValue.makeString(self.digests.get(index)));
            result.push(entry);
        }
        return result;
    }
}

class DeckRemoteEvidence {
    class string bind(string log, DeckGameModeRequest request) {
        if (log.trim().isEmpty()) { return ""; }
        string prefix = "run_id=" + request.runId
            + " harness_revision=" + request.harnessRevision
            + " artifact_sha256=" + request.releaseSha256 + " ";
        Vector<string> bound = [];
        for line in Strings.split(log, "\n") {
            string value = line.trim();
            if (value.isEmpty()) { continue; }
            if (!DeckEvidenceReceiptPolicy.field(
                    value, "run_id").isEmpty()
                    || !DeckEvidenceReceiptPolicy.field(
                        value, "harness_revision").isEmpty()
                    || !DeckEvidenceReceiptPolicy.field(
                        value, "artifact_sha256").isEmpty()) {
                return "";
            }
            bound.push(prefix + value);
        }
        return bound.isEmpty() ? "" : bound.join("\n") + "\n";
    }

    class int count(string log, Vector<string> fields) {
        int found = 0;
        for line in Strings.split(log, "\n") {
            bool matches = true;
            for field in fields {
                int separator = field.indexOf("=");
                if (separator < 1
                        || !DeckEvidenceReceiptPolicy.field(
                            line, field.substring(0, separator)).equals(
                                field.substring(separator + 1, field.len()))) {
                    matches = false;
                }
            }
            if (matches) { found++; }
        }
        return found;
    }

    class bool immediate(string log, string source, string reason,
                         int minimum) {
        int found = 0;
        for line in Strings.split(log, "\n") {
            if (!DeckEvidenceReceiptPolicy.field(
                    line, "event").equals("process-group-terminate")
                    || !DeckEvidenceReceiptPolicy.field(
                        line, "source").equals(source)
                    || !DeckEvidenceReceiptPolicy.field(
                        line, "reason").equals(reason)
                    || !DeckEvidenceReceiptPolicy.field(
                        line, "reaped").equals("1")) {
                continue;
            }
            int elapsed = DeckEvidenceReceiptPolicy.field(
                line, "elapsed_ms").toInt();
            int bound = DeckEvidenceReceiptPolicy.field(
                line, "bound_ms").toInt();
            if (elapsed >= 0 && elapsed <= 250 && bound == 250) { found++; }
        }
        return found >= minimum;
    }

    class bool radial(string log, string source, int radial, int minimum) {
        return DeckRemoteEvidence.count(log,
            ["event=action-edge", "source=" + source,
             "radial=" + f"{radial}"]) >= minimum;
    }

    class bool gameplay(string log, DeckGameModeRequest request,
                        string source) {
        for control in ["directional", "face"] {
            if (DeckRemoteEvidence.count(log,
                    ["event=gameplay-input", "system_id=" + request.systemId,
                     "emulator_id=" + request.emulatorId,
                     "source=" + source, "control=" + control,
                     "consumed=1"]) < 1) {
                return false;
            }
        }
        return true;
    }

    class bool saveLoad(string log, DeckGameModeRequest request) {
        if (!request.savestateExpected) { return true; }
        return DeckRemoteEvidence.count(log,
            ["event=state-save", "system_id=" + request.systemId,
             "emulator_id=" + request.emulatorId, "consumed=1"]) >= 1
            && DeckRemoteEvidence.count(log,
                ["event=state-load", "system_id=" + request.systemId,
                 "emulator_id=" + request.emulatorId, "consumed=1",
                 "restored=1"]) >= 1;
    }

    class bool wiiModes(string log, DeckGameModeRequest request) {
        if (!request.wiiExpected) { return true; }
        for mode in ["wii.controller.wiimote",
                     "wii.controller.nunchuk",
                     "wii.controller.classic",
                     "wii.controller.gamecube"] {
            if (DeckRemoteEvidence.count(log,
                    ["event=wii-controller-mode", "system_id=wii",
                     "emulator_id=dolphin", "action=" + mode,
                     "applied=1", "consumer=dolphin"]) < 1) {
                return false;
            }
        }
        return true;
    }
}

class DeckRemoteGame {
    class string releaseRoot(DeckGameModeRequest request) {
        return PathTools.join(PathTools.dirname(
            PathTools.dirname(request.shortcut.executable)),
            "releases/" + request.releaseSha256);
    }

    class bool packaged(int process, DeckGameModeRequest request,
                        int esDe) {
        if (!DeckRemoteProcess.descendant(process, esDe)
                || !DeckRemoteProcess.hasArgument(process,
                    "/run/semu-appdir" + request.expectedExecutable)
                || !DeckRemoteProcess.hasArgument(process, request.rom)
                || (!request.coreFilename.isEmpty()
                    && !DeckRemoteProcess.hasBasenameArgument(
                        process, request.coreFilename))) {
            return false;
        }
        if (!DeckRemoteProcess.environmentValue(process,
                "SEMU_RENDER_SYSTEM_ID").equals(request.systemId)
                || !DeckRemoteProcess.environmentValue(process,
                    "SEMU_RENDER_EMULATOR_ID").equals(request.emulatorId)
                || !DeckRemoteProcess.environmentValue(process,
                    "SEMU_RELEASE_DIGEST").equals(request.releaseSha256)
                || !DeckRemoteProcess.environmentValue(process,
                    "SEMU_ENTRYPOINT").equals(request.shortcut.executable)) {
            return false;
        }
        string relative = request.expectedExecutable.startsWith("/")
            ? request.expectedExecutable.substring(
                1, request.expectedExecutable.len() - 1)
            : request.expectedExecutable;
        string packaged = PathTools.join(
            DeckRemoteGame.releaseRoot(request), relative);
        return DeckRemoteHash.file(packaged).equals(
            request.expectedExecutableSha256);
    }

    class int find(DeckGameModeRequest request, int esDe,
                   Vector<int> excluded) {
        int found = 0;
        for process in DeckRemoteProcess.all() {
            if (excluded.contains(process)
                    || !DeckRemoteGame.packaged(process, request, esDe)) {
                continue;
            }
            if (found != 0) { return 0; }
            found = process;
        }
        return found;
    }

    class int waitFor(DeckGameModeRequest request, int esDe,
                      Vector<int> excluded) {
        for (int attempt = 0; attempt < 3000; attempt++) {
            int process = DeckRemoteGame.find(request, esDe, excluded);
            if (process > 1) { return process; }
            if (!DeckRemoteProcess.alive(esDe)
                    || !DeckRemoteClock.sleep(100)) {
                return 0;
            }
        }
        return 0;
    }

    class bool waitForExit(int process, int milliseconds) {
        int attempts = milliseconds / 100;
        for (int attempt = 0; attempt < attempts; attempt++) {
            if (!DeckRemoteProcess.alive(process)) { return true; }
            if (!DeckRemoteClock.sleep(100)) { return false; }
        }
        return !DeckRemoteProcess.alive(process);
    }
}

class DeckRemoteInput {
    class bool run(DeckGameModeRequest request, string plan,
                   string expectedSha256, string receipt) {
        if (!DeckRemoteHash.file(request.inputHelper).equals(
                request.inputHelperSha256)
                || !DeckRemoteHash.file(plan).equals(expectedSha256)
                || FileSystem.exists(receipt)) {
            return false;
        }
        ExecResult result = ChildProcess.run(request.inputHelper,
            ["--plan", plan, "--receipt", receipt], "",
            CommandEnvironment.empty(), CommandEnvironment.empty(), 120000,
            1048576, 1048576);
        return result.ok() && FileSystem.isFile(receipt)
            && FileSystem.readText(receipt).contains(
                "input_origin=synthetic-uinput")
            && FileSystem.readText(receipt).contains(
                "steam_radial_ui_proven=0");
    }

    class bool relaunch(DeckGameModeRequest request, string root,
                        int sequence) {
        string plan = PathTools.join(root,
            "relaunch-" + f"{sequence}" + ".plan");
        string receipt = PathTools.join(root,
            "relaunch-" + f"{sequence}" + ".log");
        string content = "wait|1000\ntap|gamepad|south\n";
        return !FileSystem.exists(plan)
            && FileSystem.writeText(plan, content)
            && DeckRemoteInput.run(request, plan,
                DeckRemoteHash.file(plan), receipt);
    }
}

class DeckObservedStage {
    public string name;
    public Vector<string> lines;

    public DeckObservedStage(string stageName) {
        self.name = stageName;
        self.lines = [];
    }

    public string plan() {
        return "# Semu observed synthetic stage; never physical evidence\n"
            + self.lines.join("\n") + "\n";
    }
}

class DeckObservedPlan {
    public Vector<DeckObservedStage> stages;
    public bool valid;

    public DeckObservedPlan() {
        self.stages = [];
        self.valid = false;
    }

    class DeckObservedPlan parse(string path, string expectedSha256) {
        DeckObservedPlan result = DeckObservedPlan();
        if (!DeckRemoteHash.file(path).equals(expectedSha256)) {
            return result;
        }
        string marker = "# semu-evidence-stage ";
        DeckObservedStage current = DeckObservedStage("setup");
        bool marked = false;
        for raw in Strings.split(FileSystem.readText(path), "\n") {
            string line = raw.trim();
            if (line.isEmpty()) { continue; }
            if (line.startsWith(marker)) {
                if (!current.lines.isEmpty()) { result.stages.push(current); }
                string name = line.substring(marker.len(), line.len());
                if (!["gameplay-directional", "gameplay-face", "state-save",
                      "quick-radial", "state-change", "state-load",
                      "menu-radial", "wii-modes", "radial-quit"].contains(name)) {
                    return DeckObservedPlan();
                }
                current = DeckObservedStage(name);
                marked = true;
                continue;
            }
            if (!line.startsWith("#")) { current.lines.push(line); }
        }
        if (!current.lines.isEmpty()) { result.stages.push(current); }
        Vector<string> required = [
            "gameplay-directional", "gameplay-face", "state-save",
            "state-change", "state-load", "radial-quit"
        ];
        Vector<string> found = [];
        for stage in result.stages {
            if (stage.lines.isEmpty()) { return DeckObservedPlan(); }
            found.push(stage.name);
        }
        for name in required {
            if (!found.contains(name)) { return DeckObservedPlan(); }
        }
        result.valid = marked;
        return result;
    }
}

class DeckObservedRectangle {
    public int x;
    public int y;
    public int width;
    public int height;
    public bool valid;

    public DeckObservedRectangle() {
        self.x = 0;
        self.y = 0;
        self.width = 0;
        self.height = 0;
        self.valid = false;
    }

    class DeckObservedRectangle parse(string value) {
        DeckObservedRectangle result = DeckObservedRectangle();
        Vector<string> fields = Strings.split(value, ",");
        if (fields.size() != 4) { return result; }
        result.x = fields.get(0).toInt();
        result.y = fields.get(1).toInt();
        result.width = fields.get(2).toInt();
        result.height = fields.get(3).toInt();
        result.valid = result.x >= 0 && result.y >= 0
            && result.width > 0 && result.height > 0;
        return result;
    }

    public bool inside(int outerWidth, int outerHeight) {
        return self.valid && self.x + self.width <= outerWidth
            && self.y + self.height <= outerHeight;
    }
}

class DeckObservedGeometry {
    public int width;
    public int height;
    public Vector<DeckObservedRectangle> surfaces;
    public bool valid;

    public DeckObservedGeometry() {
        self.width = 0;
        self.height = 0;
        self.surfaces = [];
        self.valid = false;
    }

    class bool dimensions(string value, int* width, int* height) {
        Vector<string> fields = Strings.split(value, "x");
        if (fields.size() != 2) { return false; }
        *width = fields.get(0).toInt();
        *height = fields.get(1).toInt();
        return *width > 0 && *height > 0;
    }

    class DeckObservedGeometry parse(string log, DeckGameModeRequest request) {
        DeckObservedGeometry result = DeckObservedGeometry();
        for line in Strings.split(log, "\n") {
            if (!DeckEvidenceReceiptPolicy.field(line, "schema").equals("3")
                    || !DeckEvidenceReceiptPolicy.field(
                        line, "phase").equals("post_ui")
                    || !DeckEvidenceReceiptPolicy.field(
                        line, "system_id").equals(request.systemId)
                    || !DeckEvidenceReceiptPolicy.field(
                        line, "emulator_id").equals(request.emulatorId)
                    || !DeckEvidenceReceiptPolicy.field(
                        line, "matched").equals("1")
                    || !DeckEvidenceReceiptPolicy.field(
                        line, "status").equals("1")
                    || !DeckObservedGeometry.dimensions(
                        DeckEvidenceReceiptPolicy.field(
                            line, "framebuffer_size"),
                        &result.width, &result.height)) {
                continue;
            }
            int count = DeckEvidenceReceiptPolicy.field(
                line, "surface_count").toInt();
            if (count < 1 || count > 4) { continue; }
            bool valid = true;
            for (int index = 0; index < count; index++) {
                DeckObservedRectangle rectangle =
                    DeckObservedRectangle.parse(
                        DeckEvidenceReceiptPolicy.field(line,
                            "surface" + f"{index}" + "_content"));
                if (!rectangle.inside(result.width, result.height)) {
                    valid = false;
                }
                result.surfaces.push(rectangle);
            }
            result.valid = valid;
            if (valid) { return result; }
            result.surfaces = [];
        }
        return result;
    }

    class DeckObservedGeometry waitFor(string path,
                                       DeckGameModeRequest request) {
        for (int attempt = 0; attempt < 300; attempt++) {
            if (FileSystem.isFile(path) && !FileSystem.isSymlink(path)) {
                DeckObservedGeometry geometry =
                    DeckObservedGeometry.parse(
                        FileSystem.readText(path), request);
                if (geometry.valid) { return geometry; }
            }
            if (!DeckRemoteClock.sleep(100)) { break; }
        }
        return DeckObservedGeometry();
    }
}

class DeckObservedFrame {
    public string fileSha256;
    public string regionHash;
    public bool valid;

    public DeckObservedFrame() {
        self.fileSha256 = "";
        self.regionHash = "";
        self.valid = false;
    }

    class DeckObservedFrame load(string path, DeckObservedGeometry geometry) {
        DeckObservedFrame result = DeckObservedFrame();
        if (!geometry.valid || !FileSystem.isFile(path)
                || FileSystem.isSymlink(path)) {
            return result;
        }
        int width = 0;
        int height = 0;
        int channels = 0;
        unsigned char* pixels = stbi_load(
            path, &width, &height, &channels, 4);
        if (pixels == null || width != geometry.width
                || height != geometry.height) {
            if (pixels != null) { stbi_image_free((void*)pixels); }
            return result;
        }
        unsigned long long hash = 1469598103934665603ULL;
        long long sampled = 0LL;
        for rectangle in geometry.surfaces {
            for (int y = rectangle.y; y < rectangle.y + rectangle.height; y++) {
                int row = height - y - 1;
                for (int x = rectangle.x;
                        x < rectangle.x + rectangle.width; x++) {
                    unsigned char* pixel = pixels
                        + ((size_t)row * (size_t)width + (size_t)x)
                            * (size_t)4;
                    for (int channel = 0; channel < 4; channel++) {
                        hash ^= (unsigned long long)pixel[channel];
                        hash *= 1099511628211ULL;
                    }
                    sampled++;
                }
            }
        }
        stbi_image_free((void*)pixels);
        char encoded[17];
        snprintf(encoded, 17, "%016llx", hash);
        result.fileSha256 = DeckRemoteHash.file(path);
        result.regionHash = Strings.copy(encoded);
        result.valid = sampled > 0LL
            && DeckGameModeContract.sha256(result.fileSha256)
            && DeckRunEvidence.lowerHex(result.regionHash, 16)
            && !result.regionHash.equals("0000000000000000");
        return result;
    }
}

class DeckObservedStateFile {
    public string path;
    public string nameSha256;
    public string sha256;
    public string bytes;
    public string modifiedNs;
    public bool valid;

    public DeckObservedStateFile() {
        self.path = "";
        self.nameSha256 = "";
        self.sha256 = "";
        self.bytes = "";
        self.modifiedNs = "";
        self.valid = false;
    }
}

class DeckObservedState {
    public Vector<DeckObservedStateFile> files;
    public bool valid;

    public DeckObservedState() {
        self.files = [];
        self.valid = false;
    }

    class DeckObservedState capture(string root) {
        DeckObservedState result = DeckObservedState();
        if (!FileSystem.isDir(root) || FileSystem.isSymlink(root)) {
            return result;
        }
        string canonical = UnixFileSystem.realPath(root);
        if (!canonical.equals(root)) { return result; }
        for name in FileSystem.listDir(root) {
            string path = PathTools.join(root, name);
            if (!FileSystem.isFile(path) || FileSystem.isSymlink(path)
                    || !UnixFileSystem.realPath(path).startsWith(root + "/")) {
                continue;
            }
            DeckObservedStateFile file = DeckObservedStateFile();
            file.path = path;
            file.nameSha256 = DeckRemoteHash.text(name);
            file.sha256 = DeckRemoteHash.file(path);
            file.bytes = DeckRemoteFile.number(DeckRemoteFile.size(path));
            file.modifiedNs = DeckRemoteFile.modifiedNanos(path);
            file.valid = DeckGameModeContract.sha256(file.nameSha256)
                && DeckGameModeContract.sha256(file.sha256)
                && DeckRunEvidence.positiveDecimal(file.bytes)
                && DeckRunEvidence.positiveDecimal(file.modifiedNs);
            if (!file.valid) { return DeckObservedState(); }
            result.files.push(file);
        }
        result.valid = true;
        return result;
    }

    public DeckObservedStateFile changedFrom(DeckObservedState before,
                                             string minimumModifiedNs) {
        DeckObservedStateFile changed = DeckObservedStateFile();
        int count = 0;
        for after in self.files {
            bool differs = true;
            for prior in before.files {
                if (after.path.equals(prior.path)) {
                    differs = !after.sha256.equals(prior.sha256)
                        || !after.bytes.equals(prior.bytes);
                }
            }
            if (differs && DeckRunEvidence.notBefore(
                    after.modifiedNs, minimumModifiedNs)) {
                changed = after;
                count++;
            }
        }
        return count == 1 ? changed : DeckObservedStateFile();
    }

    public DeckObservedStateFile named(string nameSha256) {
        for file in self.files {
            if (file.nameSha256.equals(nameSha256)) { return file; }
        }
        return DeckObservedStateFile();
    }
}

class DeckAutomatedObservation {
    public string emulatorLog;
    public bool valid;

    public DeckAutomatedObservation() {
        self.emulatorLog = "";
        self.valid = false;
    }

    class string event(DeckGameModeRequest request, string kind,
                       string fields) {
        return "schema=1 event=" + kind
            + " system_id=" + request.systemId
            + " emulator_id=" + request.emulatorId
            + " rom_sha256=" + request.protectedInputs.get(0).sha256
            + " source=steam-virtual-gamepad " + fields + "\n";
    }

    class DeckObservedFrame capture(DeckGameModeRequest request,
                                    DeckRemoteSession session,
                                    DeckObservedGeometry geometry,
                                    string name) {
        string path = PathTools.join(request.runRoot, name);
        if (DeckRemoteGameMode.screenshot(session, path).isEmpty()) {
            return DeckObservedFrame();
        }
        return DeckObservedFrame.load(path, geometry);
    }

    class bool execute(DeckGameModeRequest request, DeckObservedStage stage,
                       int index, Vector<string> receipts) {
        string plan = PathTools.join(
            request.runRoot, "observed-stage-" + f"{index}" + ".plan");
        string receipt = PathTools.join(
            request.runRoot, "observed-stage-" + f"{index}" + ".log");
        if (FileSystem.exists(plan) || FileSystem.exists(receipt)
                || !FileSystem.writeText(plan, stage.plan())
                || !DeckRemoteInput.run(
                    request, plan, DeckRemoteHash.file(plan), receipt)) {
            return false;
        }
        string evidence = FileSystem.readText(receipt);
        if (evidence.isEmpty()) { return false; }
        receipts.push(evidence);
        return true;
    }

    class DeckObservedStateFile waitForState(string root,
                                             DeckObservedState before,
                                             string minimumModifiedNs,
                                             DeckObservedState after) {
        for (int attempt = 0; attempt < 100; attempt++) {
            DeckObservedState current = DeckObservedState.capture(root);
            DeckObservedStateFile changed = current.changedFrom(
                before, minimumModifiedNs);
            if (current.valid && changed.valid) {
                after.files = current.files;
                after.valid = current.valid;
                return changed;
            }
            if (!DeckRemoteClock.sleep(100)) { break; }
        }
        return DeckObservedStateFile();
    }

    class DeckAutomatedObservation run(DeckGameModeRequest request,
                                       DeckRemoteSession session, int game,
                                       string stateRoot,
                                       string initialScreenshot) {
        DeckAutomatedObservation result = DeckAutomatedObservation();
        DeckObservedPlan plan = DeckObservedPlan.parse(
            request.actionPlan, request.actionPlanSha256);
        DeckObservedGeometry geometry = DeckObservedGeometry.waitFor(
            PathTools.join(stateRoot, "semu-render-evidence.log"), request);
        DeckObservedFrame initial = DeckObservedFrame.load(
            initialScreenshot, geometry);
        string gameStart = DeckRemoteProcess.startTime(game);
        string statesRoot = PathTools.join(
            request.projectRoot, "build/runtime/content/states");
        DeckObservedState states = DeckObservedState.capture(statesRoot);
        if (!plan.valid || !geometry.valid || !initial.valid
                || gameStart.isEmpty() || !states.valid) {
            return result;
        }

        DeckObservedFrame current = initial;
        DeckObservedFrame savedFrame = DeckObservedFrame();
        DeckObservedFrame changedFrame = DeckObservedFrame();
        DeckObservedStateFile stateFile = DeckObservedStateFile();
        string savedAt = "";
        Vector<string> inputReceipts = [];
        int directional = 0;
        int face = 0;
        int saves = 0;
        int changes = 0;
        int loads = 0;
        int index = 0;
        for stage in plan.stages {
            if (!stage.name.equals("radial-quit")
                    && (!DeckRemoteProcess.alive(game)
                        || !DeckRemoteProcess.startTime(game).equals(gameStart))) {
                return DeckAutomatedObservation();
            }
            DeckObservedFrame before = current;
            DeckObservedState beforeState = states;
            string stageStarted = DeckRemoteClock.realtimeNanos();
            if (!DeckAutomatedObservation.execute(
                    request, stage, index, inputReceipts)) {
                return DeckAutomatedObservation();
            }
            index++;
            if (stage.name.equals("radial-quit")) { continue; }
            if (!DeckRemoteClock.sleep(500)) {
                return DeckAutomatedObservation();
            }

            bool observedFrame = [
                "gameplay-directional", "gameplay-face", "state-save",
                "state-change", "state-load"
            ].contains(stage.name);
            if (observedFrame) {
                current = DeckAutomatedObservation.capture(
                    request, session, geometry,
                    "observed-" + stage.name + ".png");
                if (!current.valid) { return DeckAutomatedObservation(); }
            }

            if (stage.name.equals("gameplay-directional")) {
                directional++;
                if (before.regionHash.equals(current.regionHash)) {
                    return DeckAutomatedObservation();
                }
                result.emulatorLog += DeckAutomatedObservation.event(
                    request, "gameplay-input",
                    "control=directional consumed=1 game_pid=" + f"{game}"
                    + " game_start=" + gameStart
                    + " frame_before=" + before.regionHash
                    + " frame_after=" + current.regionHash
                    + " screenshot_before_sha256=" + before.fileSha256
                    + " screenshot_after_sha256=" + current.fileSha256);
            } else if (stage.name.equals("gameplay-face")) {
                face++;
                if (before.regionHash.equals(current.regionHash)) {
                    return DeckAutomatedObservation();
                }
                result.emulatorLog += DeckAutomatedObservation.event(
                    request, "gameplay-input",
                    "control=face consumed=1 game_pid=" + f"{game}"
                    + " game_start=" + gameStart
                    + " frame_before=" + before.regionHash
                    + " frame_after=" + current.regionHash
                    + " screenshot_before_sha256=" + before.fileSha256
                    + " screenshot_after_sha256=" + current.fileSha256);
            } else if (stage.name.equals("state-save")) {
                saves++;
                states = DeckObservedState();
                stateFile = DeckAutomatedObservation.waitForState(
                    statesRoot, beforeState, stageStarted, states);
                savedFrame = current;
                savedAt = stageStarted;
                bool created = !beforeState.named(stateFile.nameSha256).valid;
                if (!stateFile.valid || !states.valid) {
                    return DeckAutomatedObservation();
                }
                result.emulatorLog += DeckAutomatedObservation.event(
                    request, "state-save",
                    "consumed=1 slot=observed state_name_sha256="
                    + stateFile.nameSha256
                    + " state_sha256=" + stateFile.sha256
                    + " state_bytes=" + stateFile.bytes
                    + " state_modified_ns=" + stateFile.modifiedNs
                    + " state_created=" + (created ? "1" : "0")
                    + " state_changed=1 game_pid=" + f"{game}"
                    + " game_start=" + gameStart
                    + " frame_saved=" + savedFrame.regionHash
                    + " screenshot_saved_sha256=" + savedFrame.fileSha256);
            } else if (stage.name.equals("state-change")) {
                changes++;
                changedFrame = current;
                if (!savedFrame.valid
                        || savedFrame.regionHash.equals(changedFrame.regionHash)) {
                    return DeckAutomatedObservation();
                }
            } else if (stage.name.equals("state-load")) {
                loads++;
                DeckObservedState afterLoad =
                    DeckObservedState.capture(statesRoot);
                DeckObservedStateFile retained = afterLoad.named(
                    stateFile.nameSha256);
                bool restored = savedFrame.valid && changedFrame.valid
                    && retained.valid
                    && retained.sha256.equals(stateFile.sha256)
                    && !savedFrame.regionHash.equals(changedFrame.regionHash)
                    && current.regionHash.equals(savedFrame.regionHash)
                    && DeckRunEvidence.notBefore(stageStarted, savedAt);
                if (!restored) { return DeckAutomatedObservation(); }
                result.emulatorLog += DeckAutomatedObservation.event(
                    request, "state-load",
                    "consumed=1 restored=1 slot=observed"
                    + " state_name_sha256=" + retained.nameSha256
                    + " state_sha256=" + retained.sha256
                    + " state_bytes=" + retained.bytes
                    + " game_pid=" + f"{game}"
                    + " game_start=" + gameStart
                    + " frame_saved=" + savedFrame.regionHash
                    + " frame_changed=" + changedFrame.regionHash
                    + " frame_restored=" + current.regionHash
                    + " screenshot_saved_sha256=" + savedFrame.fileSha256
                    + " screenshot_changed_sha256=" + changedFrame.fileSha256
                    + " screenshot_restored_sha256=" + current.fileSha256);
            }
        }
        string combined = inputReceipts.join("");
        string receiptPath = PathTools.join(request.runRoot,
            "actions-uinput.log");
        result.valid = directional == 1 && face == 1 && saves == 1
            && changes == 1 && loads == 1
            && !result.emulatorLog.isEmpty() && !combined.isEmpty()
            && !FileSystem.exists(receiptPath)
            && FileSystem.writeText(receiptPath, combined);
        return result;
    }
}

class DeckRemoteInstalled {
    public DeckGameModeRequest request;
    public string root;
    public string artifact;
    public string current;
    public string releaseRoot;
    public string launcherSha256;

    public DeckRemoteInstalled(DeckGameModeRequest request) {
        self.request = request;
        self.root = PathTools.dirname(PathTools.dirname(
            request.shortcut.executable));
        self.artifact = PathTools.join(
            self.root, "Semu-x86_64.AppImage");
        self.current = PathTools.join(self.root, "state/current");
        self.releaseRoot = PathTools.join(
            self.root, "releases/" + request.releaseSha256);
        self.launcherSha256 = DeckRemoteHash.file(
            request.shortcut.executable);
    }

    public bool valid() {
        string identity = FileSystem.isFile(self.current)
                && !FileSystem.isSymlink(self.current)
            ? FileSystem.readText(self.current).trim() : "";
        string recordedPath = self.artifact + ".sha256";
        string recorded = FileSystem.isFile(recordedPath)
                && !FileSystem.isSymlink(recordedPath)
            ? FileSystem.readText(recordedPath).trim() : "";
        return DeckGameModeContract.sha256(self.request.releaseSha256)
            && DeckRemoteHash.file(self.artifact).equals(
                self.request.releaseSha256)
            && identity.equals(self.request.releaseSha256)
            && recorded.equals(self.request.releaseSha256)
            && FileSystem.isDir(self.releaseRoot)
            && !FileSystem.isSymlink(self.releaseRoot)
            && DeckGameModeContract.sha256(self.launcherSha256);
    }

    public JsonValue json() {
        JsonValue result = JsonValue.makeObject();
        result.set("artifact_path", JsonValue.makeString(self.artifact));
        result.set("artifact_sha256",
            JsonValue.makeString(DeckRemoteHash.file(self.artifact)));
        result.set("current_release", JsonValue.makeString(
            FileSystem.isFile(self.current)
                    && !FileSystem.isSymlink(self.current)
                ? FileSystem.readText(self.current).trim() : ""));
        result.set("release_root", JsonValue.makeString(self.releaseRoot));
        result.set("launcher_path",
            JsonValue.makeString(self.request.shortcut.executable));
        result.set("launcher_sha256",
            JsonValue.makeString(self.launcherSha256));
        return result;
    }
}

class DeckRemoteArtifacts {
    public JsonValue files;
    public bool valid;

    public DeckRemoteArtifacts() {
        self.files = JsonValue.makeArray();
        self.valid = true;
    }

    public bool add(string root, string name, string runId,
                    string startedNs) {
        string path = PathTools.join(root, name);
        long long bytes = DeckRemoteFile.size(path);
        string sha256 = DeckRemoteHash.file(path);
        string modifiedNs = DeckRemoteFile.modifiedNanos(path);
        if (!self.valid || !DeckRunEvidence.safeRelative(name)
                || !DeckRemoteFile.fresh(path, startedNs)
                || bytes < 1LL || !DeckGameModeContract.sha256(sha256)) {
            self.valid = false;
            return false;
        }
        self.files.push(DeckRunEvidence.artifact(
            runId, name, sha256, DeckRemoteFile.number(bytes), modifiedNs));
        return true;
    }
}

class DeckRemoteReceipt {
    class JsonValue evidence(string scenario, bool humanObserved) {
        JsonValue value = JsonValue.makeObject();
        bool synthetic = scenario.equals("automated-game-mode");
        bool human = scenario.startsWith("operator-") && humanObserved;
        value.set("class", JsonValue.makeString(synthetic
            ? DeckEvidenceClass.automatedHardware()
            : (human ? DeckEvidenceClass.humanPhysical()
                : DeckEvidenceClass.automatedHardware())));
        value.set("input_origin", JsonValue.makeString(synthetic
            ? "synthetic-uinput" : (human ? "human" : "none")));
        value.set("proof_mode", JsonValue.makeString(
            DeckEvidenceClass.proofMode(scenario)));
        value.set("synthetic_input", JsonValue.makeBool(synthetic));
        value.set("human_input", JsonValue.makeBool(human));
        value.set("human_observed", JsonValue.makeBool(human));
        value.set("acceptance_eligible", JsonValue.makeBool(human));
        return value;
    }

    class JsonValue shortcut(DeckExpectedShortcut shortcut) {
        return shortcut.json();
    }

    class JsonValue base(DeckGameModeRequest request, string requestSha256,
                         string startedNs, JsonValue installed) {
        JsonValue root = JsonValue.makeObject();
        root.set("schema_version", JsonValue.makeInt(2));
        root.set("operation", JsonValue.makeString(request.operation));
        root.set("run", DeckRunEvidence.binding(request.runId,
            request.harnessRevision, request.releaseSha256,
            requestSha256, startedNs));
        root.set("installed", installed);
        return root;
    }

    class bool write(string path, JsonValue receipt) {
        return !FileSystem.exists(path)
            && FileSystem.writeText(path, receipt.stringify() + "\n");
    }
}

class DeckRemoteRunner {
    public DeckGameModeRequest request;
    public string requestPath;

    public DeckRemoteRunner(string requestPath) {
        self.requestPath = requestPath;
        self.request = DeckGameModeRequest.parse(requestPath);
    }

    public bool safeRequest() {
        DeckRemoteInstalled installed = DeckRemoteInstalled(self.request);
        return self.request.valid()
            && FileSystem.isFile(self.requestPath)
            && !FileSystem.isSymlink(self.requestPath)
            && installed.valid()
            && DeckGameModeContract.contains(self.request.projectRoot
                + "/build/verification/steamdeck/requests",
                self.requestPath);
    }

    public bool prepareRunRoot(bool existing) {
        if (FileSystem.isSymlink(self.request.runRoot)) { return false; }
        if (existing) {
            return FileSystem.isDir(self.request.runRoot);
        }
        return !FileSystem.exists(self.request.runRoot)
            && FileSystem.mkdirp(self.request.runRoot) == 0
            && !FileSystem.isSymlink(self.request.runRoot);
    }

    public DeckSteamShortcutResolution shortcut() {
        return DeckRemoteShortcut.resolve(
            self.request.steamRoot, self.request.shortcut.executable);
    }

    public bool exactShortcut(DeckSteamShortcutResolution actual) {
        return DeckRemoteShortcut.matches(actual, self.request.shortcut);
    }

    public JsonValue baseReceipt(string startedNs) {
        DeckRemoteInstalled installed = DeckRemoteInstalled(self.request);
        return DeckRemoteReceipt.base(self.request,
            DeckRemoteHash.file(self.requestPath), startedNs,
            installed.json());
    }

    public int inspect() {
        if (!self.prepareRunRoot(false)) { return 71; }
        string startedNs = DeckRemoteClock.realtimeNanos();
        if (!DeckRunEvidence.positiveDecimal(startedNs)) { return 77; }
        DeckSteamShortcutResolution resolution = DeckRemoteShortcut.resolve(
            self.request.steamRoot, self.request.shortcut.executable);
        string launcherSha256 = resolution.valid
            ? DeckRemoteHash.file(self.request.shortcut.executable) : "";
        DeckExpectedShortcut expected = DeckExpectedShortcut.fromResolution(
            resolution, launcherSha256);
        if (!expected.valid()) {
            print(resolution.error.isEmpty()
                ? "installed shortcut identity is incomplete"
                : resolution.error);
            return 78;
        }
        JsonValue receipt = self.baseReceipt(startedNs);
        receipt.set("shortcut", expected.json());
        return DeckRemoteReceipt.write(PathTools.join(
            self.request.runRoot, "receipt.json"), receipt) ? 0 : 74;
    }

    public int inspectInputs() {
        if (!self.prepareRunRoot(false)) { return 71; }
        string startedNs = DeckRemoteClock.realtimeNanos();
        if (!DeckRunEvidence.positiveDecimal(startedNs)) { return 77; }
        DeckRemoteSnapshot snapshot = DeckRemoteSnapshot.capture(
            self.request.protectedInputs, self.request.externalRoots, false);
        if (!snapshot.valid) { return 77; }
        JsonValue receipt = self.baseReceipt(startedNs);
        receipt.set("protected_inputs", snapshot.json());
        return DeckRemoteReceipt.write(PathTools.join(
            self.request.runRoot, "receipt.json"), receipt) ? 0 : 74;
    }

    public int batch(bool begin) {
        if (!self.prepareRunRoot(!begin)) { return 71; }
        string startedNs = DeckRemoteClock.realtimeNanos();
        if (!DeckRunEvidence.positiveDecimal(startedNs)) { return 77; }
        string sentinel = DeckRemoteSentinel.value(self.request);
        if (!DeckGameModeContract.sha256(sentinel)) { return 77; }
        string stored = PathTools.join(
            self.request.runRoot, "external-media.sentinel");
        if (begin) {
            if (FileSystem.exists(stored)
                    || !FileSystem.writeText(stored, sentinel + "\n")) {
                return 74;
            }
        } else if (!FileSystem.readText(stored).trim().equals(sentinel)) {
            return 79;
        }
        JsonValue receipt = self.baseReceipt(startedNs);
        JsonValue media = JsonValue.makeObject();
        media.set("sentinel_sha256", JsonValue.makeString(sentinel));
        media.set("external_tree_scans", JsonValue.makeInt(0));
        media.set("external_content_bytes_hashed", JsonValue.makeInt(0));
        media.set("unchanged", JsonValue.makeBool(!begin));
        receipt.set("media", media);
        return DeckRemoteReceipt.write(PathTools.join(self.request.runRoot,
            begin ? "batch-begin.json" : "batch-end.json"), receipt)
            ? 0 : 74;
    }

    public bool prerequisites() {
        if (DeckRemoteProcess.steam() < 2
                || !self.exactShortcut(self.shortcut())
                || access("/dev/uinput", W_OK) != 0) {
            return false;
        }
        for root in self.request.externalRoots {
            if (!FileSystem.isDir(root) || FileSystem.isSymlink(root)) {
                return false;
            }
        }
        DeckGeneratedSnapshot generated = DeckGeneratedSnapshot.capture(
            self.request.generatedInputs);
        ExecResult keepawake = ChildProcess.run("/usr/bin/systemctl",
            ["--user", "is-active", "--quiet", "semu-keepawake.service"],
            "", CommandEnvironment.empty(), CommandEnvironment.empty(), 10000);
        return generated.valid && keepawake.ok();
    }

    public int preflight() {
        if (!self.prepareRunRoot(false) || !self.prerequisites()) { return 77; }
        string startedNs = DeckRemoteClock.realtimeNanos();
        if (!DeckRunEvidence.positiveDecimal(startedNs)) { return 77; }
        int steamPid = DeckRemoteProcess.steam();
        DeckSteamShortcutResolution resolution = self.shortcut();
        DeckExpectedShortcut shortcut = DeckExpectedShortcut.fromResolution(
            resolution,
            DeckRemoteHash.file(self.request.shortcut.executable));
        DeckGeneratedSnapshot generated = DeckGeneratedSnapshot.capture(
            self.request.generatedInputs);
        ExecResult keepawake = ChildProcess.run("/usr/bin/systemctl",
            ["--user", "is-active", "--quiet", "semu-keepawake.service"],
            "", CommandEnvironment.empty(), CommandEnvironment.empty(), 10000);
        if (steamPid < 2 || !self.exactShortcut(resolution)
                || !shortcut.valid() || !generated.valid || !keepawake.ok()
                || access("/dev/uinput", W_OK) != 0) {
            return 77;
        }
        JsonValue receipt = self.baseReceipt(startedNs);
        receipt.set("shortcut", shortcut.json());
        JsonValue checks = JsonValue.makeObject();
        checks.set("game_mode", JsonValue.makeBool(true));
        checks.set("steam_pid", JsonValue.makeInt(steamPid));
        checks.set("keepawake", JsonValue.makeBool(true));
        checks.set("keepawake_service",
            JsonValue.makeString("semu-keepawake.service"));
        checks.set("uinput", JsonValue.makeBool(true));
        checks.set("uinput_device", JsonValue.makeString("/dev/uinput"));
        checks.set("generated_inputs_hashed",
            JsonValue.makeBool(true));
        receipt.set("checks", checks);
        JsonValue generatedInputs = JsonValue.makeObject();
        generatedInputs.set("files", generated.json());
        receipt.set("generated_inputs", generatedInputs);
        return DeckRemoteReceipt.write(PathTools.join(
            self.request.runRoot, "receipt.json"), receipt) ? 0 : 74;
    }

    public int frontend() {
        if (!self.prepareRunRoot(false) || !self.prerequisites()) { return 77; }
        string startedNs = DeckRemoteClock.realtimeNanos();
        if (!DeckRunEvidence.positiveDecimal(startedNs)) { return 77; }
        DeckRemoteSession session = DeckRemoteGameMode.launch(self.request);
        if (!session.valid(self.request)) { return 79; }
        string screenshot = PathTools.join(
            self.request.runRoot, "frontend-game-mode.png");
        string screenshotSha256 = DeckRemoteGameMode.screenshot(
            session, screenshot);
        if (screenshotSha256.isEmpty()) { return 79; }
        string observedNs = DeckRemoteClock.realtimeNanos();
        DeckRemoteArtifacts artifacts = DeckRemoteArtifacts();
        if (!artifacts.add(self.request.runRoot, "frontend-game-mode.png",
                self.request.runId, startedNs)) {
            return 86;
        }
        JsonValue receipt = self.baseReceipt(startedNs);
        receipt.set("evidence", DeckRemoteReceipt.evidence(
            "steam-shortcut-launch", false));
        receipt.set("shortcut", self.request.shortcut.json());
        JsonValue launch = JsonValue.makeObject();
        launch.set("steam_ancestry", JsonValue.makeBool(true));
        launch.set("same_game_mode_session", JsonValue.makeBool(true));
        launch.set("gamescope_screenshot", JsonValue.makeBool(true));
        launch.set("screenshot_sha256",
            JsonValue.makeString(screenshotSha256));
        receipt.set("launch", launch);
        JsonValue phases = JsonValue.makeObject();
        JsonValue launchPhase = DeckRunEvidence.phase(
            self.request.runId, observedNs);
        launchPhase.set("screenshot_sha256",
            JsonValue.makeString(screenshotSha256));
        launchPhase.set("steam_pid", JsonValue.makeInt(session.steam));
        launchPhase.set("es_de_pid", JsonValue.makeInt(session.esDe));
        launchPhase.set("es_de_start",
            JsonValue.makeString(session.esDeStart));
        launchPhase.set("es_de_session",
            JsonValue.makeString(session.esDeSession));
        phases.set("launch", launchPhase);
        receipt.set("phases", phases);
        receipt.set("artifacts", artifacts.files);
        JsonValue media = JsonValue.makeObject();
        media.set("external_tree_scans", JsonValue.makeInt(0));
        media.set("external_content_bytes_hashed", JsonValue.makeInt(0));
        receipt.set("media", media);
        return DeckRemoteReceipt.write(PathTools.join(
            self.request.runRoot, "receipt.json"), receipt) ? 0 : 74;
    }

    public string inputStateRoot() {
        return PathTools.join(self.request.projectRoot,
            "build/runtime/state/" + self.request.emulatorId + "/rendering");
    }

    public bool resetEvidence(string stateRoot) {
        string owned = PathTools.join(
            self.request.projectRoot, "build/runtime/state");
        if (!FileSystem.isDir(owned) || FileSystem.isSymlink(owned)
                || !FileSystem.isDir(stateRoot)
                || FileSystem.isSymlink(stateRoot)) {
            return false;
        }
        string canonicalOwned = UnixFileSystem.realPath(owned);
        string canonicalState = UnixFileSystem.realPath(stateRoot);
        if (canonicalOwned.isEmpty() || canonicalState.isEmpty()
                || !DeckGameModeContract.contains(
                    canonicalOwned, canonicalState)) {
            return false;
        }
        for name in ["semu-render-evidence.log", "semu-render-final.ppm",
                     "semu-input-evidence.log",
                     "semu-emulator-evidence.log",
                     "semu-wii-controller-evidence.log"] {
            if (!DeckRemoteFile.removeRegular(
                    PathTools.join(stateRoot, name))) {
                return false;
            }
        }
        return true;
    }

    public bool copyEvidence(string stateRoot, string inputLog,
                             string emulatorLog, string wiiLog,
                             string startedNs) {
        string destination = PathTools.join(self.request.runRoot, "runtime");
        if (FileSystem.mkdirp(destination) != 0) { return false; }
        string rendererSource = PathTools.join(
            stateRoot, "semu-render-evidence.log");
        string frameSource = PathTools.join(
            stateRoot, "semu-render-final.ppm");
        if (!DeckRemoteFile.fresh(rendererSource, startedNs)
                || !DeckRemoteFile.fresh(frameSource, startedNs)) {
            return false;
        }
        string renderer = DeckRemoteEvidence.bind(
            FileSystem.readText(rendererSource), self.request);
        string input = DeckRemoteEvidence.bind(inputLog, self.request);
        string emulator = DeckRemoteEvidence.bind(emulatorLog, self.request);
        string wii = self.request.wiiExpected
            ? DeckRemoteEvidence.bind(wiiLog, self.request) : "";
        return !renderer.isEmpty() && !input.isEmpty() && !emulator.isEmpty()
            && DeckRemoteFile.copy(frameSource, PathTools.join(
                destination, "semu-render-final.ppm"))
            && FileSystem.writeText(PathTools.join(
                destination, "semu-render-evidence.log"), renderer)
            && FileSystem.writeText(PathTools.join(
                destination, "semu-input-evidence.log"), input)
            && FileSystem.writeText(PathTools.join(
                destination, "semu-emulator-evidence.log"), emulator)
            && (!self.request.wiiExpected || (!wii.isEmpty()
                && FileSystem.writeText(PathTools.join(destination,
                    "semu-wii-controller-evidence.log"), wii)));
    }

    public int scenario() {
        if (!self.prepareRunRoot(false) || !self.prerequisites()) { return 77; }
        string startedNs = DeckRemoteClock.realtimeNanos();
        if (!DeckRunEvidence.positiveDecimal(startedNs)) { return 77; }
        DeckRemoteSnapshot protectedBefore = DeckRemoteSnapshot.capture(
            self.request.protectedInputs, self.request.externalRoots, true);
        DeckGeneratedSnapshot generatedBefore = DeckGeneratedSnapshot.capture(
            self.request.generatedInputs);
        if (!protectedBefore.valid || !generatedBefore.valid) { return 77; }

        DeckRemoteSession session = DeckRemoteGameMode.launch(self.request);
        if (!session.valid(self.request)
                || DeckRemoteGame.find(
                    self.request, session.esDe, []) != 0) {
            return 79;
        }

        string stateRoot = self.inputStateRoot();
        if (!self.resetEvidence(stateRoot)) { return 78; }
        string inputLogPath = PathTools.join(
            stateRoot, "semu-input-evidence.log");
        string emulatorLogPath = PathTools.join(
            stateRoot, "semu-emulator-evidence.log");
        string wiiLogPath = PathTools.join(
            stateRoot, "semu-wii-controller-evidence.log");
        long long inputOpening = 0LL;
        long long emulatorOpening = 0LL;
        long long wiiOpening = 0LL;

        Vector<int> existing = DeckRemoteProcess.all();
        string frontendScreenshot = DeckRemoteGameMode.screenshot(session,
            PathTools.join(self.request.runRoot, "frontend-game-mode.png"));
        if (frontendScreenshot.isEmpty()) { return 79; }
        string launchObservedNs = DeckRemoteClock.realtimeNanos();

        bool automated = self.request.operation.equals("automated-game-mode");
        if (automated && !DeckRemoteInput.run(self.request,
                self.request.navigationPlan,
                self.request.navigationPlanSha256,
                PathTools.join(self.request.runRoot, "navigation-uinput.log"))) {
            return 80;
        }
        if (!automated) {
            print("Acceptance run " + self.request.runId
                + ": select the declared ROM in live Semu ES-DE using only physical Steam Deck controls.");
        }
        int game = DeckRemoteGame.waitFor(self.request, session.esDe, existing);
        if (game < 2 || !DeckRemoteMounts.externalReadOnly(
                game, self.request.externalRoots)) {
            return 81;
        }
        string gameScreenshot = DeckRemoteGameMode.screenshot(session,
            PathTools.join(self.request.runRoot, "game-running.png"));
        if (gameScreenshot.isEmpty()) { return 79; }
        int gameplayProcess = game;
        string gameplayProcessStart = DeckRemoteProcess.startTime(game);
        string gameplayObservedNs = DeckRemoteClock.realtimeNanos();
        Vector<string> operatorScreenshots = [];
        string observedEmulatorLog = "";

        if (automated) {
            DeckAutomatedObservation observation =
                DeckAutomatedObservation.run(
                    self.request, session, game, stateRoot,
                    PathTools.join(self.request.runRoot, "game-running.png"));
            if (!observation.valid
                    || !DeckRemoteGame.waitForExit(game, 30000)) {
                return 82;
            }
            observedEmulatorLog = observation.emulatorLog;
            if (!DeckRemoteInput.relaunch(self.request,
                    self.request.runRoot, 1)) { return 80; }
            game = DeckRemoteGame.waitFor(self.request, session.esDe, []);
            if (game < 2 || !DeckRemoteInput.run(self.request,
                    self.request.startSelectPlan,
                    self.request.startSelectPlanSha256,
                    PathTools.join(self.request.runRoot,
                        "start-select-uinput.log"))
                    || !DeckRemoteGame.waitForExit(game, 30000)) {
                return 82;
            }
            if (!DeckRemoteInput.relaunch(self.request,
                    self.request.runRoot, 2)) { return 80; }
            game = DeckRemoteGame.waitFor(self.request, session.esDe, []);
            if (game < 2 || !DeckRemoteInput.run(self.request,
                    self.request.reverseStartSelectPlan,
                    self.request.reverseStartSelectPlanSha256,
                    PathTools.join(self.request.runRoot,
                        "start-select-reverse-uinput.log"))
                    || !DeckRemoteGame.waitForExit(game, 30000)) {
                return 82;
            }
        } else if (self.request.operation.equals("operator-start-select")) {
            print("Acceptance run " + self.request.runId
                + ": use native gameplay controls, then press Start+Select in the first order.");
            if (!DeckRemoteGame.waitForExit(game, 300000)) { return 82; }
            print("Relaunch the same declared ROM in this ES-DE session, then press Select+Start in the opposite order.");
            game = DeckRemoteGame.waitFor(self.request, session.esDe, []);
            if (game < 2 || !DeckRemoteGame.waitForExit(game, 300000)) {
                return 82;
            }
        } else {
            print("Acceptance run " + self.request.runId
                + ": visibly exercise native gameplay, save/load, every physical quick/menu radial slot, Wii modes when applicable, then quit from the physical radial.");
            int captures = 0;
            for (int frame = 0; frame < 1200
                    && DeckRemoteProcess.alive(game); frame++) {
                string path = PathTools.join(self.request.runRoot,
                    "operator-radial-" + f"{frame}" + ".png");
                if (!DeckRemoteGameMode.screenshot(session, path).isEmpty()) {
                    captures++;
                    operatorScreenshots.push(PathTools.basename(path));
                }
                DeckRemoteClock.sleep(250);
            }
            if (captures < 1 || DeckRemoteProcess.alive(game)) { return 82; }
        }

        string quitObservedNs = DeckRemoteClock.realtimeNanos();
        if (!session.valid(self.request)
                || DeckRemoteGame.find(
                    self.request, session.esDe, []) != 0) {
            return 83;
        }
        string returnScreenshot = DeckRemoteGameMode.screenshot(session,
            PathTools.join(self.request.runRoot, "esde-return.png"));
        string returnObservedNs = DeckRemoteClock.realtimeNanos();
        DeckRemoteSnapshot protectedAfter = DeckRemoteSnapshot.capture(
            self.request.protectedInputs, self.request.externalRoots, true);
        DeckGeneratedSnapshot generatedAfter = DeckGeneratedSnapshot.capture(
            self.request.generatedInputs);
        if (returnScreenshot.isEmpty()
                || gameplayProcessStart.isEmpty()
                || !DeckRunEvidence.notBefore(launchObservedNs, startedNs)
                || !DeckRunEvidence.notBefore(
                    gameplayObservedNs, launchObservedNs)
                || !DeckRunEvidence.notBefore(
                    quitObservedNs, gameplayObservedNs)
                || !DeckRunEvidence.notBefore(
                    returnObservedNs, quitObservedNs)
                || !protectedBefore.equals(protectedAfter)
                || !generatedBefore.equals(generatedAfter)) {
            return 84;
        }

        if (!DeckRemoteFile.fresh(inputLogPath, startedNs)
                || (!automated
                    && !self.request.operation.equals("operator-start-select")
                    && !DeckRemoteFile.fresh(emulatorLogPath, startedNs))
                || (self.request.wiiExpected
                    && !DeckRemoteFile.fresh(wiiLogPath, startedNs))) {
            return 85;
        }

        string inputLog = DeckRemoteFile.tail(inputLogPath, inputOpening);
        string emulatorLog = automated ? observedEmulatorLog
            : DeckRemoteFile.tail(emulatorLogPath, emulatorOpening);
        if (self.request.operation.equals("operator-start-select")) {
            emulatorLog = "schema=1 event=scenario-scope"
                + " system_id=" + self.request.systemId
                + " emulator_id=" + self.request.emulatorId
                + " gameplay_required=0 state_required=0"
                + " game_pid=" + f"{gameplayProcess}"
                + " game_start=" + gameplayProcessStart + "\n";
        }
        string wiiLog = DeckRemoteFile.tail(wiiLogPath, wiiOpening);
        string source = automated ? "virtual" : "hardware";
        bool requireRadial = !self.request.operation.equals(
            "operator-start-select");
        bool requireStartSelect = !self.request.operation.equals(
            "operator-radial");
        bool quick = !requireRadial || DeckRemoteEvidence.radial(
            inputLog, source, 1, self.request.quickRadialSlots);
        bool menu = !requireRadial || DeckRemoteEvidence.radial(
            inputLog, source, 2, self.request.menuRadialSlots);
        bool radialQuit = !requireRadial || DeckRemoteEvidence.immediate(
            inputLog, source, "action-chord", 1);
        bool startSelect = !requireStartSelect || DeckRemoteEvidence.immediate(
            inputLog, source, "select+start", 2);
        bool requireGameplay = !self.request.operation.equals(
            "operator-start-select");
        bool gameplay = !requireGameplay || DeckRemoteEvidence.gameplay(
            emulatorLog, self.request,
            automated ? "steam-virtual-gamepad" : "hardware");
        bool saves = !requireRadial || DeckRemoteEvidence.saveLoad(
            emulatorLog, self.request);
        bool modes = !requireRadial || DeckRemoteEvidence.wiiModes(
            wiiLog, self.request);
        if (!quick || !menu || !radialQuit || !startSelect
                || !gameplay || !saves || !modes) {
            return 85;
        }
        if (!self.copyEvidence(stateRoot, inputLog, emulatorLog, wiiLog,
                startedNs)) { return 86; }

        DeckRemoteArtifacts artifacts = DeckRemoteArtifacts();
        for name in DeckGameModeReceiptPolicy.requiredArtifacts(self.request) {
            if (!artifacts.add(self.request.runRoot, name,
                    self.request.runId, startedNs)) {
                return 86;
            }
        }
        for name in operatorScreenshots {
            if (!artifacts.add(self.request.runRoot, name,
                    self.request.runId, startedNs)) {
                return 86;
            }
        }
        if (!artifacts.valid) { return 86; }

        JsonValue receipt = self.baseReceipt(startedNs);
        receipt.set("evidence", DeckRemoteReceipt.evidence(
            self.request.scenario, self.request.humanObserved));
        receipt.set("shortcut", self.request.shortcut.json());
        JsonValue launch = JsonValue.makeObject();
        launch.set("steam_ancestry", JsonValue.makeBool(true));
        launch.set("same_game_mode_session", JsonValue.makeBool(true));
        launch.set("same_es_de_session", JsonValue.makeBool(true));
        launch.set("through_es_de", JsonValue.makeBool(true));
        launch.set("packaged_process", JsonValue.makeBool(true));
        launch.set("process_return", JsonValue.makeBool(true));
        launch.set("gamescope_screenshot", JsonValue.makeBool(true));
        launch.set("frontend_screenshot_sha256",
            JsonValue.makeString(frontendScreenshot));
        launch.set("game_screenshot_sha256",
            JsonValue.makeString(gameScreenshot));
        launch.set("return_screenshot_sha256",
            JsonValue.makeString(returnScreenshot));
        receipt.set("launch", launch);
        receipt.set("artifacts", artifacts.files);

        JsonValue phases = JsonValue.makeObject();
        JsonValue launchPhase = DeckRunEvidence.phase(
            self.request.runId, launchObservedNs);
        launchPhase.set("screenshot_sha256",
            JsonValue.makeString(frontendScreenshot));
        launchPhase.set("steam_pid", JsonValue.makeInt(session.steam));
        launchPhase.set("es_de_pid", JsonValue.makeInt(session.esDe));
        launchPhase.set("es_de_start",
            JsonValue.makeString(session.esDeStart));
        launchPhase.set("es_de_session",
            JsonValue.makeString(session.esDeSession));
        phases.set("launch", launchPhase);

        JsonValue gameplayPhase = DeckRunEvidence.phase(
            self.request.runId, gameplayObservedNs);
        gameplayPhase.set("game_pid", JsonValue.makeInt(gameplayProcess));
        gameplayPhase.set("game_start",
            JsonValue.makeString(gameplayProcessStart));
        gameplayPhase.set("screenshot_sha256",
            JsonValue.makeString(gameScreenshot));
        gameplayPhase.set("renderer_log_sha256", JsonValue.makeString(
            DeckRunEvidence.artifactDigest(receipt,
                "runtime/semu-render-evidence.log")));
        gameplayPhase.set("renderer_frame_sha256", JsonValue.makeString(
            DeckRunEvidence.artifactDigest(receipt,
                "runtime/semu-render-final.ppm")));
        gameplayPhase.set("emulator_log_sha256", JsonValue.makeString(
            DeckRunEvidence.artifactDigest(receipt,
                "runtime/semu-emulator-evidence.log")));
        gameplayPhase.set("executable_sha256",
            JsonValue.makeString(self.request.expectedExecutableSha256));
        phases.set("gameplay", gameplayPhase);

        bool stateRequired = self.request.savestateExpected && requireRadial;
        JsonValue statePhase = JsonValue.makeObject();
        statePhase.set("run_id", JsonValue.makeString(self.request.runId));
        statePhase.set("verified_ns", JsonValue.makeString(
            DeckRemoteClock.realtimeNanos()));
        statePhase.set("required", JsonValue.makeBool(stateRequired));
        statePhase.set("observed", JsonValue.makeBool(stateRequired));
        statePhase.set("evidence_sha256", JsonValue.makeString(
            DeckRunEvidence.artifactDigest(receipt,
                "runtime/semu-emulator-evidence.log")));
        phases.set("state", statePhase);

        JsonValue quitPhase = DeckRunEvidence.phase(
            self.request.runId, quitObservedNs);
        quitPhase.set("radial", JsonValue.makeBool(requireRadial));
        quitPhase.set("start_select",
            JsonValue.makeBool(requireStartSelect));
        quitPhase.set("process_exited", JsonValue.makeBool(true));
        quitPhase.set("evidence_sha256", JsonValue.makeString(
            DeckRunEvidence.artifactDigest(receipt,
                "runtime/semu-input-evidence.log")));
        phases.set("quit", quitPhase);

        JsonValue returnPhase = DeckRunEvidence.phase(
            self.request.runId, returnObservedNs);
        returnPhase.set("screenshot_sha256",
            JsonValue.makeString(returnScreenshot));
        returnPhase.set("same_es_de_session", JsonValue.makeBool(true));
        returnPhase.set("game_process_absent", JsonValue.makeBool(true));
        phases.set("es_de_return", returnPhase);
        receipt.set("phases", phases);

        JsonValue observation = JsonValue.makeObject();
        observation.set("run_challenge",
            JsonValue.makeString(self.request.runId));
        observation.set("proof_mode", JsonValue.makeString(
            DeckEvidenceClass.proofMode(self.request.scenario)));
        observation.set("virtual_input_only", JsonValue.makeBool(automated));
        observation.set("physical_start_select_observed",
            JsonValue.makeBool(self.request.operation.equals(
                "operator-start-select") && self.request.humanObserved));
        observation.set("physical_radial_observed", JsonValue.makeBool(
            self.request.operation.equals("operator-radial")
                && self.request.humanObserved));
        receipt.set("observation", observation);
        JsonValue media = JsonValue.makeObject();
        media.set("external_tree_scans", JsonValue.makeInt(0));
        media.set("external_content_bytes_hashed", JsonValue.makeInt(0));
        media.set("external_mounts_readonly", JsonValue.makeBool(true));
        media.set("protected_inputs_unchanged", JsonValue.makeBool(true));
        receipt.set("media", media);
        receipt.set("protected_inputs", protectedAfter.json());
        JsonValue generated = JsonValue.makeObject();
        generated.set("unchanged", JsonValue.makeBool(true));
        generated.set("files", generatedAfter.json());
        receipt.set("generated_inputs", generated);
        JsonValue input = JsonValue.makeObject();
        input.set("gameplay_injected", JsonValue.makeBool(automated));
        input.set("gameplay_consumed", JsonValue.makeBool(gameplay));
        input.set("quick_radial_consumed", JsonValue.makeBool(quick));
        input.set("menu_radial_consumed", JsonValue.makeBool(menu));
        input.set("quick_radial_slots",
            JsonValue.makeInt(requireRadial
                ? self.request.quickRadialSlots : 0));
        input.set("menu_radial_slots",
            JsonValue.makeInt(requireRadial
                ? self.request.menuRadialSlots : 0));
        input.set("wii_mode_slots",
            JsonValue.makeInt(requireRadial
                ? self.request.wiiModeSlots : 0));
        input.set("radial_quit_immediate", JsonValue.makeBool(radialQuit));
        input.set("start_select_orders",
            JsonValue.makeInt(requireStartSelect ? 2 : 0));
        input.set("physical_start_select_proven", JsonValue.makeBool(
            self.request.operation.equals("operator-start-select")
                && self.request.humanObserved));
        input.set("steam_radial_ui_proven", JsonValue.makeBool(
            !automated && self.request.operation.equals("operator-radial")
                && self.request.humanObserved));
        input.set("save_load_consumed", JsonValue.makeBool(saves));
        input.set("wii_modes_consumed", JsonValue.makeBool(modes));
        receipt.set("input", input);
        return DeckRemoteReceipt.write(PathTools.join(
            self.request.runRoot, "receipt.json"), receipt) ? 0 : 74;
    }

    public int run() {
        if (!self.safeRequest()) { return 64; }
        if (self.request.operation.equals("inspect")) { return self.inspect(); }
        if (self.request.operation.equals("inspect-inputs")) {
            return self.inspectInputs();
        }
        if (self.request.operation.equals("batch-begin")) {
            return self.batch(true);
        }
        if (self.request.operation.equals("batch-end")) {
            return self.batch(false);
        }
        if (self.request.operation.equals("preflight")) {
            return self.preflight();
        }
        if (self.request.operation.equals("frontend")) {
            return self.frontend();
        }
        return self.scenario();
    }
}

int main(int argc, char** argv) {
    CliArgs arguments = CliArgs(argc, argv);
    string request = arguments.valueAfter("--request", "");
    if (argc != 3 || !DeckGameModeContract.absolute(request)) {
        print("usage: semu-deck-acceptance --request /absolute/request.json");
        return 64;
    }
    return DeckRemoteRunner(request).run();
}
