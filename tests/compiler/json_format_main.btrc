// json_format_main.btrc - isolated strict JSON generation contract entrypoint.

import std.{cli, fs}
import ./json_format_contract_test.btrc

int main(int argc, char** argv) {
    CliArgs arguments = CliArgs(argc, argv);
    string project = arguments.valueAfter(
        "--project", FileSystem.currentDirectory());
    return JsonFormatContractTest.run(project) == 0 ? 0 : 1;
}
