// Isolated strict-import entrypoint for the melonDS touch consumer.

import std.{cli, fs}
import ./melonds_touch_contract_test.btrc

int main(int argc, char** argv) {
    CliArgs arguments = CliArgs(argc, argv);
    string project = arguments.valueAfter(
        "--project", FileSystem.currentDirectory());
    return MelonDsTouchContractTest.run(project) == 0 ? 0 : 1;
}
