// emulator_runtime_main.btrc - isolated strict-import emulator compiler runner.

import std.{cli, fs}
import ./emulator_runtime_contract_test.btrc

int main(int argc, char** argv) {
    CliArgs arguments = CliArgs(argc, argv);
    string project = arguments.valueAfter(
        "--project", FileSystem.currentDirectory());
    return EmulatorRuntimeContractTest.run(project) == 0 ? 0 : 1;
}
