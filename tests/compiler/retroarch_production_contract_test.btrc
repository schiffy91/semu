// Standalone strict-import contract for the RetroArch production slice.

import std.{fs, json, vector}
import ../../src/generators/steam_input.btrc

class RetroArchProductionContractTest {
    class int fail(string message) {
        print("  FAIL retroarch production: " + message);
        return 1;
    }

    class string file(string project, string relative) {
        return PathTools.join(project, relative);
    }

    class bool line(JsonValue lines, string expected) {
        if (!lines.isArray()) { return false; }
        for (int index = 0; index < lines.size(); index++) {
            if (lines.at(index).isString()
                    && lines.at(index).asString().equals(expected)) {
                return true;
            }
        }
        return false;
    }

    class bool action(JsonValue profile, string setting, string action) {
        JsonValue keymap = profile.get("hotkeys").get("keymap");
        if (!keymap.isArray()) { return false; }
        for (int index = 0; index < keymap.size(); index++) {
            JsonValue entry = keymap.at(index);
            if (entry.get("setting").isString()
                    && entry.get("action").isString()
                    && entry.get("setting").asString().equals(setting)
                    && entry.get("action").asString().equals(action)) {
                return true;
            }
        }
        return false;
    }

    class bool filesystem(JsonValue platform, string path, string mode) {
        JsonValue filesystems = platform.get("sandbox").get("filesystems");
        if (!filesystems.isArray()) { return false; }
        for (int index = 0; index < filesystems.size(); index++) {
            JsonValue entry = filesystems.at(index);
            if (entry.get("path").isString()
                    && entry.get("mode").isString()
                    && entry.get("path").asString().equals(path)
                    && entry.get("mode").asString().equals(mode)) {
                return true;
            }
        }
        return false;
    }

    class bool platformIncludesLinux(JsonValue binding) {
        JsonValue platforms = binding.get("platforms");
        if (!platforms.isArray()) { return true; }
        for (int index = 0; index < platforms.size(); index++) {
            if (platforms.at(index).isString()
                    && platforms.at(index).asString().equals("linux")) {
                return true;
            }
        }
        return false;
    }

    class Vector<string> selectedLinuxCores(string project) {
        Vector<string> cores = [];
        string root = RetroArchProductionContractTest.file(
            project, "config/systems");
        for name in Directory(root).entries() {
            string systemFile = PathTools.join(
                PathTools.join(root, name), "system.json");
            if (!FileSystem.isFile(systemFile)) { continue; }
            JsonValue system = JsonValue.readFile(systemFile);
            JsonValue bindings = system.get("emulators");
            if (!bindings.isArray()) { continue; }
            for (int index = 0; index < bindings.size(); index++) {
                JsonValue binding = bindings.at(index);
                if (!binding.get("emulator").isString()
                        || !binding.get("emulator").asString().equals("retroarch")
                        || !RetroArchProductionContractTest.platformIncludesLinux(binding)
                        || !binding.get("core").isString()) {
                    continue;
                }
                string core = binding.get("core").asString();
                if (!cores.contains(core)) { cores.push(core); }
            }
        }
        return cores;
    }

    class bool exactSet(Vector<string> actual, Vector<string> expected) {
        if (actual.size() != expected.size()) { return false; }
        for value in expected {
            if (!actual.contains(value)) { return false; }
        }
        return true;
    }

    class bool autoconfigProfile(JsonValue profile, JsonValue mapping) {
        JsonValue lines = profile.get("lines");
        if (!profile.get("device_name").isString()
                || !RetroArchProductionContractTest.line(
                    lines, "input_device_display_name = \"Steam Virtual Gamepad\"")
                || !RetroArchProductionContractTest.line(
                    lines, "input_enable_hotkey_btn = \"nul\"")) {
            return false;
        }
        for key in mapping.keys() {
            if (!mapping.get(key).isString()
                    || !RetroArchProductionContractTest.line(lines,
                        key + " = \"" + mapping.get(key).asString() + "\"")) {
                return false;
            }
        }
        return true;
    }

    class int occurrences(string text, string needle) {
        int total = 0;
        string remaining = text;
        while (remaining.contains(needle)) {
            int index = remaining.indexOf(needle);
            total++;
            remaining = remaining.substring(
                index + needle.len(), remaining.len());
        }
        return total;
    }

    class bool patchSection(string section, string completedGameDraw) {
        int draw = section.indexOf(completedGameDraw);
        int build = section.indexOf(
            "video_driver_semu_build_frame_gl(&semu_frame");
        int game = section.indexOf("semu_render_game_gl(&semu_frame);");
        int overlay = section.indexOf("overlay_behind_menu");
        int postUi = section.indexOf("semu_render_post_ui_gl(&semu_frame);");
        int publish = section.indexOf(
            "video_driver_semu_publish_pointer(");
        int present = section.indexOf("ctx_driver->swap_buffers");
        bool valid = draw >= 0 && build > draw && game > build && overlay > game
            && postUi > overlay && publish > postUi && present > publish
            && RetroArchProductionContractTest.occurrences(section,
                "video_driver_semu_build_frame_gl(&semu_frame") == 1
            && RetroArchProductionContractTest.occurrences(
                section, "semu_render_game_gl(&semu_frame);") == 1
            && RetroArchProductionContractTest.occurrences(
                section, "semu_render_post_ui_gl(&semu_frame);") == 1
            && RetroArchProductionContractTest.occurrences(
                section, "video_driver_semu_publish_pointer(") == 1
            && !section.contains("semu_frame.surface");
        if (!valid) {
            print(f"  tap indexes draw={draw} build={build} game={game} overlay={overlay} post={postUi} publish={publish} present={present}");
        }
        return valid;
    }

    class bool nativeGamepadVdf(string project) {
        SteamInputResult parsed = SteamInputParser.parse(
            RetroArchProductionContractTest.file(
                project, "config/input/steam-deck/steam_input.json"));
        if (!parsed.ok()) { return false; }
        string vdf = "";
        for template in parsed.definition.templates {
            if (template.isDefault) {
                vdf = SteamInputVdf.render(parsed.definition, template);
            }
        }
        Vector<string> nativeBindings = [
            "xinput_button A", "xinput_button B", "xinput_button X",
            "xinput_button Y", "xinput_button DPAD_UP",
            "xinput_button DPAD_DOWN", "xinput_button DPAD_LEFT",
            "xinput_button DPAD_RIGHT", "xinput_button SHOULDER_LEFT",
            "xinput_button SHOULDER_RIGHT", "xinput_button TRIGGER_LEFT",
            "xinput_button TRIGGER_RIGHT", "xinput_button SELECT",
            "xinput_button START"
        ];
        for binding in nativeBindings {
            if (!vdf.contains(binding)) { return false; }
        }
        return vdf.contains("\"preset\" { \"id\" \"0\" \"name\" \"Default\"")
            && vdf.contains("\"0\" \"button_diamond active\"")
            && vdf.contains("\"1\" \"dpad active\"")
            && vdf.contains("\"2\" \"joystick active\"")
            && vdf.contains("\"3\" \"right_joystick active\"")
            && vdf.contains("\"4\" \"left_trigger active\"")
            && vdf.contains("\"5\" \"right_trigger active\"")
            && vdf.contains("\"7\" \"switch active\"")
            && vdf.contains("\"Long_Press\"")
            && vdf.contains("controller_action CHANGE_PRESET 1")
            && vdf.contains("controller_action CHANGE_PRESET 2");
    }

    class bool inputSupervisorEvidence(string supervisor, JsonValue quit) {
        JsonValue buttons = quit.get("buttons");
        if (!buttons.isArray() || buttons.size() != 2
                || !buttons.at(0).isString() || !buttons.at(1).isString()
                || buttons.at(0).asString().equals(buttons.at(1).asString())
                || !(buttons.at(0).asString().equals("select")
                    || buttons.at(1).asString().equals("select"))
                || !(buttons.at(0).asString().equals("start")
                    || buttons.at(1).asString().equals("start"))
                || !quit.get("window_ms").isInt()
                || quit.get("window_ms").asInt() != 250) {
            return false;
        }
        int edgesStart = supervisor.indexOf("class SemuInputEdges");
        int framesStart = supervisor.indexOf("class SemuInputFrames");
        int devicesStart = supervisor.indexOf(
            "class SemuLinuxInputDevices");
        int terminationStart = supervisor.indexOf(
            "class SemuSupervisedProcess");
        int evidenceStart = supervisor.indexOf(
            "class SemuInputTerminationEvidence");
        int supervisorStart = supervisor.indexOf("class SemuInputSupervisor");
        int selfTestStart = supervisor.indexOf(
            "class bool pairingSelfTest");
        int commandStart = supervisor.indexOf("class int commandIndex");
        if (edgesStart < 0 || framesStart <= edgesStart
                || devicesStart <= framesStart
                || terminationStart < 0 || evidenceStart <= terminationStart
                || supervisorStart <= evidenceStart || selfTestStart < 0
                || commandStart <= selfTestStart) {
            return false;
        }
        string edges = supervisor.substring(
            edgesStart, framesStart - edgesStart);
        string frames = supervisor.substring(
            framesStart, devicesStart - framesStart);
        string devices = supervisor.substring(
            devicesStart, terminationStart - devicesStart);
        string termination = supervisor.substring(
            terminationStart, evidenceStart - terminationStart);
        string evidence = supervisor.substring(
            evidenceStart, supervisorStart - evidenceStart);
        string selfTest = supervisor.substring(
            selfTestStart, commandStart - selfTestStart);
        int decisionStart = supervisor.indexOf("class bool handleDecision");
        int pollStart = supervisor.indexOf("class bool poll(");
        if (decisionStart < 0 || pollStart <= decisionStart) { return false; }
        string decision = supervisor.substring(
            decisionStart, pollStart - decisionStart);
        string runtime = supervisor.substring(
            commandStart, supervisor.len() - commandStart);
        Vector<string> evidenceFields = [
            "event_id=", "event_sequence=", "configured_pair=",
            "order=", "first_edge_id=", "first_button=", "first_code=",
            "first_at_ms=", "first_edge_sequence=", "second_edge_id=",
            "second_button=", "second_code=", "second_at_ms=",
            "second_edge_sequence=", "delta_ms=", "window_ms=",
            "device=", "device_id=", "path=", "source=", "physical=",
            "pair_generation=", "pair_mode=",
            "pair_gamepad_candidates=1", "pair_command_candidates=1",
            "origin_authenticated=0", "gamepad_path=",
            "gamepad_name=", "gamepad_physical=", "gamepad_uniq=",
            "command_path=", "command_name=", "command_physical=",
            "command_uniq=",
            "supervisor=", "session_started_ms=", "child=",
            "process_group=", "signal_sent=", "requested_at_ms=",
            "completed_at_ms=", "elapsed_ms=", "bound_ms=",
            "child_reaped=", "reaped_processes=", "group_empty=",
            "whole_group_reaped="
        ];
        for field in evidenceFields {
            if (!evidence.contains(field)) {
                print("  missing input evidence field: " + field);
                return false;
            }
        }
        bool edgeContract = !supervisor.contains("select+start")
            && edges.contains(
                "configuredFirst->sequence < configuredSecond->sequence")
            && edges.contains("second->at - first->at")
            && edges.contains("delta > (long long)chordWindow")
            && edges.contains("if (value == 2) { return false; }")
            && edges.contains("if (wasDown) { return false; }")
            && edges.contains("clearEvidence(");
        bool evidenceContract = evidence.contains(
                "char* configuredFirst = SemuInputQuitChord.buttonName(")
            && evidence.contains("state->quit_first_code);")
            && evidence.contains(
                "char* first = SemuInputQuitChord.buttonName(")
            && evidence.contains("state->quit_chord.first.code);")
            && evidence.contains(
                "chord->window_ms == state->chord_window_ms")
            && evidence.contains(
                "chord->delta_ms <= (long long)state->chord_window_ms")
            && evidence.contains(
                "result->requested_at != state->quit_requested_at")
            && evidence.contains(
                "state->quit_requested_at\n                        != state->quit_chord.second.at");
        evidenceContract = evidenceContract
            && evidence.contains(
                "state->quit_chord.sequence != 0ULL && !chord")
            && evidence.contains(
                "!SemuInputTerminationEvidence.validPair(state)");
        bool droppedStreamContract = frames.contains(
                "device->discard_until_syn_report = true")
            && frames.contains("SYN_DROPPED")
            && frames.contains("SYN_REPORT")
            && frames.contains("EVIOCGKEY(sizeof(keyBits))")
            && frames.contains("SemuInputFrames.clearHeld(device)")
            && frames.contains("SemuInputFrames.restoreHeld(");
        bool singletonPairContract = devices.contains(
                "gamepadCandidates == 1 && commandCandidates == 1")
            && devices.contains("ambiguous-policy-match")
            && devices.contains("unique-policy-pair")
            && devices.contains("stable-uniq")
            && devices.contains("stable-controller-root")
            && devices.contains("cryptographic_identity=0")
            && devices.contains("device->supports_extensions")
            && devices.contains("SemuInputFrames.prepareAuthorization(")
            && devices.contains("if (!state->devices[index].authorized)")
            && !devices.contains("strcmp(device->name");
        bool terminationContract = termination.contains(
                "PR_SET_CHILD_SUBREAPER")
            && termination.contains("waitpid(-processGroup")
            && termination.contains("kill(-child, SIGKILL)")
            && termination.contains(
                "result->elapsed_ms <= (long long)SEMU_QUIT_BOUND_MS")
            && termination.contains("result->group_empty")
            && termination.contains("result->whole_group_reaped");
        bool selfTestContract = selfTest.contains("quitOrderSelfTest(")
            && selfTest.contains(
                "quitFirstCode, quitSecondCode, 2000LL, &selectThenStart")
            && selfTest.contains(
                "quitSecondCode, quitFirstCode, 3000LL, &startThenSelect")
            && selfTest.contains("staleRepeatReleaseSelfTest(")
            && selfTest.contains("droppedStreamSelfTest(")
            && selfTest.contains("sequenceAfterDrop")
            && selfTest.contains("duplicateGamepadRejected")
            && selfTest.contains("duplicateCommandRejected")
            && selfTest.contains("ambiguityCleared")
            && selfTest.contains("spoofed-gamepad")
            && selfTest.contains("spoofed-command")
            && selfTest.contains("stableIdentityPreferred")
            && selfTest.contains(
                "SEMU_INPUT_GAMEPAD_VENDOR_ENV, \"28de\"")
            && selfTest.contains(
                "SEMU_INPUT_GAMEPAD_PRODUCT_ENV, \"11ff\"")
            && selfTest.contains(
                "SEMU_INPUT_COMMAND_PRODUCT_ENV, \"1205\"")
            && selfTest.contains("Microsoft X-Box 360 pad 0")
            && selfTest.contains("Valve Software Steam Controller")
            && selfTest.contains("event.value = 2;")
            && selfTest.contains("event.value = 0;")
            && selfTest.contains("first.sequence != second.sequence")
            && selfTest.contains("firstChild != secondChild")
            && selfTest.contains("firstResult.reaped_processes >= 2")
            && selfTest.contains(
                "firstResult.elapsed_ms <= (long long)SEMU_QUIT_BOUND_MS")
            && selfTest.contains("strcmp(firstLine, secondLine) != 0");
        selfTestContract = selfTestContract
            && selfTest.contains("mismatchedRequestRejected")
            && selfTest.contains("duplicateIdentityRejected")
            && selfTest.contains("mismatchedWindowRejected");
        bool noGameplaySynthesis = !supervisor.contains("event=gameplay-input")
            && !supervisor.contains("consumed=1");
        int quitCapture = decision.indexOf("if (decision->quit != 0)");
        int journalWrite = decision.indexOf(
            "bool persisted = SemuInputStateFiles.action");
        int terminateCall = runtime.indexOf(
            "bool reaped = SemuSupervisedProcess.terminate");
        int processEvidence = runtime.indexOf(
            "SemuInputStateFiles.evidence(\"process-group-terminate\"");
        int actionEvidence = runtime.indexOf(
            "bool actionFormatted = SemuInputTerminationEvidence.action");
        bool latencyContract = quitCapture >= 0 && journalWrite > quitCapture
            && terminateCall >= 0 && processEvidence > terminateCall
            && actionEvidence > processEvidence;
        if (!edgeContract) { print("  input edge evidence contract failed"); }
        if (!evidenceContract) {
            print("  input termination evidence schema contract failed");
        }
        if (!terminationContract) {
            print("  input whole-group termination contract failed");
        }
        if (!selfTestContract) {
            print("  input supervisor adversarial self-test contract failed");
        }
        if (!droppedStreamContract) {
            print("  SYN_DROPPED quarantine/resynchronization contract failed");
        }
        if (!singletonPairContract) {
            print("  evdev singleton-pair admission contract failed");
        }
        if (!noGameplaySynthesis) {
            print("  input supervisor synthesized gameplay evidence");
        }
        if (!latencyContract) {
            print("  quit evidence performs I/O before process termination");
        }
        return edgeContract && evidenceContract && terminationContract
            && droppedStreamContract && singletonPairContract
            && selfTestContract && noGameplaySynthesis && latencyContract;
    }

    class int run(string project) {
        string directory = "config/emulators/retroarch";
        JsonValue emulator = JsonValue.readFile(
            RetroArchProductionContractTest.file(
                project, directory + "/emulator.json"));
        JsonValue package = JsonValue.readFile(
            RetroArchProductionContractTest.file(
                project, directory + "/package.json"));
        JsonValue cores = JsonValue.readFile(
            RetroArchProductionContractTest.file(
                project, directory + "/cores.json"));
        JsonValue profile = JsonValue.readFile(
            RetroArchProductionContractTest.file(
                project, directory + "/profile.json"));
        JsonValue rendering = JsonValue.readFile(
            RetroArchProductionContractTest.file(
                project, directory + "/rendering.json"));
        JsonValue n64 = JsonValue.readFile(
            RetroArchProductionContractTest.file(
                project, "config/systems/n64/system.json"));
        JsonValue nds = JsonValue.readFile(
            RetroArchProductionContractTest.file(
                project, "config/systems/nds/system.json"));
        JsonValue autoconfig = JsonValue.readFile(
            RetroArchProductionContractTest.file(project,
                "config/input/steam-deck/retroarch_autoconfig.json"));
        string patch = FileSystem.readText(
            RetroArchProductionContractTest.file(
                project, directory + "/retroarch.patch"));
        string surfaceHook = FileSystem.readText(
            RetroArchProductionContractTest.file(
                project,
                "src/generators/rendering/retroarch/surface_contract.btrc"));
        string runtimeHook = FileSystem.readText(
            RetroArchProductionContractTest.file(
                project,
                "src/generators/rendering/retroarch/runtime_bridge.btrc"));
        string commandPatch = FileSystem.readText(
            RetroArchProductionContractTest.file(
                project, directory + "/retroarch_commands.patch"));
        string packageNix = FileSystem.readText(
            RetroArchProductionContractTest.file(
                project, directory + "/package.nix"));
        string emulatorNix = FileSystem.readText(
            RetroArchProductionContractTest.file(
                project, "packaging/nix/emulators.nix"));
        string deckPackageNix = FileSystem.readText(
            RetroArchProductionContractTest.file(
                project, "packaging/nix/flake/steam-deck-package.nix"));
        JsonValue deckInput = JsonValue.readFile(
            RetroArchProductionContractTest.file(
                project, "config/input/steam-deck/steam_input.json"));
        string supervisor = FileSystem.readText(
            RetroArchProductionContractTest.file(project,
                "src/generators/input/linux_supervisor.btrc"));
        int failures = 0;

        JsonValue linux = emulator.get("platforms").get("linux");
        JsonValue coreDirectories = linux.get("core_loader").get("directories");
        JsonValue fallbacks = package.get("fallbacks");
        JsonValue auxiliaryPatches = package.get("auxiliary_patches");
        JsonValue networkCommands = auxiliaryPatches.get("network_commands");
        JsonValue statusNullSafety = auxiliaryPatches.get("status_null_safety");
        JsonValue coreRuntime = package.get("core_runtime");
        JsonValue coreHost = package.get("core_host");
        JsonValue runtimeExtras = package.get("runtime_extras");
        if (!package.get("build_kind").isString()
                || !package.get("build_kind").asString().equals("source")
                || !package.get("source").get("revision").isString()
                || package.get("source").get("revision").asString().len() != 40
                || !package.get("source").get("sha256").isString()
                || !package.get("source").get("sha256").asString()
                    .startsWith("sha256-")
                || !linux.get("executable").isString()
                || !linux.get("executable").asString().equals(
                    "${asset_root}/bin/retroarch-semu")
                || !fallbacks.get("linux_host_executable").isBool()
                || fallbacks.get("linux_host_executable").asBool()
                || fallbacks.get("linux_flatpak").asBool()
                || fallbacks.get("linux_prebuilt_binary").asBool()
                || fallbacks.get("macos_host_executable").asBool()
                || fallbacks.get("macos_prebuilt_binary").asBool()
                || package.has("macos_prebuilt")
                || !networkCommands.get("kind").asString().equals(
                    "local_exact")
                || !networkCommands.get("file").asString().equals(
                    "retroarch_commands.patch")
                || !networkCommands.get("sha256").asString().equals(
                    "sha256-T6Q12aEYcrYuz2tbRGU8r5kDjYmmpZYM5KhYoqTSp1g=")
                || !statusNullSafety.get("kind").asString().equals(
                    "local_exact")
                || !statusNullSafety.get("file").asString().equals(
                    "retroarch_get_status_null_safety.patch")
                || !statusNullSafety.get("sha256").asString().equals(
                    "sha256-VFwauov45Fd/HGiJfdFdp2XyWiE4FN4xQPerrMOZ31A=")
                || !package.get("outputs").get("build_contract").asString()
                    .equals("share/semu/retroarch-build-contract.json")
                || !coreRuntime.get("exact_selection").asBool()
                || !coreRuntime.get("build_contract").isString()
                || !coreRuntime.get("build_contract").asString().equals(
                    "share/semu/core-host-build-contract.json")
                || coreRuntime.get("environment_search").asBool()
                || coreRuntime.get("host_search").asBool()
                || !coreHost.get("enabled").asBool()
                || !coreHost.get("selector_field").asString().equals("core")
                || !coreHost.get("implementation_manifest").asString()
                    .equals("cores.json")
                || runtimeExtras.keys().size() != 2
                || !runtimeExtras.get("selected_cores").get("kind")
                    .asString().equals("core_host_bundle")
                || !runtimeExtras.get("input_autoconfig").get("kind")
                    .asString().equals("merged_input_autoconfig")
                || !runtimeExtras.get("input_autoconfig").get("manifest")
                    .asString().equals(
                        "../../input/steam-deck/retroarch_autoconfig.json")
                || !coreDirectories.isArray() || coreDirectories.size() != 1
                || !coreDirectories.at(0).asString().equals(
                    "${asset_root}/lib/retroarch/cores")) {
            failures += RetroArchProductionContractTest.fail(
                "runtime can escape the exact source-built AppImage slice");
        }

        Vector<string> expectedCores = [
            "desmume", "gambatte", "genesis_plus_gx", "mednafen_psx",
            "mesen", "mgba", "mupen64plus_next", "snes9x"
        ];
        bool exactImplementations = cores.get("schema_version").asInt() == 1;
        for core in expectedCores {
            JsonValue implementation = cores.get("implementations")
                .get(core).get("linux");
            if (!implementation.get("kind").isString()
                    || !implementation.get("kind").asString().equals(
                        "nixpkgs_libretro")
                    || !implementation.get("package_attribute").isString()
                    || implementation.get("package_attribute").asString()
                        .isEmpty()) {
                exactImplementations = false;
            }
        }
        if (!RetroArchProductionContractTest.exactSet(
                RetroArchProductionContractTest.selectedLinuxCores(project),
                expectedCores)
                || !exactImplementations
                || !packageNix.contains(
                    "coreBuildContractPath = packageContract.core_runtime.build_contract")
                || packageNix.contains(
                    "coreContractPath = \"share/semu/core-host-build-contract.json\"")
                || !packageNix.contains(
                    "selected_core_ids = selectedCoreIds")
                || !packageNix.contains("host = coreHostId")
                || packageNix.contains(
                    "required_core_names = selectedCoreIds")
                || !packageNix.contains("semuCoreHostPackage")
                || !packageNix.contains("semuRuntimeExtras = runtimeExtras")
                || !packageNix.contains("steamDeckAutoconfigManifest")
                || !packageNix.contains(
                    "cp -R ${retroarch-joypad-autoconfig}/share/libretro/autoconfig")
                || !packageNix.contains(
                    "cp -RL ${steamDeckAutoconfig}/share/libretro/autoconfig/.")
                || !packageNix.contains(
                    "networkCommandPatchContract.sha256 == networkCommandPatchHash")
                || !packageNix.contains(
                    "networkCommandPatch = ./retroarch_commands.patch")
                || packageNix.contains(
                    "./. + \"/${networkCommandPatchContract.file}\"")
                || !packageNix.contains(
                    "statusNullSafetyPatchContract.sha256 == statusNullSafetyPatchHash")
                || !packageNix.contains(
                    "statusNullSafetyPatch = ./retroarch_get_status_null_safety.patch")
                || emulatorNix.toLower().contains("retroarch")
                || deckPackageNix.toLower().contains("retroarch")
                || !emulatorNix.contains("renamedCoreHostEvaluation")
                || !emulatorNix.contains("hostId = \"renamed-host\"")
                || !emulatorNix.contains("coreHostPackages")
                || !emulatorNix.contains("runtimeExtraPackages")
                || !deckPackageNix.contains(
                    "semuEmulators.runtimeExtrasByEmulator")
                || !deckPackageNix.contains("selectedRuntimeExtras")) {
            failures += RetroArchProductionContractTest.fail(
                "core host selection or runtime extras escaped the local slice");
        }

        if (RetroArchProductionContractTest.occurrences(commandPatch,
                    "string_is_equal(arg, \"menu_active\")") != 1
                || RetroArchProductionContractTest.occurrences(commandPatch,
                    "string_is_equal(arg, \"cheevos_enable\")") != 1
                || RetroArchProductionContractTest.occurrences(commandPatch,
                    "bool command_save_state_slot(command_t* cmd, const char* arg)") != 2
                || RetroArchProductionContractTest.occurrences(commandPatch,
                    "{ \"SAVE_STATE_SLOT\",command_save_state_slot, \"<slot number>\"}") != 1
                || commandPatch.contains("GET_STATUS")
                || packageNix.contains("5ff33af")) {
            failures += RetroArchProductionContractTest.fail(
                "exact local network-command patch contract regressed");
        }

        JsonValue macos = emulator.get("platforms").get("macos");
        JsonValue macosEnvironment = macos.get("env").get("set");
        if (FileSystem.readText(RetroArchProductionContractTest.file(
                    project, directory + "/emulator.json"))
                    .contains("${paths.project_bios}")
                || !RetroArchProductionContractTest.filesystem(
                    linux, "${bios}", "ro")
                || !RetroArchProductionContractTest.filesystem(
                    macos, "${project}", "ro")
                || !RetroArchProductionContractTest.filesystem(
                    macos, "${asset_root}", "ro")
                || !RetroArchProductionContractTest.filesystem(
                    macos, "${roms}", "ro")
                || !RetroArchProductionContractTest.filesystem(
                    macos, "${emulation_root}", "ro")
                || !RetroArchProductionContractTest.filesystem(
                    macos, "${bios}", "ro")
                || !RetroArchProductionContractTest.filesystem(
                    macos, "${state_root}", "create")
                || !macosEnvironment.get("HOME").asString().equals(
                    "${state_root}/home")
                || !macosEnvironment.get("SEMU_RETROARCH_CONFIG").asString()
                    .equals("${state_root}/config/RetroArch/retroarch.cfg")
                || !macos.get("state").get("profile_config_dir").asString()
                    .equals("${state_root}/config/RetroArch")
                || macos.get("firmware").get("dir").asString()
                    .contains("${home}")) {
            failures += RetroArchProductionContractTest.fail(
                "macOS package/config paths are not confined to Semu-owned state");
        }

        JsonValue frame = linux.get("retroarch").get("frame_output");
        JsonValue settings = linux.get("retroarch").get("settings_overrides");
        JsonValue profileLines = profile.get("files").at(0).get("lines");
        JsonValue prefixes = profile.get("compiler").get("line_groups")
            .get("keymap_hotkeys").get("prefix");
        if (!linux.get("args").isArray()
                || !linux.get("args").at(0).asString().equals("-f")
                || !frame.get("fullscreen").asBool()
                || frame.get("native_shader").asBool()
                || frame.get("native_bezel").asBool()
                || !settings.get("notification_show_autoconfig")
                    .asString().equals("false")
                || !settings.get("notification_show_autoconfig_fails")
                    .asString().equals("false")
                || !settings.get("video_shader_enable").asString().equals("false")
                || !settings.get("input_overlay_enable").asString().equals("false")
                || !settings.get("input_overlay_enable_autopreferred")
                    .asString().equals("false")
                || !RetroArchProductionContractTest.line(
                    profileLines, "video_fullscreen = \"true\"")
                || !RetroArchProductionContractTest.line(
                    profileLines, "video_shader_enable = \"false\"")
                || !RetroArchProductionContractTest.line(
                    profileLines, "input_overlay_enable = \"false\"")
                || !RetroArchProductionContractTest.line(profileLines,
                    "input_overlay_enable_autopreferred = \"false\"")
                || !RetroArchProductionContractTest.line(prefixes,
                    "input_quit_gamepad_combo = \"0\"")) {
            failures += RetroArchProductionContractTest.fail(
                "fullscreen or exclusive Semu rendering ownership regressed");
        }

        if (!RetroArchProductionContractTest.action(
                    profile, "input_save_state", "state.save")
                || !RetroArchProductionContractTest.action(
                    profile, "input_load_state", "state.load")
                || !deckInput.get("actions").get("state.save").get("chord")
                    .asString().equals("Ctrl+S")
                || !deckInput.get("actions").get("state.load").get("chord")
                    .asString().equals("Ctrl+A")) {
            failures += RetroArchProductionContractTest.fail(
                "save/load actions are not consumed by the RetroArch profile");
        }

        JsonValue gameplay = autoconfig.get("contract").get("gameplay_mapping");
        JsonValue profiles = autoconfig.get("profiles");
        if (!profiles.isArray() || profiles.size() != 2
                || !RetroArchProductionContractTest.autoconfigProfile(
                    profiles.at(0), gameplay)
                || !RetroArchProductionContractTest.autoconfigProfile(
                    profiles.at(1), gameplay)
                || settings.has("input_player1_reserved_device")
                || settings.has("input_player1_device_reservation_type")
                || !settings.get("input_autodetect_enable").asString()
                    .equals("true")
                || !settings.get("input_player1_joypad_index").asString()
                    .equals("0")
                || !RetroArchProductionContractTest.line(profileLines,
                    "input_autodetect_enable = \"true\"")
                || !RetroArchProductionContractTest.line(profileLines,
                    "input_player1_joypad_index = \"0\"")
                || !RetroArchProductionContractTest.line(profileLines,
                    "notification_show_autoconfig = \"false\"")
                || !RetroArchProductionContractTest.line(profileLines,
                    "notification_show_autoconfig_fails = \"false\"")
                || !RetroArchProductionContractTest.nativeGamepadVdf(project)) {
            failures += RetroArchProductionContractTest.fail(
                "SDL port-1 autoconfiguration or native VDF gamepad output is incomplete");
        }

        JsonValue quit = deckInput.get("quit_chord");
        if (!RetroArchProductionContractTest.inputSupervisorEvidence(
                supervisor, quit)
                || !supervisor.contains("setpgid(child, child)")
                || !supervisor.contains("process-group-terminate")) {
            failures += RetroArchProductionContractTest.fail(
                "configured quit pair lacks ordered, bounded whole-group evidence");
        }

        int gl3Marker = patch.indexOf("--- a/gfx/drivers/gl3.c");
        int headerMarker = patch.indexOf("--- a/gfx/video_driver.h");
        string gl3 = gl3Marker < 0 || headerMarker <= gl3Marker
            ? "" : patch.substring(gl3Marker, headerMarker - gl3Marker);
        JsonValue surfaceModes = rendering.get("surface_modes");
        JsonValue singleMode = surfaceModes.at(0);
        JsonValue singleSurface = singleMode.get("surfaces").at(0);
        JsonValue singleValidation = singleMode.get("validation");
        JsonValue verticalMode = surfaceModes.at(1);
        JsonValue verticalSurfaces = verticalMode.get("surfaces");
        JsonValue verticalValidation = verticalMode.get("validation");
        JsonValue firstSurface = verticalSurfaces.at(0);
        JsonValue secondSurface = verticalSurfaces.at(1);
        JsonValue integration = rendering.get("integration");
        JsonValue callbacks = integration.get("callbacks");
        JsonValue lifecycle = integration.get("context_lifecycle");
        JsonValue pointer = integration.get("pointer_mapping");
        JsonValue n64Binding = n64.get("emulators").at(0);
        string n64Orientation = n64.get("doc").get("orientation").asString();
        JsonValue ndsScreens = nds.get("display").get("screens");
        JsonValue ndsBinding = nds.get("emulators").at(1);
        JsonValue desmumeOptions = linux.get("retroarch")
            .get("core_options").get("desmume");
        int sameMapStart = runtimeHook.indexOf("class bool sameMap(");
        int clearStart = runtimeHook.indexOf("class void clear(");
        string sameMap = sameMapStart < 0 || clearStart <= sameMapStart
            ? "" : runtimeHook.substring(
                sameMapStart, clearStart - sameMapStart);
        int sampleStart = runtimeHook.indexOf("class void sample(");
        int snapshotStart = runtimeHook.indexOf("class bool snapshot(");
        string sample = sampleStart < 0 || snapshotStart <= sampleStart
            ? "" : runtimeHook.substring(
                sampleStart, snapshotStart - sampleStart);
        int sampleUnlock = sample.indexOf("semuRetroArchDisplayUnlock(");
        int sampleCallback = sample.indexOf(
            "mapPointer(&map, &query, &result)");
        string afterCallback = sampleCallback < 0 ? ""
            : sample.substring(sampleCallback, sample.len());
        if (!RetroArchProductionContractTest.patchSection(
                gl3, "#endif /* HAVE_SLANG */")) {
            failures += RetroArchProductionContractTest.fail(
                "GL3 game and post-UI tap ordering regressed");
        }

        bool renderingContract = integration.get("abi").asInt() == 3
            && callbacks.isArray() && callbacks.size() == 2
            && callbacks.at(0).asString().equals("get_proc_address")
            && callbacks.at(1).asString().equals("context_generation")
            && integration.get("context").get("driver")
                .asString().equals("glcore")
            && integration.get("context").get("minimum_opengl")
                .asString().equals("3.3")
            && integration.get("context").get("minimum_glsl").asInt() == 330
            && lifecycle.get("create").asString().equals(
                "video_driver_semu_context_created")
            && lifecycle.get("invalidate_before_destroy").asString().equals(
                "semu_render_context_invalidate_gl")
            && lifecycle.get("destroy").asString().equals(
                "video_driver_semu_context_destroying")
            && surfaceModes.isArray() && surfaceModes.size() == 2
            && singleMode.get("id").asString().equals("single")
            && singleMode.get("match").get("screen_count").asInt() == 1
            && singleValidation.get("native_widths").asString()
                .equals("independent")
            && singleValidation.get("live_geometry").asString()
                .equals("positive")
            && singleMode.get("surfaces").size() == 1
            && singleSurface.get("id").asString().equals("game")
            && singleSurface.get("orientation").asString().equals("upright")
            && singleSurface.get("origin").asString().equals("bottom_left")
            && singleSurface.get("rotation").asInt() == 0
            && verticalMode.get("id").asString().equals("dual_vertical")
            && verticalMode.get("match").get("screen_count").asInt() == 2
            && verticalMode.get("match").get("arrangement")
                .asString().equals("vertical")
            && verticalValidation.get("native_widths").asString()
                .equals("equal")
            && verticalValidation.get("live_geometry").asString()
                .equals("uniform_integer_scale")
            && verticalSurfaces.size() == 2
            && firstSurface.get("index").asInt() == 0
            && secondSurface.get("index").asInt() == 1
            && !firstSurface.get("id").asString().equals(
                secondSurface.get("id").asString())
            && firstSurface.get("native").asString().contains(
                "compiled system display screen 0")
            && secondSurface.get("native").asString().contains(
                "compiled system display screen 1")
            && firstSurface.get("origin").asString().equals("top_left")
            && firstSurface.get("rotation").asInt() == 0
            && secondSurface.get("origin").asString().equals("top_left")
            && secondSurface.get("rotation").asInt() == 0
            && integration.get("frame_gate").asString().contains(
                "menu state gates pointer publication")
            && pointer.get("surface_index").asString().equals(
                "SEMU_RENDER_TOUCH_SURFACE_INDEX")
            && pointer.get("surface_id").asString().equals(
                "SEMU_RENDER_TOUCH_SURFACE_ID")
            && pointer.get("origin").asString().equals("top_left")
            && !pointer.get("press_clamp").asBool()
            && pointer.get("captured_motion_clamp").asBool()
            && pointer.get("consumer").asString().equals(
                "input_driver_state_wrapper");
        if (!renderingContract) {
            failures += RetroArchProductionContractTest.fail(
                "declarative ABI-3 rendering metadata regressed");
        }

        bool patchContract = RetroArchProductionContractTest.occurrences(
                patch, "video_driver_semu_context_created()") == 1
            && RetroArchProductionContractTest.occurrences(patch,
                "video_driver_semu_context_destroying(gl->semu_context_generation);") == 1
            && RetroArchProductionContractTest.occurrences(patch,
                "video_driver_semu_pointer_clear(true);") == 2
            && patch.contains("input_driver_semu_poll_pointer(")
            && patch.contains("video_driver_semu_pointer_snapshot(")
            && patch.contains("RARCH_DEVICE_MOUSE_SCREEN")
            && patch.contains("RETRO_DEVICE_ID_MOUSE_X")
            && patch.contains("RETRO_DEVICE_ID_MOUSE_Y")
            && patch.contains("RETRO_DEVICE_ID_MOUSE_LEFT")
            && !patch.contains("RARCH_DEVICE_POINTER_SCREEN")
            && patch.contains("int semu_game_status = SEMU_RENDER_PASSTHROUGH")
            && patch.contains("(void)semu_render_post_ui_gl(&semu_frame)")
            && patch.contains("semu_game_status == SEMU_RENDER_APPLIED")
            && patch.contains("&& !menu_is_alive")
            && !patch.contains("semu_post_ui_status")
            && !patch.contains("current_context")
            && !patch.contains("frame->surface_count")
            && !patch.contains("getenv(")
            && !patch.contains("256") && !patch.contains("192")
            && !patch.contains("DeSmuME") && !patch.contains("gamescope")
            && !patch.contains("LD_PRELOAD")
            && !patch.contains("glXSwapBuffers")
            && !patch.contains("eglSwapBuffers")
            && !patch.contains("gfx/drivers/gl2.c")
            && !patch.contains("gfx/common/gl2_common.h")
            && gl3.contains("video_driver_semu_context_destroying(")
            && gl3.indexOf("video_driver_semu_context_destroying(")
                < gl3.indexOf("gl->ctx_driver->destroy(gl->ctx_data)");
        if (!patchContract) {
            failures += RetroArchProductionContractTest.fail(
                "minimal tap patch or context-destroy ordering regressed");
        }

        bool surfaceHookContract = surfaceHook.contains(
                "getenv(\"SEMU_RENDER_SURFACE_COUNT\")")
            && surfaceHook.contains(
                "getenv(\"SEMU_RENDER_SURFACE_LAYOUT\")")
            && surfaceHook.contains(
                "getenv(\"SEMU_RENDER_SURFACE_NATIVE_WIDTH_POLICY\")")
            && surfaceHook.contains(
                "getenv(\"SEMU_RENDER_SURFACE_GEOMETRY_POLICY\")")
            && surfaceHook.contains("SEMU_RENDER_TOUCH_SURFACE_INDEX")
            && surfaceHook.contains("SEMU_RETROARCH_WIDTHS_INDEPENDENT")
            && surfaceHook.contains("SEMU_RETROARCH_WIDTHS_EQUAL")
            && surfaceHook.contains("SEMU_RETROARCH_GEOMETRY_POSITIVE")
            && surfaceHook.contains(
                "SEMU_RETROARCH_GEOMETRY_UNIFORM_INTEGER_SCALE")
            && surfaceHook.contains("SEMU_RETROARCH_GEOMETRY_EXACT_NATIVE")
            && surfaceHook.contains(
                "frameWidth != contract->surfaces[0].native_width")
            && surfaceHook.contains("contract->count == 1")
            && surfaceHook.contains("validatesDual(")
            && !surfaceHook.contains("DeSmuME")
            && !surfaceHook.toLower().contains("nds")
            && !surfaceHook.contains("256") && !surfaceHook.contains("192");
        if (!surfaceHookContract) {
            failures += RetroArchProductionContractTest.fail(
                "strict BTRC declarative surface hook regressed");
        }

        bool lifecycleHookContract = runtimeHook.contains(
                "frame->context_generation = contextGeneration")
            && !runtimeHook.contains("|| menuAlive")
            && runtimeHook.contains(
                "semu_render_context_invalidate_gl(contextGeneration)")
            && runtimeHook.contains(
                "SemuRetroArchGeneration.retire(contextGeneration)")
            && runtimeHook.contains(
                "SemuRetroArchPointer.map_generation == mapGeneration")
            && runtimeHook.contains(
                "SemuRetroArchGeneration.lockActive(contextGeneration)")
            && runtimeHook.contains("slock_lock(video->display_lock)")
            && runtimeHook.contains("slock_lock(video->context_lock)")
            && !runtimeHook.contains("VIDEO_DRIVER_LOCK(")
            && !runtimeHook.contains("VIDEO_DRIVER_CONTEXT_LOCK(");
        if (!lifecycleHookContract) {
            failures += RetroArchProductionContractTest.fail(
                "strict BTRC context lifecycle hook regressed");
        }

        bool mapIdentityContract = !sameMap.isEmpty()
            && !sameMap.contains("frame_id");
        if (!mapIdentityContract) {
            failures += RetroArchProductionContractTest.fail(
                "pointer-map identity still depends on frame sequence");
        }
        bool pointerHookContract = !sample.isEmpty() && sampleUnlock >= 0
            && sampleCallback > sampleUnlock
            && afterCallback.contains("semuRetroArchDisplayLock(")
            && RetroArchProductionContractTest.occurrences(
                sample, "mapPointer(&map, &query, &result)") == 1;
        if (!pointerHookContract) {
            print(f"  pointer indexes unlock={sampleUnlock} callback={sampleCallback} callback_count={RetroArchProductionContractTest.occurrences(sample, \"mapPointer(&map, &query, &result)\")}");
            failures += RetroArchProductionContractTest.fail(
                "strict BTRC lock-safe pointer hook regressed");
        }

        bool systemContract = n64Orientation.contains(
                "upright bottom-left-origin game frame in GL space")
            && !n64Orientation.contains("top-left")
            && n64Binding.get("emulator").asString().equals("retroarch")
            && n64Binding.get("core").asString().equals("mupen64plus_next")
            && RetroArchProductionContractTest.platformIncludesLinux(n64Binding)
            && ndsScreens.size() == 2
            && ndsScreens.at(0).get("id").asString().equals("top")
            && ndsScreens.at(1).get("id").asString().equals("bottom")
            && ndsBinding.get("emulator").asString().equals("retroarch")
            && ndsBinding.get("core").asString().equals("desmume")
            && desmumeOptions.size() == 3
            && desmumeOptions.at(0).get("source").get("value")
                .asString().equals("top/bottom")
            && desmumeOptions.at(1).get("source").get("value")
                .asString().equals("0");
        if (!systemContract) {
            failures += RetroArchProductionContractTest.fail(
                "N64 orientation or NDS declarative system binding regressed");
        }

        bool packageContract = packageNix.contains("--fuzz=0")
            && packageNix.contains("semuBuildContract = buildContract")
            && packageNix.contains("outputContract.build_contract")
            && packageNix.contains(
                "builtins.length verticalMode.surfaces == 2")
            && packageNix.contains(
                "live_geometry = \"uniform_integer_scale\"")
            && packageNix.contains(
                "native_widths = \"independent\"")
            && packageNix.contains(
                "pointerMapping.surface_index == \"SEMU_RENDER_TOUCH_SURFACE_INDEX\"")
            && packageNix.contains("\"--enable-threads\"")
            && packageNix.contains(
                "--strict-imports --no-cache --no-stdlib --no-dce")
            && packageNix.contains(
                "! grep -Fq 'semu_post_ui_status' gfx/drivers/gl3.c")
            && packageNix.contains(
                "test \"$completed_line\" -lt \"$game_line\"")
            && packageNix.contains("test \"$game_line\" -lt \"$menu_line\"")
            && packageNix.contains("test \"$widget_line\" -lt \"$post_line\"")
            && packageNix.contains(
                "test \"$post_line\" -lt \"$publish_line\"")
            && packageNix.contains(
                "test \"$publish_line\" -lt \"$swap_line\"");
        if (!packageContract) {
            failures += RetroArchProductionContractTest.fail(
                "strict package source gates regressed");
        }

        if (failures == 0) {
            print("retroarch production contract: package + cores + input + hooks valid");
        }
        return failures;
    }
}
