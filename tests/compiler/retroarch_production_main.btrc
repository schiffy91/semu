// Isolated strict-import entrypoint for the RetroArch production slice.

import std.{cli, fs}
import ./retroarch_production_contract_test.btrc

int main(int argc, char** argv) {
    CliArgs arguments = CliArgs(argc, argv);
    string project = arguments.valueAfter(
        "--project", FileSystem.currentDirectory());
    return RetroArchProductionContractTest.run(project) == 0 ? 0 : 1;
}
