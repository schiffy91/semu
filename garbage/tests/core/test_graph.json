{
  "name": "semu-test-graph",
  "workspaceRoot": "../..",
  "default": [
    "payload-audit",
    "generated-smoke",
    "appimage-smoke"
  ],
  "nodes": [
    {
      "id": "payload-audit",
      "spec": "test_graph_specs/payload_audit.json",
      "after": []
    },
    {
      "id": "generated-smoke",
      "spec": "test_graph_specs/generated_smoke.json",
      "after": [
        "payload-audit"
      ]
    },
    {
      "id": "appimage-smoke",
      "spec": "test_graph_specs/appimage_smoke.json",
      "after": [
        "generated-smoke"
      ]
    },
    {
      "id": "nix-e2e",
      "spec": "test_graph_specs/nix_test.json",
      "after": [
        "appimage-smoke"
      ]
    },
    {
      "id": "verify",
      "spec": "test_graph_specs/verify.json",
      "after": [
        "nix-e2e"
      ]
    },
    {
      "id": "arch-deck-vm",
      "spec": "test_graph_specs/arch_deck_vm.json",
      "after": [
        "verify"
      ]
    },
    {
      "id": "arch-deck-vm-strict",
      "spec": "test_graph_specs/arch_deck_vm_strict.json",
      "after": [
        "arch-deck-vm"
      ]
    },
    {
      "id": "bazzite-desktop-live",
      "spec": "test_graph_specs/bazzite_desktop_live.json",
      "after": [
        "payload-audit"
      ]
    },
    {
      "id": "bazzite-deck-live",
      "spec": "test_graph_specs/bazzite_deck_live.json",
      "after": [
        "payload-audit"
      ]
    },
    {
      "id": "bazzite-installed-vm",
      "spec": "test_graph_specs/bazzite_installed_vm.json",
      "after": [
        "bazzite-deck-live"
      ]
    },
    {
      "id": "bazzite-installed-ssh",
      "spec": "test_graph_specs/bazzite_installed_ssh.json",
      "after": [
        "bazzite-installed-vm"
      ]
    }
  ]
}
