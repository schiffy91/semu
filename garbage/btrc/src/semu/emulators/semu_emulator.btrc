class SemuEmulator {
    public string name;
    public string label;
    public string flatpakId;

    public SemuEmulator(string name, string label, string flatpakId) {
        self.name = name;
        self.label = label;
        self.flatpakId = flatpakId;
    }

    public bool known() {
        return self.name.len() > 0;
    }
}
