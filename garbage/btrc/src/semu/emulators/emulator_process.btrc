import std.vector;
import ./semu_emulator.btrc;

class EmulatorProcess {
    public SemuEmulator emulator;
    public Vector<string> args;

    public EmulatorProcess(SemuEmulator emulator) {
        self.emulator = emulator;
        self.args = [];
    }

    public void addArg(string value) {
        self.args.push(value);
    }
}
