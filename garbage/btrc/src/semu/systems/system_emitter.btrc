class SemuManifestCompiler {
    class string build() { return buildJson(); }
    class string systems() { return systemEntries(); }
}

// ---- spec_helpers.btrc ----
string commandSpec(string label, string command) {
    return jsonObject([
        jsonStrField("label", label),
        jsonStrField("command", command)
    ]);
}

string platformCommands(string platform, Vector<string> commands) {
    return jsonField(platform, jsonArray(commands));
}

string systemSpec(
    string id,
    string fullname,
    string platform,
    string theme,
    string romDir,
    Vector<string> extensions,
    Vector<string> linuxCommands,
    Vector<string> macosCommands,
    Vector<string> bios,
    string controllerProfile
) {
    Vector<string> commandPlatforms = [
        platformCommands("linux", linuxCommands),
        platformCommands("macos", macosCommands)
    ];
    Vector<string> fields = [
        jsonStrField("id", id),
        jsonStrField("fullname", fullname),
        jsonStrField("platform", platform),
        jsonStrField("theme", theme),
        jsonStrField("rom_dir", romDir),
        jsonField("extensions", jsonStringArray(extensions)),
        jsonField("commands", jsonObject(commandPlatforms))
    ];
    if (bios.len > 0) {
        fields.push(jsonField("bios", jsonStringArray(bios)));
    }
    if (controllerProfile.len() > 0) {
        fields.push(jsonStrField("controller_profile", controllerProfile));
    }
    return jsonObject(fields);
}

string biosSpec(
    string id,
    string system,
    bool required,
    Vector<string> files,
    string target,
    string match,
    string note
) {
    Vector<string> fields = [
        jsonStrField("id", id),
        jsonStrField("system", system),
        jsonBoolField("required", required),
        jsonField("files", jsonStringArray(files)),
        jsonStrField("target", target),
        jsonStrField("note", note)
    ];
    if (match.len() > 0) {
        fields.push(jsonStrField("match", match));
    }
    return jsonObject(fields);
}

string steamInputTemplate(string id, string title, string source, string note) {
    return jsonObject([
        jsonStrField("id", id),
        jsonStrField("title", title),
        jsonStrField("source", source),
        jsonBoolField("required", false),
        jsonStrField("note", note)
    ]);
}

// ---- es_xml.btrc ----
string xmlEscape(string value) {
    string result = Strings.replace(value, "&", "&amp;");
    result = Strings.replace(result, "\"", "&quot;");
    result = Strings.replace(result, "<", "&lt;");
    result = Strings.replace(result, ">", "&gt;");
    return result;
}

string esExtensionList(Vector<string> extensions) {
    Vector<string> values = [];
    for extension in extensions {
        values.push(extension);
        values.push(extension.toUpper());
    }
    return values.join(" ");
}

string esCommandXml(string commandJson) {
    JsonObject command = JsonObject.parse(commandJson);
    return "    <command label=\"" + xmlEscape(command.getString("label", "")) + "\">"
        + xmlEscape(command.getString("command", ""))
        + "</command>\n";
}

string esSystemSpec(
    string id,
    string fullname,
    string platform,
    string theme,
    string romDir,
    Vector<string> extensions,
    Vector<string> linuxCommands
) {
    string result = "  <system>\n"
        + "    <name>" + xmlEscape(id) + "</name>\n"
        + "    <fullname>" + xmlEscape(fullname) + "</fullname>\n"
        + "    <path>%ROMPATH%/" + xmlEscape(romDir) + "</path>\n"
        + "    <extension>" + xmlEscape(esExtensionList(extensions)) + "</extension>\n";
    for command in linuxCommands {
        result = result + esCommandXml(command);
    }
    result = result
        + "    <platform>" + xmlEscape(platform) + "</platform>\n"
        + "    <theme>" + xmlEscape(theme) + "</theme>\n"
        + "  </system>\n";
    return result;
}

// ---- paths_esde.btrc ----
string manifestPaths() {
    return jsonObject([
        jsonStrField("config_root", "${project}/src/semu"),
        jsonStrField("generated_root", "${project}/src/generated"),
        jsonStrField("project_content_root", "${project}/src/generated/runtime/content"),
        jsonStrField("runtime_content_root", "${portable}"),
        jsonStrField("roms", "${paths.runtime_content_root}/ROMs"),
        jsonStrField("project_roms", "${paths.project_content_root}/ROMs"),
        jsonStrField("bios", "${paths.runtime_content_root}/bios"),
        jsonStrField("project_bios", "${paths.project_content_root}/bios"),
        jsonStrField("saves", "${paths.runtime_content_root}/saves"),
        jsonStrField("project_saves", "${paths.project_content_root}/saves"),
        jsonStrField("states", "${paths.runtime_content_root}/states"),
        jsonStrField("project_states", "${paths.project_content_root}/states"),
        jsonStrField("screenshots", "${paths.runtime_content_root}/screenshots"),
        jsonStrField("project_screenshots", "${paths.project_content_root}/screenshots"),
        jsonStrField("media", "${paths.runtime_content_root}/downloaded_media"),
        jsonStrField("project_media", "${paths.project_content_root}/downloaded_media"),
        jsonStrField("gamelists", "${paths.runtime_content_root}/gamelists"),
        jsonStrField("project_gamelists", "${paths.project_content_root}/gamelists"),
        jsonStrField("themes", "${paths.runtime_content_root}/themes"),
        jsonStrField("project_themes", "${paths.project_content_root}/themes"),
        jsonStrField("custom_systems", "${paths.runtime_content_root}/custom_systems"),
        jsonStrField("project_custom_systems", "${project}/src/generated/packaging/es-de/custom_systems"),
        jsonStrField("settings", "${paths.runtime_content_root}/settings"),
        jsonStrField("project_settings", "${project}/src/generated/packaging/es-de/settings"),
        jsonStrField("keymaps", "${project}/src/semu/input/targets/steamdeck"),
        jsonStrField("steam_input", "${project}/src/generated/packaging/input/steam-input"),
        jsonStrField("emulator_profiles", "${project}/src/generated/packaging/emulators/profiles"),
        jsonStrField("es_de_profiles", "${project}/src/generated/packaging/es-de"),
        jsonStrField("linux_packaging", "${project}/src/generated/packaging/linux"),
        jsonStrField("retroarch_system", "${paths.bios}")
