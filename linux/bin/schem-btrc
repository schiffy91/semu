#!/usr/bin/env sh
set -eu

here="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd -P)"
cli="${SCHEMULATOR_BIN:-${SCHEMULATOR_CLI:-}}"

if [ -z "$cli" ] && [ -x "$here/schemulator" ]; then
  cli="$here/schemulator"
fi
if [ -z "$cli" ] && [ -x "$here/../schemulator" ]; then
  cli="$here/../schemulator"
fi
if [ -z "$cli" ] && [ -x "$here/../../build/schemulator" ]; then
  cli="$here/../../build/schemulator"
fi
if [ -z "$cli" ] && [ -n "${APPDIR:-}" ] && [ -x "$APPDIR/usr/bin/schemulator" ]; then
  cli="$APPDIR/usr/bin/schemulator"
fi
if [ -z "$cli" ]; then
  cli="$(command -v schemulator || true)"
fi

if [ -z "$cli" ] || [ ! -x "$cli" ]; then
  echo "schem-btrc: compiled BTRC CLI not found" >&2
  exit 127
fi

exec "$cli" "$@"
